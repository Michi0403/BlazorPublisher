@namespace PublisherStudio.Components.Editor
@inject PublicationDataService DataService

@if (Visible && _draft is not null)
{
    <div class="modal-backdrop data-modal-backdrop">
        <section class="data-visual-editor-dialog" role="dialog" aria-modal="true" aria-label="Data visual editor">
            <header>
                <div>
                    <strong>Insert / edit data visual</strong>
                    <span>The complete DevExtreme chart-series workbench plus pies, polar charts, sparklines, gauges, Sankey, funnel, pyramid, tree map, range selector, grid, and KPI.</span>
                </div>
                <button type="button" class="window-close" @onclick="Cancel">×</button>
            </header>

            <DxRibbon CssClass="data-visual-editor-ribbon categorized-ribbon" SizeMode="SizeMode.Small" AdaptivityAutoCollapseItemsToGroups="true">
                <DxRibbonTab Text="Visual">
                    <DxRibbonGroup Text="Data" IconCssClass="pub-icon pub-icon-data">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-chart" Text="Manage publication data" IsPrimary="true" Click="RequestManage" />
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-chart" Text="Refresh live data" Click="Refresh" />
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-chart" Text="Auto-map fields" Click="AutoMapFields" />
                    </DxRibbonGroup>
                    <DxRibbonGroup Text="Options">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-chart" Text="Reset visual options" Click="ResetVisualOptions" />
                    </DxRibbonGroup>
                </DxRibbonTab>
            </DxRibbon>

            <div class="data-visual-editor-body">
                <aside class="visual-type-list">
                    @foreach (var kind in Enum.GetValues<DataVisualKind>())
                    {
                        <button type="button" class="@(_draft.VisualKind == kind ? "selected" : null)" @onclick="() => SetKind(kind)">
                            <span class="visual-type-icon">@KindIcon(kind)</span>
                            <strong>@KindName(kind)</strong>
                            <small>@KindDescription(kind)</small>
                        </button>
                    }
                </aside>

                <main class="visual-settings">
                    <div class="data-form-grid">
                        <label>Title<input value="@_draft.Title" @onchange="ChangeTitle" /></label>
                        <label>Data object
                            <select value="@_draft.DataObjectId" @onchange="ChangeDataObject">
                                @foreach (var data in State.Document.DataObjects)
                                {
                                    <option value="@data.Id">@data.Name (@data.SourceKind)</option>
                                }
                            </select>
                        </label>
                    </div>

                    @if (CurrentData is null)
                    {
                        <div class="inline-error">No data object is available. Open the data manager and create one.</div>
                    }
                    else
                    {
                        <div class="data-form-grid">
                            <label>Argument / category
                                <select value="@_draft.ArgumentField" @onchange="ChangeArgumentField">
                                    @foreach (var column in Columns)
                                    {
                                        <option value="@column.Name">@column.Name</option>
                                    }
                                </select>
                            </label>
                            <label>Series grouping (optional)
                                <select value="@_draft.SeriesField" @onchange="ChangeSeriesField">
                                    <option value="">None</option>
                                    @foreach (var column in Columns)
                                    {
                                        <option value="@column.Name">@column.Name</option>
                                    }
                                </select>
                            </label>
                        </div>

                        @if (_draft.VisualKind != DataVisualKind.DataTable)
                        {
                            <div class="data-form-grid chart-data-semantics">
                                <label>Argument axis
                                    <select value="@_draft.ArgumentMode" @onchange="ChangeArgumentMode">
                                        @foreach (var mode in Enum.GetValues<DataVisualArgumentMode>())
                                        {
                                            <option value="@mode">@Friendly(mode.ToString())</option>
                                        }
                                    </select>
                                </label>
                                <label>Repeated categories
                                    <select value="@_draft.AggregationMode" @onchange="ChangeAggregationMode" disabled="@(!SupportsAggregation)">
                                        @foreach (var mode in Enum.GetValues<DataVisualAggregationMode>())
                                        {
                                            <option value="@mode">@AggregationLabel(mode)</option>
                                        }
                                    </select>
                                </label>
                                <label>Point order
                                    <select value="@_draft.SortMode" @onchange="ChangeSortMode">
                                        @foreach (var mode in Enum.GetValues<DataVisualSortMode>())
                                        {
                                            <option value="@mode">@Friendly(mode.ToString())</option>
                                        }
                                    </select>
                                </label>
                                <div class="chart-mapping-advice"><strong>Mapping check</strong><span>@MappingAdvice</span><button type="button" @onclick="AutoMapFields">Auto-map</button></div>
                            </div>

                            <fieldset class="value-field-picker">
                                <legend>@(AllowsMultipleValueFields ? "Data fields" : "Data field")</legend>
                                @foreach (var column in MeasureColumns)
                                {
                                    <label class="check-row">
                                        <input type="checkbox"
                                               checked="@_draft.ValueFields.Contains(column.Name, StringComparer.OrdinalIgnoreCase)"
                                               @onchange="(ChangeEventArgs args) => ToggleValueField(column.Name, args)" />
                                        @column.Name <small>@column.ValueKind</small>
                                    </label>
                                }
                                @if (MeasureColumns.Count == 0)
                                {
                                    <small>No field was detected in this data object.</small>
                                }
                                else
                                {
                                    <small class="field-measure-help">Numbers are plotted directly, Boolean values use 1/0, and non-empty text or date values count as 1.</small>
                                }
                            </fieldset>
                        }

                        @if (_draft.VisualKind == DataVisualKind.CartesianChart)
                        {
                            <label>Chart subtype
                                <select value="@_draft.CartesianStyle" @onchange="ChangeCartesianStyle">
                                    @foreach (var value in Enum.GetValues<CartesianChartStyle>())
                                    {
                                        <option value="@value">@Friendly(value.ToString())</option>
                                    }
                                </select>
                            </label>
                        }
                        else if (_draft.VisualKind == DataVisualKind.PieChart)
                        {
                            <label>Pie subtype
                                <select value="@_draft.PieStyle" @onchange="ChangePieStyle">
                                    @foreach (var value in Enum.GetValues<PieChartStyle>())
                                    {
                                        <option value="@value">@Friendly(value.ToString())</option>
                                    }
                                </select>
                            </label>
                        }
                        else if (_draft.VisualKind == DataVisualKind.PolarChart)
                        {
                            <label>Polar subtype
                                <select value="@_draft.PolarStyle" @onchange="ChangePolarStyle">
                                    @foreach (var value in Enum.GetValues<PolarChartStyle>())
                                    {
                                        <option value="@value">@Friendly(value.ToString())</option>
                                    }
                                </select>
                            </label>
                        }
                        else if (_draft.VisualKind == DataVisualKind.Sparkline)
                        {
                            <label>Sparkline subtype
                                <select value="@_draft.SparklineStyle" @onchange="ChangeSparklineStyle">
                                    @foreach (var value in Enum.GetValues<SparklineChartStyle>())
                                    {
                                        <option value="@value">@Friendly(value.ToString())</option>
                                    }
                                </select>
                            </label>
                        }

                        @if (_draft.VisualKind == DataVisualKind.CartesianChart && (_draft.CartesianStyle is CartesianChartStyle.RangeArea or CartesianChartStyle.RangeBar))
                        {
                            <div class="data-form-grid">
                                @FieldSelect("Low value", _draft.LowValueField, ChangeLowValueField, NumericColumns)
                                @FieldSelect("High value", _draft.HighValueField, ChangeHighValueField, NumericColumns)
                            </div>
                        }
                        @if (_draft.VisualKind == DataVisualKind.CartesianChart && _draft.CartesianStyle == CartesianChartStyle.Bubble)
                        {
                            @FieldSelect("Bubble size", _draft.SizeField, ChangeSizeField, NumericColumns)
                        }
                        @if (_draft.VisualKind == DataVisualKind.CartesianChart && (_draft.CartesianStyle is CartesianChartStyle.Candlestick or CartesianChartStyle.Stock))
                        {
                            <div class="data-form-grid financial-field-grid">
                                @FieldSelect("Open", _draft.OpenValueField, ChangeOpenValueField, NumericColumns)
                                @FieldSelect("High", _draft.HighValueField, ChangeHighValueField, NumericColumns)
                                @FieldSelect("Low", _draft.LowValueField, ChangeLowValueField, NumericColumns)
                                @FieldSelect("Close", _draft.CloseValueField, ChangeCloseValueField, NumericColumns)
                            </div>
                        }
                        @if (_draft.VisualKind == DataVisualKind.Sankey)
                        {
                            @FieldSelect("Target node", _draft.TargetField, ChangeTargetField, Columns)
                        }
                        @if (_draft.VisualKind == DataVisualKind.TreeMap)
                        {
                            @FieldSelect("Parent field (optional)", _draft.ParentField, ChangeParentField, Columns, true)
                        }

                        @if (_draft.VisualKind is DataVisualKind.BarGauge or DataVisualKind.CircularGauge or DataVisualKind.LinearGauge or DataVisualKind.KpiProgress)
                        {
                            <div class="data-form-grid">
                                <label>Minimum<input type="number" step="any" value="@Inv(_draft.MinimumValue)" @onchange="ChangeMinimum" /></label>
                                <label>Maximum<input type="number" step="any" value="@Inv(_draft.MaximumValue)" @onchange="ChangeMaximum" /></label>
                            </div>
                        }
                        @if (_draft.VisualKind == DataVisualKind.DataTable)
                        {
                            <div class="data-form-grid">
                                <label>Maximum rows<input type="number" min="1" max="100" value="@_draft.RowLimit" @onchange="ChangeRowLimit" /></label>
                                <label class="check-row"><input type="checkbox" checked="@_draft.TableShowFilterRow" @onchange="ToggleFilterRow" /> Interactive filter row</label>
                            </div>
                        }

                        <div class="visual-option-grid">
                            <label class="check-row"><input type="checkbox" checked="@_draft.ShowTitle" @onchange="ToggleTitle" /> Show title</label>
                            @if (_draft.VisualKind is DataVisualKind.CartesianChart or DataVisualKind.PieChart or DataVisualKind.PolarChart or DataVisualKind.BarGauge or DataVisualKind.Sankey)
                            {
                                <label class="check-row"><input type="checkbox" checked="@_draft.ShowLegend" @onchange="ToggleLegend" /> Show legend</label>
                            }
                            @if (_draft.VisualKind is DataVisualKind.PieChart or DataVisualKind.PolarChart or DataVisualKind.Sankey or DataVisualKind.Funnel or DataVisualKind.Pyramid)
                            {
                                <label class="check-row"><input type="checkbox" checked="@_draft.ShowLabels" @onchange="ToggleLabels" /> Show point labels</label>
                            }
                        </div>
                    }
                </main>

                <section class="visual-live-preview">
                    <div class="pane-heading"><strong>Live preview</strong><span>@CurrentData?.Name</span></div>
                    <div class="visual-preview-frame"
                         tabindex="0"
                         title="Right-click for visual commands"
                         @oncontextmenu="ShowVisualContextMenu"
                         @oncontextmenu:preventDefault
                         @oncontextmenu:stopPropagation>
                        <DataVisualView Document="State.Document" Item="_draft" CurrentPageId="State.SelectedPageId" />
                    </div>
                    <p>Visuals remain live DevExpress components on the publication canvas. Web bindings are refreshed by the local monolith and standalone HTML can optionally continue polling with embedded JavaScript.</p>
                </section>
            </div>

            <footer>
                <span>@ValidationText</span>
                <div><DxButton Text="Cancel" Click="Cancel" /><DxButton Text="Apply to object" Click="Save" RenderStyle="ButtonRenderStyle.Primary" Enabled="@CanSave" /></div>
            </footer>
        </section>
    </div>

    <DxContextMenu @ref="_visualContextMenu">
        <Items>
            <DxContextMenuItem Text="Apply changes" IconCssClass="pub-icon pub-icon-edit" Enabled="@CanSave" Click="Save" />
            <DxContextMenuItem Text="Refresh live data" IconCssClass="pub-icon pub-icon-data" Click="Refresh" />
            <DxContextMenuItem Text="Manage publication data…" IconCssClass="pub-icon pub-icon-data" Click="RequestManage" />
            <DxContextMenuItem Text="Visual type" BeginGroup="true">
                <Items>
                    <DxContextMenuItem Text="@(CheckedText(_draft.VisualKind == DataVisualKind.CartesianChart, KindName(DataVisualKind.CartesianChart)))" Click="SetCartesianChart" />
                    <DxContextMenuItem Text="@(CheckedText(_draft.VisualKind == DataVisualKind.PieChart, KindName(DataVisualKind.PieChart)))" Click="SetPieChart" />
                    <DxContextMenuItem Text="@(CheckedText(_draft.VisualKind == DataVisualKind.PolarChart, KindName(DataVisualKind.PolarChart)))" Click="SetPolarChart" />
                    <DxContextMenuItem Text="@(CheckedText(_draft.VisualKind == DataVisualKind.Sparkline, KindName(DataVisualKind.Sparkline)))" Click="SetSparkline" />
                    <DxContextMenuItem Text="@(CheckedText(_draft.VisualKind == DataVisualKind.BarGauge, KindName(DataVisualKind.BarGauge)))" Click="SetBarGauge" />
                    <DxContextMenuItem Text="@(CheckedText(_draft.VisualKind == DataVisualKind.CircularGauge, KindName(DataVisualKind.CircularGauge)))" Click="SetCircularGauge" />
                    <DxContextMenuItem Text="@(CheckedText(_draft.VisualKind == DataVisualKind.LinearGauge, KindName(DataVisualKind.LinearGauge)))" Click="SetLinearGauge" />
                    <DxContextMenuItem Text="@(CheckedText(_draft.VisualKind == DataVisualKind.RangeSelector, KindName(DataVisualKind.RangeSelector)))" Click="SetRangeSelector" />
                    <DxContextMenuItem Text="@(CheckedText(_draft.VisualKind == DataVisualKind.Sankey, KindName(DataVisualKind.Sankey)))" Click="SetSankey" />
                    <DxContextMenuItem Text="@(CheckedText(_draft.VisualKind == DataVisualKind.Funnel, KindName(DataVisualKind.Funnel)))" Click="SetFunnel" />
                    <DxContextMenuItem Text="@(CheckedText(_draft.VisualKind == DataVisualKind.Pyramid, KindName(DataVisualKind.Pyramid)))" Click="SetPyramid" />
                    <DxContextMenuItem Text="@(CheckedText(_draft.VisualKind == DataVisualKind.TreeMap, KindName(DataVisualKind.TreeMap)))" Click="SetTreeMap" />
                    <DxContextMenuItem Text="@(CheckedText(_draft.VisualKind == DataVisualKind.DataTable, KindName(DataVisualKind.DataTable)))" Click="SetDataTable" />
                    <DxContextMenuItem Text="@(CheckedText(_draft.VisualKind == DataVisualKind.KpiProgress, KindName(DataVisualKind.KpiProgress)))" Click="SetKpiProgress" />
                </Items>
            </DxContextMenuItem>
            <DxContextMenuItem Text="@(CheckedText(_draft.ShowTitle, "Show title"))" Click="ToggleTitleMenu" />
            @if (_draft.VisualKind is DataVisualKind.CartesianChart or DataVisualKind.PieChart or DataVisualKind.PolarChart or DataVisualKind.BarGauge or DataVisualKind.Sankey)
            {
                <DxContextMenuItem Text="@(CheckedText(_draft.ShowLegend, "Show legend"))" Click="ToggleLegendMenu" />
            }
            @if (_draft.VisualKind is DataVisualKind.PieChart or DataVisualKind.PolarChart or DataVisualKind.Sankey or DataVisualKind.Funnel or DataVisualKind.Pyramid)
            {
                <DxContextMenuItem Text="@(CheckedText(_draft.ShowLabels, "Show point labels"))" Click="ToggleLabelsMenu" />
            }
            @if (_draft.VisualKind == DataVisualKind.DataTable)
            {
                <DxContextMenuItem Text="@(CheckedText(_draft.TableShowFilterRow, "Interactive filter row"))" Click="ToggleFilterRowMenu" />
            }
            <DxContextMenuItem Text="Reset visual options" BeginGroup="true" Click="ResetVisualOptions" />
        </Items>
    </DxContextMenu>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter, EditorRequired] public EditorStateService State { get; set; } = default!;
    [Parameter] public EventCallback Saved { get; set; }
    [Parameter] public EventCallback Cancelled { get; set; }
    [Parameter] public EventCallback ManageDataRequested { get; set; }

    private DxContextMenu _visualContextMenu = default!;
    private bool _wasVisible;
    private Guid? _targetId;
    private DataVisualElement? _draft;
    private PublicationDataObject? CurrentData => _draft is null ? null : State.Document.DataObjects.FirstOrDefault(data => data.Id == _draft.DataObjectId);
    private IReadOnlyList<PublicationDataColumn> Columns => DataService.ResolveColumns(CurrentData);
    private IReadOnlyList<PublicationDataColumn> MeasureColumns => NumericColumns.Count > 0 ? NumericColumns : Columns;
    private IReadOnlyList<PublicationDataColumn> NumericColumns => Columns
        .Where(column => column.ValueKind is PublicationDataValueKind.Number or PublicationDataValueKind.Boolean)
        .ToArray();
    private bool AllowsMultipleValueFields => _draft?.VisualKind is DataVisualKind.CartesianChart or DataVisualKind.PolarChart or DataVisualKind.BarGauge or DataVisualKind.CircularGauge or DataVisualKind.LinearGauge;
    private bool SupportsAggregation => _draft?.VisualKind is DataVisualKind.CartesianChart or DataVisualKind.PieChart or DataVisualKind.PolarChart or DataVisualKind.Sparkline or DataVisualKind.RangeSelector or DataVisualKind.Funnel or DataVisualKind.Pyramid;
    private string MappingAdvice => BuildMappingAdvice();
    private bool CanSave => _draft is not null && CurrentData is not null && ValidateFields(_draft);
    private string ValidationText => CurrentData is null
        ? "Choose or create a data object."
        : _draft is not null && !ValidateFields(_draft)
            ? "Choose the required argument, value, range, financial, target, or hierarchy fields for this visual."
            : CurrentData.SourceKind == PublicationDataSourceKind.Web
                ? "This visual uses an embedded snapshot and the configured web binding."
                : "The visual uses publication data stored in the document.";

    protected override void OnParametersSet()
    {
        if (Visible && !_wasVisible)
        {
            if (State.SelectedElement is DataVisualElement selected)
            {
                _targetId = selected.Id;
                _draft = Clone(selected);
                EnsureSpecialFields();
            }
            else
            {
                _targetId = null;
                _draft = null;
            }
        }
        _wasVisible = Visible;
    }

    private async Task Save()
    {
        if (_draft is null || _targetId is null || !CanSave) return;
        State.SelectElement(_targetId);
        State.UpdateSelected(element =>
        {
            if (element is not DataVisualElement target) return;
            CopySettings(_draft, target);
        });
        await Saved.InvokeAsync();
    }

    private Task ShowVisualContextMenu(MouseEventArgs args) => _visualContextMenu.ShowAsync(args);
    private Task Cancel() => Cancelled.InvokeAsync();
    private Task RequestManage() => ManageDataRequested.InvokeAsync();
    private async Task Refresh()
    {
        if (_draft is null) return;
        await State.RefreshWebDataAsync(_draft.DataObjectId, true);
        State.RefreshDataVisuals();
    }
    private void SetKind(DataVisualKind kind)
    {
        if (_draft is null) return;
        _draft.VisualKind = kind;
        if (!AllowsMultipleValueFields && _draft.ValueFields.Count > 1)
            _draft.ValueFields = [ _draft.ValueFields[0] ];
        EnsureSpecialFields();
    }

    private void SetCartesianChart() => SetKind(DataVisualKind.CartesianChart);
    private void SetPieChart() => SetKind(DataVisualKind.PieChart);
    private void SetPolarChart() => SetKind(DataVisualKind.PolarChart);
    private void SetSparkline() => SetKind(DataVisualKind.Sparkline);
    private void SetBarGauge() => SetKind(DataVisualKind.BarGauge);
    private void SetCircularGauge() => SetKind(DataVisualKind.CircularGauge);
    private void SetLinearGauge() => SetKind(DataVisualKind.LinearGauge);
    private void SetRangeSelector() => SetKind(DataVisualKind.RangeSelector);
    private void SetSankey() => SetKind(DataVisualKind.Sankey);
    private void SetFunnel() => SetKind(DataVisualKind.Funnel);
    private void SetPyramid() => SetKind(DataVisualKind.Pyramid);
    private void SetTreeMap() => SetKind(DataVisualKind.TreeMap);
    private void SetDataTable() => SetKind(DataVisualKind.DataTable);
    private void SetKpiProgress() => SetKind(DataVisualKind.KpiProgress);

    private void ChangeDataObject(ChangeEventArgs args)
    {
        if (_draft is null || !Guid.TryParse(args.Value?.ToString(), out var id)) return;
        _draft.DataObjectId = id;
        AutoMapFields();
    }

    private void ToggleValueField(string field, ChangeEventArgs args)
    {
        if (_draft is null) return;
        var selected = args.Value is bool value && value;
        _draft.ValueFields.RemoveAll(value => string.Equals(value, field, StringComparison.OrdinalIgnoreCase));
        if (!selected) return;
        if (!AllowsMultipleValueFields) _draft.ValueFields.Clear();
        _draft.ValueFields.Add(field);
    }

    private void ChangeTitle(ChangeEventArgs args) { if (_draft is not null) _draft.Title = args.Value?.ToString() ?? string.Empty; }
    private void ChangeArgumentField(ChangeEventArgs args) { if (_draft is not null) _draft.ArgumentField = args.Value?.ToString() ?? string.Empty; }
    private void ChangeSeriesField(ChangeEventArgs args) { if (_draft is not null) _draft.SeriesField = args.Value?.ToString() ?? string.Empty; }
    private void ChangeArgumentMode(ChangeEventArgs args) { if (_draft is not null && Enum.TryParse<DataVisualArgumentMode>(args.Value?.ToString(), out var value)) _draft.ArgumentMode = value; }
    private void ChangeAggregationMode(ChangeEventArgs args) { if (_draft is not null && Enum.TryParse<DataVisualAggregationMode>(args.Value?.ToString(), out var value)) _draft.AggregationMode = value; }
    private void ChangeSortMode(ChangeEventArgs args) { if (_draft is not null && Enum.TryParse<DataVisualSortMode>(args.Value?.ToString(), out var value)) _draft.SortMode = value; }
    private void ChangeLowValueField(ChangeEventArgs args) { if (_draft is not null) _draft.LowValueField = args.Value?.ToString() ?? string.Empty; }
    private void ChangeHighValueField(ChangeEventArgs args) { if (_draft is not null) _draft.HighValueField = args.Value?.ToString() ?? string.Empty; }
    private void ChangeOpenValueField(ChangeEventArgs args) { if (_draft is not null) _draft.OpenValueField = args.Value?.ToString() ?? string.Empty; }
    private void ChangeCloseValueField(ChangeEventArgs args) { if (_draft is not null) _draft.CloseValueField = args.Value?.ToString() ?? string.Empty; }
    private void ChangeSizeField(ChangeEventArgs args) { if (_draft is not null) _draft.SizeField = args.Value?.ToString() ?? string.Empty; }
    private void ChangeTargetField(ChangeEventArgs args) { if (_draft is not null) _draft.TargetField = args.Value?.ToString() ?? string.Empty; }
    private void ChangeParentField(ChangeEventArgs args) { if (_draft is not null) _draft.ParentField = args.Value?.ToString() ?? string.Empty; }
    private void ChangeCartesianStyle(ChangeEventArgs args) { if (_draft is not null && Enum.TryParse<CartesianChartStyle>(args.Value?.ToString(), out var value)) { _draft.CartesianStyle = value; EnsureSpecialFields(); } }
    private void ChangePieStyle(ChangeEventArgs args) { if (_draft is not null && Enum.TryParse<PieChartStyle>(args.Value?.ToString(), out var value)) _draft.PieStyle = value; }
    private void ChangePolarStyle(ChangeEventArgs args) { if (_draft is not null && Enum.TryParse<PolarChartStyle>(args.Value?.ToString(), out var value)) _draft.PolarStyle = value; }
    private void ChangeSparklineStyle(ChangeEventArgs args) { if (_draft is not null && Enum.TryParse<SparklineChartStyle>(args.Value?.ToString(), out var value)) _draft.SparklineStyle = value; }
    private void ChangeMinimum(ChangeEventArgs args) { if (_draft is not null && TryDouble(args.Value, out var value)) _draft.MinimumValue = value; }
    private void ChangeMaximum(ChangeEventArgs args) { if (_draft is not null && TryDouble(args.Value, out var value)) _draft.MaximumValue = Math.Max(value, _draft.MinimumValue + .001); }
    private void ChangeRowLimit(ChangeEventArgs args) { if (_draft is not null && int.TryParse(args.Value?.ToString(), out var value)) _draft.RowLimit = Math.Clamp(value, 1, 100); }
    private void ToggleTitle(ChangeEventArgs args) { if (_draft is not null) _draft.ShowTitle = Checked(args); }
    private void ToggleLegend(ChangeEventArgs args) { if (_draft is not null) _draft.ShowLegend = Checked(args); }
    private void ToggleLabels(ChangeEventArgs args) { if (_draft is not null) _draft.ShowLabels = Checked(args); }
    private void ToggleFilterRow(ChangeEventArgs args) { if (_draft is not null) _draft.TableShowFilterRow = Checked(args); }

    private void ToggleTitleMenu() { if (_draft is not null) _draft.ShowTitle = !_draft.ShowTitle; }
    private void ToggleLegendMenu() { if (_draft is not null) _draft.ShowLegend = !_draft.ShowLegend; }
    private void ToggleLabelsMenu() { if (_draft is not null) _draft.ShowLabels = !_draft.ShowLabels; }
    private void ToggleFilterRowMenu() { if (_draft is not null) _draft.TableShowFilterRow = !_draft.TableShowFilterRow; }
    private void ResetVisualOptions()
    {
        if (_draft is null) return;
        _draft.ShowTitle = true;
        _draft.ShowLegend = true;
        _draft.ShowLabels = false;
        _draft.TableShowHeader = true;
        _draft.TableShowFilterRow = false;
        _draft.RowLimit = 12;
        _draft.MinimumValue = 0;
        _draft.MaximumValue = 100;
        _draft.ArgumentMode = DataVisualArgumentMode.Auto;
        _draft.AggregationMode = DataVisualAggregationMode.Auto;
        _draft.SortMode = DataVisualSortMode.DataOrder;
    }
    private static string CheckedText(bool selected, string text) => selected ? $"✓ {text}" : text;

    private static DataVisualElement Clone(DataVisualElement source)
    {
        var result = new DataVisualElement();
        CopySettings(source, result);
        result.Id = source.Id;
        result.Name = source.Name;
        result.X = source.X; result.Y = source.Y; result.Width = source.Width; result.Height = source.Height;
        result.Rotation = source.Rotation; result.ZIndex = source.ZIndex; result.Visible = source.Visible; result.Locked = source.Locked;
        return result;
    }

    private static void CopySettings(DataVisualElement source, DataVisualElement target)
    {
        target.DataObjectId = source.DataObjectId; target.VisualKind = source.VisualKind;
        target.CartesianStyle = source.CartesianStyle; target.PieStyle = source.PieStyle; target.PolarStyle = source.PolarStyle; target.SparklineStyle = source.SparklineStyle;
        target.Title = source.Title; target.ArgumentField = source.ArgumentField; target.SeriesField = source.SeriesField;
        target.ArgumentMode = source.ArgumentMode; target.AggregationMode = source.AggregationMode; target.SortMode = source.SortMode; target.ValueFields = [.. source.ValueFields];
        target.LowValueField = source.LowValueField; target.HighValueField = source.HighValueField; target.OpenValueField = source.OpenValueField; target.CloseValueField = source.CloseValueField;
        target.SizeField = source.SizeField; target.TargetField = source.TargetField; target.ParentField = source.ParentField;
        target.ShowLegend = source.ShowLegend; target.ShowLabels = source.ShowLabels; target.ShowTitle = source.ShowTitle;
        target.TableShowHeader = source.TableShowHeader; target.TableShowFilterRow = source.TableShowFilterRow; target.RowLimit = source.RowLimit;
        target.MinimumValue = source.MinimumValue; target.MaximumValue = source.MaximumValue;
        target.Background = source.Background; target.BorderColor = source.BorderColor; target.BorderWidthMm = source.BorderWidthMm;
    }

    private static string KindIcon(DataVisualKind kind) => kind switch
    {
