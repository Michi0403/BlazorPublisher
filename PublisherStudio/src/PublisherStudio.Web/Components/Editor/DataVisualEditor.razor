    private RenderFragment FieldSelect(string label, string value, Action<ChangeEventArgs> changed, IReadOnlyList<PublicationDataColumn> columns, bool allowNone = false) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "label");
        builder.AddContent(sequence++, label);
        builder.OpenElement(sequence++, "select");
        builder.AddAttribute(sequence++, "value", value);
        builder.AddAttribute(sequence++, "onchange", EventCallback.Factory.Create(this, changed));
        if (allowNone)
        {
            builder.OpenElement(sequence++, "option"); builder.AddAttribute(sequence++, "value", ""); builder.AddContent(sequence++, "None"); builder.CloseElement();
        }
        foreach (var column in columns)
        {
            builder.OpenElement(sequence++, "option"); builder.AddAttribute(sequence++, "value", column.Name); builder.AddContent(sequence++, column.Name); builder.CloseElement();
        }
        builder.CloseElement(); builder.CloseElement();
    };

    private void AutoMapFields()
    {
        if (_draft is null) return;
        var columns = Columns;
        if (columns.Count == 0) return;
        var numeric = columns.Where(column => column.ValueKind is PublicationDataValueKind.Number or PublicationDataValueKind.Boolean).Select(column => column.Name).ToArray();
        var dates = columns.Where(column => column.ValueKind == PublicationDataValueKind.DateTime).Select(column => column.Name).ToArray();
        var text = columns.Where(column => column.ValueKind == PublicationDataValueKind.Text).Select(column => column.Name).ToArray();
        string First(params IEnumerable<string>[] choices) => choices.SelectMany(value => value).FirstOrDefault() ?? columns[0].Name;

        _draft.SeriesField = string.Empty;
        _draft.ArgumentMode = DataVisualArgumentMode.Auto;
        _draft.AggregationMode = DataVisualAggregationMode.Auto;
        _draft.SortMode = dates.Length > 0 ? DataVisualSortMode.ArgumentAscending : DataVisualSortMode.DataOrder;

        if (_draft.VisualKind == DataVisualKind.Sankey)
        {
            _draft.ArgumentField = First(text, dates, columns.Select(column => column.Name));
            _draft.TargetField = text.FirstOrDefault(name => !string.Equals(name, _draft.ArgumentField, StringComparison.OrdinalIgnoreCase))
                ?? columns.Select(column => column.Name).FirstOrDefault(name => !string.Equals(name, _draft.ArgumentField, StringComparison.OrdinalIgnoreCase)) ?? string.Empty;
            _draft.ValueFields = numeric.Take(1).ToList();
        }
        else if (_draft.VisualKind == DataVisualKind.TreeMap)
        {
            _draft.ArgumentField = First(text, dates, columns.Select(column => column.Name));
            _draft.ParentField = text.FirstOrDefault(name => !string.Equals(name, _draft.ArgumentField, StringComparison.OrdinalIgnoreCase)) ?? string.Empty;
            _draft.ValueFields = numeric.Take(1).ToList();
        }
        else if (_draft.VisualKind == DataVisualKind.CartesianChart && _draft.CartesianStyle == CartesianChartStyle.Bubble)
        {
            _draft.ArgumentField = First(numeric, dates, text);
            _draft.ValueFields = numeric.Where(name => !string.Equals(name, _draft.ArgumentField, StringComparison.OrdinalIgnoreCase)).Take(1).ToList();
            _draft.SizeField = numeric.Where(name => !string.Equals(name, _draft.ArgumentField, StringComparison.OrdinalIgnoreCase) && !_draft.ValueFields.Contains(name, StringComparer.OrdinalIgnoreCase)).FirstOrDefault() ?? _draft.ValueFields.FirstOrDefault() ?? string.Empty;
            _draft.ArgumentMode = numeric.Contains(_draft.ArgumentField, StringComparer.OrdinalIgnoreCase) ? DataVisualArgumentMode.Continuous : DataVisualArgumentMode.Auto;
        }
        else if (_draft.VisualKind == DataVisualKind.CartesianChart && (_draft.CartesianStyle is CartesianChartStyle.Candlestick or CartesianChartStyle.Stock))
        {
            _draft.ArgumentField = First(dates, text, columns.Select(column => column.Name));
            _draft.ValueFields = numeric.Take(1).ToList();
            _draft.OpenValueField = numeric.ElementAtOrDefault(0) ?? string.Empty;
            _draft.HighValueField = numeric.ElementAtOrDefault(1) ?? _draft.OpenValueField;
            _draft.LowValueField = numeric.ElementAtOrDefault(2) ?? _draft.OpenValueField;
            _draft.CloseValueField = numeric.ElementAtOrDefault(3) ?? _draft.OpenValueField;
        }
        else
        {
            _draft.ArgumentField = First(dates, text, columns.Select(column => column.Name));
            _draft.ValueFields = numeric
                .Where(name => !string.Equals(name, _draft.ArgumentField, StringComparison.OrdinalIgnoreCase))
                .Take(AllowsMultipleValueFields ? 2 : 1)
                .ToList();
            if (_draft.ValueFields.Count == 0)
                _draft.ValueFields.Add(columns.FirstOrDefault(column => !string.Equals(column.Name, _draft.ArgumentField, StringComparison.OrdinalIgnoreCase))?.Name ?? _draft.ArgumentField);
        }
        EnsureSpecialFields();
    }

    private string BuildMappingAdvice()
    {
        if (_draft is null || CurrentData is null) return "Choose a data object.";
        if (string.IsNullOrWhiteSpace(_draft.ArgumentField)) return "Choose an argument/category field.";
        if (NumericColumns.Count == 0)
            return "No numeric or Boolean measure was detected. Check the publication-data column types before building this chart.";
        if (!string.IsNullOrWhiteSpace(_draft.SeriesField) && string.Equals(_draft.SeriesField, _draft.ArgumentField, StringComparison.OrdinalIgnoreCase))
            return "Argument and series grouping use the same field. Choose a different series field or None.";
        if (_draft.ValueFields.Any(field => string.Equals(field, _draft.ArgumentField, StringComparison.OrdinalIgnoreCase)))
            return "A value field also acts as the argument. This is valid for XY/scatter data but usually wrong for category charts.";
        if (_draft.VisualKind == DataVisualKind.CartesianChart && _draft.CartesianStyle == CartesianChartStyle.Bubble && NumericColumns.Count < 3)
            return "Bubble charts work best with three numeric roles: X argument, Y value, and bubble size.";
        if (_draft.VisualKind == DataVisualKind.CartesianChart && (_draft.CartesianStyle is CartesianChartStyle.Candlestick or CartesianChartStyle.Stock) && NumericColumns.Count < 4)
            return "Financial charts require four numeric columns: open, high, low, and close.";
        if (_draft.VisualKind == DataVisualKind.Sankey && string.IsNullOrWhiteSpace(_draft.TargetField))
            return "Sankey requires separate source and target fields plus a numeric weight.";
        if (!SupportsAggregation && _draft.AggregationMode is not (DataVisualAggregationMode.Auto or DataVisualAggregationMode.None))
            return "Aggregation is not applied to this specialized visual; rows remain explicit.";
        return _draft.AggregationMode == DataVisualAggregationMode.None
            ? "Repeated argument/series combinations remain separate points."
            : "Typed arguments, repeated-category aggregation, and sorting are applied in the browser and export runtime.";
    }

    private static string AggregationLabel(DataVisualAggregationMode mode) => mode switch
    {
        DataVisualAggregationMode.Auto => "Auto (sum duplicates)",
        DataVisualAggregationMode.None => "Keep every row",
        DataVisualAggregationMode.Minimum => "Minimum",
        DataVisualAggregationMode.Maximum => "Maximum",
        _ => Friendly(mode.ToString())
    };

    private void EnsureSpecialFields()
    {
        if (_draft is null) return;
        var numeric = NumericColumns.Select(column => column.Name).ToArray();
        var all = Columns.Select(column => column.Name).ToArray();
        string Pick(int index, string current) => !string.IsNullOrWhiteSpace(current) ? current : numeric.ElementAtOrDefault(index) ?? numeric.FirstOrDefault() ?? string.Empty;
        _draft.OpenValueField = Pick(0, _draft.OpenValueField);
        _draft.HighValueField = Pick(1, _draft.HighValueField);
        _draft.LowValueField = Pick(2, _draft.LowValueField);
        _draft.CloseValueField = Pick(3, _draft.CloseValueField);
        _draft.SizeField = Pick(1, _draft.SizeField);
        if (string.IsNullOrWhiteSpace(_draft.TargetField)) _draft.TargetField = all.FirstOrDefault(field => !string.Equals(field, _draft.ArgumentField, StringComparison.OrdinalIgnoreCase)) ?? string.Empty;
    }

    private static bool ValidateFields(DataVisualElement item)
    {
        if (item.VisualKind == DataVisualKind.DataTable) return true;
        if (item.ValueFields.Count == 0) return false;
        if (item.VisualKind == DataVisualKind.Sankey) return !string.IsNullOrWhiteSpace(item.ArgumentField) && !string.IsNullOrWhiteSpace(item.TargetField);
        if (item.VisualKind == DataVisualKind.TreeMap) return !string.IsNullOrWhiteSpace(item.ArgumentField);
        if (item.VisualKind == DataVisualKind.CartesianChart && (item.CartesianStyle is CartesianChartStyle.RangeArea or CartesianChartStyle.RangeBar))
            return !string.IsNullOrWhiteSpace(item.LowValueField) && !string.IsNullOrWhiteSpace(item.HighValueField);
        if (item.VisualKind == DataVisualKind.CartesianChart && item.CartesianStyle == CartesianChartStyle.Bubble)
            return !string.IsNullOrWhiteSpace(item.SizeField);
        if (item.VisualKind == DataVisualKind.CartesianChart && (item.CartesianStyle is CartesianChartStyle.Candlestick or CartesianChartStyle.Stock))
            return !string.IsNullOrWhiteSpace(item.OpenValueField) && !string.IsNullOrWhiteSpace(item.HighValueField)
                && !string.IsNullOrWhiteSpace(item.LowValueField) && !string.IsNullOrWhiteSpace(item.CloseValueField);
        return true;
    }
    private static string Friendly(string value) => string.Concat(value.Select((character, index) => index > 0 && char.IsUpper(character) ? $" {character}" : character.ToString()));
    private static bool Checked(ChangeEventArgs args) => args.Value is bool value && value;
    private static bool TryDouble(object? value, out double result) => double.TryParse(value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out result) || double.TryParse(value?.ToString(), out result);
    private static string Inv(double value) => value.ToString("0.###", CultureInfo.InvariantCulture);
}
