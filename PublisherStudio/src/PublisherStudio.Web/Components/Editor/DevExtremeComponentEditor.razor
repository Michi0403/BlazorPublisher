    private void AddField()
    {
        if (_draft is null) return;
        var used = _draft.Fields.Select(field => field.DataField).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var column = SourceColumns.FirstOrDefault(candidate => !used.Contains(candidate.Name));
        if (column is null)
        {
            var customName = $"field{_draft.Fields.Count + 1}";
            _draft.Fields.Add(new PublicationComponentField { DataField = customName, Caption = Friendly(customName) });
            return;
        }

        _draft.Fields.Add(new PublicationComponentField
        {
            DataField = column.Name,
            Caption = Friendly(column.Name),
            ValueKind = column.ValueKind,
            Editor = column.ValueKind switch
            {
                PublicationDataValueKind.Number => PublicationComponentEditorKind.NumberBox,
                PublicationDataValueKind.Boolean => PublicationComponentEditorKind.CheckBox,
                PublicationDataValueKind.DateTime => PublicationComponentEditorKind.DateBox,
                _ => PublicationComponentEditorKind.TextBox
            }
        });
    }
