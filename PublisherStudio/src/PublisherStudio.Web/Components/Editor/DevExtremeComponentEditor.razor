    private void AddPublicationPagesToMenu()
    {
        if (_draft is null) return;
        _draft.MenuSourceMode = PublicationMenuSourceMode.ManualItems;
        var existing = _draft.MenuItems.Where(item => item.Destination == PublicationMenuDestinationKind.Page && item.TargetPageId is not null)
            .Select(item => item.TargetPageId!.Value).ToHashSet();
        foreach (var page in State.Document.Pages.Where(page => !existing.Contains(page.Id)))
            _draft.MenuItems.Add(new PublicationMenuItem { Text = page.Name, Destination = PublicationMenuDestinationKind.Page, TargetPageId = page.Id });
    }

