    private RenderFragment MethodOptions() => builder =>
    {
        var sequence = 0;
        foreach (var method in Enum.GetValues<PublicationComponentHttpMethod>())
        {
            builder.OpenElement(sequence++, "option");
            builder.AddAttribute(sequence++, "value", method);
            builder.AddContent(sequence++, method);
            builder.CloseElement();
        }
    };

