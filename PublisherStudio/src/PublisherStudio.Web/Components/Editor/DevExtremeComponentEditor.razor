@namespace PublisherStudio.Components.Editor
@implements IAsyncDisposable
@inject PublicationComponentService Components
@inject PublicationDataService DataService
@inject IJSRuntime JS

@if (Visible && _draft is not null)
{
    <div class="modal-backdrop component-modal-backdrop">
        <section class="component-editor-dialog" role="dialog" aria-modal="true" aria-label="Component Studio">
            <header>
                <div>
                    <strong>Component Studio · @_draft.Title</strong>
                    <span>Browser-native DevExtreme controls with publication datasets, REST, OData, CRUD, page navigation, and component-to-component actions.</span>
                </div>
                <button type="button" class="window-close" @onclick="Cancel"><span aria-hidden="true">×</span></button>
            </header>

            <div class="component-editor-commandbar">
                <button type="button" class="@SectionClass("general")" @onclick="ShowGeneral">General</button>
                <button type="button" class="@SectionClass("data")" @onclick="ShowData">Data &amp; API</button>
                @if (_draft.ComponentKind is PublicationComponentKind.Menu or PublicationComponentKind.ContextMenu)
                {
                    <button type="button" class="@SectionClass("menu")" @onclick="ShowMenuItems">Menu items</button>
                }
                <button type="button" class="@SectionClass("fields")" @onclick="ShowFields">Fields &amp; editors</button>
                <button type="button" class="@SectionClass("behavior")" @onclick="ShowBehavior">Behavior</button>
                @if (_draft.ComponentKind is PublicationComponentKind.Map or PublicationComponentKind.VectorMap)
                {
                    <button type="button" class="@SectionClass("map")" @onclick="ShowMap">Map &amp; drawing</button>
                }
                @if (_draft.IsLayoutContainer)
                {
                    <button type="button" class="@SectionClass("layout")" @onclick="ShowLayout">Layout panels</button>
                }
                <button type="button" class="@SectionClass("actions")" @onclick="ShowActions">Actions</button>
                <button type="button" class="@SectionClass("advanced")" @onclick="ShowAdvanced">Advanced</button>
                <span></span>
                <button type="button" @onclick="RequestManageData">Manage publication data</button>
            </div>

            <div class="component-editor-body">
                <aside class="component-kind-list" aria-label="Component type">
                    @foreach (var kind in Enum.GetValues<PublicationComponentKind>())
                    {
                        <button type="button" class="@(_draft.ComponentKind == kind ? "selected" : null)" @onclick="() => ChangeKind(kind)">
                            <b>@ComponentIcon(kind)</b>
                            <span>@PublicationComponentService.ComponentName(kind)</span>
                        </button>
                    }
                </aside>

                <main class="component-settings">
                    @if (_section == "general")
                    {
                        <section class="component-section">
                            <h3>Identity and scope</h3>
                            <div class="component-form-grid">
                                <label>Object name<input @bind="_draft.Name" /></label>
                                <label>Displayed title<input @bind="_draft.Title" /></label>
                                <label>Scope
                                    <select @bind="_draft.Scope">
                                        <option value="@PublicationComponentScope.Page">This page only</option>
                                        <option value="@PublicationComponentScope.Document">Document-wide synchronized</option>
                                    </select>
                                </label>
                                <label>Background<input type="color" @bind="_draft.Background" /></label>
                                <label>Border color<input type="color" @bind="_draft.BorderColor" /></label>
                                <label>Border width (mm)<input type="number" min="0" max="8" step="0.05" @bind="_draft.BorderWidthMm" /></label>
                            </div>
                            <div class="component-option-grid">
                                <label><input type="checkbox" @bind="_draft.ShowTitle" /> Show component title</label>
                                @if (SupportsInternalBorders)
                                {
                                    <label><input type="checkbox" @bind="_draft.ShowBorders" /> Show internal borders</label>
                                }
                                @if (SupportsWordWrap)
                                {
                                    <label><input type="checkbox" @bind="_draft.WordWrap" /> Wrap field text</label>
                                }
                            </div>
                            @if (_draft.Scope == PublicationComponentScope.Document)
                            {
                                <p class="component-info">Content, data bindings, fields, actions, and styling stay synchronized on every publication page. Position and size remain page-specific so portrait and landscape pages can use different layouts.</p>
                            }
                        </section>
                    }
                    else if (_section == "data")
                    {
                        <section class="component-section">
                            <div class="component-section-heading">
                                <h3>Smart data connection</h3>
                                @if (_draft.ComponentKind is PublicationComponentKind.Menu or PublicationComponentKind.ContextMenu)
                                {
                                    <button type="button" @onclick="UseLivePageDataset">Use live publication pages</button>
                                }
                                @if (_draft.ComponentKind is PublicationComponentKind.Gallery or PublicationComponentKind.TileView)
                                {
                                    <button type="button" @onclick="UsePublicationMediaDataset">Use pictures &amp; videos from document</button>
                                }
                            </div>
                            @if (_draft.ComponentKind is PublicationComponentKind.Menu or PublicationComponentKind.ContextMenu)
                            {
                                <div class="component-form-grid">
                                    <label>Menu content
                                        <select @bind="_draft.MenuSourceMode">
                                            <option value="@PublicationMenuSourceMode.ManualItems">Editable menu items</option>
                                            <option value="@PublicationMenuSourceMode.DataConnection">Data object / API rows</option>
                                        </select>
                                    </label>
                                </div>
                                <p class="component-info">Editable items may point to a publication page, an external URL, or perform no navigation. Pages are never inserted automatically. Data-driven menus use the text, target-page, URL, key, and parent mappings from Fields &amp; editors.</p>
                                @if (_draft.MenuSourceMode == PublicationMenuSourceMode.ManualItems)
                                {
                                    <button type="button" @onclick="ShowMenuItems">Edit menu items</button>
                                }
                            }
                            @if (_draft.ComponentKind is PublicationComponentKind.Gallery or PublicationComponentKind.TileView)
                            {
                                <p class="component-info"><b>Fast media workflow:</b> choose “Use pictures &amp; videos from document” to bind this component to the live Publication media object. Pictures, videos, and audio already inserted in the publication appear automatically; no binary file is copied into a second dataset. REST/JSON media feeds remain available below.</p>
                            }
                            @if (_draft.ComponentKind == PublicationComponentKind.Chat)
                            {
                                <p class="component-info"><b>Chat data:</b> bind a snapshot/API with one row per message, or let the streaming bridge push messages at runtime. Platform and channel filtering is enforced inside the component so Twitch and YouTube messages are never combined.</p>
                            }
                            @if (IsManualMenu)
                            {
                                <div class="component-info">This menu uses its editable item list. No dataset, API, key field, or CRUD configuration is required. Open <b>Menu items</b> to assign an internal page, an external URL, or no navigation to every item.</div>
                            }
                            else
                            {
                            <div class="component-form-grid">
                                <label>Source
                                    <select @bind="_draft.Connection.Mode" @bind:after="ConnectionModeChanged">
                                        <option value="@PublicationComponentDataMode.PublicationDataObject">Publication data object</option>
                                        <option value="@PublicationComponentDataMode.StaticSnapshot">Embedded snapshot only</option>
                                        <option value="@PublicationComponentDataMode.Rest">REST / JSON endpoint</option>
                                        <option value="@PublicationComponentDataMode.OData">OData service</option>
                                    </select>
                                </label>
                                <label>Processing
                                    <select @bind="_draft.Connection.ProcessingMode">
                                        <option value="@PublicationComponentProcessingMode.Client">Client-side sorting/filtering</option>
                                        <option value="@PublicationComponentProcessingMode.Remote">Remote/server operations</option>
                                    </select>
                                </label>
                                <label>Key field
                                    <select @bind="_draft.Connection.KeyField" @bind:after="SyncKeyField">
                                        <option value="">Automatic / not used</option>
                                        @foreach (var column in SourceColumns)
                                        {
                                            <option value="@column.Name">@column.Name (@column.ValueKind)</option>
                                        }
                                    </select>
                                </label>
                            </div>

                            @if (_draft.Connection.Mode is PublicationComponentDataMode.PublicationDataObject or PublicationComponentDataMode.StaticSnapshot)
                            {
                                <div class="component-data-object-row">
                                    <label>Publication data object
                                        <select @bind="_draft.Connection.DataObjectId" @bind:after="UseDatasetFieldsIfEmpty">
                                            @foreach (var data in State.Document.DataObjects)
                                            {
                                                <option value="@data.Id">@data.Name · @data.SourceKind</option>
                                            }
                                        </select>
                                    </label>
                                    <button type="button" @onclick="UseDatasetFields">Read fields from dataset</button>
                                    <button type="button" @onclick="RequestManageData">Open data manager</button>
                                </div>
                                <p class="component-info">Publication data objects can already contain embedded tables, spreadsheet selections, web polling, webhook snapshots, or document-object data. The same parsed rows are reused by charts and these controls.</p>
                            }
                            else
                            {
                                <div class="component-form-grid wide">
                                    <label class="span-2">Endpoint URL<input @bind="_draft.Connection.Url" placeholder="https://server.example/api/items or /odata/Orders" /></label>
                                    @if (_draft.Connection.Mode == PublicationComponentDataMode.Rest)
                                    {
                                        <label>Load method
                                            <select @bind="_draft.Connection.LoadMethod">
                                                @foreach (var method in Enum.GetValues<PublicationComponentHttpMethod>()) { <option value="@method">@method</option> }
                                            </select>
                                        </label>
                                        <label>JSON result path<input @bind="_draft.Connection.JsonPath" placeholder="data.items" /></label>
                                        @if (_draft.Connection.LoadMethod is not PublicationComponentHttpMethod.Get and not PublicationComponentHttpMethod.Delete)
                                        {
                                            <label class="span-2">Load request body<textarea @bind="_draft.Connection.LoadBody" spellcheck="false"></textarea></label>
                                        }
                                    }
                                    else
                                    {
                                        <label>OData version
                                            <select @bind="_draft.Connection.ODataVersion"><option value="2">2</option><option value="3">3</option><option value="4">4</option></select>
                                        </label>
                                        <label>Key type
                                            <select @bind="_draft.Connection.KeyType"><option>Int32</option><option>Int64</option><option>String</option><option>Guid</option></select>
                                        </label>
                                    }
                                </div>
                                <label class="component-header-editor">Request headers <small>one Name: Value pair per line</small>
                                    <textarea value="@_headersText" @oninput="ChangeHeaders" spellcheck="false" placeholder="Authorization: Bearer …"></textarea>
                                </label>
                                <div class="component-api-tools">
                                    <button type="button" @onclick="TestEndpoint" disabled="@_testingConnection">@(_testingConnection ? "Reading endpoint…" : "Test endpoint and discover fields")</button>
                                    <label><input type="checkbox" @bind="_draft.Connection.WithCredentials" /> Include browser credentials</label>
                                    @if (!string.IsNullOrWhiteSpace(_connectionStatus)) { <span>@_connectionStatus</span> }
                                </div>
                                <p class="component-warning">The single-file HTML export can call only endpoints the browser is allowed to reach. Any direct URL and header value required by the browser becomes part of the exported HTML. Never embed private credentials in a file you distribute.</p>
                            }

                            <h3>Editing and CRUD</h3>
                            <div class="component-option-grid">
                                <label><input type="checkbox" @bind="_draft.Connection.AllowInsert" /> Allow insert</label>
                                <label><input type="checkbox" @bind="_draft.Connection.AllowUpdate" /> Allow update</label>
                                <label><input type="checkbox" @bind="_draft.Connection.AllowDelete" /> Allow delete</label>
                                <label><input type="checkbox" @bind="_draft.Connection.AppendKeyToWriteUrl" /> Append key to update/delete URL</label>
                            </div>
                            @if (_draft.Connection.AllowInsert || _draft.Connection.AllowUpdate || _draft.Connection.AllowDelete)
                            {
                                <div class="component-form-grid wide">
                                    @if (_draft.Connection.AllowInsert)
                                    {
                                        <label>Insert method<select @bind="_draft.Connection.InsertMethod">@MethodOptions()</select></label>
                                        <label>Insert URL<input @bind="_draft.Connection.InsertUrl" placeholder="blank = load URL" /></label>
                                    }
                                    @if (_draft.Connection.AllowUpdate)
                                    {
                                        <label>Update method<select @bind="_draft.Connection.UpdateMethod">@MethodOptions()</select></label>
                                        <label>Update URL<input @bind="_draft.Connection.UpdateUrl" placeholder="blank = load URL" /></label>
                                    }
                                    @if (_draft.Connection.AllowDelete)
                                    {
                                        <label>Delete method<select @bind="_draft.Connection.DeleteMethod">@MethodOptions()</select></label>
                                        <label>Delete URL<input @bind="_draft.Connection.DeleteUrl" placeholder="blank = load URL" /></label>
                                    }
                                </div>
                            }
                            }
                        </section>
                    }
                    else if (_section == "menu")
                    {
                        <section class="component-section">
                            <div class="component-section-heading">
                                <h3>Menu items</h3>
                                <div>
                                    <button type="button" @onclick="AddMenuItem">Add item</button>
                                    <button type="button" @onclick="AddPublicationPagesToMenu">Add publication pages</button>
                                </div>
                            </div>
                            <div class="component-form-grid">
                                <label>Menu content
                                    <select @bind="_draft.MenuSourceMode">
                                        <option value="@PublicationMenuSourceMode.ManualItems">Editable menu items</option>
                                        <option value="@PublicationMenuSourceMode.DataConnection">Data object / API rows</option>
                                    </select>
                                </label>
                                @if (_draft.ComponentKind == PublicationComponentKind.Menu)
                                {
                                    <label>Build direction
                                        <select @bind="_draft.Orientation"><option value="horizontal">Horizontal</option><option value="vertical">Vertical</option></select>
                                    </label>
                                }
                            </div>
                            @if (_draft.MenuSourceMode == PublicationMenuSourceMode.DataConnection)
                            {
                                <div class="component-info">This menu is generated from the selected data object or API. Use <b>Fields &amp; editors</b> to choose the text, target-page, URL, key, and optional parent fields. An item navigates to its page when the target-page field has a value; otherwise it opens its URL when the URL field has a value.</div>
                                <div class="component-section-heading"><span></span><button type="button" @onclick="UseLivePageDataset">Use the self-updating Publication pages object</button></div>
                            }
                            else
                            {
                                <p class="component-info">Choose a destination per item. “No navigation” is useful for headings or entries handled by custom actions. External-only menus are supported; adding publication pages is optional.</p>
                                <div class="component-menu-item-list">
                                    @foreach (var menuItem in _draft.MenuItems)
                                    {
                                        <article @key="menuItem.Id">
                                            <div class="component-form-grid wide">
                                                <label>Text<input @bind="menuItem.Text" /></label>
                                                <label>Parent item
                                                    <select value="@menuItem.ParentId" @onchange="args => SetMenuParent(menuItem, args)">
                                                        <option value="">Top level</option>
                                                        @foreach (var parent in _draft.MenuItems.Where(candidate => candidate.Id != menuItem.Id))
                                                        {
                                                            <option value="@parent.Id">@parent.Text</option>
                                                        }
                                                    </select>
                                                </label>
                                                <label>Destination
                                                    <select @bind="menuItem.Destination">
                                                        <option value="@PublicationMenuDestinationKind.None">No navigation</option>
                                                        <option value="@PublicationMenuDestinationKind.Page">Publication page</option>
                                                        <option value="@PublicationMenuDestinationKind.ExternalUrl">External URL</option>
                                                    </select>
                                                </label>
                                                @if (menuItem.Destination == PublicationMenuDestinationKind.Page)
                                                {
                                                    <label>Page
                                                        <select value="@menuItem.TargetPageId" @onchange="args => SetMenuTargetPage(menuItem, args)">
                                                            <option value="">Select page</option>
                                                            @foreach (var publicationPage in State.Document.Pages)
                                                            {
                                                                <option value="@publicationPage.Id">@publicationPage.Name</option>
                                                            }
                                                        </select>
                                                    </label>
                                                }
                                                else if (menuItem.Destination == PublicationMenuDestinationKind.ExternalUrl)
                                                {
                                                    <label class="span-2">External URL<input @bind="menuItem.Url" placeholder="https://example.com" /></label>
                                                    <label><input type="checkbox" @bind="menuItem.OpenInNewWindow" /> Open in new window</label>
                                                }
                                                <label>Icon CSS class<input @bind="menuItem.IconCssClass" placeholder="optional" /></label>
                                            </div>
                                            <div class="component-option-grid">
                                                <label><input type="checkbox" @bind="menuItem.Enabled" /> Enabled</label>
                                                <label><input type="checkbox" @bind="menuItem.Visible" /> Visible</label>
                                            </div>
                                            <button type="button" class="danger" @onclick="() => RemoveMenuItem(menuItem)">Remove item</button>
                                        </article>
                                    }
                                </div>
                                @if (_draft.MenuItems.Count == 0)
                                {
                                    <div class="empty-panel">No menu items yet. Add an external link, a page link, or a non-navigating item.</div>
                                }
                            }
                        </section>
                    }
                    else if (_section == "fields")
                    {
                        <section class="component-section">
                            <div class="component-section-heading">
                                <h3>Fields and editors</h3>
                                @if (!IsManualMenu)
                                {
                                    <div><button type="button" @onclick="UseDatasetFields">Reset from dataset</button><button type="button" @onclick="AddField">Add field</button></div>
                                }
                            </div>
                            @if (IsManualMenu)
                            {
                                <p class="component-info">This menu uses editable menu items, so dataset fields are intentionally not used. Switch Menu content to <b>Data object / API rows</b> when you want a menu generated from source properties.</p>
                                <button type="button" @onclick="ShowMenuItems">Open editable menu items</button>
                            }
                            else
                            {
                                <p class="component-info">Each field below maps to a property provisioned by the selected data source. Select the source property rather than guessing its name. Lookup value/display fields are read from the selected lookup object.</p>
                            <div class="component-field-table-wrap">
                                <table class="component-field-table">
                                    <thead><tr><th>Data field</th><th>Caption</th><th>Type</th><th>Editor</th><th>Visible</th><th>Edit</th><th>Required</th><th>Width</th><th>Pivot area</th><th>Lookup dataset</th><th>Lookup value</th><th>Lookup display</th><th></th></tr></thead>
                                    <tbody>
                                        @foreach (var field in _draft.Fields)
                                        {
                                            <tr @key="field.Id">
                                                <td>
                                                    <select value="@field.DataField" @onchange="args => SetFieldDataProperty(field, args)">
                                                        <option value="">Select source property</option>
                                                        @foreach (var column in FieldChoices(field))
                                                        {
                                                            <option value="@column.Name">@column.Name (@column.ValueKind)</option>
                                                        }
                                                    </select>
                                                </td>
                                                <td><input @bind="field.Caption" /></td>
                                                <td><select @bind="field.ValueKind">@foreach (var value in Enum.GetValues<PublicationDataValueKind>()) { <option value="@value">@value</option> }</select></td>
                                                <td><select @bind="field.Editor">@foreach (var value in Enum.GetValues<PublicationComponentEditorKind>()) { <option value="@value">@value</option> }</select></td>
                                                <td><input type="checkbox" @bind="field.Visible" /></td>
                                                <td><input type="checkbox" @bind="field.Editable" /></td>
                                                <td><input type="checkbox" @bind="field.Required" /></td>
                                                <td><input type="number" min="0" max="2000" @bind="field.Width" /></td>
                                                <td><select @bind="field.Area" disabled="@(_draft.ComponentKind != PublicationComponentKind.PivotGrid)">@foreach (var value in Enum.GetValues<PublicationComponentFieldArea>()) { <option value="@value">@value</option> }</select></td>
                                                <td><select value="@field.LookupDataObjectId" @onchange="args => SetLookupDataObject(field, args)"><option value="">None</option>@foreach (var data in State.Document.DataObjects) { <option value="@data.Id">@data.Name</option> }</select></td>
                                                <td><select @bind="field.LookupDataField" disabled="@(field.LookupDataObjectId is null)"><option value="">Automatic</option>@foreach (var lookupColumn in LookupColumns(field)) { <option value="@lookupColumn.Name">@lookupColumn.Name</option> }</select></td>
                                                <td><select @bind="field.LookupDisplayField" disabled="@(field.LookupDataObjectId is null)"><option value="">Automatic</option>@foreach (var lookupColumn in LookupColumns(field)) { <option value="@lookupColumn.Name">@lookupColumn.Name</option> }</select></td>
                                                <td><button type="button" class="danger" @onclick="() => RemoveField(field)">×</button></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            @if (_draft.Fields.Count == 0)
                            {
                                <div class="empty-panel">No fields are available. Select a data object and use “Read fields from dataset”, or add a field manually.</div>
                            }
                            else
                            {
                                <h3>Component field mappings</h3>
                                <div class="component-form-grid mapping-grid">
                                    @if (UsesKeyField)
                                    {
                                        <label>Key field<select @bind="_draft.KeyField" @bind:after="SyncConnectionKey"><option value="">Not used</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                    }
                                    @if (UsesParentField)
                                    {
                                        <label>Parent field<select @bind="_draft.ParentField"><option value="">No hierarchy</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                    }
                                    @if (UsesTextField)
                                    {
                                        <label>Text / title field<select @bind="_draft.TextField"><option value="">Not used</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                    }
                                    @if (UsesDisplayField)
                                    {
                                        <label>Display field<select @bind="_draft.DisplayField"><option value="">Automatic</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                    }
                                    @if (UsesValueField)
                                    {
                                        <label>Value field<select @bind="_draft.ValueField"><option value="">Automatic</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                    }
                                    @if (UsesImageField)
                                    {
                                        <label>Image field<select @bind="_draft.ImageField"><option value="">No image</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                    }
                                    @if (_draft.ComponentKind is PublicationComponentKind.Gallery or PublicationComponentKind.TileView)
                                    {
                                        <label>Media type field<select @bind="_draft.MediaKindField"><option value="">Infer from URL</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                        <label>Media source field<select @bind="_draft.MediaSourceField"><option value="">Use image field</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                        <label>Video poster field<select @bind="_draft.MediaPosterField"><option value="">No poster</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                        <label>Alternative text field<select @bind="_draft.MediaAltTextField"><option value="">Use title</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                    }
                                    @if (_draft.ComponentKind == PublicationComponentKind.Chat)
                                    {
                                        <label>Platform field<select @bind="_draft.ChatPlatformField"><option value="">Use configured platform</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                        <label>Channel field<select @bind="_draft.ChatChannelField"><option value="">Use configured channel</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                        <label>Message field<select @bind="_draft.ChatMessageField"><option value="">Select field</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                        <label>Timestamp field<select @bind="_draft.ChatTimestampField"><option value="">No timestamp</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                        <label>Author ID field<select @bind="_draft.ChatAuthorIdField"><option value="">Automatic</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                        <label>Author name field<select @bind="_draft.ChatAuthorNameField"><option value="">Select field</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                        <label>Author avatar field<select @bind="_draft.ChatAuthorAvatarField"><option value="">No avatars</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                    }
                                    @if (_draft.ComponentKind == PublicationComponentKind.Scheduler)
                                    {
                                        <label>Start date field<select @bind="_draft.StartDateField"><option value="">Select field</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                        <label>End date field<select @bind="_draft.EndDateField"><option value="">Select field</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                        <label>All-day field<select @bind="_draft.AllDayField"><option value="">Not used</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                    }
                                    @if (_draft.ComponentKind is PublicationComponentKind.Menu or PublicationComponentKind.ContextMenu)
                                    {
                                        <label>Target page field<select @bind="_draft.TargetPageField"><option value="">No page navigation</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                        <label>External URL field<select @bind="_draft.UrlField"><option value="">No external links</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                    }
                                </div>
                            }
                            }
                        </section>
                    }
                    else if (_section == "behavior")
                    {
                        <section class="component-section">
                            <h3>@PublicationComponentService.ComponentName(_draft.ComponentKind) behavior</h3>
                            <p class="component-info">Only options supported by the selected component are shown here.</p>
                            <div class="component-form-grid">
                                @if (SupportsEditMode)
                                {
                                    <label>Edit mode<select @bind="_draft.EditMode">@foreach (var value in Enum.GetValues<PublicationComponentEditMode>()) { <option value="@value">@value</option> }</select></label>
                                }
                                @if (SupportsSelection)
                                {
                                    <label>Selection<select @bind="_draft.SelectionMode">@foreach (var value in Enum.GetValues<PublicationComponentSelectionMode>()) { <option value="@value">@value</option> }</select></label>
                                }
                                @if (SupportsPageSize)
                                {
                                    <label>Page size<input type="number" min="1" max="1000" @bind="_draft.PageSize" /></label>
                                }
                                @if (_draft.ComponentKind == PublicationComponentKind.Form)
                                {
                                    <label>Form columns<input type="number" min="1" max="12" @bind="_draft.ColumnCount" /></label>
                                }
                                @if (_draft.ComponentKind == PublicationComponentKind.Scheduler)
                                {
                                    <label>Scheduler view<select @bind="_draft.CurrentView"><option>day</option><option>week</option><option>workWeek</option><option>month</option><option>agenda</option></select></label>
                                }
                                @if (SupportsOrientation)
                                {
                                    <label>Build direction<select @bind="_draft.Orientation"><option value="horizontal">Horizontal</option><option value="vertical">Vertical</option></select></label>
                                }
                                @if (SupportsButtonText)
                                {
                                    <label>Button / label text<input @bind="_draft.ButtonText" /></label>
                                }
                                @if (SupportsPlaceholder)
                                {
                                    <label>Placeholder<input @bind="_draft.Placeholder" /></label>
                                }
                                @if (SupportsInitialValue)
                                {
                                    <label>Initial value<input @bind="_draft.InitialValue" /></label>
                                }
                            </div>
                            @if (_draft.ComponentKind is PublicationComponentKind.Gallery or PublicationComponentKind.TileView)
                            {
                                <div class="component-option-grid three">
                                    <label><input type="checkbox" @bind="_draft.MediaShowControls" /> Video/audio controls</label>
                                    <label><input type="checkbox" @bind="_draft.MediaAutoPlay" /> Autoplay active media</label>
                                    <label><input type="checkbox" @bind="_draft.MediaMuted" /> Mute media</label>
                                    <label><input type="checkbox" @bind="_draft.MediaLoop" /> Loop media</label>
                                </div>
                            }
                            @if (_draft.ComponentKind == PublicationComponentKind.Chat)
                            {
                                <div class="component-form-grid">
                                    <label>Platform<select @bind="_draft.ChatPlatform">@foreach (var platform in Enum.GetValues<PublicationChatPlatform>()) { <option value="@platform">@platform</option> }</select></label>
                                    <label>Channel / stream ID<input @bind="_draft.ChatChannel" placeholder="optional until streaming is connected" /></label>
                                    <label>Sender ID<input @bind="_draft.ChatCurrentUserId" /></label>
                                    <label>Sender name<input @bind="_draft.ChatCurrentUserName" /></label>
                                    <label>Sender avatar URL<input @bind="_draft.ChatCurrentUserAvatar" placeholder="optional" /></label>
                                    <label>Input placeholder<input @bind="_draft.Placeholder" placeholder="Send a message…" /></label>
                                </div>
                                <div class="component-option-grid three">
                                    <label><input type="checkbox" @bind="_draft.ChatAllowSending" /> Show answer field</label>
                                    <label><input type="checkbox" @bind="_draft.ChatShowAvatar" /> Show avatars</label>
                                    <label><input type="checkbox" @bind="_draft.ChatShowTimestamp" /> Show timestamps</label>
                                    <label><input type="checkbox" @bind="_draft.ChatOptimisticSend" /> Show sent message immediately</label>
                                </div>
                                <p class="component-info">The runtime accepts a platform adapter through <code>window.PublisherStudioChatBridge</code>. It subscribes and sends only for the selected platform and channel. The same publication can therefore be rendered once for Twitch and once for YouTube without exposing the other platform's chat.</p>
                            }
                            @if (SupportsGridOptions || _draft.ComponentKind == PublicationComponentKind.TreeList)
                            {
                                <div class="component-option-grid three">
                                    <label><input type="checkbox" @bind="_draft.ShowFilterRow" /> Filter row</label>
                                    <label><input type="checkbox" @bind="_draft.ShowHeaderFilter" /> Header filter</label>
                                    <label><input type="checkbox" @bind="_draft.ShowSearchPanel" /> Search panel</label>
                                    @if (_draft.ComponentKind == PublicationComponentKind.DataGrid)
                                    {
                                        <label><input type="checkbox" @bind="_draft.ShowGroupPanel" /> Group panel</label>
                                    }
                                    <label><input type="checkbox" @bind="_draft.ShowColumnChooser" /> Column chooser</label>
                                    <label><input type="checkbox" @bind="_draft.AllowPaging" /> Paging</label>
                                    <label><input type="checkbox" @bind="_draft.AllowSorting" /> Sorting</label>
                                    <label><input type="checkbox" @bind="_draft.AllowFiltering" /> Filtering</label>
                                    <label><input type="checkbox" @bind="_draft.AllowReordering" /> Column reordering</label>
                                    <label><input type="checkbox" @bind="_draft.AllowResizing" /> Column resizing</label>
                                    @if (_draft.ComponentKind == PublicationComponentKind.TreeList)
                                    {
                                        <label><input type="checkbox" @bind="_draft.AutoExpandAll" /> Expand tree nodes</label>
                                    }
                                </div>
                            }
                        </section>
                    }
                    else if (_section == "map")
                    {
                        <section class="component-section vector-map-editor">
                            <h3>@(_draft.ComponentKind == PublicationComponentKind.VectorMap ? "Vector map designer" : "Interactive map")</h3>
                            <div class="component-form-grid wide">
                                <label>Latitude field<select @bind="_draft.LatitudeField"><option value="">Not used</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                <label>Longitude field<select @bind="_draft.LongitudeField"><option value="">Not used</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                <label>Label / tooltip field<select @bind="_draft.MarkerTooltipField"><option value="">No label</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                <label>Center latitude<input type="number" min="-90" max="90" step="0.0001" @bind="_draft.MapCenterLatitude" /></label>
                                <label>Center longitude<input type="number" min="-180" max="180" step="0.0001" @bind="_draft.MapCenterLongitude" /></label>
                                <label>Zoom<input type="number" min="1" max="20" step="0.25" @bind="_draft.MapZoom" /></label>
                            </div>
                            <div class="component-option-grid">
                                <label><input type="checkbox" @bind="_draft.MapControls" /> Navigation controls</label>
                                <label><input type="checkbox" @bind="_draft.MapAutoAdjust" /> Auto-fit markers</label>
                            </div>

                            @if (_draft.ComponentKind == PublicationComponentKind.Map)
                            {
                                <div class="component-form-grid wide">
                                    <label>Provider<select @bind="_draft.MapProvider"><option value="">Select a provider…</option><option value="google">Google Maps</option><option value="googleStatic">Google Static Maps</option><option value="azure">Azure Maps</option><option value="bing">Bing Maps (legacy)</option></select></label>
                                    <label>Map type<select @bind="_draft.MapType"><option value="roadmap">Road map</option><option value="satellite">Satellite</option><option value="hybrid">Hybrid</option></select></label>
                                    <label class="span-2">Provider API key<input type="password" @bind="_draft.MapApiKey" autocomplete="off" placeholder="Required before preview or export" /></label>
                                    @if (UsesGoogleMapProvider)
                                    {
                                        <label class="span-2">Google Map ID (optional)<input @bind="_draft.MapId" autocomplete="off" placeholder="Enables Google advanced markers" /></label>
                                    }
                                    <label>Address field<select @bind="_draft.AddressField"><option value="">Not used</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                    <label>Route group field<select @bind="_draft.MapRouteField"><option value="">One route</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                    <label>Route order field<select @bind="_draft.MapOrderField"><option value="">Row order</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                    <label><input type="checkbox" @bind="_draft.MapShowRoutes" /> Build routes from grouped rows</label>
                                </div>
                                <div class="component-warning map-provider-gate">
                                    <strong>External provider gate</strong>
                                    <span>PublisherStudio does not contact a provider until both a supported provider and an API key are configured. Standalone HTML contains that browser key, so restrict it to the intended origins and APIs.</span>
                                    <button type="button" @onclick="UseBundledVectorMap">Use bundled keyless Vector Map instead</button>
                                </div>
                                <p class="component-info">Rows with latitude/longitude become live markers. Rows sharing a route group become an ordered route. The bundled DevExtreme Map supports Google, Google Static, Azure, and legacy Bing provider contracts; OpenStreetMap is not injected as an unsupported hidden default.</p>
                            }
                            else
                            {
                                <div class="component-form-grid wide">
                                    <label>Bundled base map<select @bind="_draft.VectorBaseLayer">@foreach (var value in Enum.GetValues<PublicationVectorMapBaseLayer>()) { <option value="@value">@Friendly(value.ToString())</option> }</select></label>
                                    <label>Projection<select @bind="_draft.VectorProjection"><option value="mercator">Mercator</option><option value="miller">Miller</option><option value="lambert">Lambert</option><option value="equirectangular">Equirectangular</option></select></label>
                                    <label>Data label field<select @bind="_draft.VectorLabelField"><option value="">No data label</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                    <label>Data value field<select @bind="_draft.VectorValueField"><option value="">No value</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                    <label>Data color field<select @bind="_draft.VectorColorField"><option value="">Default color</option>@foreach (var field in _draft.Fields) { <option value="@field.DataField">@field.Caption (@field.DataField)</option> }</select></label>
                                    <label><input type="checkbox" @bind="_draft.VectorShowLabels" /> Show labels</label>
                                </div>
                                <div class="vector-draw-toolbar">
                                    <button type="button" class="@DrawClassMarker" @onclick="SetMarkerDrawMode">Marker</button>
                                    <button type="button" class="@DrawClassLine" @onclick="SetLineDrawMode">Line</button>
                                    <button type="button" class="@DrawClassPolygon" @onclick="SetPolygonDrawMode">Polygon</button>
                                    <button type="button" @onclick="FinishFeature">Finish shape</button>
                                    <button type="button" @onclick="UndoPoint">Undo point</button>
                                    <button type="button" class="danger" @onclick="ClearFeatures">Clear drawings</button>
                                </div>
                                <p class="component-info">Choose a drawing tool, then click directly in the live preview. Coordinates are stored as precise longitude/latitude values and remain editable below.</p>
                                <div class="component-panel-list vector-feature-list">
                                    @foreach (var feature in _draft.VectorFeatures)
                                    {
                                        <article @key="feature.Id" class="@(feature.Id == _activeFeatureId ? "active-feature" : null)">
                                            <div class="component-section-heading"><strong>@feature.Name</strong><button type="button" class="danger" @onclick="() => RemoveFeature(feature)">Remove</button></div>
                                            <div class="component-form-grid wide">
                                                <label>Name<input @bind="feature.Name" /></label>
                                                <label>Kind<select @bind="feature.Kind">@foreach (var kind in Enum.GetValues<PublicationVectorFeatureKind>()) { <option value="@kind">@kind</option> }</select></label>
                                                <label>Fill / marker color<input type="color" @bind="feature.Color" /></label>
                                                <label>Border color<input type="color" @bind="feature.BorderColor" /></label>
                                                <label>Opacity<input type="number" min="0" max="1" step="0.05" @bind="feature.Opacity" /></label>
                                                <label>Line width<input type="number" min="0.25" max="40" step="0.25" @bind="feature.Width" /></label>
                                                <label>Marker size<input type="number" min="2" max="100" step="1" @bind="feature.Size" /></label>
                                                <label>Label<input @bind="feature.Label" /></label>
                                            </div>
                                            <div class="vector-point-table">
                                                @for (var pointIndex = 0; pointIndex < feature.Points.Count; pointIndex++)
                                                {
                                                    var point = feature.Points[pointIndex];
                                                    <label>Lng <input type="number" min="-180" max="180" step="0.000001" @bind="point.Longitude" /></label>
                                                    <label>Lat <input type="number" min="-90" max="90" step="0.000001" @bind="point.Latitude" /></label>
                                                }
                                            </div>
                                        </article>
                                    }
                                </div>
                                <label>Import GeoJSON FeatureCollection<textarea class="component-code-editor" @bind="_geoJson" spellcheck="false" placeholder="Paste Point, LineString, Polygon, MultiLineString, or MultiPolygon GeoJSON"></textarea></label>
                                <div class="component-section-heading"><span>@_geoJsonStatus</span><button type="button" @onclick="ImportGeoJson">Import GeoJSON</button></div>
                            }
                        </section>
                    }
                    else if (_section == "layout")
                    {
                        <section class="component-section">
                            <div class="component-section-heading"><h3>Dynamic layout panels</h3><button type="button" @onclick="AddPanel">Add panel</button></div>
                            <p class="component-info">Splitter, Tab Panel, Multi View, and Scroll View host browser-native child controls. Each panel can use another publication dataset without a Blazor adapter.</p>
                            <div class="component-panel-list">
                                @foreach (var panel in _draft.Panels)
                                {
                                    <article @key="panel.Id">
                                        <div class="component-form-grid wide">
                                            <label>Title<input @bind="panel.Title" /></label>
                                            <label>Child component<select @bind="panel.ChildKind">@foreach (var kind in PanelComponentKinds) { <option value="@kind">@PublicationComponentService.ComponentName(kind)</option> }</select></label>
                                            <label>Dataset<select @bind="panel.DataObjectId">@foreach (var data in State.Document.DataObjects) { <option value="@data.Id">@data.Name</option> }</select></label>
                                            <label>Size<input @bind="panel.Size" placeholder="50% or 320px" /></label>
                                            <label>Minimum<input @bind="panel.MinSize" /></label>
                                            <label>Maximum<input @bind="panel.MaxSize" /></label>
                                        </div>
                                        <div class="component-option-grid"><label><input type="checkbox" @bind="panel.Collapsible" /> Collapsible</label><label><input type="checkbox" @bind="panel.Collapsed" /> Initially collapsed</label></div>
                                        <label>Optional safe HTML content<textarea @bind="panel.ContentHtml"></textarea></label>
                                        <button type="button" class="danger" @onclick="() => RemovePanel(panel)">Remove panel</button>
                                    </article>
                                }
                            </div>
                        </section>
                    }
                    else if (_section == "actions")
                    {
                        <section class="component-section">
                            <div class="component-section-heading"><h3>Events and actions</h3><button type="button" @onclick="AddAction">Add action</button></div>
                            <p class="component-info">Actions connect buttons, menus, editors, rows, appointments, and selections to pages, URLs, REST submission, mail preparation, visibility, or other components.</p>
                            <div class="component-action-list">
                                @foreach (var action in _draft.Actions)
                                {
                                    <article @key="action.Id">
                                        <div class="component-form-grid wide">
                                            <label>When<select @bind="action.Trigger">@foreach (var value in Enum.GetValues<PublicationComponentActionTrigger>()) { <option value="@value">@value</option> }</select></label>
                                            <label>Do<select @bind="action.Action">@foreach (var value in Enum.GetValues<PublicationComponentActionKind>()) { <option value="@value">@Friendly(value.ToString())</option> }</select></label>
                                           @if (action.Action is PublicationComponentActionKind.GoToPage or PublicationComponentActionKind.Navigate)
                                           {
                                                <label>
                                                    Target page
                                                    <select value="@action.TargetPageId"
                                                            @onchange="args => SetTargetPage(action, args)">
                                                        <option value="">From item/data field</option>

                                                        @foreach (var publicationPage in State.Document.Pages)
                                                        {
                                                            <option value="@publicationPage.Id">
                                                                @publicationPage.Name
                                                            </option>
                                                        }
                                                    </select>
                                                </label>
                                           }
                                            @if (action.Action is PublicationComponentActionKind.ShowElement or PublicationComponentActionKind.HideElement or PublicationComponentActionKind.ToggleElement or PublicationComponentActionKind.SetValue or PublicationComponentActionKind.ApplyFilter or PublicationComponentActionKind.ClearFilter)
                                            {
                                                <label>Target component/object<select value="@action.TargetElementId" @onchange="args => SetTargetElement(action, args)"><option value="">Select target</option>@foreach (var target in CurrentPageElements) { <option value="@target.Id">@target.Name</option> }</select></label>
                                            }
                                            @if (action.Action is PublicationComponentActionKind.OpenUrl or PublicationComponentActionKind.SubmitRest or PublicationComponentActionKind.Navigate)
                                            {
                                                <label class="span-2">@(action.Action == PublicationComponentActionKind.Navigate ? "Fallback / fixed external URL" : "URL")<input @bind="action.Url" placeholder="https://… or {{url}}" /></label>
                                            }
                                            @if (action.Action is PublicationComponentActionKind.OpenUrl or PublicationComponentActionKind.Navigate)
                                            {
                                                <label><input type="checkbox" @bind="action.OpenInNewWindow" /> Open external links in new window</label>
                                            }
                                            @if (action.Action == PublicationComponentActionKind.MailTo)
                                            {
                                                <label>Recipient<input @bind="action.MailTo" /></label><label>Subject<input @bind="action.MailSubject" /></label><label class="span-2">Body<textarea @bind="action.MailBody"></textarea></label>
                                            }
                                            @if (action.Action is PublicationComponentActionKind.SetValue or PublicationComponentActionKind.ApplyFilter)
                                            {
                                                <label>Source field<input @bind="action.SourceField" /></label><label>Target field / option<input @bind="action.TargetField" /></label><label class="span-2">Value template<input @bind="action.ValueTemplate" placeholder="{{value}} or {{FieldName}}" /></label>
                                            }
                                            <label class="span-2">Confirmation text (optional)<input @bind="action.ConfirmationText" /></label>
                                            @if (action.Action == PublicationComponentActionKind.CustomScript)
                                            {
                                                <label class="span-2">JavaScript body<textarea @bind="action.Script" spellcheck="false"></textarea></label>
                                            }
                                        </div>
                                        <button type="button" class="danger" @onclick="() => RemoveAction(action)">Remove action</button>
                                    </article>
                                }
                            </div>
                        </section>
                    }
                    else
                    {
                        <section class="component-section">
                            <h3>Advanced DevExtreme options</h3>
                            <div class="component-form-grid wide"><label>Custom CSS class<input @bind="_draft.CustomCssClass" placeholder="my-component compact" /></label></div>
                            <label>Custom inline CSS declarations<textarea class="component-code-editor" @bind="_draft.CustomCss" spellcheck="false" placeholder="box-shadow: 0 10px 30px rgba(0,0,0,.18); border-radius: 12px"></textarea></label>
                            <p class="component-info">CSS declarations are applied to the component frame. Unsafe script-like CSS and selector blocks are removed when the component is saved.</p>
                            <label>Options JSON<textarea class="component-code-editor" @bind="_draft.AdvancedOptionsJson" spellcheck="false"></textarea></label>
                            <p class="component-info">The JSON object is merged after PublisherStudio's generated safe options. It keeps the project file declarative and remains compatible with the single-file export.</p>
                            <label class="component-script-toggle"><input type="checkbox" @bind="_draft.AllowCustomScript" /> Enable custom JavaScript actions for this component</label>
                            @if (_draft.AllowCustomScript)
                            {
                                <p class="component-warning">Scripts execute with the permissions of the exported page. Use only code you trust. PublisherStudio never enables script actions automatically.</p>
                            }
                        </section>
                    }
                </main>

                <aside class="component-preview-pane">
                    <div class="pane-heading"><strong>Live preview</strong><span>@PublicationComponentService.ComponentName(_draft.ComponentKind)</span></div>
                    <div class="component-preview-frame">
                        <DevExtremeComponentView Document="State.Document" Item="_draft" CurrentPageId="State.SelectedPageId" IdPrefix="studio"
                            ElementIdOverride="ps-component-vector-designer" DesignerMode="true" DesignerInteractionMode="content" />
                    </div>
                    <small>The preview and both HTML exports use the same component JSON and browser runtime.</small>
                </aside>
            </div>

            <footer>
                <span>@ValidationMessage</span>
                <div><button type="button" @onclick="Cancel">Cancel</button><button type="button" class="primary" @onclick="Save" disabled="@(!CanSave)">Apply component</button></div>
            </footer>
        </section>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter, EditorRequired] public EditorStateService State { get; set; } = default!;
    [Parameter] public EventCallback<DevExtremeComponentElement> Saved { get; set; }
    [Parameter] public EventCallback Cancelled { get; set; }
    [Parameter] public EventCallback ManageDataRequested { get; set; }

    private DevExtremeComponentElement? _draft;
    private Guid? _loadedId;
    private bool _wasVisible;
    private string _section = "general";
    private string _headersText = string.Empty;
    private bool _testingConnection;
    private string _connectionStatus = string.Empty;
    private string _drawMode = string.Empty;
    private Guid? _activeFeatureId;
    private string _geoJson = string.Empty;
    private string _geoJsonStatus = string.Empty;
    private DotNetObjectReference<DevExtremeComponentEditor>? _self;
    private bool _designerAttached;

    private static readonly PublicationComponentKind[] PanelComponentKinds =
    [
        PublicationComponentKind.DataGrid, PublicationComponentKind.TreeList, PublicationComponentKind.Form,
        PublicationComponentKind.Scheduler, PublicationComponentKind.Gallery, PublicationComponentKind.TileView,
        PublicationComponentKind.PivotGrid, PublicationComponentKind.TextBox, PublicationComponentKind.TextArea,
        PublicationComponentKind.NumberBox, PublicationComponentKind.DateBox, PublicationComponentKind.CheckBox,
        PublicationComponentKind.SelectBox, PublicationComponentKind.TagBox, PublicationComponentKind.Map,
        PublicationComponentKind.VectorMap, PublicationComponentKind.Chat, PublicationComponentKind.Button
    ];

    private IEnumerable<PublicationElement> CurrentPageElements => State.CurrentPage.Elements.Where(element => element.Id != _draft?.Id);
    private bool SupportsInternalBorders => _draft?.ComponentKind is PublicationComponentKind.DataGrid or PublicationComponentKind.TreeList or PublicationComponentKind.PivotGrid;
    private bool SupportsWordWrap => _draft?.ComponentKind is PublicationComponentKind.DataGrid or PublicationComponentKind.TreeList;
    private bool SupportsEditMode => _draft?.ComponentKind is PublicationComponentKind.DataGrid or PublicationComponentKind.TreeList or PublicationComponentKind.Scheduler;
    private bool SupportsSelection => _draft?.ComponentKind is PublicationComponentKind.DataGrid or PublicationComponentKind.TreeList;
    private bool SupportsPageSize => _draft?.ComponentKind is PublicationComponentKind.DataGrid or PublicationComponentKind.TreeList;
    private bool SupportsOrientation => _draft?.ComponentKind is PublicationComponentKind.Menu or PublicationComponentKind.TileView or PublicationComponentKind.Splitter or PublicationComponentKind.ScrollView;
    private bool SupportsButtonText => _draft?.ComponentKind is PublicationComponentKind.Button or PublicationComponentKind.Form or PublicationComponentKind.CheckBox;
    private bool SupportsPlaceholder => _draft?.ComponentKind is PublicationComponentKind.TextBox or PublicationComponentKind.TextArea or PublicationComponentKind.NumberBox or PublicationComponentKind.DateBox or PublicationComponentKind.SelectBox or PublicationComponentKind.TagBox;
    private bool SupportsInitialValue => _draft?.ComponentKind is PublicationComponentKind.TextBox or PublicationComponentKind.TextArea or PublicationComponentKind.NumberBox or PublicationComponentKind.DateBox or PublicationComponentKind.CheckBox or PublicationComponentKind.SelectBox or PublicationComponentKind.TagBox;
    private bool SupportsGridOptions => _draft?.ComponentKind == PublicationComponentKind.DataGrid;
    private bool UsesKeyField => _draft?.ComponentKind is PublicationComponentKind.DataGrid or PublicationComponentKind.TreeList or PublicationComponentKind.Form or PublicationComponentKind.Scheduler or PublicationComponentKind.SelectBox or PublicationComponentKind.TagBox or PublicationComponentKind.Gallery or PublicationComponentKind.TileView or PublicationComponentKind.Menu or PublicationComponentKind.ContextMenu or PublicationComponentKind.PivotGrid or PublicationComponentKind.Chat;
    private bool UsesParentField => _draft?.ComponentKind is PublicationComponentKind.TreeList or PublicationComponentKind.Menu or PublicationComponentKind.ContextMenu;
    private bool UsesTextField => _draft?.ComponentKind is PublicationComponentKind.TreeList or PublicationComponentKind.Scheduler or PublicationComponentKind.Gallery or PublicationComponentKind.TileView or PublicationComponentKind.Menu or PublicationComponentKind.ContextMenu;
    private bool UsesDisplayField => _draft?.ComponentKind is PublicationComponentKind.SelectBox or PublicationComponentKind.TagBox or PublicationComponentKind.Gallery or PublicationComponentKind.TileView or PublicationComponentKind.Menu or PublicationComponentKind.ContextMenu;
    private bool UsesValueField => _draft?.ComponentKind is PublicationComponentKind.SelectBox or PublicationComponentKind.TagBox or PublicationComponentKind.Gallery or PublicationComponentKind.TileView;
    private bool UsesImageField => _draft?.ComponentKind is PublicationComponentKind.Gallery or PublicationComponentKind.TileView;
    private bool IsManualMenu => _draft is not null
        && (_draft.ComponentKind is PublicationComponentKind.Menu or PublicationComponentKind.ContextMenu)
        && _draft.MenuSourceMode == PublicationMenuSourceMode.ManualItems;
    private bool UsesDataConnection => !IsManualMenu;
    private static readonly HashSet<string> SupportedMapProviders = new(StringComparer.OrdinalIgnoreCase) { "google", "googleStatic", "azure", "bing" };
    private bool UsesGoogleMapProvider => _draft?.MapProvider is "google" or "googleStatic";
    private bool MapConfigurationValid => _draft?.ComponentKind != PublicationComponentKind.Map
        || (SupportedMapProviders.Contains(_draft.MapProvider ?? string.Empty) && !string.IsNullOrWhiteSpace(_draft.MapApiKey));
    private bool CanSave => _draft is not null && !string.IsNullOrWhiteSpace(_draft.Title)
        && MapConfigurationValid
