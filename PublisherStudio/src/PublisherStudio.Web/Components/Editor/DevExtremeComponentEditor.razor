    [JSInvokable]
    public void AddVectorDesignerPoint(double longitude, double latitude)
    {
        if (_draft is null || string.IsNullOrWhiteSpace(_drawMode)) return;
        var kind = _drawMode switch { "line" => PublicationVectorFeatureKind.Line, "polygon" => PublicationVectorFeatureKind.Polygon, _ => PublicationVectorFeatureKind.Marker };
        PublicationVectorMapFeature? feature = null;
        if (kind != PublicationVectorFeatureKind.Marker && _activeFeatureId is { } active)
            feature = _draft.VectorFeatures.FirstOrDefault(item => item.Id == active && item.Kind == kind);
        if (feature is null)
        {
            feature = new PublicationVectorMapFeature { Name = $"{kind} {_draft.VectorFeatures.Count + 1}", Kind = kind, Color = kind == PublicationVectorFeatureKind.Marker ? "#ef4444" : "#2563eb" };
            _draft.VectorFeatures.Add(feature);
            _activeFeatureId = kind == PublicationVectorFeatureKind.Marker ? null : feature.Id;
        }
        feature.Points.Add(new PublicationMapPoint { Longitude = Math.Clamp(longitude, -180, 180), Latitude = Math.Clamp(latitude, -90, 90) });
        _ = InvokeAsync(StateHasChanged);
    }

    private void ImportGeoJson()
    {
        if (_draft is null || string.IsNullOrWhiteSpace(_geoJson)) return;
        try
        {
            using var json = System.Text.Json.JsonDocument.Parse(_geoJson);
            var root = json.RootElement;
            var items = root.TryGetProperty("features", out var features) ? features.EnumerateArray().ToArray() : new[] { root };
            var added = 0;
            foreach (var item in items)
            {
                if (!item.TryGetProperty("geometry", out var geometry)) geometry = item;
                if (!geometry.TryGetProperty("type", out var typeProperty) || !geometry.TryGetProperty("coordinates", out var coordinates)) continue;
                var type = typeProperty.GetString() ?? string.Empty;
                var properties = item.TryGetProperty("properties", out var p) ? p : default;
                var name = properties.ValueKind == System.Text.Json.JsonValueKind.Object && properties.TryGetProperty("name", out var n) ? n.GetString() ?? $"Feature {_draft.VectorFeatures.Count + 1}" : $"Feature {_draft.VectorFeatures.Count + 1}";
                foreach (var parsed in ParseGeoGeometry(type, coordinates, name)) { _draft.VectorFeatures.Add(parsed); added++; }
            }
            _geoJsonStatus = $"Imported {added} feature(s).";
        }
        catch (Exception error) { _geoJsonStatus = $"GeoJSON import failed: {error.Message}"; }
    }

    private static IEnumerable<PublicationVectorMapFeature> ParseGeoGeometry(string type, System.Text.Json.JsonElement coordinates, string name)
    {
        PublicationVectorMapFeature Feature(PublicationVectorFeatureKind kind, IEnumerable<System.Text.Json.JsonElement> points) => new()
        {
            Name = name, Kind = kind, Points = points.Where(point => point.ValueKind == System.Text.Json.JsonValueKind.Array && point.GetArrayLength() >= 2)
                .Select(point => new PublicationMapPoint { Longitude = point[0].GetDouble(), Latitude = point[1].GetDouble() }).ToList()
        };
        if (type.Equals("Point", StringComparison.OrdinalIgnoreCase)) return new[] { Feature(PublicationVectorFeatureKind.Marker, new[] { coordinates }) };
        if (type.Equals("LineString", StringComparison.OrdinalIgnoreCase)) return new[] { Feature(PublicationVectorFeatureKind.Line, coordinates.EnumerateArray()) };
        if (type.Equals("Polygon", StringComparison.OrdinalIgnoreCase)) return coordinates.GetArrayLength() > 0
            ? new[] { Feature(PublicationVectorFeatureKind.Polygon, coordinates[0].EnumerateArray()) }
            : Array.Empty<PublicationVectorMapFeature>();
        if (type.Equals("MultiLineString", StringComparison.OrdinalIgnoreCase)) return coordinates.EnumerateArray().Select((line, index) => Feature(PublicationVectorFeatureKind.Line, line.EnumerateArray())).ToArray();
        if (type.Equals("MultiPolygon", StringComparison.OrdinalIgnoreCase)) return coordinates.EnumerateArray().Where(polygon => polygon.GetArrayLength() > 0).Select(polygon => Feature(PublicationVectorFeatureKind.Polygon, polygon[0].EnumerateArray())).ToArray();
        return Array.Empty<PublicationVectorMapFeature>();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var shouldAttach = Visible && _draft?.ComponentKind == PublicationComponentKind.VectorMap && _section == "map";
        if (shouldAttach && !_designerAttached)
        {
            _self ??= DotNetObjectReference.Create(this);
            try { _designerAttached = await JS.InvokeAsync<bool>("PublisherStudioComponentRuntime.attachVectorDesigner", "ps-component-vector-designer", _self); } catch { _designerAttached = false; }
        }
        else if (!shouldAttach && _designerAttached)
        {
            try { await JS.InvokeVoidAsync("PublisherStudioComponentRuntime.detachVectorDesigner", "ps-component-vector-designer"); } catch { }
            _designerAttached = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("PublisherStudioComponentRuntime.detachVectorDesigner", "ps-component-vector-designer"); } catch { }
        _self?.Dispose();
    }

