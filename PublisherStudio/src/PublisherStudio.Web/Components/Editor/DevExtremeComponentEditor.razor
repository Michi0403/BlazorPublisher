    private async Task TestEndpoint()
    {
        if (_draft is null || string.IsNullOrWhiteSpace(_draft.Connection.Url)) return;
        _testingConnection = true;
        _connectionStatus = string.Empty;
        try
        {
            var text = await JS.InvokeAsync<string>("PublisherStudioComponentRuntime.probeConnection", _draft.Connection);
            var sample = new PublicationDataObject { Name = "Endpoint preview", SourceKind = PublicationDataSourceKind.Json, RawSource = text };
            DataService.ParseInto(sample);
            _draft.Fields = DataService.ResolveColumns(sample).Select((column, index) => new PublicationComponentField
            {
                DataField = column.Name, Caption = Friendly(column.Name), ValueKind = column.ValueKind,
                Editor = column.ValueKind switch { PublicationDataValueKind.Number => PublicationComponentEditorKind.NumberBox, PublicationDataValueKind.Boolean => PublicationComponentEditorKind.CheckBox, PublicationDataValueKind.DateTime => PublicationComponentEditorKind.DateBox, _ => PublicationComponentEditorKind.TextBox },
                Area = index == 0 ? PublicationComponentFieldArea.Row : column.ValueKind == PublicationDataValueKind.Number ? PublicationComponentFieldArea.Data : PublicationComponentFieldArea.Column
            }).ToList();
            if (_draft.Fields.Count > 0)
            {
                _draft.KeyField = _draft.Fields.FirstOrDefault(field => string.Equals(field.DataField, "id", StringComparison.OrdinalIgnoreCase))?.DataField ?? _draft.Fields[0].DataField;
                _draft.Connection.KeyField = _draft.KeyField;
                _draft.TextField = _draft.Fields.FirstOrDefault(field => new[] { "text", "title", "name", "subject" }.Contains(field.DataField, StringComparer.OrdinalIgnoreCase))?.DataField ?? _draft.Fields[0].DataField;
                _draft.DisplayField = _draft.TextField;
                _draft.ValueField = _draft.Fields.FirstOrDefault(field => field.ValueKind == PublicationDataValueKind.Number)?.DataField ?? _draft.Fields[0].DataField;
            }
            _connectionStatus = $"Connected: {sample.Rows.Count} sample rows, {_draft.Fields.Count} fields discovered.";
            _section = "fields";
        }
        catch (Exception error) { _connectionStatus = $"Connection failed: {error.Message}"; }
        finally { _testingConnection = false; }
    }

    private static List<PublicationWebHeader> ParseHeaders(string value) => value.Replace("\r", string.Empty).Split('\n', StringSplitOptions.RemoveEmptyEntries)
        .Select(line => line.Split(':', 2)).Where(parts => parts.Length == 2 && !string.IsNullOrWhiteSpace(parts[0]))
        .Select(parts => new PublicationWebHeader { Name = parts[0].Trim(), Value = parts[1].Trim() }).ToList();
    private static string FormatHeaders(IEnumerable<PublicationWebHeader> headers) => string.Join(Environment.NewLine, headers.Select(header => $"{header.Name}: {header.Value}"));

    private IReadOnlyList<PublicationDataColumn> SourceColumns
    {
        get
        {
            if (_draft is null) return Array.Empty<PublicationDataColumn>();
            if (_draft.Connection.Mode is PublicationComponentDataMode.PublicationDataObject or PublicationComponentDataMode.StaticSnapshot)
            {
                var data = State.Document.DataObjects.FirstOrDefault(candidate => candidate.Id == _draft.Connection.DataObjectId);
                return DataService.ResolveColumns(data);
            }

            return _draft.Fields
                .Where(column => !string.IsNullOrWhiteSpace(column.DataField))
                .DistinctBy(column => column.DataField, StringComparer.OrdinalIgnoreCase)
                .Select(column => new PublicationDataColumn { Name = column.DataField, ValueKind = column.ValueKind })
                .ToArray();
        }
    }

    private IReadOnlyList<PublicationDataColumn> FieldChoices(PublicationComponentField field)
    {
        var columns = SourceColumns.ToList();
        if (!string.IsNullOrWhiteSpace(field.DataField) && columns.All(column => !string.Equals(column.Name, field.DataField, StringComparison.OrdinalIgnoreCase)))
            columns.Add(new PublicationDataColumn { Name = field.DataField, ValueKind = field.ValueKind });
        return columns;
    }

    private void SetFieldDataProperty(PublicationComponentField field, ChangeEventArgs args)
    {
        var previous = field.DataField;
        field.DataField = args.Value?.ToString() ?? string.Empty;
        var selected = SourceColumns.FirstOrDefault(column => string.Equals(column.Name, field.DataField, StringComparison.OrdinalIgnoreCase));
        if (selected is null) return;
        field.ValueKind = selected.ValueKind;
        field.Editor = selected.ValueKind switch
        {
            PublicationDataValueKind.Number => PublicationComponentEditorKind.NumberBox,
            PublicationDataValueKind.Boolean => PublicationComponentEditorKind.CheckBox,
            PublicationDataValueKind.DateTime => PublicationComponentEditorKind.DateBox,
            _ => PublicationComponentEditorKind.TextBox
        };
        if (string.IsNullOrWhiteSpace(field.Caption) || string.Equals(field.Caption, Friendly(previous), StringComparison.OrdinalIgnoreCase))
            field.Caption = Friendly(selected.Name);
    }

    private IReadOnlyList<PublicationDataColumn> LookupColumns(PublicationComponentField field)
        => field.LookupDataObjectId is { } id
            ? DataService.ResolveColumns(State.Document.DataObjects.FirstOrDefault(data => data.Id == id))
            : Array.Empty<PublicationDataColumn>();

    private void SetLookupDataObject(PublicationComponentField field, ChangeEventArgs args)
    {
        field.LookupDataObjectId = Guid.TryParse(args.Value?.ToString(), out var id) ? id : null;
        if (field.LookupDataObjectId is not { } dataId) return;
        var data = State.Document.DataObjects.FirstOrDefault(candidate => candidate.Id == dataId);
        var columns = DataService.ResolveColumns(data);
        field.LookupDataField = columns.FirstOrDefault()?.Name ?? string.Empty;
        field.LookupDisplayField = columns.Skip(1).FirstOrDefault()?.Name ?? field.LookupDataField;
        if (field.Editor is PublicationComponentEditorKind.Auto or PublicationComponentEditorKind.TextBox)
            field.Editor = PublicationComponentEditorKind.SelectBox;
    }

    private void SetTargetPage(PublicationComponentAction action, ChangeEventArgs args) => action.TargetPageId = Guid.TryParse(args.Value?.ToString(), out var id) ? id : null;
