    private void ChangeKind(PublicationComponentKind kind)
    {
        if (_draft is null || _draft.ComponentKind == kind) return;
        _draft.ComponentKind = kind;
        _draft.Title = PublicationComponentService.ComponentName(kind);
        _draft.Name = _draft.Title;
        if (_draft.IsLayoutContainer && _draft.Panels.Count == 0) AddPanel();
        if (kind == PublicationComponentKind.Button && _draft.Actions.Count == 0)
            _draft.Actions.Add(new PublicationComponentAction { Trigger = PublicationComponentActionTrigger.Click, Action = PublicationComponentActionKind.NextPage });
        if (kind is PublicationComponentKind.Menu or PublicationComponentKind.ContextMenu)
        {
            _draft.MenuSourceMode = PublicationMenuSourceMode.ManualItems;
            if (_draft.MenuItems.Count == 0) _draft.MenuItems.Add(new PublicationMenuItem { Text = "Menu item" });
            if (_draft.Actions.All(action => action.Trigger != PublicationComponentActionTrigger.ItemClick || action.Action == PublicationComponentActionKind.None))
                _draft.Actions.Add(new PublicationComponentAction { Trigger = PublicationComponentActionTrigger.ItemClick, Action = PublicationComponentActionKind.Navigate });
        }
        if (kind is PublicationComponentKind.Gallery or PublicationComponentKind.TileView) UsePublicationMediaDataset();
        if (kind == PublicationComponentKind.Chat)
        {
            var chatData = State.Document.DataObjects.FirstOrDefault(data => string.Equals(data.SourceReference, "publisherstudio:chat-preview", StringComparison.Ordinal));
            if (chatData is not null)
            {
                _draft.Connection.Mode = PublicationComponentDataMode.StaticSnapshot;
                _draft.Connection.DataObjectId = chatData.Id;
                Components.ApplyFieldsFromDataObject(State.Document, _draft, replace: true);
            }
        }
        _section = kind is PublicationComponentKind.Map or PublicationComponentKind.VectorMap ? "map" : kind is PublicationComponentKind.Menu or PublicationComponentKind.ContextMenu ? "menu" : "general";
    }

