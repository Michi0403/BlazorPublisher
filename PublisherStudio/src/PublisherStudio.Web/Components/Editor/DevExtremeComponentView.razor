@namespace PublisherStudio.Components.Editor
@implements IAsyncDisposable
@inject PublicationComponentService Components
@inject IJSRuntime JS

<div class="devextreme-publication-component @(Item.ShowTitle ? "has-component-title" : null) @Item.CustomCssClass" style="@ContainerStyle">
    @if (Item.ShowTitle)
    {
        <div class="devextreme-component-title">@Item.Title</div>
    }
    @if (MissingData)
    {
        <div class="ps-component-empty">
            <strong>@Item.Title</strong>
            <span>Select a publication dataset, REST endpoint, or OData entity in Component Studio.</span>
        </div>
    }
    else
    {
        <div class="devextreme-component-viewport" data-content-fit="clip" data-content-kind="component" data-content-viewport
             data-content-offset-x="@Inv(Item.ContentOffsetX)" data-content-offset-y="@Inv(Item.ContentOffsetY)" data-content-scale="@Inv(Item.ContentScale)">
            <div class="publication-content-source devextreme-component-source" data-content-fit-source>
                <div id="@ElementId" class="devextreme-component-host" data-ps-component-config="@ClientConfigBase64"
                     data-ps-designer-interaction="@NormalizedDesignerInteractionMode"></div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public PublicationDocument Document { get; set; } = default!;
    [Parameter, EditorRequired] public DevExtremeComponentElement Item { get; set; } = default!;
    [Parameter] public Guid CurrentPageId { get; set; }
    [Parameter] public string IdPrefix { get; set; } = "canvas";
    [Parameter] public string? ElementIdOverride { get; set; }
    [Parameter] public bool DesignerMode { get; set; }
    [Parameter] public string DesignerInteractionMode { get; set; } = "content";

    private readonly string _instanceId = Guid.NewGuid().ToString("N");
    private string? _lastRenderedConfig;
    private string ElementId => string.IsNullOrWhiteSpace(ElementIdOverride) ? $"ps-component-{IdPrefix}-{Item.Id:N}-{_instanceId}" : ElementIdOverride;
    private string NormalizedDesignerInteractionMode => string.Equals(DesignerInteractionMode, "object", StringComparison.OrdinalIgnoreCase) ? "object" : "content";
    private string ClientConfigBase64 => Components.BuildClientConfigurationBase64(Document, Item, CurrentPageId, DesignerMode, NormalizedDesignerInteractionMode);
    private bool MissingData => RequiresDataObject
        && (Item.Connection.Mode == PublicationComponentDataMode.PublicationDataObject
            || Item.Connection.Mode == PublicationComponentDataMode.StaticSnapshot)
        && Document.DataObjects.All(data => data.Id != Item.Connection.DataObjectId);

    private bool RequiresDataObject => Item.ComponentKind switch
    {
        PublicationComponentKind.Menu or PublicationComponentKind.ContextMenu =>
            Item.MenuSourceMode == PublicationMenuSourceMode.DataConnection,
        PublicationComponentKind.DataGrid or PublicationComponentKind.TreeList or PublicationComponentKind.Scheduler or
        PublicationComponentKind.Form or PublicationComponentKind.SelectBox or PublicationComponentKind.TagBox or
        PublicationComponentKind.Gallery or PublicationComponentKind.TileView or PublicationComponentKind.PivotGrid => true,
        _ => false
    };
    private string ContainerStyle => $"background:{Item.Background};border:{Item.BorderWidthMm.ToString("0.###", CultureInfo.InvariantCulture)}mm solid {Item.BorderColor};{Item.CustomCss}";
    private static string Inv(double value) => value.ToString("0.####", CultureInfo.InvariantCulture);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (MissingData) return;
        var config = ClientConfigBase64;
        if (string.Equals(config, _lastRenderedConfig, StringComparison.Ordinal)) return;
        try
        {
            await JS.InvokeVoidAsync("PublisherStudioComponentRuntime.renderById", ElementId, config);
            _lastRenderedConfig = config;
        }
        catch (JSDisconnectedException) { }
        catch (InvalidOperationException) { }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("PublisherStudioComponentRuntime.disposeById", ElementId); }
        catch (JSDisconnectedException) { }
        catch (InvalidOperationException) { }
    }
}
