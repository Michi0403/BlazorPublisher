@namespace PublisherStudio.Components.Editor

<aside class="inspector-panel">
    <div class="inspector-tabs three">
        <button class="@PropertiesTabClass" @onclick="ShowProperties">Properties</button>
        <button class="@PageTabClass" @onclick="ShowPage">Page</button>
        <button class="@LayersTabClass" @onclick="ShowLayers">Layers</button>
    </div>

    @if (_tab == "layers")
    {
        <div class="layers-panel">
            <div class="layer-help"><strong>Objects are layers</strong><span>Higher rows appear in front. Use the eye and lock buttons per object.</span></div>
            <div class="layer-create-bar">
                <button title="Add text box" @onclick="AddText">T</button>
                <button title="Add WordArt" @onclick="AddWordArt">A★</button>
                <button title="Add picture" @onclick="RequestInsertPicture">▧</button>
                <button title="Create picture in Picture Studio" @onclick="RequestCreatePicture">▣</button>
                <button title="Add rectangle" @onclick="AddRectangle">◇</button>
                <button title="Insert chart" @onclick="AddChart">▥</button>
                <button title="Draw connector: click, then drag between object ports" @onclick="StartConnector">↝</button>
                <button title="Delete selected layer" disabled="@(State.SelectedElement is null || State.SelectedElement.Locked)" @onclick="State.DeleteSelected">⌫</button>
            </div>
            <div class="layer-arrange-bar">
                <button title="Bring to front" disabled="@(State.SelectedElement is null)" @onclick="State.BringToFront">Front</button>
                <button title="Bring forward" disabled="@(State.SelectedElement is null)" @onclick="State.BringForward">Up</button>
                <button title="Send backward" disabled="@(State.SelectedElement is null)" @onclick="State.SendBackward">Down</button>
                <button title="Send to back" disabled="@(State.SelectedElement is null)" @onclick="State.SendToBack">Back</button>
            </div>
            <div class="layers-list">
                @foreach (var item in State.CurrentPage.Elements.OrderByDescending(element => element.ZIndex))
                {
                    <div class="layer-row @(item.Id == State.SelectedElementId ? "selected" : null)">
                        <button class="layer-select" title="Select @item.Name" @onclick="() => State.SelectElement(item.Id)">
                            <span class="layer-kind">@KindGlyph(item)</span>
                            <span class="layer-name">@item.Name</span>
                        </button>
                        <button class="layer-toggle" title="@(item.Visible ? "Hide" : "Show")" @onclick="() => ToggleLayerVisibility(item)">@(item.Visible ? "◉" : "○")</button>
                        <button class="layer-toggle" title="@(item.Locked ? "Unlock" : "Lock")" @onclick="() => ToggleLayerLock(item)">@(item.Locked ? "🔒" : "🔓")</button>
                    </div>
                }
                @if (State.CurrentPage.Elements.Count == 0)
                {
                    <div class="empty-panel">This page has no objects.</div>
                }
            </div>
        </div>
    }
    else if (_tab == "page")
    {
        <div class="property-scroll">
            <section class="property-section">
                <h3>Page format</h3>
                <label>Preset
                    <select value="@CurrentPresetKey" @onchange="ChangePagePreset">
                        <option value="custom">Custom</option>
                        @foreach (var preset in PagePreset.All)
                        {
                            <option value="@preset.Key">@preset.Name</option>
                        }
                    </select>
                </label>
                <div class="property-grid two">
                    <label>Width (mm)<input type="number" min="10" max="2000" step="0.1" value="@Inv(State.CurrentPage.WidthMm)" @onchange="ChangePageWidth" /></label>
                    <label>Height (mm)<input type="number" min="10" max="2000" step="0.1" value="@Inv(State.CurrentPage.HeightMm)" @onchange="ChangePageHeight" /></label>
                </div>
                <DxButton Text="Swap width / height" Click="SwapOrientation" CssClass="wide-button" />
                <label>Background
                    <span class="color-field"><input type="color" value="@UsableColor(State.CurrentPage.Background)" @onchange="ChangePageBackground" /><code>@State.CurrentPage.Background</code></span>
                </label>
                <div class="property-button-row">
                    <DxButton Text="Transparent" Click="SetTransparentPage" />
                    <DxButton Text="White" Click="SetWhitePage" />
                </div>
            </section>

            <section class="property-section">
                <h3>Canvas and rulers</h3>
                <label>Ruler unit
                    <select value="@State.Document.View.RulerUnit" @onchange="ChangeRulerUnit">
                        <option value="Millimeter">Millimetres</option>
                        <option value="Centimeter">Centimetres</option>
                        <option value="Inch">Inches</option>
                        <option value="Pixel">Pixels</option>
                    </select>
                </label>
                <label>Grid spacing (mm)<input type="number" min="0.5" max="100" step="0.5" value="@Inv(State.Document.View.GridSpacingMm)" @onchange="ChangeGridSpacing" /></label>
                <label class="check-row"><input type="checkbox" checked="@State.Document.View.RulersVisible" @onchange="ToggleRulers" /> Show rulers</label>
                <label class="check-row"><input type="checkbox" checked="@State.Document.View.GridVisible" @onchange="ToggleGrid" /> Show grid</label>
                <label class="check-row"><input type="checkbox" checked="@State.Document.View.GuidesVisible" @onchange="ToggleGuides" /> Show guides</label>
                <label class="check-row"><input type="checkbox" checked="@State.Document.View.SnapToGrid" @onchange="ToggleSnapGrid" /> Snap to grid</label>
                <label class="check-row"><input type="checkbox" checked="@State.Document.View.SnapToGuides" @onchange="ToggleSnapGuides" /> Snap to guides</label>
                <label class="check-row"><input type="checkbox" checked="@State.Document.View.SnapToPage" @onchange="ToggleSnapPage" /> Snap to page edges</label>
                <div class="property-button-row">
                    <DxButton Text="Vertical guide" Click="AddVerticalGuide" />
                    <DxButton Text="Horizontal guide" Click="AddHorizontalGuide" />
                </div>
                <DxButton Text="Clear guides" Enabled="@(State.CurrentPage.Guides.Count > 0)" Click="ClearGuides" CssClass="wide-button" />
            </section>

            <section class="property-section">
                <h3>Export</h3>
                <label>Raster export DPI
                    <select value="@State.Document.View.ExportDpi" @onchange="ChangeExportDpi">
                        <option value="96">96 DPI — screen</option>
                        <option value="150">150 DPI — draft print</option>
                        <option value="300">300 DPI — print</option>
                        <option value="600">600 DPI — high resolution</option>
                    </select>
                </label>
                <p class="property-note">PNG preserves page and image transparency. JPEG always receives a white background.</p>
            </section>
        </div>
    }
    else if (State.SelectedElement is { } element)
    {
        <div class="property-scroll">
            <section class="property-section">
                <h3>Object</h3>
                <label>Name<input value="@element.Name" @onchange="ChangeName" /></label>
                @if (element is not ConnectorElement)
                {
                    <div class="property-grid two">
                        @NumberField("X", element.X, "x")
                        @NumberField("Y", element.Y, "y")
                        @NumberField("Width", element.Width, "width")
                        @NumberField("Height", element.Height, "height")
                        @NumberField("Rotation", element.Rotation, "rotation")
                        @NumberField("Layer", element.ZIndex, "z")
                    </div>
                }
                else
                {
                    <div class="property-grid two">@NumberField("Layer", element.ZIndex, "z")</div>
                }
                <label class="check-row"><input type="checkbox" checked="@element.Visible" @onchange="ToggleVisible" /> Visible</label>
                <label class="check-row"><input type="checkbox" checked="@element.Locked" @onchange="ToggleLocked" /> Locked</label>
            </section>

            @if (element is ImageFrameElement image)
            {
                <section class="property-section picture-properties">
                    <h3>Picture</h3>
                    <DxButton Text="Edit in Picture Studio" Click="RequestEditPicture" CssClass="wide-button" />
                    <div class="property-button-row">
                        <DxButton Text="Replace…" Click="RequestReplacePicture" />
                        <DxButton Text="@(State.CropMode ? "Finish crop" : "Crop")" Click="ToggleCrop" />
                    </div>
                    <div class="property-button-row">
                        <DxButton Text="Fit" Click="PictureFit" />
                        <DxButton Text="Fill" Click="PictureFill" />
                        <DxButton Text="Reset" Click="ResetPicture" />
                    </div>
                    @RangeField("Crop zoom", image.CropScale, .2, 8, .02, "cropScale")
                    @RangeField("Picture rotation", image.ImageRotation, -180, 180, 1, "imageRotation")
                    @RangeField("Opacity", image.Opacity, 0, 1, .01, "opacity")
                    @RangeField("Brightness", image.Brightness, 0, 2, .01, "brightness")
                    @RangeField("Contrast", image.Contrast, 0, 2, .01, "contrast")
                    @RangeField("Saturation", image.Saturation, 0, 2, .01, "saturation")
                    @RangeField("Hue", image.HueRotation, -180, 180, 1, "hue")
                    @RangeField("Invert", image.Invert, 0, 1, .01, "invert")
                    @RangeField("Grayscale", image.Grayscale, 0, 1, .01, "grayscale")
                    @RangeField("Sepia", image.Sepia, 0, 1, .01, "sepia")
                    @RangeField("Blur", image.Blur, 0, 12, .1, "blur")
                </section>

                <section class="property-section picture-color-tools">
                    <h3>Recolor and transparency</h3>
                    <label>Color treatment
                        <select value="@image.TintMode" @onchange="ChangeTintMode">
                            <option value="Overlay">Tint overlay</option>
                            <option value="Recolor">Full recolor</option>
                        </select>
                    </label>
                    <label>Blend mode
                        <select value="@image.BlendMode" @onchange="ChangeBlendMode">
                            <option value="Normal">Normal</option>
                            <option value="Multiply">Multiply</option>
                            <option value="Screen">Screen</option>
                            <option value="Darken">Darken</option>
                            <option value="Lighten">Lighten</option>
                        </select>
                    </label>
                    @ColorField("Tint color", image.TintColor, "tintColor")
                    @RangeField("Tint strength", image.TintOpacity, 0, 1, .01, "tintOpacity")
                    <div class="color-preset-row">
                        <button @onclick="TintBlue">Blue</button>
                        <button @onclick="TintWarm">Warm</button>
                        <button @onclick="TintGreen">Green</button>
                        <button @onclick="ClearTint">Clear</button>
                    </div>
                    @ColorField("Color to remove", image.TransparentColor, "transparentColor")
                    @RangeField("Color tolerance", image.TransparentColorTolerance, 0, 255, 1, "transparentTolerance")
                    <div class="property-button-row">
                        <DxButton Text="Make transparent" Click="RequestApplyTransparentColor" />
                        <DxButton Text="Restore original" Click="RequestRestoreOriginalPicture" />
                    </div>
                    <p class="property-note">Recolor and tint preserve the picture's alpha channel. “Make transparent” edits a copy; Restore Original keeps the imported source.</p>
                </section>

                <section class="property-section">
                    <h3>Picture frame</h3>
                    <label>Mask
                        <select value="@image.MaskShape" @onchange="ChangeImageMask">
                            <option value="Rectangle">Rectangle</option>
                            <option value="RoundedRectangle">Rounded rectangle</option>
                            <option value="Ellipse">Ellipse</option>
                        </select>
                    </label>
                    @RangeField("Rounded corners", image.CornerRadiusMm, 0, 30, .1, "corner")
                    @ColorField("Border", image.BorderColor, "imageBorder")
                    @RangeField("Border width", image.BorderWidthMm, 0, 5, .05, "imageBorderWidth")
                    <label class="check-row"><input type="checkbox" checked="@image.ShadowEnabled" @onchange="ToggleImageShadow" /> Drop shadow</label>
                    <label class="check-row"><input type="checkbox" checked="@image.FlipHorizontal" @onchange="ToggleFlipHorizontal" /> Flip horizontal</label>
                    <label class="check-row"><input type="checkbox" checked="@image.FlipVertical" @onchange="ToggleFlipVertical" /> Flip vertical</label>
                    <label>Alt text<input value="@image.AltText" @onchange="ChangeAltText" /></label>
                </section>
            }
            else if (element is TextFrameElement text)
            {
                <section class="property-section">
                    <h3>Text frame</h3>
                    @RangeField("Padding", text.PaddingMm, 0, 20, .1, "padding")
                    @ColorField("Background", text.Background, "textBackground")
                    @ColorField("Border", text.BorderColor, "textBorder")
                    @RangeField("Border width", text.BorderWidth, 0, 5, .05, "textBorderWidth")
                    <DxButton Text="Edit story" Click="RequestEditStory" CssClass="wide-button" />
                </section>
            }
            else if (element is WordArtElement wordArt)
            {
                <section class="property-section wordart-properties">
                    <h3>WordArt / LogoArt</h3>
                    <label>Text<textarea rows="3" value="@wordArt.Text" @onchange="ChangeWordArtText"></textarea></label>
                    <label>Font family<input value="@wordArt.FontFamily" @onchange="ChangeWordArtFont" /></label>
                    @RangeField("Font size", wordArt.FontSizePt, 8, 180, 1, "wordFontSize")
                    @RangeField("Letter spacing", wordArt.LetterSpacing, -5, 30, .5, "wordLetterSpacing")
                    @ColorField("Fill", wordArt.FillColor, "wordFill")
                    @ColorField("Second color", wordArt.SecondaryColor, "wordSecondary")
                    @ColorField("Outline", wordArt.OutlineColor, "wordOutline")
                    @RangeField("Outline width", wordArt.OutlineWidth, 0, 12, .25, "wordOutlineWidth")
                    @ColorField("3D color", wordArt.ExtrudeColor, "wordExtrude")
                    @RangeField("3D depth", wordArt.ExtrudeDepth, 0, 18, .5, "wordExtrudeDepth")
                    <label>Warp
                        <select value="@wordArt.Warp" @onchange="ChangeWordArtWarp">
                            <option value="None">Straight</option>
                            <option value="ArchUp">Arch up</option>
                            <option value="ArchDown">Arch down</option>
                            <option value="Wave">Wave</option>
                            <option value="Custom">Custom drawn path</option>
                        </select>
                    </label>
                    @if (wordArt.Warp == WordArtWarp.Custom)
                    {
                        <WordArtPathEditor @key="wordArt.Id" Item="wordArt" PathChanged="ChangeWordArtPath" />
                    }
                    @if (wordArt.Warp != WordArtWarp.None)
                    {
                        @RangeField("Text position on path", wordArt.PathStartOffsetPercent, 0, 100, 1, "wordPathStart")
                        @RangeField("Distance from path", wordArt.PathBaselineOffset, -80, 80, 1, "wordPathOffset")
                    }
                    <label class="check-row"><input type="checkbox" checked="@wordArt.Bold" @onchange="ToggleWordArtBold" /> Bold</label>
                    <label class="check-row"><input type="checkbox" checked="@wordArt.Italic" @onchange="ToggleWordArtItalic" /> Italic</label>
                    <label class="check-row"><input type="checkbox" checked="@wordArt.GradientFill" @onchange="ToggleWordArtGradient" /> Gradient fill</label>
                    <label class="check-row"><input type="checkbox" checked="@wordArt.ShadowEnabled" @onchange="ToggleWordArtShadow" /> Shadow</label>
                </section>
            }
            else if (element is DataVisualElement dataVisual)
            {
                <section class="property-section data-visual-properties">
                    <h3>Data visual</h3>
                    <p class="property-note">@DataVisualDescription(dataVisual). The source is stored once in the publication and may be reused by several visuals.</p>
                    <label>Title<input value="@dataVisual.Title" @onchange="ChangeDataVisualTitle" /></label>
                    <div class="data-source-summary">
                        <span><b>Component:</b> @Friendly(dataVisual.VisualKind.ToString())</span>
                        <span><b>Data:</b> @DataObjectName(dataVisual.DataObjectId)</span>
                        <span><b>Category:</b> @dataVisual.ArgumentField</span>
                        <span><b>Values:</b> @string.Join(", ", dataVisual.ValueFields)</span>
                    </div>
                    <DxButton Text="Edit data visual" Click="RequestEditDataVisual" RenderStyle="ButtonRenderStyle.Primary" CssClass="wide-button" />
                    <DxButton Text="Manage publication data" Click="RequestManageData" CssClass="wide-button" />
                    <DxButton Text="Refresh data" Click="RefreshData" CssClass="wide-button" />
                    <label class="check-row"><input type="checkbox" checked="@dataVisual.ShowTitle" @onchange="ToggleDataTitle" /> Show title</label>
                    <label class="check-row"><input type="checkbox" checked="@dataVisual.ShowLegend" @onchange="ToggleDataLegend" /> Show legend</label>
                    <label class="check-row"><input type="checkbox" checked="@dataVisual.ShowLabels" @onchange="ToggleDataLabels" /> Show point labels</label>
                    @ColorField("Background", dataVisual.Background, "dataBackground")
                    @ColorField("Border", dataVisual.BorderColor, "dataBorder")
                    @RangeField("Border width", dataVisual.BorderWidthMm, 0, 5, .05, "dataBorderWidth")
                </section>
            }
            else if (element is ConnectorElement connector)
            {
                <section class="property-section connector-properties">
                    <h3>Connector</h3>
                    <p class="property-note">Drag either round endpoint to another snap port. While no valid port is in range, the preview disappears; releasing restores the original connection.</p>
                    <label>Path
                        <select value="@connector.PathKind" @onchange="ChangeConnectorPath">
                            <option value="Straight">Straight</option>
                            <option value="Elbow">Elbow</option>
                            <option value="Curved">Curved</option>
                        </select>
                    </label>
                    <label>Line style
                        <select value="@connector.DashStyle" @onchange="ChangeConnectorDash">
                            <option value="Solid">Solid</option>
                            <option value="Dash">Dashed</option>
                            <option value="Dot">Dotted</option>
                        </select>
                    </label>
                    @ColorField("Line color", connector.Stroke, "connectorStroke")
                    @RangeField("Line width", connector.StrokeWidthMm, .15, 6, .05, "connectorWidth")
                    <div class="property-grid two">
                        <label>Start marker
                            <select value="@connector.StartMarker" @onchange="ChangeConnectorStartMarker">
                                <option value="None">None</option>
                                <option value="Arrow">Arrow</option>
                                <option value="Triangle">Triangle</option>
                                <option value="Diamond">Diamond</option>
                            </select>
                        </label>
                        <label>End marker
                            <select value="@connector.EndMarker" @onchange="ChangeConnectorEndMarker">
                                <option value="None">None</option>
                                <option value="Arrow">Arrow</option>
                                <option value="Triangle">Triangle</option>
                                <option value="Diamond">Diamond</option>
                            </select>
                        </label>
                    </div>
                    <div class="connector-endpoint-summary">
                        <span><b>From:</b> @EndpointName(connector.Source)</span>
                        <span><b>To:</b> @EndpointName(connector.Target)</span>
                    </div>
                </section>
            }
            else if (element is ShapeElement shape)
            {
                <section class="property-section">
                    <h3>Shape</h3>
                    @ColorField("Fill", shape.Fill, "shapeFill")
                    @ColorField("Outline", shape.Stroke, "shapeStroke")
                    @RangeField("Outline width", shape.StrokeWidth, 0, 8, .05, "shapeStrokeWidth")
                    @RangeField("Corner radius", shape.CornerRadiusMm, 0, 30, .1, "shapeCorner")
                </section>
            }
        </div>
    }
    else
    {
        <div class="empty-panel selection-help">
            <strong>No object selected</strong>
            <span>Select a text box, picture, WordArt, or shape. Page and ruler settings are available on the Page tab.</span>
        </div>
    }
</aside>

@code {
    [Parameter, EditorRequired] public EditorStateService State { get; set; } = default!;
    [Parameter] public EventCallback OnEditStory { get; set; }
    [Parameter] public EventCallback OnReplacePicture { get; set; }
    [Parameter] public EventCallback OnInsertPicture { get; set; }
    [Parameter] public EventCallback OnCreatePicture { get; set; }
    [Parameter] public EventCallback OnEditPicture { get; set; }
    [Parameter] public EventCallback OnApplyTransparentColor { get; set; }
    [Parameter] public EventCallback OnRestoreOriginalPicture { get; set; }
    [Parameter] public EventCallback<DataVisualKind> OnInsertDataVisual { get; set; }
    [Parameter] public EventCallback OnEditDataVisual { get; set; }
    [Parameter] public EventCallback OnManageData { get; set; }

    private string _tab = "properties";
    private string PropertiesTabClass => _tab == "properties" ? "active" : string.Empty;
    private string PageTabClass => _tab == "page" ? "active" : string.Empty;
    private string LayersTabClass => _tab == "layers" ? "active" : string.Empty;
    private string CurrentPresetKey => PagePreset.All.FirstOrDefault(preset => Nearly(preset.WidthMm, State.CurrentPage.WidthMm) && Nearly(preset.HeightMm, State.CurrentPage.HeightMm))?.Key ?? "custom";

    private Task RequestEditStory() => OnEditStory.InvokeAsync();
    private Task RequestReplacePicture() => OnReplacePicture.InvokeAsync();
    private Task RequestInsertPicture() => OnInsertPicture.InvokeAsync();
    private Task RequestCreatePicture() => OnCreatePicture.InvokeAsync();
    private Task RequestEditPicture() => OnEditPicture.InvokeAsync();
    private Task RequestApplyTransparentColor() => OnApplyTransparentColor.InvokeAsync();
    private Task RequestRestoreOriginalPicture() => OnRestoreOriginalPicture.InvokeAsync();
    private Task RequestEditDataVisual() => OnEditDataVisual.InvokeAsync();
    private Task RequestManageData() => OnManageData.InvokeAsync();
    private void ShowProperties() => _tab = "properties";
    private void ShowPage() => _tab = "page";
    private void ShowLayers() => _tab = "layers";
    private void AddText() => State.AddText();
    private void AddWordArt() => State.AddWordArt();
    private void AddRectangle() => State.AddShape(PublicationShape.Rectangle);
    private Task AddChart() => OnInsertDataVisual.InvokeAsync(DataVisualKind.CartesianChart);
    private void StartConnector() => State.SetConnectorTool(ConnectorToolKind.Line);

    private void ToggleLayerVisibility(PublicationElement item)
    {
        State.SelectElement(item.Id);
        State.UpdateSelected(element => element.Visible = !element.Visible, allowLocked: true);
    }

    private void ToggleLayerLock(PublicationElement item)
    {
        State.SelectElement(item.Id);
        State.UpdateSelected(element => element.Locked = !element.Locked, allowLocked: true);
    }

    private static string KindGlyph(PublicationElement item) => item.Kind switch
    {
        PublicationElementKind.Text => "T",
        PublicationElementKind.Image => "▧",
        PublicationElementKind.WordArt => "A★",
        PublicationElementKind.Connector => "↝",
        PublicationElementKind.DataVisual => "▥",
        _ => "◇"
    };

    private string EndpointName(ConnectorEndpoint endpoint)
    {
        var owner = State.CurrentPage.Elements.FirstOrDefault(item => item.Id == endpoint.ElementId);
        return $"{owner?.Name ?? "Missing object"} · {endpoint.Anchor}";
    }

    private RenderFragment NumberField(string label, double value, string field) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "label");
        builder.AddContent(sequence++, label);
        builder.OpenElement(sequence++, "input");
        builder.AddAttribute(sequence++, "type", "number");
        builder.AddAttribute(sequence++, "step", field == "z" ? "1" : ".1");
        builder.AddAttribute(sequence++, "value", Inv(value));
        builder.AddAttribute(sequence++, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, args => ChangeNumber(field, args)));
        builder.CloseElement();
        builder.CloseElement();
    };

    private RenderFragment RangeField(string label, double value, double min, double max, double step, string field) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "label");
        builder.AddAttribute(sequence++, "class", "range-field");
        builder.OpenElement(sequence++, "span");
        builder.AddContent(sequence++, label);
        builder.OpenElement(sequence++, "b");
        builder.AddContent(sequence++, Inv(value));
        builder.CloseElement();
        builder.CloseElement();
        builder.OpenElement(sequence++, "input");
        builder.AddAttribute(sequence++, "type", "range");
        builder.AddAttribute(sequence++, "min", min);
        builder.AddAttribute(sequence++, "max", max);
        builder.AddAttribute(sequence++, "step", step);
        builder.AddAttribute(sequence++, "value", value.ToString(CultureInfo.InvariantCulture));
        builder.AddAttribute(sequence++, "oninput", EventCallback.Factory.Create<ChangeEventArgs>(this, args => ChangeNumberLive(field, args)));
        builder.AddAttribute(sequence++, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, EndLiveEdit));
        builder.CloseElement();
        builder.CloseElement();
    };

    private RenderFragment ColorField(string label, string value, string field) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "label");
        builder.AddContent(sequence++, label);
        builder.OpenElement(sequence++, "span");
        builder.AddAttribute(sequence++, "class", "color-field");
        builder.OpenElement(sequence++, "input");
        builder.AddAttribute(sequence++, "type", "color");
        builder.AddAttribute(sequence++, "value", UsableColor(value));
        builder.AddAttribute(sequence++, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, args => ChangeColor(field, args)));
        builder.CloseElement();
        builder.OpenElement(sequence++, "code");
        builder.AddContent(sequence++, value);
        builder.CloseElement();
        builder.CloseElement();
        builder.CloseElement();
    };

    private void ChangePagePreset(ChangeEventArgs args)
    {
        var preset = PagePreset.Find(args.Value?.ToString());
        if (preset is not null) State.SetPageSize(preset.WidthMm, preset.HeightMm);
    }

    private void ChangePageWidth(ChangeEventArgs args) { if (TryDouble(args, out var value)) State.SetPageSize(value, State.CurrentPage.HeightMm); }
    private void ChangePageHeight(ChangeEventArgs args) { if (TryDouble(args, out var value)) State.SetPageSize(State.CurrentPage.WidthMm, value); }
    private void SwapOrientation() => State.SwapPageOrientation();
    private void ChangePageBackground(ChangeEventArgs args) => State.UpdatePage(publicationPage => publicationPage.Background = args.Value?.ToString() ?? "#ffffff");
    private void SetTransparentPage() => State.UpdatePage(publicationPage => publicationPage.Background = "transparent");
    private void SetWhitePage() => State.UpdatePage(publicationPage => publicationPage.Background = "#ffffff");
    private void ChangeRulerUnit(ChangeEventArgs args) { if (Enum.TryParse<MeasurementUnit>(args.Value?.ToString(), out var unit)) State.SetRulerUnit(unit); }
    private void ChangeGridSpacing(ChangeEventArgs args) { if (TryDouble(args, out var value)) State.SetViewOption(view => view.GridSpacingMm = value); }
