@namespace PublisherStudio.Components.Editor
@inject IJSRuntime JS
@inject StreamingProfileStore StreamingProfiles

<aside class="inspector-panel">
    <div class="inspector-tabs four">
        <button class="@PropertiesTabClass" @onclick="ShowProperties">Properties</button>
        <button class="@PageTabClass" @onclick="ShowPage">Page</button>
        <button class="@LayersTabClass" @onclick="ShowLayers">Layers</button>
        <button class="@AnimationsTabClass" @onclick="ShowAnimations">Animations</button>
    </div>

    @if (_tab == "animations")
    {
        <AnimationPanel State="State" />
    }
    else if (_tab == "layers")
    {
        <div class="layers-panel">
            <div class="layer-help"><strong>Objects are layers</strong><span>Higher rows appear in front. Use the eye and lock buttons per object.</span></div>
            <div class="layer-create-bar">
                <button title="Add text box" @onclick="AddText">T</button>
                <button title="Add WordArt" @onclick="AddWordArt">A★</button>
                <button title="Add picture" @onclick="RequestInsertPicture">▧</button>
                <button title="Create picture in Picture Studio" @onclick="RequestCreatePicture">▣</button>
                <button title="Open spreadsheet" @onclick="RequestInsertSpreadsheet">▦</button>
                <button title="Create spreadsheet" @onclick="RequestCreateSpreadsheet">▦+</button>
                <button title="Insert video" @onclick="RequestInsertVideo">▶</button>
                <button title="Insert audio" @onclick="RequestInsertAudio">♪</button>
                <button title="Create video" @onclick="RequestCreateVideo">●▶</button>
                <button title="Create audio" @onclick="RequestCreateAudio">●♪</button>
                <button title="Add rectangle" @onclick="AddRectangle">◇</button>
                <button title="Insert chart" @onclick="AddChart">▥</button>
                <button title="Insert professional Data Grid" @onclick="AddComponentDataGrid">▦</button>
                <button title="Draw connector: click, then drag between object ports" @onclick="StartConnector">↝</button>
                <button title="Delete selected layer" disabled="@(State.SelectedElement is null || State.SelectedElement.Locked)" @onclick="State.DeleteSelected">⌫</button>
            </div>
            <div class="layer-arrange-bar">
                <button title="Bring to front" disabled="@(State.SelectedElement is null)" @onclick="State.BringToFront">Front</button>
                <button title="Bring forward" disabled="@(State.SelectedElement is null)" @onclick="State.BringForward">Up</button>
                <button title="Send backward" disabled="@(State.SelectedElement is null)" @onclick="State.SendBackward">Down</button>
                <button title="Send to back" disabled="@(State.SelectedElement is null)" @onclick="State.SendToBack">Back</button>
            </div>
            <div class="layers-list">
                @foreach (var item in State.CurrentPage.Elements.OrderByDescending(element => element.ZIndex))
                {
                    <div class="layer-row @(State.IsSelected(item.Id) ? "selected" : null) @(item.Id == State.SelectedElementId ? "selection-primary" : null)"
                         @oncontextmenu="args => ShowLayerContextMenu(item, args)" @oncontextmenu:preventDefault>
                        <button class="layer-select" title="Select @item.Name" @onclick="args => SelectLayer(item, args)">
                            <span class="layer-kind">@KindGlyph(item)</span>
                            <span class="layer-name">@item.Name</span>
                        </button>
                        <button class="layer-toggle" title="@(item.Visible ? "Hide" : "Show")" @onclick="() => ToggleLayerVisibility(item)">@(item.Visible ? "◉" : "○")</button>
                        <button class="layer-toggle" title="@(item.Locked ? "Unlock" : "Lock")" @onclick="() => ToggleLayerLock(item)">@(item.Locked ? "🔒" : "🔓")</button>
                    </div>
                }
                @if (State.CurrentPage.Elements.Count == 0)
                {
                    <div class="empty-panel">This page has no objects.</div>
                }
            </div>
        </div>
    }
    else if (_tab == "page")
    {
        <div class="property-scroll">
            <section class="property-section">
                <h3>Page format</h3>
                <label>Preset
                    <select value="@CurrentPresetKey" @onchange="ChangePagePreset">
                        <option value="custom">Custom</option>
                        @foreach (var preset in PagePreset.All)
                        {
                            <option value="@preset.Key">@preset.Name</option>
                        }
                    </select>
                </label>
                <div class="property-grid two">
                    <label>Width (mm)<input type="number" min="10" max="2000" step="0.1" value="@Inv(State.CurrentPage.WidthMm)" @onchange="ChangePageWidth" /></label>
                    <label>Height (mm)<input type="number" min="10" max="2000" step="0.1" value="@Inv(State.CurrentPage.HeightMm)" @onchange="ChangePageHeight" /></label>
                </div>
                <DxButton Text="Swap width / height" Click="SwapOrientation" CssClass="wide-button" />
                <label>Background
                    <span class="color-field"><input type="color" value="@UsableColor(State.CurrentPage.Background)" @onchange="ChangePageBackground" /><code>@State.CurrentPage.Background</code></span>
                </label>
                <div class="property-button-row">
                    <DxButton Text="Transparent" Click="SetTransparentPage" />
                    <DxButton Text="White" Click="SetWhitePage" />
                </div>
            </section>

            <section class="property-section">
                <h3>Presentation timeline</h3>
                <label>Page duration (seconds)
                    <input type="number" min="1" max="3600" step="0.1" value="@Inv(State.CurrentPage.TimelineDurationSeconds)" @onchange="ChangePageTimelineDuration" />
                </label>
                <div class="property-button-row">
                    <DxButton Text="Fit to content" Click="FitPageTimelineToContent" />
                    <DxButton Text="10 seconds" Click="SetTenSecondTimeline" />
                </div>
                <p class="property-note">Effective duration: @Time(State.EffectivePageTimelineDuration()). The timeline expands automatically when media or animation clips extend beyond the page duration.</p>
            </section>

            <section class="property-section">
                <h3>Canvas and rulers</h3>
                <label>Ruler unit
                    <select value="@State.Document.View.RulerUnit" @onchange="ChangeRulerUnit">
                        <option value="Millimeter">Millimetres</option>
                        <option value="Centimeter">Centimetres</option>
                        <option value="Inch">Inches</option>
                        <option value="Pixel">Pixels</option>
                    </select>
                </label>
                <label>Grid spacing (mm)<input type="number" min="0.5" max="100" step="0.5" value="@Inv(State.Document.View.GridSpacingMm)" @onchange="ChangeGridSpacing" /></label>
                <label class="check-row"><input type="checkbox" checked="@State.Document.View.RulersVisible" @onchange="ToggleRulers" /> Show rulers</label>
                <label class="check-row"><input type="checkbox" checked="@State.Document.View.GridVisible" @onchange="ToggleGrid" /> Show grid</label>
                <label class="check-row"><input type="checkbox" checked="@State.Document.View.GuidesVisible" @onchange="ToggleGuides" /> Show guides</label>
                <label class="check-row"><input type="checkbox" checked="@State.Document.View.SnapToGrid" @onchange="ToggleSnapGrid" /> Snap to grid</label>
                <label class="check-row"><input type="checkbox" checked="@State.Document.View.SnapToGuides" @onchange="ToggleSnapGuides" /> Snap to guides</label>
                <label class="check-row"><input type="checkbox" checked="@State.Document.View.SnapToPage" @onchange="ToggleSnapPage" /> Snap to page edges</label>
                <label class="check-row"><input type="checkbox" checked="@State.Document.View.SnapToObjects" @onchange="ToggleSnapObjects" /> Snap to other objects</label>
                <div class="property-button-row">
                    <DxButton Text="Vertical guide" Click="AddVerticalGuide" />
                    <DxButton Text="Horizontal guide" Click="AddHorizontalGuide" />
                </div>
                <DxButton Text="Clear guides" Enabled="@(State.CurrentPage.Guides.Count > 0)" Click="ClearGuides" CssClass="wide-button" />
            </section>

            <section class="property-section">
                <h3>Export</h3>
                <label>Raster export DPI
                    <select value="@State.Document.View.ExportDpi" @onchange="ChangeExportDpi">
                        <option value="96">96 DPI — screen</option>
                        <option value="150">150 DPI — draft print</option>
                        <option value="300">300 DPI — print</option>
                        <option value="600">600 DPI — high resolution</option>
                    </select>
                </label>
                <p class="property-note">PNG preserves page and image transparency. JPEG always receives a white background.</p>
            </section>
        </div>
    }
    else if (State.SelectedElement is { } element)
    {
        <div class="property-scroll">
            <section class="property-section">
                <h3>Object</h3>
                <label>Name<input value="@element.Name" @onchange="ChangeName" /></label>
                @if (element is not ConnectorElement)
                {
                    <div class="property-grid two">
                        @NumberField("X", element.X, "x")
                        @NumberField("Y", element.Y, "y")
                        @NumberField("Width", element.Width, "width")
                        @NumberField("Height", element.Height, "height")
                        @NumberField("Rotation", element.Rotation, "rotation")
                        @NumberField("Layer", element.ZIndex, "z")
                    </div>
                }
                else
                {
                    <div class="property-grid two">@NumberField("Layer", element.ZIndex, "z")</div>
                }
                <label class="check-row"><input type="checkbox" checked="@element.Visible" @onchange="ToggleVisible" /> Visible</label>
                <label class="check-row"><input type="checkbox" checked="@element.Locked" @onchange="ToggleLocked" /> Locked</label>
            </section>

            @if (element is ImageFrameElement image)
            {
                <section class="property-section picture-properties">
                    <h3>Picture</h3>
                    <DxButton Text="Edit in Picture Studio" Click="RequestEditPicture" CssClass="wide-button" />
                    <div class="property-button-row">
                        <DxButton Text="Replace…" Click="RequestReplacePicture" />
                        <DxButton Text="@(State.CropMode ? "Finish crop" : "Crop")" Click="ToggleCrop" />
                    </div>
                    <div class="property-button-row">
                        <DxButton Text="Fit" Click="PictureFit" />
                        <DxButton Text="Fill" Click="PictureFill" />
                        <DxButton Text="Reset" Click="ResetPicture" />
                    </div>
                    @RangeField("Crop zoom", image.CropScale, .2, 8, .02, "cropScale")
                    @RangeField("Picture rotation", image.ImageRotation, -180, 180, 1, "imageRotation")
                    @RangeField("Opacity", image.Opacity, 0, 1, .01, "opacity")
                    @RangeField("Brightness", image.Brightness, 0, 2, .01, "brightness")
                    @RangeField("Contrast", image.Contrast, 0, 2, .01, "contrast")
                    @RangeField("Saturation", image.Saturation, 0, 2, .01, "saturation")
                    @RangeField("Hue", image.HueRotation, -180, 180, 1, "hue")
                    @RangeField("Invert", image.Invert, 0, 1, .01, "invert")
                    @RangeField("Grayscale", image.Grayscale, 0, 1, .01, "grayscale")
                    @RangeField("Sepia", image.Sepia, 0, 1, .01, "sepia")
                    @RangeField("Blur", image.Blur, 0, 12, .1, "blur")
                </section>

                <section class="property-section picture-color-tools">
                    <h3>Recolor and transparency</h3>
                    <label>Color treatment
                        <select value="@image.TintMode" @onchange="ChangeTintMode">
                            <option value="Overlay">Tint overlay</option>
                            <option value="Recolor">Full recolor</option>
                        </select>
                    </label>
                    <label>Blend mode
                        <select value="@image.BlendMode" @onchange="ChangeBlendMode">
                            <option value="Normal">Normal</option>
                            <option value="Multiply">Multiply</option>
                            <option value="Screen">Screen</option>
                            <option value="Darken">Darken</option>
                            <option value="Lighten">Lighten</option>
                        </select>
                    </label>
                    @ColorField("Tint color", image.TintColor, "tintColor")
                    @RangeField("Tint strength", image.TintOpacity, 0, 1, .01, "tintOpacity")
                    <div class="color-preset-row">
                        <button @onclick="TintBlue">Blue</button>
                        <button @onclick="TintWarm">Warm</button>
                        <button @onclick="TintGreen">Green</button>
                        <button @onclick="ClearTint">Clear</button>
                    </div>
                    @ColorField("Color to remove", image.TransparentColor, "transparentColor")
                    @RangeField("Color tolerance", image.TransparentColorTolerance, 0, 255, 1, "transparentTolerance")
                    <div class="property-button-row">
                        <DxButton Text="Make transparent" Click="RequestApplyTransparentColor" />
                        <DxButton Text="Restore original" Click="RequestRestoreOriginalPicture" />
                    </div>
                    <p class="property-note">Recolor and tint preserve the picture's alpha channel. “Make transparent” edits a copy; Restore Original keeps the imported source.</p>
                </section>

                <section class="property-section">
                    <h3>Picture frame</h3>
                    <label>Mask
                        <select value="@image.MaskShape" @onchange="ChangeImageMask">
                            <option value="Rectangle">Rectangle</option>
                            <option value="RoundedRectangle">Rounded rectangle</option>
                            <option value="Ellipse">Ellipse</option>
                        </select>
                    </label>
                    @RangeField("Rounded corners", image.CornerRadiusMm, 0, 30, .1, "corner")
                    @ColorField("Border", image.BorderColor, "imageBorder")
                    @RangeField("Border width", image.BorderWidthMm, 0, 5, .05, "imageBorderWidth")
                    <label class="check-row"><input type="checkbox" checked="@image.ShadowEnabled" @onchange="ToggleImageShadow" /> Drop shadow</label>
                    <label class="check-row"><input type="checkbox" checked="@image.FlipHorizontal" @onchange="ToggleFlipHorizontal" /> Flip horizontal</label>
                    <label class="check-row"><input type="checkbox" checked="@image.FlipVertical" @onchange="ToggleFlipVertical" /> Flip vertical</label>
                    <label>Alt text<input value="@image.AltText" @onchange="ChangeAltText" /></label>
                </section>
            }
            else if (element is TextFrameElement text)
            {
                <section class="property-section">
                    <h3>Text frame</h3>
                    @RangeField("Padding", text.PaddingMm, 0, 20, .1, "padding")
                    @ColorField("Background", text.Background, "textBackground")
                    @ColorField("Border", text.BorderColor, "textBorder")
                    @RangeField("Frame border width (mm)", text.BorderWidth, 0, 5, .05, "textBorderWidth")
                    <label>Content sizing
                        <select value="@text.ContentFit" @onchange="ChangeTextContentFit">
                            <option value="Clip">Natural / clip fragments</option>
                            <option value="Fit">Fit whole text</option>
                            <option value="Fill">Fill and crop</option>
                            <option value="Stretch">Stretch to frame</option>
                        </select>
                    </label>
                    <DxButton Text="Edit story" Click="RequestEditStory" CssClass="wide-button" />
                </section>
            }
            else if (element is WordArtElement wordArt)
            {
                <section class="property-section wordart-properties">
                    <h3>WordArt / LogoArt</h3>
                    <label>Text<textarea rows="3" value="@wordArt.Text" @onchange="ChangeWordArtText"></textarea></label>
                    <label>Font family
                        <select value="@wordArt.FontFamily" @onchange="ChangeWordArtFont">
                            @if (!WordArtFonts.Contains(wordArt.FontFamily, StringComparer.OrdinalIgnoreCase))
                            {
                                <option value="@wordArt.FontFamily">@wordArt.FontFamily</option>
                            }
                            @foreach (var font in WordArtFonts)
                            {
                                <option value="@font">@font</option>
                            }
                        </select>
                    </label>
                    @RangeField("Font size", wordArt.FontSizePt, 8, 180, 1, "wordFontSize")
                    @RangeField("Letter spacing", wordArt.LetterSpacing, -5, 30, .5, "wordLetterSpacing")
                    @ColorField("Fill", wordArt.FillColor, "wordFill")
                    @ColorField("Second color", wordArt.SecondaryColor, "wordSecondary")
                    @ColorField("Outline", wordArt.OutlineColor, "wordOutline")
                    @RangeField("Outline width", wordArt.OutlineWidth, 0, 12, .25, "wordOutlineWidth")
                    @ColorField("3D color", wordArt.ExtrudeColor, "wordExtrude")
                    @RangeField("3D depth", wordArt.ExtrudeDepth, 0, 18, .5, "wordExtrudeDepth")
                    <label>Warp
                        <select value="@wordArt.Warp" @onchange="ChangeWordArtWarp">
                            <option value="None">Straight</option>
                            <option value="ArchUp">Arch up</option>
                            <option value="ArchDown">Arch down</option>
                            <option value="Wave">Wave</option>
                            <option value="Custom">Custom drawn path</option>
                        </select>
                    </label>
                    @if (wordArt.Warp == WordArtWarp.Custom)
                    {
                        <WordArtPathEditor @key="wordArt.Id" Item="wordArt" PathChanged="ChangeWordArtPath" />
                    }
                    @if (wordArt.Warp != WordArtWarp.None)
                    {
                        @RangeField("Text position on path", wordArt.PathStartOffsetPercent, 0, 100, 1, "wordPathStart")
                        @RangeField("Distance from path", wordArt.PathBaselineOffset, -80, 80, 1, "wordPathOffset")
                    }
                    <label class="check-row"><input type="checkbox" checked="@wordArt.Bold" @onchange="ToggleWordArtBold" /> Bold</label>
                    <label class="check-row"><input type="checkbox" checked="@wordArt.Italic" @onchange="ToggleWordArtItalic" /> Italic</label>
                    <label class="check-row"><input type="checkbox" checked="@wordArt.GradientFill" @onchange="ToggleWordArtGradient" /> Gradient fill</label>
                    <label class="check-row"><input type="checkbox" checked="@wordArt.ShadowEnabled" @onchange="ToggleWordArtShadow" /> Shadow</label>
                </section>
            }
            else if (element is PublicationMediaElement media)
            {
                <section class="property-section media-properties">
                    <h3>@(media is VideoElement ? "Video" : "Audio")</h3>
                    <DxButton Text="Edit in Media Studio" Click="RequestEditMedia" RenderStyle="ButtonRenderStyle.Primary" CssClass="wide-button" />
                    <div class="property-grid two">
                        <label>Timeline start<input type="number" min="0" max="3600" step="0.01" value="@Inv(media.TimelineStartSeconds)" @onchange="ChangeMediaTimelineStart" /></label>
                        <label>Playback rate<input type="number" min="0.25" max="4" step="0.05" value="@Inv(media.PlaybackRate)" @onchange="ChangeMediaPlaybackRate" /></label>
                        <label>Trim start<input type="number" min="0" max="@Inv(media.DurationSeconds)" step="0.01" value="@Inv(media.TrimStartSeconds)" @onchange="ChangeMediaTrimStart" /></label>
                        <label>Trim end<input type="number" min="0" max="@Inv(media.DurationSeconds)" step="0.01" value="@Inv(media.EffectiveTrimEndSeconds)" @onchange="ChangeMediaTrimEnd" /></label>
                    </div>
                    @RangeField("Volume", media.Volume, 0, 1, .01, "mediaVolume")
                    @if (media is AudioElement)
                    {
                        @RangeField("Fade in", media.FadeInSeconds, 0, Math.Max(.05, media.TimelineLengthSeconds / 2), .05, "mediaFadeIn")
                        @RangeField("Fade out", media.FadeOutSeconds, 0, Math.Max(.05, media.TimelineLengthSeconds / 2), .05, "mediaFadeOut")
                    }
                    <label>Start behavior
                        <select value="@media.PlaybackTrigger" @onchange="ChangeMediaTrigger">
                            <option value="OnPageEnter">On page entry</option>
                            <option value="OnClick">On click</option>
                            <option value="WithAnimation">With animation timeline</option>
                        </select>
                    </label>
                    <label class="check-row"><input type="checkbox" checked="@media.Muted" @onchange="ToggleMediaMuted" /> Muted</label>
                    <label class="check-row"><input type="checkbox" checked="@media.Loop" @onchange="ToggleMediaLoop" /> Loop selected range</label>
                    <label class="check-row"><input type="checkbox" checked="@media.AutoPlay" @onchange="ToggleMediaAutoPlay" /> Play during presentation</label>
                    @if (media is VideoElement video)
                    {
                        <label>Video fit
                            <select value="@video.FitMode" @onchange="ChangeVideoFit">
                                <option value="Contain">Fit inside frame</option>
                                <option value="Cover">Fill frame</option>
                                <option value="Stretch">Stretch</option>
                            </select>
                        </label>
                        <label class="check-row"><input type="checkbox" checked="@video.ShowControls" @onchange="ToggleVideoControls" /> Show controls</label>
                    }
                    else if (media is AudioElement audio)
                    {
                        <label>Audio appearance
                            <select value="@audio.DisplayKind" @onchange="ChangeAudioDisplay">
                                <option value="Waveform">Waveform</option>
                                <option value="Compact">Compact</option>
                                <option value="Hidden">Hidden during presentation</option>
                            </select>
                        </label>
                        @ColorField("Accent", audio.AccentColor, "audioAccent")
                        <label class="check-row"><input type="checkbox" checked="@audio.ShowControls" @onchange="ToggleAudioControls" /> Show controls</label>
                    }
                    <p class="property-note">The source remains embedded. Trimming, fades, playback rate, and timeline placement are non-destructive.</p>
                </section>
            }
            else if (element is LiveSourceElement liveSource)
            {
                <section class="property-section live-source-properties">
                    <h3>Live source</h3>
                    <div class="data-source-summary">
                        <span><b>Kind:</b> @liveSource.SourceKind</span>
                        <span><b>Clock:</b> @(liveSource.UseDeviceTimestamp ? "Device timestamp" : "Session clock")</span>
                    </div>
                    <label>Saved device profile
                        <select value="@GuidText(liveSource.DeviceProfileId)" @onchange="ChangeLiveDeviceProfile">
                            <option value="">Custom settings</option>
                            @foreach (var profile in _streamingDeviceProfiles)
                            {
                                <option value="@profile.Id">@profile.Name · @profile.Kind</option>
                            }
                        </select>
                    </label>
                    <button type="button" class="wide-button" @onclick="RefreshStreamingDeviceProfiles">Refresh saved profiles</button>
                    <label>Capture backend
                        <select value="@liveSource.CaptureBackend" @onchange="ChangeLiveCaptureBackend">
                            @foreach (var value in Enum.GetValues<PublicationCaptureBackend>()) { <option value="@value">@value</option> }
                        </select>
                    </label>
                    @if (liveSource.CaptureBackend == PublicationCaptureBackend.Native)
                    {
                        <label>Native backend<input value="@liveSource.NativeBackend" @onchange="ChangeLiveNativeBackend" placeholder="dshow, avfoundation, v4l2, wasapi-process-loopback" /></label>
                    }
                    <label>Source kind
                        <select value="@liveSource.SourceKind" @onchange="ChangeLiveSourceKind">
                            @foreach (var value in Enum.GetValues<PublicationLiveSourceKind>()) { <option value="@value">@value</option> }
                        </select>
                    </label>
                    @if (liveSource.SourceKind is PublicationLiveSourceKind.Camera or PublicationLiveSourceKind.CaptureDevice or PublicationLiveSourceKind.Microphone)
                    {
                        <label>Video / primary device ID<input value="@liveSource.DeviceId" @onchange="ChangeLiveDeviceId" placeholder="Blank uses the default device" /></label>
                    }
                    @if (liveSource.SourceKind is PublicationLiveSourceKind.Camera or PublicationLiveSourceKind.CaptureDevice)
                    {
                        <label>Audio device ID<input value="@liveSource.AudioDeviceId" @onchange="ChangeLiveAudioDeviceId" placeholder="Optional paired capture-card audio device" /></label>
                    }
                    @if (liveSource.SourceKind == PublicationLiveSourceKind.ApplicationAudio)
                    {
                        <label>Application / process<input value="@liveSource.ApplicationId" @onchange="ChangeLiveApplicationId" placeholder="discord.exe or another process" /></label>
                        <label>Window-title hint<input value="@liveSource.WindowTitle" @onchange="ChangeLiveWindowTitle" /></label>
                    }
                    @if (liveSource.SourceKind == PublicationLiveSourceKind.NetworkMedia)
                    {
                        <label>Network URL<input value="@liveSource.NetworkUrl" @onchange="ChangeLiveNetworkUrl" placeholder="https, rtsp, srt, or provider URL" /></label>
                    }
                    @if (liveSource.SourceKind == PublicationLiveSourceKind.NowPlaying)
                    {
                        <label>Watched music directory<input value="@liveSource.NowPlayingDirectory" @onchange="ChangeNowPlayingDirectory" /></label>
                    }
                    @if (liveSource.IsVisual)
                    {
                        <label>Capture width<input type="number" min="320" max="7680" step="2" value="@liveSource.CaptureWidth" @onchange="ChangeLiveCaptureWidth" /></label>
                        <label>Capture height<input type="number" min="180" max="4320" step="2" value="@liveSource.CaptureHeight" @onchange="ChangeLiveCaptureHeight" /></label>
                        <label>Capture FPS<input type="number" min="15" max="120" value="@liveSource.CaptureFrameRate" @onchange="ChangeLiveCaptureFrameRate" /></label>
                        <label>Fit
                            <select value="@liveSource.FitMode" @onchange="ChangeLiveFit">
                                @foreach (var value in Enum.GetValues<PublicationLiveSourceFitMode>()) { <option value="@value">@value</option> }
                            </select>
                        </label>
                        @RangeField("Brightness", liveSource.Brightness, 0, 4, .01, "liveBrightness")
                        @RangeField("Contrast", liveSource.Contrast, 0, 4, .01, "liveContrast")
                        @RangeField("Saturation", liveSource.Saturation, 0, 4, .01, "liveSaturation")
                        @RangeField("Hue", liveSource.HueRotation, -360, 360, 1, "liveHue")
                        @RangeField("Blur", liveSource.Blur, 0, 64, .1, "liveBlur")
                        <label class="check-row"><input type="checkbox" checked="@liveSource.ChromaKeyEnabled" @onchange="ToggleLiveChroma" /> Chroma key</label>
                        @if (liveSource.ChromaKeyEnabled)
                        {
                            @ColorField("Key color", liveSource.ChromaKeyColor, "liveChromaColor")
                            @RangeField("Similarity", liveSource.ChromaSimilarity, 0, 1, .01, "liveChromaSimilarity")
                            @RangeField("Smoothness", liveSource.ChromaSmoothness, 0, 1, .01, "liveChromaSmoothness")
                            @RangeField("Spill reduction", liveSource.ChromaSpill, 0, 1, .01, "liveChromaSpill")
                            @RangeField("Keyed residual opacity", liveSource.ChromaResidualOpacity, 0, 1, .01, "liveChromaResidual")
                        }
                    }
                    @RangeField("Volume", liveSource.Volume, 0, 1, .01, "liveVolume")
                    <label>Audio delay (ms)<input type="number" min="-10000" max="10000" step="1" value="@Inv(liveSource.AudioDelayMilliseconds)" @onchange="ChangeLiveAudioDelay" /></label>
                    <label class="check-row"><input type="checkbox" checked="@liveSource.IncludeAudio" @onchange="ToggleLiveAudio" /> Include source audio</label>
                    <label class="check-row"><input type="checkbox" checked="@liveSource.Muted" @onchange="ToggleLiveMuted" /> Mute preview / visual source</label>
                    <label class="check-row"><input type="checkbox" checked="@liveSource.UseDeviceTimestamp" @onchange="ToggleLiveDeviceTimestamp" /> Use device timestamps</label>
                    <p class="property-note">Camera, screen, window, tab, microphone, and network media can preview through browser APIs. Isolated application/system audio and global devices are resolved by PublisherStudio.MediaHost.</p>
                </section>
            }
            else if (element is SpreadsheetElement spreadsheet)
            {
                <section class="property-section spreadsheet-properties">
                    <h3>Spreadsheet</h3>
                    <div class="data-source-summary">
                        <span><b>Workbook:</b> @spreadsheet.WorkbookFileName</span>
                        <span><b>Active sheet:</b> @spreadsheet.ActiveSheetName</span>
                        <span><b>Stored format:</b> @spreadsheet.StorageFormat</span>
                    </div>
                    <DxButton Text="Edit spreadsheet" Click="RequestEditSpreadsheet" RenderStyle="ButtonRenderStyle.Primary" CssClass="wide-button" />
                    <div class="property-button-row">
                        <DxButton Text="Download workbook" Click="RequestDownloadSpreadsheet" />
                        <DxButton Text="Insert another…" Click="RequestInsertSpreadsheet" />
                    </div>
                    <DxButton Text="Create blank spreadsheet" Click="RequestCreateSpreadsheet" CssClass="wide-button" />
                    <label class="check-row"><input type="checkbox" checked="@spreadsheet.ShowGridLines" @onchange="ToggleSpreadsheetGridLines" /> Show grid lines on canvas</label>
                    <label class="check-row"><input type="checkbox" checked="@spreadsheet.ShowSheetName" @onchange="ToggleSpreadsheetSheetName" /> Show worksheet name on canvas</label>
                    <label>Content sizing
                        <select value="@spreadsheet.ContentFit" @onchange="ChangeSpreadsheetContentFit">
                            <option value="Clip">Natural / crop fragments</option>
                            <option value="Fit">Fit whole worksheet</option>
                            <option value="Fill">Fill and crop</option>
                            <option value="Stretch">Stretch to frame</option>
                        </select>
                    </label>
                    @ColorField("Background", spreadsheet.Background, "spreadsheetBackground")
                    @ColorField("Border", spreadsheet.BorderColor, "spreadsheetBorder")
                    @RangeField("Border width", spreadsheet.BorderWidthMm, 0, 5, .05, "spreadsheetBorderWidth")
                    <p class="property-note">Double-click the frame to open the full DevExpress Spreadsheet component. Workbook content stays embedded in the publication.</p>
                </section>
            }
            else if (element is BarcodeElement barcode)
            {
                <section class="property-section barcode-properties">
                    <h3>Barcode / QR</h3>
                    <div class="inspector-barcode-preview"><BarcodeView Item="barcode" /></div>
                    <p class="property-note"><b>@barcode.Format</b> · @barcode.Value</p>
                    <DxButton Text="Edit barcode" Click="RequestEditBarcode" RenderStyle="ButtonRenderStyle.Primary" CssClass="wide-button" />
                    <DxButton Text="Insert another barcode" Click="RequestInsertBarcode" CssClass="wide-button" />
                </section>
            }
            else if (element is DataVisualElement dataVisual)
            {
                <section class="property-section data-visual-properties">
                    <h3>Data visual</h3>
                    <p class="property-note">@DataVisualDescription(dataVisual). The source is stored once in the publication and may be reused by several visuals.</p>
                    <label>Title<input value="@dataVisual.Title" @onchange="ChangeDataVisualTitle" /></label>
                    <div class="data-source-summary">
                        <span><b>Component:</b> @Friendly(dataVisual.VisualKind.ToString())</span>
                        <span><b>Data:</b> @DataObjectName(dataVisual.DataObjectId)</span>
                        <span><b>Category:</b> @dataVisual.ArgumentField</span>
                        <span><b>Values:</b> @string.Join(", ", dataVisual.ValueFields)</span>
                    </div>
                    <DxButton Text="Edit data visual" Click="RequestEditDataVisual" RenderStyle="ButtonRenderStyle.Primary" CssClass="wide-button" />
                    <DxButton Text="Manage publication data" Click="RequestManageData" CssClass="wide-button" />
                    <DxButton Text="Refresh data" Click="RefreshData" CssClass="wide-button" />
                    <label class="check-row"><input type="checkbox" checked="@dataVisual.ShowTitle" @onchange="ToggleDataTitle" /> Show title</label>
                    <label class="check-row"><input type="checkbox" checked="@dataVisual.ShowLegend" @onchange="ToggleDataLegend" /> Show legend</label>
                    <label class="check-row"><input type="checkbox" checked="@dataVisual.ShowLabels" @onchange="ToggleDataLabels" /> Show point labels</label>
                    @ColorField("Background", dataVisual.Background, "dataBackground")
                    @ColorField("Border", dataVisual.BorderColor, "dataBorder")
                    @RangeField("Border width", dataVisual.BorderWidthMm, 0, 5, .05, "dataBorderWidth")
                </section>
            }
            else if (element is DevExtremeComponentElement component)
            {
                <section class="property-section component-properties">
                    <h3>Interactive component</h3>
                    <p class="property-note">Browser-native @PublicationComponentService.ComponentName(component.ComponentKind), exported with the same embedded DevExtreme runtime as the interactive charts.</p>
                    <div class="data-source-summary">
                        <span><b>Control:</b> @PublicationComponentService.ComponentName(component.ComponentKind)</span>
                        <span><b>Scope:</b> @(component.Scope == PublicationComponentScope.Document ? "All pages" : "This page")</span>
                        <span><b>Source:</b> @ComponentSource(component)</span>
                        <span><b>Fields:</b> @component.Fields.Count</span>
                    </div>
                    <DxButton Text="Open Component Studio" Click="RequestEditComponent" RenderStyle="ButtonRenderStyle.Primary" CssClass="wide-button" />
                    <DxButton Text="Manage publication data" Click="RequestManageData" CssClass="wide-button" />
                    <DxButton Text="Refresh component data" Click="RefreshData" CssClass="wide-button" />
                    <label class="check-row"><input type="checkbox" checked="@component.ShowTitle" @onchange="ToggleComponentTitle" /> Show component title</label>
                    <label class="check-row"><input type="checkbox" checked="@(component.Scope == PublicationComponentScope.Document)" @onchange="ToggleComponentScope" /> Synchronize content on all pages</label>
                    @ColorField("Background", component.Background, "componentBackground")
                    @ColorField("Border", component.BorderColor, "componentBorder")
                    @RangeField("Border width", component.BorderWidthMm, 0, 5, .05, "componentBorderWidth")
                </section>
            }
            else if (element is ConnectorElement connector)
            {
                <section class="property-section connector-properties">
                    <h3>@(connector.Signal.Enabled ? "Signal Arrow / Connector" : "Connector")</h3>
                    <p class="property-note">Normal connectors snap object-to-object. Signal connectors may also end at an exact canvas point and execute offline click, hover, transform, visibility, media, highlight, CSS-class, animation, or chained-signal actions in HTML and video output.</p>
                    <label>Path
                        <select value="@connector.PathKind" @onchange="ChangeConnectorPath">
                            <option value="Straight">Straight</option>
                            <option value="Elbow">Elbow</option>
                            <option value="Curved">Curved</option>
                        </select>
                    </label>
                    <label>Line style
                        <select value="@connector.DashStyle" @onchange="ChangeConnectorDash">
                            <option value="Solid">Solid</option>
                            <option value="Dash">Dashed</option>
                            <option value="Dot">Dotted</option>
                        </select>
                    </label>
                    @ColorField("Line color", connector.Stroke, "connectorStroke")
                    @RangeField("Line width", connector.StrokeWidthMm, .15, 6, .05, "connectorWidth")
                    <div class="property-grid two">
                        <label>Start marker
                            <select value="@connector.StartMarker" @onchange="ChangeConnectorStartMarker">
                                <option value="None">None</option>
                                <option value="Arrow">Arrow</option>
                                <option value="Triangle">Triangle</option>
                                <option value="Diamond">Diamond</option>
                            </select>
                        </label>
                        <label>End marker
                            <select value="@connector.EndMarker" @onchange="ChangeConnectorEndMarker">
                                <option value="None">None</option>
                                <option value="Arrow">Arrow</option>
                                <option value="Triangle">Triangle</option>
                                <option value="Diamond">Diamond</option>
                            </select>
                        </label>
                    </div>
                    <div class="connector-endpoint-summary">
                        <span><b>From:</b> @EndpointName(connector.Source)</span>
                        <span><b>To:</b> @EndpointName(connector.Target)</span>
                    </div>
                    <label>Start inner selector
                        <input value="@connector.Source.TargetSelector" placeholder="Optional CSS selector, e.g. [data-cell='B4']" @onchange="ChangeSignalStartSelector" />
                    </label>
                    <label>End inner selector
                        <input value="@connector.Target.TargetSelector" placeholder="Optional CSS selector inside the endpoint object" @onchange="ChangeSignalEndSelector" />
                    </label>
                    @if (connector.Source.Kind == ConnectorEndpointKind.Canvas || connector.Target.Kind == ConnectorEndpointKind.Canvas)
                    {
                        <div class="property-grid two">
                            @if (connector.Source.Kind == ConnectorEndpointKind.Canvas)
                            {
                                <label>Start X (mm)<input type="number" step=".1" value="@Inv(connector.Source.X)" @onchange="ChangeSignalStartX" /></label>
                                <label>Start Y (mm)<input type="number" step=".1" value="@Inv(connector.Source.Y)" @onchange="ChangeSignalStartY" /></label>
                            }
                            @if (connector.Target.Kind == ConnectorEndpointKind.Canvas)
                            {
                                <label>End X (mm)<input type="number" step=".1" value="@Inv(connector.Target.X)" @onchange="ChangeSignalEndX" /></label>
                                <label>End Y (mm)<input type="number" step=".1" value="@Inv(connector.Target.Y)" @onchange="ChangeSignalEndY" /></label>
                            }
                        </div>
                    }
                </section>

                <section class="property-section signal-connector-properties">
                    <h3>Signal runtime</h3>
                    <label class="check-row"><input type="checkbox" checked="@connector.Signal.Enabled" @onchange="ToggleSignalEnabled" /> Enable dynamic signal</label>
                    <label class="check-row"><input type="checkbox" checked="@connector.Signal.LineVisible" @onchange="ToggleSignalLineVisible" /> Draw arrow / connector while it runs</label>
                    <div class="property-grid two">
                        <label>Trigger
                            <select value="@connector.Signal.Trigger" @onchange="ChangeSignalTrigger">
                                @foreach (var trigger in Enum.GetValues<SignalConnectorTrigger>())
                                {
                                    <option value="@trigger">@Friendly(trigger.ToString())</option>
                                }
                            </select>
                        </label>
                        <label>Visual
                            <select value="@connector.Signal.Visual" @onchange="ChangeSignalVisual">
                                @foreach (var visual in Enum.GetValues<SignalConnectorVisual>())
                                {
                                    <option value="@visual">@Friendly(visual.ToString())</option>
                                }
                            </select>
                        </label>
                        <label>Start gesture
                            <select value="@connector.Signal.StartGesture" @onchange="ChangeSignalStartGesture">
                                @foreach (var gesture in Enum.GetValues<SignalGesture>())
                                {
                                    <option value="@gesture">@gesture</option>
                                }
                            </select>
                        </label>
                        <label>End gesture
                            <select value="@connector.Signal.EndGesture" @onchange="ChangeSignalEndGesture">
                                @foreach (var gesture in Enum.GetValues<SignalGesture>())
                                {
                                    <option value="@gesture">@gesture</option>
                                }
                            </select>
                        </label>
                        <label>Delay (s)<input type="number" min="0" max="3600" step=".05" value="@Inv(connector.Signal.DelaySeconds)" @onchange="ChangeSignalDelay" /></label>
                        <label>Travel time (s)<input type="number" min=".05" max="3600" step=".05" value="@Inv(connector.Signal.DurationSeconds)" @onchange="ChangeSignalDuration" /></label>
                        <label>Repeats<input type="number" min="1" max="1000" step="1" value="@connector.Signal.RepeatCount" @onchange="ChangeSignalRepeat" /></label>
                        <label class="check-row"><input type="checkbox" checked="@connector.Signal.Loop" @onchange="ToggleSignalLoop" /> Loop</label>
                        <label class="check-row"><input type="checkbox" checked="@connector.Signal.AutoReverse" @onchange="ToggleSignalAutoReverse" /> Auto reverse</label>
                    </div>
                    <DxButton Text="Preview signal now" Click="PreviewSignal" RenderStyle="ButtonRenderStyle.Primary" CssClass="wide-button" />
                </section>

                <section class="property-section signal-motion-properties">
                    <h3>Travel morph / transform</h3>
                    <label>Target object
                        <select value="@GuidText(connector.Signal.MotionTargetElementId)" @onchange="ChangeSignalMotionTarget">
                            <option value="">No transform target</option>
                            @foreach (var target in SignalTargetElements(connector))
                            {
                                <option value="@target.Id">@target.Name</option>
                            }
                        </select>
                    </label>
                    <label>Inner selector
                        <input value="@connector.Signal.MotionTargetSelector" placeholder="Optional: img, [data-content-fit-source], .dx-chart" @onchange="ChangeSignalMotionSelector" />
                    </label>
                    <div class="property-grid two">
                        <label>Move X (%)<input type="number" step=".1" value="@Inv(connector.Signal.TranslateXPercent)" @onchange="ChangeSignalMoveX" /></label>
                        <label>Move Y (%)<input type="number" step=".1" value="@Inv(connector.Signal.TranslateYPercent)" @onchange="ChangeSignalMoveY" /></label>
                        <label>Scale<input type="number" min=".01" max="100" step=".01" value="@Inv(connector.Signal.Scale)" @onchange="ChangeSignalScale" /></label>
                        <label>Resize width (%)<input type="number" min=".01" max="10000" step=".1" value="@Inv(connector.Signal.ResizeWidthPercent)" @onchange="ChangeSignalResizeWidth" /></label>
                        <label>Resize height (%)<input type="number" min=".01" max="10000" step=".1" value="@Inv(connector.Signal.ResizeHeightPercent)" @onchange="ChangeSignalResizeHeight" /></label>
                        <label>Rotation (°)<input type="number" step=".1" value="@Inv(connector.Signal.RotationDegrees)" @onchange="ChangeSignalRotation" /></label>
                        <label>Opacity<input type="number" min="0" max="1" step=".01" value="@Inv(connector.Signal.Opacity)" @onchange="ChangeSignalOpacity" /></label>
                        <label class="check-row"><input type="checkbox" checked="@connector.Signal.RestoreMotionAfterRun" @onchange="ToggleSignalRestoreMotion" /> Restore afterwards</label>
                    </div>
                </section>

                <section class="property-section signal-completion-properties">
                    <h3>At destination</h3>
                    <label>Action target
                        <select value="@GuidText(connector.Signal.CompletionTargetElementId)" @onchange="ChangeSignalCompletionTarget">
                            <option value="">Endpoint / current object</option>
                            @foreach (var target in SignalTargetElements(connector))
                            {
                                <option value="@target.Id">@target.Name</option>
                            }
                        </select>
                    </label>
                    <label>Inner selector
                        <input value="@connector.Signal.CompletionTargetSelector" placeholder="Cell, chart point, button, or any exported HTML selector" @onchange="ChangeSignalCompletionSelector" />
                    </label>
                    <label>Action
                        <select value="@connector.Signal.CompletionAction" @onchange="ChangeSignalCompletionAction">
                            @foreach (var action in Enum.GetValues<SignalCompletionAction>())
                            {
                                <option value="@action">@Friendly(action.ToString())</option>
                            }
                        </select>
                    </label>
                    <label>Action value
                        <input value="@connector.Signal.CompletionValue" placeholder="Opacity, CSS class, or highlight color" @onchange="ChangeSignalCompletionValue" />
                    </label>
                    <label>Action duration (s)
                        <input type="number" min=".01" max="3600" step=".05" value="@Inv(connector.Signal.CompletionDurationSeconds)" @onchange="ChangeSignalCompletionDuration" />
                    </label>
                    <label>Continue with signal
                        <select value="@GuidText(connector.Signal.NextConnectorId)" @onchange="ChangeSignalNextConnector">
                            <option value="">Stop here</option>
                            @foreach (var next in State.CurrentPage.Elements.OfType<ConnectorElement>().Where(item => item.Id != connector.Id && item.Signal.Enabled))
                            {
                                <option value="@next.Id">@next.Name</option>
                            }
                        </select>
                    </label>
                    <p class="property-note">Selectors are evaluated locally inside the exported file. No server or network request is needed. Use one chained signal per cell/chart part when a sequence must highlight several targets in order.</p>
                </section>
            }
            else if (element is ShapeElement shape)
            {
                <section class="property-section">
                    <h3>Shape</h3>
                    @ColorField("Fill", shape.Fill, "shapeFill")
                    @ColorField("Outline", shape.Stroke, "shapeStroke")
                    @RangeField("Outline width", shape.StrokeWidth, 0, 8, .05, "shapeStrokeWidth")
                    @RangeField("Corner radius", shape.CornerRadiusMm, 0, 30, .1, "shapeCorner")
                </section>
            }
        </div>
    }
    else
    {
        <div class="empty-panel selection-help">
            <strong>No object selected</strong>
            <span>Select a text box, picture, WordArt, or shape. Page and ruler settings are available on the Page tab.</span>
        </div>
    }
    <DxContextMenu @ref="_layerContextMenu">
        <Items>
            <DxContextMenuItem Text="Select layer" Click="SelectContextLayer" />
            @if (ContextLayer is BarcodeElement)
            {
                <DxContextMenuItem Text="Edit barcode" BeginGroup="true" Click="EditContextBarcode" />
            }
            @if (ContextLayer is SpreadsheetElement)
            {
                <DxContextMenuItem Text="Edit spreadsheet" BeginGroup="true" Click="EditContextSpreadsheet" />
                <DxContextMenuItem Text="Download workbook" Click="DownloadContextSpreadsheet" />
            }
            @if (ContextLayer is PublicationMediaElement contextMedia)
            {
                <DxContextMenuItem Text="Edit in Media Studio" BeginGroup="true" Click="EditContextMedia" />
                <DxContextMenuItem Text="@(CheckedText(contextMedia.Muted, "Muted"))" Click="ToggleContextMediaMuted" />
                <DxContextMenuItem Text="@(CheckedText(contextMedia.Loop, "Loop clip"))" Click="ToggleContextMediaLoop" />
            }
            @if (State.CanGroupSelection)
            {
                <DxContextMenuItem Text="Group selected objects" BeginGroup="true" Click="State.GroupSelected" />
            }
            @if (State.CanUngroupSelection)
            {
                <DxContextMenuItem Text="Ungroup objects" BeginGroup="true" Click="State.UngroupSelected" />
            }
            <DxContextMenuItem Text="Duplicate" BeginGroup="true" Click="DuplicateContextLayer" />
            <DxContextMenuItem Text="Delete" Enabled="@(ContextLayer is { Locked: false })" Click="DeleteContextLayer" />
            <DxContextMenuItem Text="Bring to front" BeginGroup="true" Click="ContextBringToFront" />
            <DxContextMenuItem Text="Bring forward" Click="ContextBringForward" />
            <DxContextMenuItem Text="Send backward" Click="ContextSendBackward" />
            <DxContextMenuItem Text="Send to back" Click="ContextSendToBack" />
            <DxContextMenuItem Text="@(ContextLayer?.Visible == true ? "Hide" : "Show")" BeginGroup="true" Click="ToggleContextVisibility" />
            <DxContextMenuItem Text="@(ContextLayer?.Locked == true ? "Unlock" : "Lock")" Click="ToggleContextLock" />
        </Items>
    </DxContextMenu>
</aside>

@code {
    private static readonly string[] WordArtFonts =
    [
        "Segoe UI", "Arial", "Arial Black", "Calibri", "Cambria", "Georgia", "Impact",
        "Tahoma", "Times New Roman", "Trebuchet MS", "Verdana"
    ];
    [Parameter, EditorRequired] public EditorStateService State { get; set; } = default!;
    [Parameter] public EventCallback OnEditStory { get; set; }
    [Parameter] public EventCallback OnReplacePicture { get; set; }
    [Parameter] public EventCallback OnInsertPicture { get; set; }
    [Parameter] public EventCallback OnCreatePicture { get; set; }
    [Parameter] public EventCallback OnEditPicture { get; set; }
    [Parameter] public EventCallback OnInsertSpreadsheet { get; set; }
    [Parameter] public EventCallback OnCreateSpreadsheet { get; set; }
    [Parameter] public EventCallback OnEditSpreadsheet { get; set; }
    [Parameter] public EventCallback OnDownloadSpreadsheet { get; set; }
    [Parameter] public EventCallback OnApplyTransparentColor { get; set; }
    [Parameter] public EventCallback OnRestoreOriginalPicture { get; set; }
    [Parameter] public EventCallback<DataVisualKind> OnInsertDataVisual { get; set; }
    [Parameter] public EventCallback OnEditDataVisual { get; set; }
    [Parameter] public EventCallback OnManageData { get; set; }
    [Parameter] public EventCallback<PublicationComponentKind> OnInsertComponent { get; set; }
    [Parameter] public EventCallback OnEditComponent { get; set; }
    [Parameter] public EventCallback OnInsertVideo { get; set; }
    [Parameter] public EventCallback OnInsertAudio { get; set; }
    [Parameter] public EventCallback OnCreateVideo { get; set; }
    [Parameter] public EventCallback OnCreateAudio { get; set; }
    [Parameter] public EventCallback OnEditMedia { get; set; }
    [Parameter] public EventCallback OnInsertBarcode { get; set; }
    [Parameter] public EventCallback OnEditBarcode { get; set; }

    private List<StreamingDeviceProfile> _streamingDeviceProfiles = [];
    private bool _streamingProfilesLoaded;

    protected override async Task OnParametersSetAsync()
    {
        if (State.SelectedElement is LiveSourceElement && !_streamingProfilesLoaded)
            await RefreshStreamingDeviceProfiles();
    }

    private string _tab = "properties";
    private DxContextMenu _layerContextMenu = default!;
    private Guid? _contextLayerId;
    private PublicationElement? ContextLayer => _contextLayerId is Guid id ? State.CurrentPage.Elements.FirstOrDefault(item => item.Id == id) : null;
    private string PropertiesTabClass => _tab == "properties" ? "active" : string.Empty;
    private string PageTabClass => _tab == "page" ? "active" : string.Empty;
    private string LayersTabClass => _tab == "layers" ? "active" : string.Empty;
    private string AnimationsTabClass => _tab == "animations" ? "active" : string.Empty;
    private string CurrentPresetKey => PagePreset.All.FirstOrDefault(preset => Nearly(preset.WidthMm, State.CurrentPage.WidthMm) && Nearly(preset.HeightMm, State.CurrentPage.HeightMm))?.Key ?? "custom";
    private double PageTimelineContentEnd => Math.Max(
        State.CurrentPage.Elements.SelectMany(item => item.Animations)
            .Select(item => State.EffectiveAnimationStart(item) + Math.Max(.05, item.DurationSeconds) * Math.Max(1, item.RepeatCount) * (item.AutoReverse ? 2 : 1))
            .DefaultIfEmpty(0).Max(),
        State.CurrentPage.Elements.OfType<PublicationMediaElement>()
            .Select(item => item.TimelineStartSeconds + item.TimelineLengthSeconds)
            .DefaultIfEmpty(0).Max());

    private Task RequestEditStory() => OnEditStory.InvokeAsync();
    private Task RequestReplacePicture() => OnReplacePicture.InvokeAsync();
    private Task RequestInsertPicture() => OnInsertPicture.InvokeAsync();
    private Task RequestCreatePicture() => OnCreatePicture.InvokeAsync();
    private Task RequestEditPicture() => OnEditPicture.InvokeAsync();
    private Task RequestInsertSpreadsheet() => OnInsertSpreadsheet.InvokeAsync();
    private Task RequestCreateSpreadsheet() => OnCreateSpreadsheet.InvokeAsync();
    private Task RequestEditSpreadsheet() => OnEditSpreadsheet.InvokeAsync();
    private Task RequestDownloadSpreadsheet() => OnDownloadSpreadsheet.InvokeAsync();
    private Task RequestApplyTransparentColor() => OnApplyTransparentColor.InvokeAsync();
    private Task RequestRestoreOriginalPicture() => OnRestoreOriginalPicture.InvokeAsync();
    private Task RequestEditDataVisual() => OnEditDataVisual.InvokeAsync();
    private Task RequestManageData() => OnManageData.InvokeAsync();
    private Task RequestInsertVideo() => OnInsertVideo.InvokeAsync();
    private Task RequestInsertAudio() => OnInsertAudio.InvokeAsync();
    private Task RequestCreateVideo() => OnCreateVideo.InvokeAsync();
    private Task RequestCreateAudio() => OnCreateAudio.InvokeAsync();
    private Task RequestEditMedia() => OnEditMedia.InvokeAsync();
    private Task RequestInsertBarcode() => OnInsertBarcode.InvokeAsync();
    private Task RequestEditBarcode() => OnEditBarcode.InvokeAsync();
    private void ShowProperties() => _tab = "properties";
    private void ShowPage() => _tab = "page";
    private void ShowLayers() => _tab = "layers";
    private void ShowAnimations() => _tab = "animations";
    private void AddText() => State.AddText();
    private void AddWordArt() => State.AddWordArt();
    private void AddRectangle() => State.AddShape(PublicationShape.Rectangle);
    private Task AddChart() => OnInsertDataVisual.InvokeAsync(DataVisualKind.CartesianChart);
    private void StartConnector() => State.SetConnectorTool(ConnectorToolKind.Line);
    private void SelectLayer(PublicationElement item, MouseEventArgs args) =>
        State.SelectElement(item.Id, args.CtrlKey || args.MetaKey || args.ShiftKey);

    private void ToggleLayerVisibility(PublicationElement item)
    {
        State.SelectElement(item.Id);
        State.UpdateSelected(element => element.Visible = !element.Visible, allowLocked: true);
    }

    private void ToggleLayerLock(PublicationElement item)
    {
        State.SelectElement(item.Id);
        State.UpdateSelected(element => element.Locked = !element.Locked, allowLocked: true);
    }

    private async Task ShowLayerContextMenu(PublicationElement item, MouseEventArgs args)
    {
        _contextLayerId = item.Id;
        State.SetPrimarySelection(item.Id);
        await InvokeAsync(StateHasChanged);
        await _layerContextMenu.ShowAsync(args);
    }
    private void SelectContextLayer() { if (_contextLayerId is Guid id) State.SetPrimarySelection(id); }
    private Task EditContextMedia() { SelectContextLayer(); return OnEditMedia.InvokeAsync(); }
    private Task EditContextSpreadsheet() { SelectContextLayer(); return OnEditSpreadsheet.InvokeAsync(); }
    private Task DownloadContextSpreadsheet() { SelectContextLayer(); return OnDownloadSpreadsheet.InvokeAsync(); }
    private Task EditContextBarcode() { SelectContextLayer(); return OnEditBarcode.InvokeAsync(); }
    private void DuplicateContextLayer() { SelectContextLayer(); State.DuplicateSelected(); }
    private void DeleteContextLayer() { SelectContextLayer(); State.DeleteSelected(); }
    private void ContextBringToFront() { SelectContextLayer(); State.BringToFront(); }
    private void ContextBringForward() { SelectContextLayer(); State.BringForward(); }
    private void ContextSendBackward() { SelectContextLayer(); State.SendBackward(); }
    private void ContextSendToBack() { SelectContextLayer(); State.SendToBack(); }
    private void ToggleContextVisibility() { if (ContextLayer is { } item) ToggleLayerVisibility(item); }
    private void ToggleContextLock() { if (ContextLayer is { } item) ToggleLayerLock(item); }
    private void ToggleContextMediaMuted() { if (ContextLayer is PublicationMediaElement media) State.UpdateMedia(media.Id, item => item.Muted = !item.Muted); }
    private void ToggleContextMediaLoop() { if (ContextLayer is PublicationMediaElement media) State.UpdateMedia(media.Id, item => item.Loop = !item.Loop); }
    private static string CheckedText(bool checkedValue, string text) => checkedValue ? $"✓ {text}" : text;

    private static string KindGlyph(PublicationElement item) => item.Kind switch
    {
        PublicationElementKind.Text => "T",
        PublicationElementKind.Image => "▧",
        PublicationElementKind.Video => "▶",
