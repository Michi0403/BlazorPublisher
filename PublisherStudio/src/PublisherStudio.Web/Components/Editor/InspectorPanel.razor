    private void ChangeLiveDeviceProfile(ChangeEventArgs args)
    {
        var id = ParseGuid(args);
        if (id is null)
        {
            UpdateLiveSource(source => source.DeviceProfileId = null);
            return;
        }

        var profile = _streamingDeviceProfiles.FirstOrDefault(item => item.Id == id.Value);
        if (profile is null) return;
        UpdateLiveSource(source =>
        {
            source.DeviceProfileId = profile.Id;
            source.SourceKind = profile.Kind;
            source.DeviceId = profile.DeviceId;
            source.AudioDeviceId = profile.AudioDeviceId;
            source.ApplicationId = profile.ApplicationId;
            source.WindowTitle = profile.WindowTitle;
            source.CaptureBackend = profile.CaptureBackend;
            source.NativeBackend = profile.NativeBackend;
            source.UseDeviceTimestamp = profile.UseDeviceTimestamps;
        });
    }

