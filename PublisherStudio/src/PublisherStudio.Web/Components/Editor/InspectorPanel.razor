    private void ChangeColor(string field, ChangeEventArgs args)
    {
        var value = args.Value?.ToString() ?? "#ffffff";
        State.UpdateSelected(element =>
        {
            if (element is ImageFrameElement image && field == "imageBorder") image.BorderColor = value;
            if (element is ImageFrameElement tint && field == "tintColor") tint.TintColor = value;
            if (element is ImageFrameElement transparent && field == "transparentColor") transparent.TransparentColor = value;
            if (element is TextFrameElement text && field == "textBackground") text.Background = value;
            if (element is TextFrameElement textBorder && field == "textBorder") textBorder.BorderColor = value;
            if (element is ShapeElement shape && field == "shapeFill") shape.Fill = value;
            if (element is ShapeElement shapeStroke && field == "shapeStroke") shapeStroke.Stroke = value;
            if (element is WordArtElement word && field == "wordFill") word.FillColor = value;
            if (element is WordArtElement wordSecondary && field == "wordSecondary") wordSecondary.SecondaryColor = value;
            if (element is WordArtElement wordOutline && field == "wordOutline") wordOutline.OutlineColor = value;
            if (element is WordArtElement wordExtrude && field == "wordExtrude") wordExtrude.ExtrudeColor = value;
            if (element is ConnectorElement connector && field == "connectorStroke") connector.Stroke = value;
            if (element is DataVisualElement dataVisual && field == "dataBackground") dataVisual.Background = value;
            if (element is DataVisualElement dataBorder && field == "dataBorder") dataBorder.BorderColor = value;
            if (element is SpreadsheetElement spreadsheet && field == "spreadsheetBackground") spreadsheet.Background = value;
            if (element is SpreadsheetElement spreadsheetBorder && field == "spreadsheetBorder") spreadsheetBorder.BorderColor = value;
            if (element is DevExtremeComponentElement component && field == "componentBackground") component.Background = value;
            if (element is DevExtremeComponentElement componentBorder && field == "componentBorder") componentBorder.BorderColor = value;
            if (element is AudioElement audio && field == "audioAccent") audio.AccentColor = value;
            if (element is LiveSourceElement live && field == "liveChromaColor") live.ChromaKeyColor = value;
        });
    }

    private void ChangeNumber(string field, ChangeEventArgs args)
    {
        if (!TryDouble(args, out var value)) return;
        if (field == "z")
        {
            State.SetSelectedLayerPosition((int)Math.Round(value));
            return;
        }
        if (State.SelectedElement is PublicationMediaElement media && IsMediaNumberField(field))
        {
            State.UpdateMedia(media.Id, item => ApplyNumber(item, field, value));
            return;
        }
        State.UpdateSelected(element => ApplyNumber(element, field, value));
    }

    private void ChangeNumberLive(string field, ChangeEventArgs args)
    {
        if (!TryDouble(args, out var value)) return;
        if (field == "z")
        {
            State.SetSelectedLayerPosition((int)Math.Round(value));
            return;
        }
        if (State.SelectedElement is PublicationMediaElement media && IsMediaNumberField(field))
        {
            State.UpdateMediaLive(media.Id, field, item => ApplyNumber(item, field, value));
            return;
        }
        State.UpdateSelectedLive(field, element => ApplyNumber(element, field, value));
    }

    private static bool IsMediaNumberField(string field) => field is "mediaVolume" or "mediaFadeIn" or "mediaFadeOut";
    private void EndLiveEdit(ChangeEventArgs _) => State.EndLiveEdit();

    private static void ApplyNumber(PublicationElement element, string field, double value)
    {
        switch (field)
        {
            case "x": element.X = value; return;
            case "y": element.Y = value; return;
            case "width": element.Width = Math.Max(2, value); return;
            case "height": element.Height = Math.Max(2, value); return;
            case "rotation": element.Rotation = value; return;
            case "z": element.ZIndex = (int)Math.Round(value); return;
        }
        if (element is ImageFrameElement image)
        {
            switch (field)
            {
                case "cropScale": image.CropScale = value; break;
                case "imageRotation": image.ImageRotation = value; break;
                case "opacity": image.Opacity = value; break;
                case "brightness": image.Brightness = value; break;
                case "contrast": image.Contrast = value; break;
                case "saturation": image.Saturation = value; break;
                case "hue": image.HueRotation = value; break;
                case "invert": image.Invert = value; break;
                case "grayscale": image.Grayscale = value; break;
                case "sepia": image.Sepia = value; break;
                case "blur": image.Blur = value; break;
                case "corner": image.CornerRadiusMm = value; break;
                case "imageBorderWidth": image.BorderWidthMm = value; break;
                case "tintOpacity": image.TintOpacity = value; break;
                case "transparentTolerance": image.TransparentColorTolerance = (int)Math.Round(value); break;
            }
        }
        if (element is PublicationMediaElement media)
        {
            if (field == "mediaVolume") media.Volume = Math.Clamp(value, 0, 1);
            if (field == "mediaFadeIn") media.FadeInSeconds = Math.Clamp(value, 0, media.TimelineLengthSeconds / 2);
            if (field == "mediaFadeOut") media.FadeOutSeconds = Math.Clamp(value, 0, media.TimelineLengthSeconds / 2);
        }
        if (element is LiveSourceElement live)
        {
            if (field == "liveBrightness") live.Brightness = value;
            if (field == "liveContrast") live.Contrast = value;
            if (field == "liveSaturation") live.Saturation = value;
            if (field == "liveHue") live.HueRotation = value;
            if (field == "liveBlur") live.Blur = value;
            if (field == "liveChromaSimilarity") live.ChromaSimilarity = value;
            if (field == "liveChromaSmoothness") live.ChromaSmoothness = value;
            if (field == "liveChromaSpill") live.ChromaSpill = value;
            if (field == "liveChromaResidual") live.ChromaResidualOpacity = value;
            if (field == "liveVolume") live.Volume = value;
        }
        if (element is TextFrameElement text)
        {
            if (field == "padding") text.PaddingMm = value;
            if (field == "textBorderWidth") text.BorderWidth = Math.Clamp(value, 0, 5);
        }
        if (element is ShapeElement shape)
        {
            if (field == "shapeStrokeWidth") shape.StrokeWidth = value;
            if (field == "shapeCorner") shape.CornerRadiusMm = value;
        }
        if (element is ConnectorElement connector)
        {
            if (field == "connectorWidth") connector.StrokeWidthMm = value;
        }
        if (element is DataVisualElement dataVisual)
        {
            if (field == "dataBorderWidth") dataVisual.BorderWidthMm = value;
        }
        if (element is SpreadsheetElement spreadsheet)
        {
            if (field == "spreadsheetBorderWidth") spreadsheet.BorderWidthMm = Math.Clamp(value, 0, 5);
        }
        if (element is DevExtremeComponentElement component)
        {
            if (field == "componentBorderWidth") component.BorderWidthMm = Math.Clamp(value, 0, 8);
        }
        if (element is WordArtElement word)
        {
            if (field == "wordFontSize") word.FontSizePt = value;
            if (field == "wordLetterSpacing") word.LetterSpacing = value;
            if (field == "wordOutlineWidth") word.OutlineWidth = value;
            if (field == "wordExtrudeDepth") word.ExtrudeDepth = value;
            if (field == "wordPathStart") word.PathStartOffsetPercent = Math.Clamp(value, 0, 100);
            if (field == "wordPathOffset") word.PathBaselineOffset = Math.Clamp(value, -80, 80);
        }
    }

    private void SetImage(Action<ImageFrameElement> update) { if (State.SelectedElement is ImageFrameElement image) State.UpdateSelected(_ => update(image)); }
    private void SetWordArt(Action<WordArtElement> update) { if (State.SelectedElement is WordArtElement item) State.UpdateSelected(_ => update(item)); }
    private void SetDataVisual(Action<DataVisualElement> update) { if (State.SelectedElement is DataVisualElement item) State.UpdateSelected(_ => update(item)); }

    private void ResetPicture()
    {
        SetImage(image =>
        {
            image.CropX = 0; image.CropY = 0; image.CropScale = 1; image.ImageRotation = 0;
            image.Opacity = 1; image.Brightness = 1; image.Contrast = 1; image.Saturation = 1;
            image.HueRotation = 0; image.Invert = 0; image.Grayscale = 0; image.Sepia = 0; image.Blur = 0;
            image.FlipHorizontal = false; image.FlipVertical = false; image.FitInsideFrame = false; image.TintOpacity = 0;
        });
    }

    private static bool TryDouble(ChangeEventArgs args, out double value) => double.TryParse(args.Value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out value);
    private static bool ReadBool(ChangeEventArgs args) => args.Value is bool value ? value : bool.TryParse(args.Value?.ToString(), out var parsed) && parsed;
    private static bool Nearly(double left, double right) => Math.Abs(left - right) < .05;
    private static string Time(double value) => TimeSpan.FromSeconds(Math.Max(0, value)).ToString(value >= 3600 ? @"h\:mm\:ss\.f" : @"m\:ss\.f", CultureInfo.InvariantCulture);
    private static string Inv(double value) => value.ToString("0.##", CultureInfo.InvariantCulture);
    private static string UsableColor(string value) => value.StartsWith('#') && value.Length >= 7 ? value[..7] : "#ffffff";
}
