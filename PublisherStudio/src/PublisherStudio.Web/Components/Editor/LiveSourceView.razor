@namespace PublisherStudio.Components.Editor
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject StreamingProfileStore ProfileStore

<div class="live-source-frame source-@Item.SourceKind.ToString().ToLowerInvariant() @(Item.IsVisual ? "visual" : "audio-only")"
     style="@FrameStyle" data-live-source-id="@Item.Id">
    @if (Item.SourceKind == PublicationLiveSourceKind.NowPlaying)
    {
        <div id="@MetadataId" class="live-source-now-playing">
            <img data-now-playing-cover alt="" hidden />
            <div><b data-now-playing-title>Waiting for music…</b><span data-now-playing-artist></span><small data-now-playing-album>@SourceDescription</small></div>
        </div>
    }
    else if (Item.IsVisual)
    {
        <video id="@VideoId" class="live-source-video" autoplay playsinline muted="@Item.Muted"></video>
        <canvas id="@CanvasId" class="live-source-filter-canvas"></canvas>
    }
    else
    {
        <div class="live-source-audio-visual">
            <span class="live-source-kind-icon">@SourceIcon</span>
            <div><b>@Item.Name</b><small>@SourceDescription</small></div>
            <meter id="@MeterId" min="0" max="1" value="0"></meter>
        </div>
    }
    @if (!_active)
    {
        <button id="@ActivateButtonId" type="button" class="live-source-activate" @onclick="Activate" @onclick:stopPropagation title="Activate live source">
            <span>@SourceIcon</span><b>Activate @SourceLabel</b><small>@ActivationHint</small>
        </button>
    }
    else
    {
        <span class="live-source-active-badge">● LIVE SOURCE</span>
    }
</div>

@code {
    [Parameter, EditorRequired] public LiveSourceElement Item { get; set; } = default!;
    [Parameter] public bool DesignerMode { get; set; }

    private bool _active;
    private string ActivateButtonId => $"live-source-activate-{Item.Id:N}";
    private string VideoId => $"live-source-video-{Item.Id:N}";
    private string CanvasId => $"live-source-canvas-{Item.Id:N}";
    private string MeterId => $"live-source-meter-{Item.Id:N}";
    private string MetadataId => $"live-source-metadata-{Item.Id:N}";
    private string SourceLabel => Item.SourceKind switch
    {
        PublicationLiveSourceKind.BrowserTab => "browser tab",
        PublicationLiveSourceKind.CaptureDevice => "capture device",
        PublicationLiveSourceKind.ApplicationAudio => "application audio",
        PublicationLiveSourceKind.SystemAudio => "system audio",
        PublicationLiveSourceKind.NetworkMedia => "network media",
        PublicationLiveSourceKind.NowPlaying => "Now Playing",
        _ => Item.SourceKind.ToString().ToLowerInvariant()
    };
    private string SourceIcon => Item.SourceKind switch
    {
        PublicationLiveSourceKind.Camera => "📷",
        PublicationLiveSourceKind.Screen => "▣",
        PublicationLiveSourceKind.Window => "▤",
        PublicationLiveSourceKind.BrowserTab => "▱",
        PublicationLiveSourceKind.CaptureDevice => "◉",
        PublicationLiveSourceKind.Microphone => "🎙",
        PublicationLiveSourceKind.SystemAudio => "🔊",
        PublicationLiveSourceKind.ApplicationAudio => "♫",
        PublicationLiveSourceKind.NetworkMedia => "⌁",
        PublicationLiveSourceKind.NowPlaying => "♪",
        _ => "●"
    };
    private string SourceDescription => Item.SourceKind switch
    {
        PublicationLiveSourceKind.ApplicationAudio when !string.IsNullOrWhiteSpace(Item.ApplicationId) => Item.ApplicationId,
        PublicationLiveSourceKind.NetworkMedia when !string.IsNullOrWhiteSpace(Item.NetworkUrl) => Item.NetworkUrl,
        PublicationLiveSourceKind.NowPlaying when !string.IsNullOrWhiteSpace(Item.NowPlayingDirectory) => Item.NowPlayingDirectory,
        _ => Item.UseDeviceTimestamp ? "Device timestamps enabled" : "Session timestamps"
    };
    private string ActivationHint => Item.SourceKind switch
    {
        PublicationLiveSourceKind.ApplicationAudio or PublicationLiveSourceKind.SystemAudio => "Uses the browser audio picker when available; native isolated capture remains the fallback",
        PublicationLiveSourceKind.NowPlaying => "Reads current MP3 tags through PublisherStudio's integrated streaming runtime",
        _ => "Browser permission may be requested"
    };
    private string FrameStyle => $"background:{Item.Background};--live-brightness:{Inv(Item.Brightness)};--live-contrast:{Inv(Item.Contrast)};--live-saturation:{Inv(Item.Saturation)};--live-hue:{Inv(Item.HueRotation)}deg;--live-blur:{Inv(Item.Blur)}px";

    private async Task Activate()
    {
        try
        {
            var machine = await ProfileStore.LoadAsync();
            var profile = Item.DeviceProfileId is Guid profileId
                ? machine.Devices.FirstOrDefault(candidate => candidate.Id == profileId)
                : null;
            var sourceKind = Item.SourceKind;
            var deviceId = string.IsNullOrWhiteSpace(Item.DeviceId) ? profile?.DeviceId ?? string.Empty : Item.DeviceId;
            var audioDeviceId = string.IsNullOrWhiteSpace(Item.AudioDeviceId) ? profile?.AudioDeviceId ?? string.Empty : Item.AudioDeviceId;
            var applicationId = string.IsNullOrWhiteSpace(Item.ApplicationId) ? profile?.ApplicationId ?? string.Empty : Item.ApplicationId;
            var windowTitle = string.IsNullOrWhiteSpace(Item.WindowTitle) ? profile?.WindowTitle ?? string.Empty : Item.WindowTitle;
            var useDeviceTimestamp = Item.UseDeviceTimestamp;
            var captureBackend = Item.CaptureBackend == PublicationCaptureBackend.Auto ? profile?.CaptureBackend ?? PublicationCaptureBackend.Auto : Item.CaptureBackend;
            var nativeBackend = string.IsNullOrWhiteSpace(Item.NativeBackend) ? profile?.NativeBackend ?? string.Empty : Item.NativeBackend;

            _active = await JS.InvokeAsync<bool>("publisherStreaming.attachSource", new
            {
                id = Item.Id.ToString("D"),
                videoId = VideoId,
                canvasId = CanvasId,
                meterId = MeterId,
                metadataId = MetadataId,
                kind = sourceKind.ToString(),
                deviceId,
                audioDeviceId,
                applicationId,
                windowTitle,
                captureBackend = captureBackend.ToString(),
                nativeBackend,
                networkUrl = Item.NetworkUrl,
                nowPlayingDirectory = Item.NowPlayingDirectory,
                mediaHostUrl = string.Empty,
                ffmpegPath = machine.FfmpegPath,
                includeAudio = Item.IncludeAudio,
                muted = Item.Muted,
                volume = Item.Volume,
                audioDelayMilliseconds = Item.AudioDelayMilliseconds,
                fitMode = Item.FitMode.ToString().ToLowerInvariant(),
                captureWidth = Item.CaptureWidth,
                captureHeight = Item.CaptureHeight,
                captureFrameRate = Item.CaptureFrameRate,
                useDeviceTimestamp,
                chromaKeyEnabled = Item.ChromaKeyEnabled,
                chromaKeyColor = Item.ChromaKeyColor,
                chromaSimilarity = Item.ChromaSimilarity,
                chromaSmoothness = Item.ChromaSmoothness,
                chromaSpill = Item.ChromaSpill,
                chromaResidualOpacity = Item.ChromaResidualOpacity
            });
        }
        catch { _active = false; }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("publisherStreaming.detachSource", Item.Id.ToString("D")); }
        catch { }
    }

    private static string Inv(double value) => value.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
}
