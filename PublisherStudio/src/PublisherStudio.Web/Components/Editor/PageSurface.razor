    public Task CompleteExternalFileDrop(string assetId, string kind, string name, string mimeType, long size,
        double durationSeconds, int pixelWidth, int pixelHeight, double x, double y)
    {
        if (!Guid.TryParse(assetId, out var parsed))
            return RequestExternalDropError.InvokeAsync("The dropped file could not be registered.");
        return RequestExternalFileDrop.InvokeAsync(new ExternalFileDropRequest(
            parsed, kind, name, mimeType, size, durationSeconds, pixelWidth, pixelHeight, x, y));
