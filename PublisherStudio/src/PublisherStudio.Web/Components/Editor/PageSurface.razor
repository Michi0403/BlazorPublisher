    private async Task RefreshData()
    {
        Guid? dataObjectId = State.SelectedElement switch
        {
            DataVisualElement visual => visual.DataObjectId,
            DevExtremeComponentElement component
                when component.Connection.Mode ==
                     PublicationComponentDataMode.PublicationDataObject
                => component.Connection.DataObjectId,
            _ => null
        };

        await State.RefreshWebDataAsync(dataObjectId, true);
        State.RefreshDataVisuals();

        await JS.InvokeVoidAsync(
            "PublisherStudioComponentRuntime.refreshAll",
            "publisher-page",
            new
            {
                polling = false,
                fetchNow = true
            });
    }
