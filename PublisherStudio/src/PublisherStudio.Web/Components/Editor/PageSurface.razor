    [JSInvokable] public void CommitConnector(string sourceId, string sourceAnchor, string targetId, string targetAnchor, string tool)
    {
        if (!Guid.TryParse(sourceId, out var sourceGuid) || !Guid.TryParse(targetId, out var targetGuid)) return;
        if (!Enum.TryParse<ConnectorAnchor>(sourceAnchor, true, out var parsedSource) || !Enum.TryParse<ConnectorAnchor>(targetAnchor, true, out var parsedTarget)) return;
        var marker = string.Equals(tool, nameof(ConnectorToolKind.Arrow), StringComparison.OrdinalIgnoreCase) ? ConnectorMarker.Arrow : ConnectorMarker.None;
        State.AddConnector(sourceGuid, parsedSource, targetGuid, parsedTarget, marker);
    }
    [JSInvokable] public void ReconnectConnector(string connectorId, string endpoint, string elementId, string anchor)
    {
        if (!Guid.TryParse(connectorId, out var connectorGuid) || !Guid.TryParse(elementId, out var elementGuid)) return;
        if (!Enum.TryParse<ConnectorAnchor>(anchor, true, out var parsedAnchor)) return;
        State.ReconnectConnector(connectorGuid, string.Equals(endpoint, "source", StringComparison.OrdinalIgnoreCase), elementGuid, parsedAnchor);
    }
    [JSInvokable]
    public void CommitSignalConnector(string sourceKind, string sourceId, string sourceAnchor, double sourceX, double sourceY,
        string targetKind, string targetId, string targetAnchor, double targetX, double targetY, string tool)
    {
        if (!TryConnectorEndpoint(sourceKind, sourceId, sourceAnchor, sourceX, sourceY, out var source) ||
            !TryConnectorEndpoint(targetKind, targetId, targetAnchor, targetX, targetY, out var target)) return;
        var marker = string.Equals(tool, nameof(ConnectorToolKind.SignalArrow), StringComparison.OrdinalIgnoreCase)
            ? ConnectorMarker.Arrow : ConnectorMarker.None;
        State.AddSignalConnector(source, target, marker);
    }
    [JSInvokable]
    public void ReconnectSignalConnector(string connectorId, string endpoint, string kind, string elementId, string anchor, double x, double y)
    {
        if (!Guid.TryParse(connectorId, out var connectorGuid) ||
            !TryConnectorEndpoint(kind, elementId, anchor, x, y, out var replacement)) return;
        State.ReconnectConnectorEndpoint(connectorGuid, string.Equals(endpoint, "source", StringComparison.OrdinalIgnoreCase), replacement);
    }
    private bool TryConnectorEndpoint(string kind, string elementId, string anchor, double x, double y, out ConnectorEndpoint endpoint)
    {
        endpoint = new ConnectorEndpoint();
        if (!Enum.TryParse<ConnectorEndpointKind>(kind, true, out var parsedKind)) return false;
        endpoint.Kind = parsedKind;
        endpoint.X = Math.Clamp(x, 0, State.CurrentPage.WidthMm);
        endpoint.Y = Math.Clamp(y, 0, State.CurrentPage.HeightMm);
        if (parsedKind == ConnectorEndpointKind.Canvas) return true;
        if (!Guid.TryParse(elementId, out var elementGuid) || !Enum.TryParse<ConnectorAnchor>(anchor, true, out var parsedAnchor)) return false;
        endpoint.ElementId = elementGuid;
        endpoint.Anchor = parsedAnchor;
        return true;
    }
    [JSInvokable]
    public void CommitConnectorAdvanced(
        string sourceKind, string sourceId, string sourceAnchor, string sourcePortId, bool sourceCreatePort, double sourceRelativeX, double sourceRelativeY, double sourceX, double sourceY,
        string targetKind, string targetId, string targetAnchor, string targetPortId, bool targetCreatePort, double targetRelativeX, double targetRelativeY, double targetX, double targetY,
        string tool)
    {
        if (!TryConnectorEndpointAdvanced(sourceKind, sourceId, sourceAnchor, sourcePortId, sourceCreatePort, sourceRelativeX, sourceRelativeY, sourceX, sourceY, out var source, out var pendingSource) ||
            !TryConnectorEndpointAdvanced(targetKind, targetId, targetAnchor, targetPortId, targetCreatePort, targetRelativeX, targetRelativeY, targetX, targetY, out var target, out var pendingTarget)) return;
        var marker = tool is nameof(ConnectorToolKind.Arrow) or nameof(ConnectorToolKind.SignalArrow) ? ConnectorMarker.Arrow : ConnectorMarker.None;
        var signal = tool is nameof(ConnectorToolKind.SignalConnector) or nameof(ConnectorToolKind.SignalArrow);
        State.AddConnectorAdvanced(source, target, marker, signal, pendingSource, pendingTarget);
    }

