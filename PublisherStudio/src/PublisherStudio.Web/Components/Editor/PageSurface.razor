@namespace PublisherStudio.Components.Editor
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject PublicationMediaAssetStore MediaAssets

<div id="publisher-stage" class="publication-stage @(State.Document.View.RulersVisible ? null : "rulers-hidden") @(State.ConnectorTool != ConnectorToolKind.None ? "connector-tool-active" : null)"
     tabindex="0" @oncontextmenu="ShowPageContextMenu" @oncontextmenu:preventDefault>
    @if (State.Document.View.RulersVisible)
    {
        <button class="corner-ruler" title="Change ruler unit" @onclick:stopPropagation="true" @onclick="CycleRulerUnit">@UnitLabel</button>
        <canvas id="publisher-horizontal-ruler" class="ruler-canvas horizontal-ruler" aria-label="Horizontal ruler"></canvas>
        <canvas id="publisher-vertical-ruler" class="ruler-canvas vertical-ruler" aria-label="Vertical ruler"></canvas>
    }

    @if (State.ConnectorTool != ConnectorToolKind.None)
    {
        <div class="connector-tool-hint" @onclick:stopPropagation="true">
            <strong>@(State.ConnectorTool == ConnectorToolKind.Arrow ? "Arrow connector" : "Connector")</strong>
            <span>Drag from a round object port to another port. Press Esc to stop.</span>
            <button type="button" @onclick="State.CancelActiveTool">Done</button>
        </div>
    }

    <div class="pointer-state-indicator" @onclick:stopPropagation="true" title="Current mouse mode">
        <strong>Mouse</strong>
        <span>@PointerStateText</span>
        @if (CanResetPointerState)
        {
            <button type="button" @onclick="ResetPointerState">Reset</button>
        }
    </div>

    <div id="publisher-scroll-area" class="page-scroll-area">
        <div id="publisher-page" class="publication-page @(State.CropMode ? "crop-mode" : null)"
             style="@PageStyle"
             data-px-per-mm="@Inv(PixelsPerMm)"
             data-zoom="@Inv(State.Document.Zoom)"
             data-page-width-mm="@Inv(State.CurrentPage.WidthMm)"
             data-page-height-mm="@Inv(State.CurrentPage.HeightMm)"
             data-page-id="@State.CurrentPage.Id"
             data-transition-kind="@State.CurrentPage.Transition.Kind"
             data-transition-direction="@State.CurrentPage.Transition.Direction"
             data-transition-easing="@State.CurrentPage.Transition.Easing"
             data-transition-duration="@Inv(State.CurrentPage.Transition.DurationSeconds)"
             data-advance-on-click="@State.CurrentPage.Transition.AdvanceOnClick.ToString().ToLowerInvariant()"
             data-auto-advance="@State.CurrentPage.Transition.AutoAdvance.ToString().ToLowerInvariant()"
             data-auto-advance-seconds="@Inv(State.CurrentPage.Transition.AutoAdvanceSeconds)"
             data-timeline-duration="@Inv(State.CurrentPage.TimelineDurationSeconds)">
            @if (State.Document.View.GuidesVisible)
            {
                @foreach (var guide in State.CurrentPage.Guides)
                {
                    <div class="guide-line @guide.Orientation.ToString().ToLowerInvariant()"
                         data-guide-id="@guide.Id"
                         data-guide-orientation="@guide.Orientation"
                         style="@GuideStyle(guide)"></div>
                }
            }

            @foreach (var connector in State.CurrentPage.Elements.OfType<ConnectorElement>().Where(e => e.Visible))
            {
                if (ConnectorGeometry.TryResolve(State.CurrentPage, connector, out var sourcePoint, out var targetPoint))
                {
                    var connectorPath = ConnectorGeometry.Path(connector, sourcePoint, targetPoint);
                    <svg @key="connector.Id" id="element-@connector.Id" class="pub-connector @(State.IsSelected(connector.Id) ? "selected" : null) @(connector.Id == State.SelectedElementId ? "selection-primary" : null) @(connector.Locked ? "locked" : null)"
                         style="z-index:@connector.ZIndex"
                         viewBox="0 0 @Inv(State.CurrentPage.WidthMm) @Inv(State.CurrentPage.HeightMm)"
                         preserveAspectRatio="none"
                         data-publication-element
                         data-element-id="@connector.Id"
                         data-selected="@State.IsSelected(connector.Id).ToString().ToLowerInvariant()"
                         data-group-id="@connector.GroupId"
                         data-animations="@PublicationAnimationData.Animations(connector)"
                         data-interaction="@PublicationAnimationData.Interaction(connector)"
                         data-interaction-action="@connector.Interaction.Action"
                         data-playback-hidden="@connector.HiddenAtPresentationStart.ToString().ToLowerInvariant()"
                         data-connector-id="@connector.Id"
                         data-source-element-id="@connector.Source.ElementId" data-source-anchor="@connector.Source.Anchor"
                         data-target-element-id="@connector.Target.ElementId" data-target-anchor="@connector.Target.Anchor"
                         data-path-kind="@connector.PathKind" data-start-marker="@connector.StartMarker" data-end-marker="@connector.EndMarker"
                         data-stroke="@connector.Stroke" data-stroke-width="@Inv(connector.StrokeWidthMm)" data-dash-style="@connector.DashStyle"
                         @oncontextmenu="args => ShowElementContextMenu(connector, args)" @oncontextmenu:preventDefault @oncontextmenu:stopPropagation>
                        <defs>
                            @ConnectorMarkerDefinition(connector, true)
                            @ConnectorMarkerDefinition(connector, false)
                        </defs>
                        <path class="connector-hit" d="@connectorPath"></path>
                        <path class="connector-line" d="@connectorPath" stroke="@connector.Stroke" stroke-width="@Inv(connector.StrokeWidthMm)"
                              stroke-dasharray="@ConnectorGeometry.DashArray(connector)"
                              marker-start="@MarkerUrl(connector, true)" marker-end="@MarkerUrl(connector, false)"></path>
                        @if (connector.Id == State.SelectedElementId && !connector.Locked)
                        {
                            <circle class="connector-endpoint" cx="@Inv(sourcePoint.X)" cy="@Inv(sourcePoint.Y)" r="@Inv(5 / PixelsPerMm)" data-connector-end="source"></circle>
                            <circle class="connector-endpoint" cx="@Inv(targetPoint.X)" cy="@Inv(targetPoint.Y)" r="@Inv(5 / PixelsPerMm)" data-connector-end="target"></circle>
                        }
                    </svg>
                }
            }

            @foreach (var element in State.CurrentPage.Elements.Where(e => e.Visible && e is not ConnectorElement))
            {
                <div @key="element.Id" id="element-@element.Id" data-publication-element data-element-id="@element.Id"
                     data-animations="@PublicationAnimationData.Animations(element)"
                     data-interaction="@PublicationAnimationData.Interaction(element)"
                     data-interaction-action="@element.Interaction.Action"
                     data-selected="@State.IsSelected(element.Id).ToString().ToLowerInvariant()"
                     data-group-id="@element.GroupId"
                     data-playback-hidden="@element.HiddenAtPresentationStart.ToString().ToLowerInvariant()"
                     data-media-kind="@(element is PublicationMediaElement ? element.Kind.ToString().ToLowerInvariant() : null)"
                     data-media-start="@(element is PublicationMediaElement mediaData ? Inv(mediaData.TimelineStartSeconds) : null)"
                     data-media-trim-start="@(element is PublicationMediaElement mediaTrimStart ? Inv(mediaTrimStart.TrimStartSeconds) : null)"
                     data-media-trim-end="@(element is PublicationMediaElement mediaTrimEnd ? Inv(mediaTrimEnd.EffectiveTrimEndSeconds) : null)"
                     data-media-volume="@(element is PublicationMediaElement mediaVolume ? Inv(mediaVolume.Volume) : null)"
                     data-media-rate="@(element is PublicationMediaElement mediaRate ? Inv(mediaRate.PlaybackRate) : null)"
                     data-media-muted="@(element is PublicationMediaElement mediaMuted ? mediaMuted.Muted.ToString().ToLowerInvariant() : null)"
                     data-media-loop="@(element is PublicationMediaElement mediaLoop ? mediaLoop.Loop.ToString().ToLowerInvariant() : null)"
                     data-media-autoplay="@(element is PublicationMediaElement mediaAuto ? mediaAuto.AutoPlay.ToString().ToLowerInvariant() : null)"
                     data-media-trigger="@(element is PublicationMediaElement mediaTrigger ? mediaTrigger.PlaybackTrigger.ToString() : null)"
                     data-media-fade-in="@(element is PublicationMediaElement mediaFadeIn ? Inv(mediaFadeIn.FadeInSeconds) : null)"
                     data-media-fade-out="@(element is PublicationMediaElement mediaFadeOut ? Inv(mediaFadeOut.FadeOutSeconds) : null)"
                     class="pub-element kind-@element.Kind.ToString().ToLowerInvariant() @(State.IsSelected(element.Id) ? "selected" : null) @(element.Id == State.SelectedElementId ? "selection-primary" : null) @(element.GroupId is not null ? "grouped" : null) @(element.Locked ? "locked" : null)"
                     style="@ElementStyle(element)"
                     @oncontextmenu="args => ShowElementContextMenu(element, args)"
                     @oncontextmenu:preventDefault
                     @oncontextmenu:stopPropagation>
                    @switch (element)
                    {
                        case TextFrameElement text:
                            <div class="text-frame-content" style="padding:@Mm(text.PaddingMm);background:@StoryBackground(text);--publisher-story-page-background:@text.DocumentBackground;border:@Mm(text.BorderWidth) solid @text.BorderColor">
                                @((MarkupString)text.PreviewHtml)
                            </div>
                            break;
                        case ImageFrameElement image:
                            <div class="image-frame" style="@ImageFrameStyle(image)">
                                @PictureFilter(image)
                                <img src="@image.DataUrl" alt="@image.AltText" draggable="false" style="@ImageStyle(image)"
                                     data-crop-x="@Inv(image.CropX)" data-crop-y="@Inv(image.CropY)" data-crop-scale="@Inv(image.CropScale)"
                                     data-image-rotation="@Inv(image.ImageRotation)"
                                     data-flip-x="@(image.FlipHorizontal ? -1 : 1)" data-flip-y="@(image.FlipVertical ? -1 : 1)" />
                                @if (State.CropMode && element.Id == State.SelectedElementId)
                                {
                                    <div class="crop-thirds" aria-hidden="true"><i></i><i></i><i></i><i></i></div>
                                    <div class="crop-help">Drag picture · mouse wheel zooms · double-click finishes</div>
                                }
                            </div>
                            break;
                        case VideoElement video:
                            <div class="publication-video-frame" style="background:@video.Background">
                                <video src="@MediaSource(video)" poster="@video.PosterDataUrl" controls="@video.ShowControls" muted="@video.Muted" loop="@video.Loop"
                                       preload="metadata" playsinline data-media-control draggable="false" style="object-fit:@VideoFit(video.FitMode)"></video>
                                <span class="media-object-badge">▶ @Time(video.TimelineLengthSeconds)</span>
                            </div>
                            break;
                        case AudioElement audio:
                            <div class="publication-audio-frame display-@audio.DisplayKind.ToString().ToLowerInvariant()" style="--media-accent:@audio.AccentColor">
                                @if (audio.DisplayKind != PublicationAudioDisplayKind.Hidden)
                                {
                                    <div class="publication-audio-heading"><span>♪</span><b>@audio.Name</b><small>@Time(audio.TimelineLengthSeconds)</small></div>
                                    @if (audio.DisplayKind == PublicationAudioDisplayKind.Waveform)
                                    {
                                        <div class="publication-audio-waveform">
                                            @foreach (var sample in AudioSamples(audio))
                                            {
                                                <i style="height:@WaveHeight(sample)"></i>
                                            }
                                        </div>
                                    }
                                }
                                <audio src="@MediaSource(audio)" controls="@audio.ShowControls" muted="@audio.Muted" loop="@audio.Loop" preload="metadata" data-media-control></audio>
                            </div>
                            break;
                        case ShapeElement shape:
                            <div class="shape shape-@shape.Shape.ToString().ToLowerInvariant()" style="@ShapeStyle(shape)"></div>
                            break;
                        case WordArtElement wordArt:
                            <WordArtView Item="wordArt" IdPrefix="canvas" />
                            break;
                        case DataVisualElement dataVisual:
                            <DataVisualView @key="dataVisual.Id" Document="State.Document" Item="dataVisual" CurrentPageId="State.SelectedPageId" />
                            break;
                        case BarcodeElement barcode:
                            <BarcodeView Item="barcode" />
                            break;
                    }
                    @if (!element.Locked)
                    {
                        foreach (var anchor in ConnectorAnchors)
                        {
                            <span class="connector-port connector-port-@AnchorCss(anchor)" data-connector-port data-owner-id="@element.Id" data-anchor="@anchor" title="Connect at @anchor"></span>
                        }
                    }
                    @if (element.Id == State.SelectedElementId && !State.HasMultipleSelection && !element.Locked && !(State.CropMode && element is ImageFrameElement))
                    {
                        foreach (var handle in Handles)
                        {
                            <span class="selection-handle handle-@handle" data-resize-handle="@handle"></span>
                        }
                    }
                </div>
            }
        </div>
    </div>
</div>

<DxContextMenu @ref="_contextMenu">
    <Items>
        <DxContextMenuItem Text="Undo" IconCssClass="pub-icon pub-icon-undo" Enabled="@State.CanUndo" Click="State.Undo" />
        <DxContextMenuItem Text="Redo" IconCssClass="pub-icon pub-icon-redo" Enabled="@State.CanRedo" Click="State.Redo" />
        <DxContextMenuItem Text="Page transition" IconCssClass="pub-icon pub-icon-transition" BeginGroup="true">
            <Items>
                <DxContextMenuItem Text="@(CheckedText(State.CurrentPage.Transition.Kind == PublicationPageTransitionKind.None, "None"))" Click="TransitionNone" />
                <DxContextMenuItem Text="@(CheckedText(State.CurrentPage.Transition.Kind == PublicationPageTransitionKind.Fade, "Fade"))" Click="TransitionFade" />
                <DxContextMenuItem Text="@(CheckedText(State.CurrentPage.Transition.Kind == PublicationPageTransitionKind.Push, "Push"))" Click="TransitionPush" />
                <DxContextMenuItem Text="@(CheckedText(State.CurrentPage.Transition.Kind == PublicationPageTransitionKind.Wipe, "Wipe"))" Click="TransitionWipe" />
                <DxContextMenuItem Text="@(CheckedText(State.CurrentPage.Transition.Kind == PublicationPageTransitionKind.Zoom, "Zoom"))" Click="TransitionZoom" />
                <DxContextMenuItem Text="@(CheckedText(State.CurrentPage.Transition.Kind == PublicationPageTransitionKind.Flip, "Flip"))" Click="TransitionFlip" />
                <DxContextMenuItem Text="Preview page" BeginGroup="true" Click="PreviewPageAnimations" />
                <DxContextMenuItem Text="@TimelineCommandText" Click="ToggleTimeline" />
            </Items>
        </DxContextMenuItem>
        @if (State.SelectedElement is TextFrameElement textFrame)
        {
            <DxContextMenuItem Text="Edit story" IconCssClass="pub-icon pub-icon-edit" BeginGroup="true" Click="EditSelectedStory" />
            <DxContextMenuItem Text="Frame fill">
                <Items>
                    <DxContextMenuItem Text="@(CheckedText(string.Equals(textFrame.Background, "transparent", StringComparison.OrdinalIgnoreCase), "No fill"))" Click="TextFrameNoFill" />
                    <DxContextMenuItem Text="@(CheckedText(string.Equals(textFrame.Background, "#ffffff", StringComparison.OrdinalIgnoreCase), "White fill"))" Click="TextFrameWhiteFill" />
                </Items>
            </DxContextMenuItem>
        }
        @if (State.SelectedElement is ImageFrameElement imageFrame)
        {
            <DxContextMenuItem Text="Edit in Picture Studio" IconCssClass="pub-icon pub-icon-create-picture" BeginGroup="true" Click="EditSelectedPicture" />
            <DxContextMenuItem Text="Replace picture…" IconCssClass="pub-icon pub-icon-picture" Click="ReplaceSelectedPicture" />
            <DxContextMenuItem Text="@(State.CropMode ? "Finish crop" : "Crop picture")" IconCssClass="pub-icon pub-icon-crop" Click="ToggleCrop" />
            <DxContextMenuItem Text="Fit picture" Click="PictureFit" />
            <DxContextMenuItem Text="Fill frame" Click="PictureFill" />
            <DxContextMenuItem Text="Transform picture">
                <Items>
                    <DxContextMenuItem Text="Rotate left" Click="RotatePictureLeft" />
                    <DxContextMenuItem Text="Rotate right" Click="RotatePictureRight" />
                    <DxContextMenuItem Text="@(CheckedText(imageFrame.FlipHorizontal, "Flip horizontal"))" Click="FlipPictureHorizontal" />
                    <DxContextMenuItem Text="@(CheckedText(imageFrame.FlipVertical, "Flip vertical"))" Click="FlipPictureVertical" />
                </Items>
            </DxContextMenuItem>
            <DxContextMenuItem Text="Reset picture" Click="ResetPicture" />
        }
        @if (State.SelectedElement is PublicationMediaElement mediaElement)
        {
            <DxContextMenuItem Text="Edit in Media Studio" IconCssClass="pub-icon pub-icon-media" BeginGroup="true" Click="EditSelectedMedia" />
            <DxContextMenuItem Text="Play selected clip" Click="PlaySelectedMedia" />
            <DxContextMenuItem Text="Pause" Click="PauseSelectedMedia" />
            <DxContextMenuItem Text="Playback">
                <Items>
                    <DxContextMenuItem Text="@(CheckedText(mediaElement.Muted, "Muted"))" Click="ToggleMediaMuted" />
                    <DxContextMenuItem Text="@(CheckedText(mediaElement.Loop, "Loop clip"))" Click="ToggleMediaLoop" />
                    <DxContextMenuItem Text="@(CheckedText(mediaElement.AutoPlay, "Play in presentation"))" Click="ToggleMediaAutoPlay" />
                    <DxContextMenuItem Text="Start behavior">
                        <Items>
                            <DxContextMenuItem Text="@(CheckedText(mediaElement.PlaybackTrigger == PublicationMediaPlaybackTrigger.OnPageEnter, "On page entry"))" Click="MediaOnPageEnter" />
                            <DxContextMenuItem Text="@(CheckedText(mediaElement.PlaybackTrigger == PublicationMediaPlaybackTrigger.OnClick, "On click"))" Click="MediaOnClick" />
                            <DxContextMenuItem Text="@(CheckedText(mediaElement.PlaybackTrigger == PublicationMediaPlaybackTrigger.WithAnimation, "With animation"))" Click="MediaWithAnimation" />
                        </Items>
                    </DxContextMenuItem>
                </Items>
            </DxContextMenuItem>
        }
        @if (State.SelectedElement is WordArtElement)
        {
            <DxContextMenuItem Text="Use custom text path" IconCssClass="pub-icon pub-icon-path" BeginGroup="true" Click="WordArtCustomPath" />
            <DxContextMenuItem Text="Reverse text path" Click="WordArtReversePath" />
        }
        @if (State.SelectedElement is BarcodeElement)
        {
            <DxContextMenuItem Text="Edit barcode / QR" IconCssClass="pub-icon pub-icon-barcode" BeginGroup="true" Click="EditSelectedBarcode" />
        }
        @if (State.SelectedElement is DataVisualElement dataVisual)
        {
            <DxContextMenuItem Text="Edit data visual" IconCssClass="pub-icon pub-icon-chart" BeginGroup="true" Click="EditSelectedDataVisual" />
            <DxContextMenuItem Text="Visual type">
                <Items>
                    <DxContextMenuItem Text="@(CheckedText(dataVisual.VisualKind == DataVisualKind.CartesianChart, DataVisualMenuName(DataVisualKind.CartesianChart)))" Click="SelectedVisualChart" />
                    <DxContextMenuItem Text="@(CheckedText(dataVisual.VisualKind == DataVisualKind.PieChart, DataVisualMenuName(DataVisualKind.PieChart)))" Click="SelectedVisualPie" />
                    <DxContextMenuItem Text="@(CheckedText(dataVisual.VisualKind == DataVisualKind.PolarChart, DataVisualMenuName(DataVisualKind.PolarChart)))" Click="SelectedVisualPolar" />
                    <DxContextMenuItem Text="@(CheckedText(dataVisual.VisualKind == DataVisualKind.Sparkline, DataVisualMenuName(DataVisualKind.Sparkline)))" Click="SelectedVisualSparkline" />
                    <DxContextMenuItem Text="@(CheckedText(dataVisual.VisualKind == DataVisualKind.BarGauge, DataVisualMenuName(DataVisualKind.BarGauge)))" Click="SelectedVisualBarGauge" />
                    <DxContextMenuItem Text="@(CheckedText(dataVisual.VisualKind == DataVisualKind.DataTable, DataVisualMenuName(DataVisualKind.DataTable)))" Click="SelectedVisualDataTable" />
                    <DxContextMenuItem Text="@(CheckedText(dataVisual.VisualKind == DataVisualKind.KpiProgress, DataVisualMenuName(DataVisualKind.KpiProgress)))" Click="SelectedVisualKpi" />
                </Items>
            </DxContextMenuItem>
            <DxContextMenuItem Text="@(CheckedText(dataVisual.ShowTitle, "Show title"))" Click="ToggleDataVisualTitle" />
            @if (dataVisual.VisualKind is DataVisualKind.CartesianChart or DataVisualKind.PieChart or DataVisualKind.PolarChart or DataVisualKind.BarGauge)
            {
                <DxContextMenuItem Text="@(CheckedText(dataVisual.ShowLegend, "Show legend"))" Click="ToggleDataVisualLegend" />
            }
            @if (dataVisual.VisualKind is DataVisualKind.PieChart or DataVisualKind.PolarChart)
            {
                <DxContextMenuItem Text="@(CheckedText(dataVisual.ShowLabels, "Show point labels"))" Click="ToggleDataVisualLabels" />
            }
            @if (dataVisual.VisualKind == DataVisualKind.DataTable)
            {
                <DxContextMenuItem Text="@(CheckedText(dataVisual.TableShowFilterRow, "Interactive filter row"))" Click="ToggleDataVisualFilterRow" />
            }
            <DxContextMenuItem Text="Manage publication data" IconCssClass="pub-icon pub-icon-data" Click="ManageData" />
            <DxContextMenuItem Text="Refresh data" Click="RefreshData" />
        }
        @if (State.SelectedElement is ShapeElement shape)
        {
            <DxContextMenuItem Text="Shape type" BeginGroup="true">
                <Items>
                    <DxContextMenuItem Text="@(CheckedText(shape.Shape == PublicationShape.Rectangle, ShapeMenuName(PublicationShape.Rectangle)))" Click="SelectedShapeRectangle" />
                    <DxContextMenuItem Text="@(CheckedText(shape.Shape == PublicationShape.RoundedRectangle, ShapeMenuName(PublicationShape.RoundedRectangle)))" Click="SelectedShapeRoundedRectangle" />
                    <DxContextMenuItem Text="@(CheckedText(shape.Shape == PublicationShape.Ellipse, ShapeMenuName(PublicationShape.Ellipse)))" Click="SelectedShapeEllipse" />
                    <DxContextMenuItem Text="@(CheckedText(shape.Shape == PublicationShape.Line, ShapeMenuName(PublicationShape.Line)))" Click="SelectedShapeLine" />
                </Items>
            </DxContextMenuItem>
        }
        @if (State.SelectedElement is ConnectorElement)
        {
            <DxContextMenuItem Text="Straight connector" BeginGroup="true" Click="ConnectorStraight" />
            <DxContextMenuItem Text="Elbow connector" Click="ConnectorElbow" />
            <DxContextMenuItem Text="Curved connector" Click="ConnectorCurved" />
            <DxContextMenuItem Text="Arrow at end" Click="ConnectorArrowEnd" />
            <DxContextMenuItem Text="No arrow" Click="ConnectorNoArrow" />
        }
        @if (State.SelectedElement is not null)
        {
            <DxContextMenuItem Text="Animations" IconCssClass="pub-icon pub-icon-animation" BeginGroup="true">
                <Items>
                    <DxContextMenuItem Text="Entrance">
                        <Items>
                            <DxContextMenuItem Text="Fade in" Click="AddFadeInAnimation" />
                            <DxContextMenuItem Text="Fly in" Click="AddFlyInAnimation" />
                            <DxContextMenuItem Text="Float in" Click="AddFloatInAnimation" />
                            <DxContextMenuItem Text="Zoom in" Click="AddZoomInAnimation" />
                            <DxContextMenuItem Text="Wipe in" Click="AddWipeInAnimation" />
                            <DxContextMenuItem Text="Bounce in" Click="AddBounceInAnimation" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="Emphasis / motion">
                        <Items>
                            <DxContextMenuItem Text="Pulse" Click="AddPulseAnimation" />
                            <DxContextMenuItem Text="Spin" Click="AddSpinAnimation" />
                            <DxContextMenuItem Text="Shake" Click="AddShakeAnimation" />
                            <DxContextMenuItem Text="Grow / shrink" Click="AddGrowShrinkAnimation" />
                            <DxContextMenuItem Text="Bounce" Click="AddBounceAnimation" />
                            <DxContextMenuItem Text="Move" Click="AddMoveAnimation" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="Exit">
                        <Items>
                            <DxContextMenuItem Text="Fade out" Click="AddFadeOutAnimation" />
                            <DxContextMenuItem Text="Fly out" Click="AddFlyOutAnimation" />
                            <DxContextMenuItem Text="Zoom out" Click="AddZoomOutAnimation" />
                            <DxContextMenuItem Text="Wipe out" Click="AddWipeOutAnimation" />
                        </Items>
                    </DxContextMenuItem>
                    @if (State.SelectedElement is PublicationMediaElement)
                    {
                        <DxContextMenuItem Text="Media step" BeginGroup="true">
                            <Items>
                                <DxContextMenuItem Text="Play media" Click="AddPlayMediaAnimation" />
                                <DxContextMenuItem Text="Pause media" Click="AddPauseMediaAnimation" />
                                <DxContextMenuItem Text="Stop media" Click="AddStopMediaAnimation" />
                            </Items>
                        </DxContextMenuItem>
                    }
                    <DxContextMenuItem Text="Preview object" BeginGroup="true" Enabled="@(State.SelectedElement.Animations.Count > 0)" Click="PreviewSelectedAnimations" />
                    <DxContextMenuItem Text="Edit animation details / timeline" Click="ToggleTimeline" />
                    <DxContextMenuItem Text="Remove all object animations" Enabled="@(State.SelectedElement.Animations.Count > 0)" Click="ClearSelectedAnimations" />
                </Items>
            </DxContextMenuItem>
            @if (State.CanGroupSelection)
            {
                <DxContextMenuItem Text="Group selected objects" BeginGroup="true" Click="GroupSelected" />
            }
            @if (State.CanUngroupSelection)
            {
                <DxContextMenuItem Text="Ungroup objects" BeginGroup="true" Click="UngroupSelected" />
            }
            <DxContextMenuItem Text="Copy" IconCssClass="pub-icon pub-icon-copy" BeginGroup="true" Click="Copy" />
            <DxContextMenuItem Text="Paste" IconCssClass="pub-icon pub-icon-paste" Enabled="@State.CanPaste" Click="Paste" />
            <DxContextMenuItem Text="Duplicate" Click="Duplicate" />
            <DxContextMenuItem Text="Delete" IconCssClass="pub-icon pub-icon-delete" Click="Delete" />
            <DxContextMenuItem Text="Arrange" BeginGroup="true">
                <Items>
                    <DxContextMenuItem Text="Bring to front" Click="BringToFront" />
                    <DxContextMenuItem Text="Bring forward" Click="BringForward" />
                    <DxContextMenuItem Text="Send backward" Click="SendBackward" />
                    <DxContextMenuItem Text="Send to back" Click="SendToBack" />
                </Items>
            </DxContextMenuItem>
            @if (State.SelectedElement is not ConnectorElement)
            {
            <DxContextMenuItem Text="Align to page">
                <Items>
                    <DxContextMenuItem Text="Left" Click="AlignLeft" />
                    <DxContextMenuItem Text="Center" Click="AlignCenter" />
                    <DxContextMenuItem Text="Right" Click="AlignRight" />
                    <DxContextMenuItem Text="Top" Click="AlignTop" />
                    <DxContextMenuItem Text="Middle" Click="AlignMiddle" />
                    <DxContextMenuItem Text="Bottom" Click="AlignBottom" />
                </Items>
            </DxContextMenuItem>
            }
            <DxContextMenuItem Text="@(State.SelectedElement.Locked ? "Unlock" : "Lock")" BeginGroup="true" Click="ToggleLock" />
            <DxContextMenuItem Text="@(State.SelectedElement.Visible ? "Hide" : "Show")" Click="ToggleVisibility" />
        }
        else
        {
            <DxContextMenuItem Text="Paste" IconCssClass="pub-icon pub-icon-paste" Enabled="@State.CanPaste" BeginGroup="true" Click="Paste" />
            <DxContextMenuItem Text="Insert text box" IconCssClass="pub-icon pub-icon-text" Click="AddText" />
            <DxContextMenuItem Text="Insert WordArt" IconCssClass="pub-icon pub-icon-wordart" Click="AddWordArt" />
            <DxContextMenuItem Text="Insert picture…" IconCssClass="pub-icon pub-icon-picture" Click="InsertPicture" />
            <DxContextMenuItem Text="Create picture…" IconCssClass="pub-icon pub-icon-create-picture" Click="CreatePicture" />
            <DxContextMenuItem Text="Insert video…" IconCssClass="pub-icon pub-icon-video" Click="InsertVideo" />
            <DxContextMenuItem Text="Create video…" Click="CreateVideo" />
            <DxContextMenuItem Text="Insert audio…" IconCssClass="pub-icon pub-icon-audio" Click="InsertAudio" />
            <DxContextMenuItem Text="Create audio…" Click="CreateAudio" />
            <DxContextMenuItem Text="Insert data visual" IconCssClass="pub-icon pub-icon-chart">
                <Items>
                    <DxContextMenuItem Text="Chart" Click="InsertChart" />
