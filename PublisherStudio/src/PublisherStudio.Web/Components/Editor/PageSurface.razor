    private bool TryConnectorEndpointAdvanced(
        string kind, string elementId, string anchor, string portId, bool createPort, double relativeX, double relativeY, double x, double y,
        out ConnectorEndpoint endpoint, out PublicationConnectorPort? pendingPort)
    {
        pendingPort = null;
        endpoint = new ConnectorEndpoint();
        if (!Enum.TryParse<ConnectorEndpointKind>(kind, true, out var parsedKind)) return false;
        endpoint.Kind = parsedKind;
        endpoint.X = Math.Clamp(x, 0, State.CurrentPage.WidthMm);
        endpoint.Y = Math.Clamp(y, 0, State.CurrentPage.HeightMm);
        if (parsedKind == ConnectorEndpointKind.Canvas) return true;
        if (!Guid.TryParse(elementId, out var elementGuid)) return false;
        endpoint.ElementId = elementGuid;
        endpoint.Anchor = Enum.TryParse<ConnectorAnchor>(anchor, true, out var parsedAnchor) ? parsedAnchor : ConnectorAnchor.Center;
        if (Guid.TryParse(portId, out var parsedPortId)) endpoint.PortId = parsedPortId;
        if (createPort)
        {
            pendingPort = new PublicationConnectorPort
            {
                Name = "Connector point",
                XPercent = Math.Clamp(relativeX, 0, 1),
                YPercent = Math.Clamp(relativeY, 0, 1)
            };
            endpoint.PortId = pendingPort.Id;
            endpoint.Anchor = ConnectorAnchor.Center;
        }
        return true;
    }

