    private Task DoubleClick(PublicationElement element)
    {
        if (element is TextFrameElement) return EditTextRequested.InvokeAsync(element.Id);
        if (element is ImageFrameElement) State.ToggleCropMode();
        if (element is DataVisualElement) return RequestEditDataVisual.InvokeAsync();
        if (element is DevExtremeComponentElement) return RequestEditComponent.InvokeAsync();
        if (element is SpreadsheetElement) return RequestEditSpreadsheet.InvokeAsync();
        if (element is PublicationMediaElement) return RequestEditMedia.InvokeAsync();
        if (element is BarcodeElement) return RequestEditBarcode.InvokeAsync();
        if (element is LiveSourceElement liveSource) return ActivateLiveSource(liveSource);
        return Task.CompletedTask;
    }

    private async Task ShowElementContextMenu(PublicationElement element, MouseEventArgs args)
    {
        State.SetPrimarySelection(element.Id);
        if (element is not ConnectorElement)
        {
            try
            {
                _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/publisherInterop.js");
                var point = await _module.InvokeAsync<double[]>("elementRelativePoint", "publisher-page", element.Id.ToString("D"), args.ClientX, args.ClientY);
                if (point.Length >= 2)
                {
                    _contextPortX = Math.Clamp(point[0], 0, 1);
                    _contextPortY = Math.Clamp(point[1], 0, 1);
                }
            }
            catch { _contextPortX = _contextPortY = .5; }
        }
        await InvokeAsync(StateHasChanged);
        await _contextMenu.ShowAsync(args);
    }

    private async Task ShowPageContextMenu(MouseEventArgs args)
    {
        State.SelectElement(null);
        await InvokeAsync(StateHasChanged);
        await _contextMenu.ShowAsync(args);
    }

