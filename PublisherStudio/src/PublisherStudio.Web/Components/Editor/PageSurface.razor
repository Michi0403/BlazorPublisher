    [Parameter] public EventCallback RequestInsertBarcode { get; set; }
    [Parameter] public EventCallback RequestEditBarcode { get; set; }
    [Parameter] public bool TimelineVisible { get; set; }
    [Parameter] public EventCallback RequestToggleTimeline { get; set; }
    [Parameter] public EventCallback<CanvasInsertRequest> RequestCanvasInsert { get; set; }
    [Parameter] public EventCallback<ExternalFileDropRequest> RequestExternalFileDrop { get; set; }
    [Parameter] public EventCallback<string> RequestExternalDropError { get; set; }

    private string TimelineCommandText => TimelineVisible ? "✓ Timeline pane" : "Timeline pane";

    private DxContextMenu _contextMenu = default!;
    private IJSObjectReference? _module;
    private DotNetObjectReference<PageSurface>? _self;
    private bool _disposed;
    private bool _canvasInitializationInProgress;
    private string? _canvasInitializationKey;
    private string? _dataVisualLayoutKey;
    private double _contextPortX = .5;
    private double _contextPortY = .5;
    private static readonly string[] Handles = ["nw", "n", "ne", "e", "se", "s", "sw", "w"];
    private static readonly ConnectorAnchor[] ConnectorAnchors =
    [
        ConnectorAnchor.TopLeft, ConnectorAnchor.Top, ConnectorAnchor.TopRight, ConnectorAnchor.Right,
        ConnectorAnchor.BottomRight, ConnectorAnchor.Bottom, ConnectorAnchor.BottomLeft, ConnectorAnchor.Left
    ];
    private double PixelsPerMm => 3.7795275591 * State.Document.Zoom;
    private string UnitLabel => State.Document.View.RulerUnit switch
    {
        MeasurementUnit.Millimeter => "mm",
        MeasurementUnit.Centimeter => "cm",
        MeasurementUnit.Inch => "in",
        MeasurementUnit.Pixel => "px",
        _ => "mm"
    };

    private string PointerStateText => State.ConnectorTool != ConnectorToolKind.None
        ? State.ConnectorTool switch
        {
            ConnectorToolKind.Arrow => "Draw arrow connector",
            ConnectorToolKind.SignalConnector => "Draw signal connector",
            ConnectorToolKind.SignalArrow => "Draw signal arrow",
            _ => "Draw connector"
        }
        : State.CropMode ? "Crop picture"
        : State.HasMultipleSelection ? $"Move {State.SelectedElements.Count} objects"
        : "Select / move";
    private string ConnectorToolTitle => State.ConnectorTool switch
    {
        ConnectorToolKind.Arrow => "Arrow connector",
        ConnectorToolKind.SignalConnector => "Signal connector",
        ConnectorToolKind.SignalArrow => "Signal arrow",
        _ => "Connector"
    };
    private string ConnectorToolHint => State.ConnectorTool is ConnectorToolKind.SignalConnector or ConnectorToolKind.SignalArrow
        ? "Drag from any object port or empty canvas point to another port or canvas point. Signal actions work offline in exported HTML. Press Esc to stop."
        : "Drag from a round object port to another port. Press Esc to stop.";

    private bool CanResetPointerState => State.ConnectorTool != ConnectorToolKind.None || State.CropMode || State.ContentPanMode;

    private string PageStyle
    {
        get
        {
            var grid = Math.Max(.5, State.Document.View.GridSpacingMm) * PixelsPerMm;
            var gridStyle = State.Document.View.GridVisible
                ? $"background-image:linear-gradient(#0000 calc(100% - 1px),#00000010 calc(100% - 1px)),linear-gradient(90deg,#0000 calc(100% - 1px),#00000010 calc(100% - 1px));background-size:{Px(grid)} {Px(grid)};"
                : "background-image:none;";
            return $"width:{Px(State.CurrentPage.WidthMm * PixelsPerMm)};height:{Px(State.CurrentPage.HeightMm * PixelsPerMm)};background-color:{State.CurrentPage.Background};{gridStyle}";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_disposed || _canvasInitializationInProgress) return;
        var selectedElementIds = State.SelectedElementIds
            .OrderBy(id => id)
            .Select(id => id.ToString("D"))
            .ToArray();
        var selectionKey = string.Join(",", selectedElementIds);
        var clipboardKey = $"{State.CanPaste}:{State.ClipboardRevision}";
        var initializationKey = $"{State.CurrentPage.Id:N}|" +
            $"{State.Document.Zoom.ToString("R", CultureInfo.InvariantCulture)}|{State.CropMode}|{State.ContentPanMode}|{State.Document.View.RulerUnit}|" +
            $"{State.Document.View.RulersVisible}|{State.Document.View.GuidesVisible}|{State.Document.View.SnapToGrid}|" +
            $"{State.Document.View.SnapToGuides}|{State.Document.View.SnapToPage}|{State.Document.View.SnapToObjects}|{State.Document.View.SnapInObjects}|" +
            $"{State.Document.View.GridSpacingMm.ToString("R", CultureInfo.InvariantCulture)}|{State.ConnectorTool}|{selectionKey}|{clipboardKey}";
        var dataVisualLayoutKey = $"{State.CurrentPage.Id:N}|{State.Revision}|{State.Document.Zoom.ToString("R", CultureInfo.InvariantCulture)}";

        _canvasInitializationInProgress = true;
        try
        {
            _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/publisherInterop.js");
            if (initializationKey != _canvasInitializationKey)
            {
                _self ??= DotNetObjectReference.Create(this);
                var initialized = await _module.InvokeAsync<bool>("initializeCanvas",
                    "publisher-stage", "publisher-scroll-area", "publisher-page", "publisher-horizontal-ruler", "publisher-vertical-ruler", _self,
                    new
                    {
                        pxPerMm = PixelsPerMm,
                        cropMode = State.CropMode,
                        contentPanMode = State.ContentPanMode,
                        unit = State.Document.View.RulerUnit.ToString(),
                        rulersVisible = State.Document.View.RulersVisible,
                        guidesVisible = State.Document.View.GuidesVisible,
                        snapToGrid = State.Document.View.SnapToGrid,
                        snapToGuides = State.Document.View.SnapToGuides,
                        snapToPage = State.Document.View.SnapToPage,
                        snapToObjects = State.Document.View.SnapToObjects,
                        snapInObjects = State.Document.View.SnapInObjects,
                        gridSpacingMm = State.Document.View.GridSpacingMm,
                        connectorTool = State.ConnectorTool.ToString(),
                        selectedElementIds,
                        internalClipboardAvailable = State.CanPaste,
                        clipboardRevision = State.ClipboardRevision
                    });
                if (initialized) _canvasInitializationKey = initializationKey;
            }

            if (dataVisualLayoutKey != _dataVisualLayoutKey)
            {
                _dataVisualLayoutKey = dataVisualLayoutKey;
                if (State.CurrentPage.Elements.Any(element => element is DataVisualElement))
                    await _module.InvokeVoidAsync("refreshDataVisualLayout", "publisher-page");
                await _module.InvokeVoidAsync("initializeSignalConnectors", "publisher-page", new { autoStart = false, editor = true });
            }
        }
        catch (JSDisconnectedException) { }
        catch (TaskCanceledException) { }
        catch (ObjectDisposedException) { }
        catch (InvalidOperationException) { }
        catch (JSException ex)
        {
            Console.WriteLine($"Publisher canvas initialization failed: {ex.Message}");
        }
        finally
        {
            _canvasInitializationInProgress = false;
        }
    }

    public async Task FitPageAsync()
    {
        _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/publisherInterop.js");
        var zoom = await _module.InvokeAsync<double>("calculateFitZoom", "publisher-stage", State.CurrentPage.WidthMm, State.CurrentPage.HeightMm, State.Document.View.RulersVisible);
        State.SetZoom(zoom);
    }

    [JSInvokable] public void SelectElement(string id, bool additive = false) { if (Guid.TryParse(id, out var guid)) State.SelectElement(guid, additive); }
    [JSInvokable] public void ClearSelectionFromCanvas() => State.SelectElement(null);
    [JSInvokable]
    public void NavigateToPage(string target)
    {
        var value = (target ?? string.Empty).Trim();
        var page = State.Document.Pages.FirstOrDefault(candidate => string.Equals(candidate.Id.ToString("D"), value, StringComparison.OrdinalIgnoreCase))
            ?? State.Document.Pages.FirstOrDefault(candidate => string.Equals(candidate.Name, value, StringComparison.OrdinalIgnoreCase));
        if (page is null && int.TryParse(value, out var number) && number >= 1 && number <= State.Document.Pages.Count) page = State.Document.Pages[number - 1];
        if (page is not null) State.SelectPage(page.Id);
    }
    [JSInvokable]
    public void SetSelectionFromCanvas(string[]? ids)
    {
        State.SetSelection((ids ?? [])
            .Select(value => Guid.TryParse(value, out var parsed) ? parsed : Guid.Empty)
            .Where(value => value != Guid.Empty));
    }
    [JSInvokable]
    public Task ActivateElement(string id)
    {
        if (!Guid.TryParse(id, out var guid)) return Task.CompletedTask;
        var element = State.CurrentPage.Elements.FirstOrDefault(item => item.Id == guid);
        if (element is null) return Task.CompletedTask;
        State.SelectElement(guid);
        return DoubleClick(element);
    }

    [JSInvokable]
    public async Task OpenElementContextMenu(string id, double clientX, double clientY, double pageX, double pageY, double screenX, double screenY)
    {
        if (!Guid.TryParse(id, out var guid)) return;
        var element = State.CurrentPage.Elements.FirstOrDefault(item => item.Id == guid);
        if (element is null) return;
        // DevExpress positions a context menu from PageX/PageY. Supplying only
        // ClientX/ClientY caused the menu to jump to stale or zero page coordinates.
        var args = new MouseEventArgs
        {
            Type = "contextmenu",
            Button = 2,
            Buttons = 2,
            ClientX = clientX,
            ClientY = clientY,
            PageX = pageX,
            PageY = pageY,
            ScreenX = screenX,
            ScreenY = screenY
        };
        await ShowElementContextMenu(element, args);
