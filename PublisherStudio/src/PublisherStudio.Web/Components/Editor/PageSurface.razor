    public void ReconnectConnectorAdvanced(
        string connectorId, string endpoint,
        string kind, string elementId, string anchor, string portId, bool createPort, double relativeX, double relativeY, double x, double y)
    {
        if (!Guid.TryParse(connectorId, out var connectorGuid) ||
            !TryConnectorEndpointAdvanced(kind, elementId, anchor, portId, createPort, relativeX, relativeY, x, y, out var replacement, out var pendingPort)) return;
        State.ReconnectConnectorEndpoint(connectorGuid, string.Equals(endpoint, "source", StringComparison.OrdinalIgnoreCase), replacement, pendingPort);
    }

