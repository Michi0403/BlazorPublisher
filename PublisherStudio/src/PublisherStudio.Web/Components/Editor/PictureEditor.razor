@namespace PublisherStudio.Components.Editor
@implements IDisposable
@implements IAsyncDisposable

@if (Visible)
{
    <div class="modal-backdrop picture-studio-backdrop">
        <section class="picture-studio-dialog" role="dialog" aria-modal="true" aria-label="Picture Studio">
            <header class="picture-studio-titlebar">
                <div>
                    <strong>Picture Studio</strong>
                    <span>@State.Document.Name · @State.Document.WidthPx × @State.Document.HeightPx px</span>
                </div>
                <button type="button" class="window-close" title="Close" @onclick="Cancel">×</button>
            </header>

            <DxRibbon CssClass="picture-studio-ribbon categorized-ribbon" SizeMode="SizeMode.Medium" AdaptivityAutoCollapseItemsToGroups="true">
                <DxRibbonTab Text="Home">
                    <DxRibbonGroup Text="History">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-undo" Text="Undo" Enabled="State.CanUndo" Click="State.Undo" />
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-redo" Text="Redo" Enabled="State.CanRedo" Click="State.Redo" />
                    </DxRibbonGroup>
                    <DxRibbonGroup Text="Edit">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-copy" Text="Clipboard & layers" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-copy" Text="Copy" Enabled="HasSelection" Click="State.CopySelected" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-paste" Text="Paste" Enabled="State.CanPaste" Click="State.Paste" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-duplicate" Text="Duplicate" Enabled="HasSelection" Click="State.DuplicateSelected" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-layers" Text="Move layer up" Enabled="HasSelection" Click="MoveUp" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-layers" Text="Move layer down" Enabled="HasSelection" Click="MoveDown" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-delete" Text="Delete" Enabled="CanDelete" Click="State.DeleteSelected" />
                        </DxRibbonItem>
                    </DxRibbonGroup>
                    <DxRibbonGroup Text="View">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-properties" Text="Canvas view" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-fit" Text="Fit canvas" Click="FitCanvas" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-fit" Text="100%" Click="Zoom100" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-grid" Text="@GridText" Click="ToggleGridRibbon" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-snap" Text="@SnapText" Click="ToggleSnapRibbon" />
                        </DxRibbonItem>
                    </DxRibbonGroup>
                </DxRibbonTab>
                <DxRibbonTab Text="Insert">
                    <DxRibbonGroup Text="Content">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-insert" Text="Add content" IsPrimary="true" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-picture" Text="Image" Click="RequestImage" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-text" Text="Text" Click="AddTextLayer" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-layers" Text="Paint layer" Click="AddPaintLayer" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-color" Text="Solid fill" Click="AddSolidFill" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-color" Text="Gradient fill" Click="AddGradient" />
                        </DxRibbonItem>
                    </DxRibbonGroup>
                    <DxRibbonGroup Text="Shapes">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-shape" Text="Basic shapes" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-rectangle" Text="Rectangle" Click="AddRectangle" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-ellipse" Text="Ellipse" Click="AddEllipse" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-arrow" Text="Arrow" Click="AddArrowShape" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-line" Text="Line" Click="AddLineShape" />
                        </DxRibbonItem>
                    </DxRibbonGroup>
                    <DxRibbonGroup Text="Renderers">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Texture & light" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Clouds" Click="AddClouds" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Noise" Click="AddNoise" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Grain noise" Click="AddGrainNoise" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Stripes" Click="AddStripes" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Vignette" Click="AddVignette" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Bloom" Click="AddBloom" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Neon" Click="AddNeon" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Lens flare" Click="AddLensFlare" />
                        </DxRibbonItem>
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-animation" Text="Motion & surfaces" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Motion blur" Click="AddMotionBlur" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Wind" Click="AddWind" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Ocean waves" Click="AddOceanWaves" />
                        </DxRibbonItem>
                    </DxRibbonGroup>
                </DxRibbonTab>
                <DxRibbonTab Text="Draw">
                    <DxRibbonGroup Text="Drawing">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-brush" Text="Drawing tools" IsPrimary="true" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-select" Text="@SelectToolText" Click="SelectTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-brush" Text="@BrushToolText" Click="BrushTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-pencil" Text="@PencilToolText" Click="PencilTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-spray" Text="@SprayToolText" Click="SprayTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-brush" Text="@ToothbrushToolText" Click="ToothbrushTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-rectangle" Text="@SquareToolText" Click="SquareTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-rectangle" Text="@RectangleToolText" Click="RectangleTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-ellipse" Text="@EllipseToolText" Click="EllipseTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-arrow" Text="@ArrowToolText" Click="ArrowTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-line" Text="@LineToolText" Click="LineTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-eraser" Text="@EraserToolText" Click="EraserTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-eyedropper" Text="@EyedropperToolText" Click="EyedropperTool" />
                        </DxRibbonItem>
                    </DxRibbonGroup>
                    <DxRibbonGroup Text="Selection & fill">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-select" Text="Selection tools" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-select" Text="@RectangleSelectToolText" Click="RectangleSelectTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-select" Text="@EllipseSelectToolText" Click="EllipseSelectTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-select" Text="@FreeSelectToolText" Click="FreeSelectTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-select" Text="@MagneticSelectToolText" Click="MagneticSelectTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-delete" Text="Clear selection" Click="ClearAreaSelection" />
                        </DxRibbonItem>
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-color" Text="Area fill" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-gradient" Text="@FillSolidToolText" Click="FillSolidTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-gradient" Text="@FillGradientToolText" Click="FillGradientTool" />
                        </DxRibbonItem>
                    </DxRibbonGroup>
                    <DxRibbonGroup Text="Color">
                        <DxRibbonColorPaletteItem Text="Primary" Value="@_drawColor" ValueChanged="ChangeDrawColor"><Groups><DxRibbonColorGroup Header="Drawing" Colors="@PictureColors" /></Groups></DxRibbonColorPaletteItem>
                        <DxRibbonColorPaletteItem Text="Secondary" Value="@_drawSecondaryColor" ValueChanged="ChangeDrawSecondaryColor"><Groups><DxRibbonColorGroup Header="Drawing" Colors="@PictureColors" /></Groups></DxRibbonColorPaletteItem>
                    </DxRibbonGroup>
                    <DxRibbonGroup Text="Width">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-brush" Text="Brush width" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-brush" Text="@DrawWidthText(1)" Click="DrawWidth1" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-brush" Text="@DrawWidthText(3)" Click="DrawWidth3" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-brush" Text="@DrawWidthText(8)" Click="DrawWidth8" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-brush" Text="@DrawWidthText(16)" Click="DrawWidth16" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-brush" Text="@DrawWidthText(32)" Click="DrawWidth32" />
                        </DxRibbonItem>
                    </DxRibbonGroup>
                </DxRibbonTab>
                <DxRibbonTab Text="Output">
                    <DxRibbonGroup Text="Export">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-download" Text="Download" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-download" Text="Download PNG" Click="DownloadPng" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-download" Text="Download JPEG" Click="DownloadJpeg" />
                        </DxRibbonItem>
                    </DxRibbonGroup>
                    <DxRibbonGroup Text="Publication">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-picture" Text="@(EditingExisting ? "Apply to picture" : "Insert into publication")" Enabled="@(!IsPictureExporting)" IsPrimary="true" Click="Apply" />
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-command" Text="Cancel" Click="Cancel" />
                    </DxRibbonGroup>
                </DxRibbonTab>
                <DxRibbonTab Text="Effects">
                    <DxRibbonGroup Text="Adjust">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-audio" Text="Tone" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-color" Text="Brighten" Enabled="HasSelection" Click="Brighten" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-color" Text="Darken" Enabled="HasSelection" Click="Darken" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-color" Text="More contrast" Enabled="HasSelection" Click="MoreContrast" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-color" Text="More saturation" Enabled="HasSelection" Click="MoreSaturation" />
                        </DxRibbonItem>
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-color" Text="Soften" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-color" Text="Light soften" Enabled="HasSelection" Click="SoftenLight" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-color" Text="Medium soften" Enabled="HasSelection" Click="SoftenMedium" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-delete" Text="Remove soften" Enabled="HasSelection" Click="RemoveSoftening" />
                        </DxRibbonItem>
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-color" Text="Color effects" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-properties" Text="Grayscale" Enabled="HasSelection" Click="ToggleGrayscalePreset" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-properties" Text="Sepia" Enabled="HasSelection" Click="ToggleSepiaPreset" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-properties" Text="Invert" Enabled="HasSelection" Click="ToggleInvertPreset" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-properties" Text="Reset all" Enabled="HasSelection" Click="ResetAdjustments" />
                        </DxRibbonItem>
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Glow & flare" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-save" Text="Bloom glow" Enabled="HasSelection" Click="ApplyBloomEffect" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-save" Text="Neon glow" Enabled="HasSelection" Click="ApplyNeonEffect" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-save" Text="Lens flare" Enabled="HasSelection" Click="ApplyLensFlareEffect" />
                        </DxRibbonItem>
                    </DxRibbonGroup>
                </DxRibbonTab>
                <DxRibbonTab Text="Render Tools" Contextual="true" Visible="IsRenderSelected">
                    <DxRibbonGroup Text="Renderer">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Change renderer" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Clouds" Click="MakeRenderClouds" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Noise" Click="MakeRenderNoise" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Stripes" Click="MakeRenderStripes" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Vignette" Click="MakeRenderVignette" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Bloom" Click="MakeRenderBloom" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Neon" Click="MakeRenderNeon" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Lens flare" Click="MakeRenderLensFlare" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Grain noise" Click="MakeRenderGrainNoise" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Motion blur" Click="MakeRenderMotionBlur" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Wind" Click="MakeRenderWind" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="Ocean waves" Click="MakeRenderOceanWaves" />
                        </DxRibbonItem>
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-render" Text="New seed" IsPrimary="true" Click="RandomizeRender" />
                    </DxRibbonGroup>
                </DxRibbonTab>
                <DxRibbonTab Text="Paint Tools" Contextual="true" Visible="IsPaintSelected">
                    <DxRibbonGroup Text="Paint layer">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-brush" Text="Paint tool" IsPrimary="true" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-brush" Text="Brush" Click="BrushTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-spray" Text="Spray can" Click="SprayTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-brush" Text="Toothbrush" Click="ToothbrushTool" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-eraser" Text="Eraser" Click="EraserTool" />
                        </DxRibbonItem>
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-delete" Text="Clear strokes" Enabled="CanDelete" Click="State.ClearSelectedPaint" />
                    </DxRibbonGroup>
                </DxRibbonTab>
                <DxRibbonTab Text="Picture Tools" Contextual="true" Visible="IsRasterSelected">
                    <DxRibbonGroup Text="Raster">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-delete" Text="Replace" IsPrimary="true" Enabled="CanDelete" Click="RequestRasterReplacement" />
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-rotate" Text="Fit and flip" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-delete" Text="Contain" Enabled="CanDelete" Click="RasterContain" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-delete" Text="Cover" Enabled="CanDelete" Click="RasterCover" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-delete" Text="Stretch" Enabled="CanDelete" Click="RasterStretch" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-delete" Text="Flip horizontal" Enabled="CanDelete" Click="RasterFlipHorizontal" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-delete" Text="Flip vertical" Enabled="CanDelete" Click="RasterFlipVertical" />
                        </DxRibbonItem>
                    </DxRibbonGroup>
                </DxRibbonTab>
            </DxRibbon>

            <div class="picture-studio-workspace">
                <aside class="picture-studio-layers">
                    <div class="picture-pane-heading">
                        <strong>Layers</strong>
                        <span>@State.Document.Layers.Count</span>
                    </div>
                    <div class="picture-layer-actions">
                        <button type="button" title="Add image" @onclick="RequestImage">▧</button>
                        <button type="button" title="Add text" @onclick="AddTextLayer">T</button>
                        <button type="button" title="Add shape" @onclick="AddRectangle">◇</button>
                        <button type="button" title="Add gradient" @onclick="AddGradient">◩</button>
                        <button type="button" title="Add render layer" @onclick="AddClouds">☁</button>
                        <button type="button" title="Add paint layer" @onclick="AddPaintLayer">✎</button>
                    </div>
                    <div class="picture-layer-list"
                         @oncontextmenu="ShowLayerListContextMenu"
                         @oncontextmenu:preventDefault>
                        @foreach (var layer in State.Document.Layers.AsEnumerable().Reverse())
                        {
                            <div class="picture-layer-row @(layer.Id == State.SelectedLayerId ? "selected" : null)"
                                 @oncontextmenu="args => ShowLayerContextMenu(layer, args)"
                                 @oncontextmenu:preventDefault
                                 @oncontextmenu:stopPropagation>
                                <button type="button" class="picture-layer-select" @onclick="() => State.SelectLayer(layer.Id)">
                                    <span class="picture-layer-icon">@LayerIcon(layer)</span>
                                    <span>
                                        <b>@layer.Name</b>
                                        <small>@LayerDescription(layer)</small>
                                    </span>
                                </button>
                                <button type="button" class="picture-layer-toggle" title="Show or hide" @onclick="() => State.ToggleVisibility(layer.Id)">@(layer.Visible ? "●" : "○")</button>
                                <button type="button" class="picture-layer-toggle" title="Lock or unlock" @onclick="() => State.ToggleLock(layer.Id)">@(layer.Locked ? "🔒" : "🔓")</button>
                            </div>
                        }
                        @if (State.Document.Layers.Count == 0)
                        {
                            <div class="picture-empty-layers">
                                <strong>Transparent canvas</strong>
                                <span>Add an image, text, shape, fill, paint, or procedural render layer.</span>
                            </div>
                        }
                    </div>
                    <div class="picture-layer-footer">
                        <DxButton Text="Back" Enabled="HasSelection" Click="State.SendSelectedToBack" />
                        <DxButton Text="Front" Enabled="HasSelection" Click="State.BringSelectedToFront" />
                    </div>
                </aside>

                <main id="picture-studio-canvas-host" class="picture-studio-canvas-host">
                    <div class="picture-canvas-scroll">
                        <div class="picture-canvas-mat">
                            <canvas id="picture-studio-canvas" class="picture-studio-canvas" tabindex="0" aria-label="Picture canvas"
                                    @oncontextmenu="ShowCanvasContextMenu"
                                    @oncontextmenu:preventDefault
                                    @oncontextmenu:stopPropagation></canvas>
                        </div>
                    </div>
                    <div class="picture-canvas-hint">@CanvasHint</div>
                </main>

                <aside class="picture-studio-properties">
                    <div class="picture-pane-heading picture-selection-heading @(State.SelectedLayer is null ? string.Empty : "has-selection")">
                        <span class="picture-selection-glyph">@(State.SelectedLayer is { } selectedHeadingLayer ? LayerIcon(selectedHeadingLayer) : "▱")</span>
                        <span class="picture-selection-copy">
                            <strong>@(State.SelectedLayer is null ? "Canvas properties" : "Selected layer")</strong>
                            <small>@(State.SelectedLayer is { } selectedHeading ? $"{selectedHeading.Name} · {LayerDescription(selectedHeading)}" : $"{State.Document.WidthPx} × {State.Document.HeightPx} px")</small>
                        </span>
                    </div>
                    <div class="picture-property-scroll">
                        <section class="picture-property-section">
                            <h3>Canvas</h3>
                            <label>Name
                                <input value="@State.Document.Name" @onchange="ChangeDocumentName" />
                            </label>
                            <div class="picture-property-grid">
                                <label>Width (px)
                                    <input type="number" min="16" max="8192" value="@State.Document.WidthPx" @onchange="ChangeCanvasWidth" />
                                </label>
                                <label>Height (px)
                                    <input type="number" min="16" max="8192" value="@State.Document.HeightPx" @onchange="ChangeCanvasHeight" />
                                </label>
                            </div>
                            <label>Background
                                <select value="@State.Document.Background" @onchange="ChangeBackgroundPreset">
                                    <option value="transparent">Transparent</option>
                                    <option value="#ffffff">White</option>
                                    <option value="#000000">Black</option>
                                    <option value="#f1f5f9">Light gray</option>
                                </select>
                            </label>
                            <label>Custom background
                                <input type="color" value="@CanvasColor" @onchange="ChangeCanvasColor" />
                            </label>
                            <div class="picture-preset-buttons">
                                <button type="button" @onclick="PresetSquare">Square</button>
                                <button type="button" @onclick="PresetLandscape">Landscape</button>
                                <button type="button" @onclick="PresetFullHd">Full HD</button>
                                <button type="button" @onclick="PresetA4">A4 300 DPI</button>
                            </div>
                            <label>Grid spacing (px)
                                <input type="number" min="2" max="1000" value="@State.Document.GridSpacingPx" @onchange="ChangeGridSpacing" />
                            </label>
                        </section>

                        <section class="picture-property-section picture-drawing-properties">
                            <h3>Drawing tools</h3>
                            <label>Tool
                                <select value="@_drawTool" @onchange="ChangeDrawTool">
                                    @foreach (var tool in Enum.GetValues<PictureDrawTool>())
                                    {
                                        <option value="@tool">@tool</option>
                                    }
                                </select>
                            </label>
                            <div class="picture-property-grid">
                                <label>Primary color
                                    <input type="color" value="@SafeColor(_drawColor)" @onchange="ChangeDrawColorInput" />
                                </label>
                                <label>Secondary color
                                    <input type="color" value="@SafeColor(_drawSecondaryColor)" @onchange="ChangeDrawSecondaryColorInput" />
                                </label>
                                <label>Exact width (px)
                                    <input type="number" min="0.25" max="512" step="0.25" value="@Inv(_drawWidth)" @onchange="ChangeDrawWidth" />
                                </label>
                            </div>
                            <label class="picture-brush-size-label">Brush size
                                <span class="picture-brush-size-row">
                                    <input class="picture-dynamic-range"
                                           type="range"
                                           min="0"
                                           max="100"
                                           step="0.1"
                                           value="@Inv(BrushWidthSliderValue)"
                                           style="@BrushWidthSliderStyle"
                                           aria-label="Brush size"
                                           aria-valuemin="0.25"
                                           aria-valuemax="512"
                                           aria-valuenow="@Inv(_drawWidth)"
                                           @oninput="ChangeDrawWidthSlider" />
                                    <output>@DrawWidthDisplay</output>
                                </span>
                            </label>
                            <div class="picture-brush-presets" role="group" aria-label="Brush size presets">
                                <button type="button" class="@DrawWidthButtonClass(1)" aria-pressed="@(IsDrawWidth(1) ? "true" : "false")" @onclick="DrawWidth1">1</button>
                                <button type="button" class="@DrawWidthButtonClass(3)" aria-pressed="@(IsDrawWidth(3) ? "true" : "false")" @onclick="DrawWidth3">3</button>
                                <button type="button" class="@DrawWidthButtonClass(8)" aria-pressed="@(IsDrawWidth(8) ? "true" : "false")" @onclick="DrawWidth8">8</button>
                                <button type="button" class="@DrawWidthButtonClass(16)" aria-pressed="@(IsDrawWidth(16) ? "true" : "false")" @onclick="DrawWidth16">16</button>
                                <button type="button" class="@DrawWidthButtonClass(32)" aria-pressed="@(IsDrawWidth(32) ? "true" : "false")" @onclick="DrawWidth32">32</button>
                            </div>
                            <label>Opacity
                                <input type="range" min="0" max="1" step="0.01" value="@Inv(_drawOpacity)" @oninput="ChangeDrawOpacity" />
                                <span class="picture-range-value">@Math.Round(_drawOpacity * 100)%</span>
                            </label>
                            <label>Brush hardness
                                <input type="range" min="0" max="1" step="0.01" value="@Inv(_drawHardness)" @oninput="ChangeDrawHardness" />
                                <span class="picture-range-value">@Math.Round(_drawHardness * 100)%</span>
                            </label>
                            <DxButton Text="New paint layer" Click="AddPaintLayer" CssClass="wide-button" />
                        </section>

                        @if (State.SelectedLayer is PictureLayer selected)
                        {
                            <section class="picture-property-section">
                                <h3>Layer</h3>
                                <label>Name
                                    <input value="@selected.Name" @onchange="ChangeLayerName" />
                                </label>
                                <div class="picture-property-grid">
                                    <label>X
                                        <input type="number" step="1" value="@Inv(selected.X)" @onchange="ChangeLayerX" />
                                    </label>
                                    <label>Y
                                        <input type="number" step="1" value="@Inv(selected.Y)" @onchange="ChangeLayerY" />
                                    </label>
                                    <label>Width
                                        <input type="number" min="1" step="1" value="@Inv(selected.Width)" @onchange="ChangeLayerWidth" />
                                    </label>
                                    <label>Height
                                        <input type="number" min="1" step="1" value="@Inv(selected.Height)" @onchange="ChangeLayerHeight" />
                                    </label>
                                </div>
                                <label>Rotation
                                    <input type="range" min="0" max="359" step="1" value="@Inv(selected.Rotation)" @oninput="ChangeLayerRotation" @onchange="EndLiveEdit" />
                                    <span class="picture-range-value">@Math.Round(selected.Rotation)°</span>
                                </label>
                                <label>Opacity
                                    <input type="range" min="0" max="1" step="0.01" value="@Inv(selected.Opacity)" @oninput="ChangeLayerOpacity" @onchange="EndLiveEdit" />
                                    <span class="picture-range-value">@Math.Round(selected.Opacity * 100)%</span>
                                </label>
                                <label>Blend mode
                                    <select value="@selected.BlendMode" @onchange="ChangeBlendMode">
                                        @foreach (var mode in Enum.GetValues<PictureBlendMode>())
                                        {
                                            <option value="@mode">@mode</option>
                                        }
                                    </select>
                                </label>
                                <div class="picture-check-grid">
                                    <label><input type="checkbox" checked="@selected.Visible" @onchange="ToggleSelectedVisibility" /> Visible</label>
                                    <label><input type="checkbox" checked="@selected.Locked" @onchange="ToggleSelectedLock" /> Locked</label>
                                </div>
                            </section>

                            @switch (selected)
                            {
                                case RasterPictureLayer raster:
                                    <section class="picture-property-section">
                                        <h3>Image</h3>
                                        <label>Fit
                                            <select value="@raster.FitMode" @onchange="ChangeRasterFit">
                                                @foreach (var fit in Enum.GetValues<PictureRasterFitMode>())
                                                {
                                                    <option value="@fit">@fit</option>
                                                }
                                            </select>
                                        </label>
                                        <div class="picture-check-grid">
                                            <label><input type="checkbox" checked="@raster.FlipHorizontal" @onchange="ToggleRasterFlipHorizontal" /> Flip horizontal</label>
                                            <label><input type="checkbox" checked="@raster.FlipVertical" @onchange="ToggleRasterFlipVertical" /> Flip vertical</label>
                                        </div>
                                        <label>Tint color
                                            <input type="color" value="@SafeColor(raster.TintColor)" @onchange="ChangeRasterTintColor" />
                                        </label>
                                        <label>Tint / recolor strength
                                            <input type="range" min="0" max="1" step="0.01" value="@Inv(raster.TintOpacity)" @oninput="ChangeRasterTintOpacity" @onchange="EndLiveEdit" />
                                            <span class="picture-range-value">@Math.Round(raster.TintOpacity * 100)%</span>
                                        </label>
                                    </section>
                                    break;
                                case TextPictureLayer textLayer:
                                    <section class="picture-property-section">
                                        <h3>Text</h3>
                                        <label>Content
                                            <textarea rows="4" @onchange="ChangeTextContent">@textLayer.Text</textarea>
                                        </label>
                                        <label>Font
                                            <select value="@textLayer.FontFamily" @onchange="ChangeTextFont">
                                                @foreach (var font in PictureFonts)
                                                {
                                                    <option value="@font">@font</option>
                                                }
                                            </select>
                                        </label>
                                        <div class="picture-property-grid">
                                            <label>Size
                                                <input type="number" min="4" max="1024" value="@Inv(textLayer.FontSizePx)" @onchange="ChangeTextSize" />
                                            </label>
                                            <label>Alignment
                                                <select value="@textLayer.Alignment" @onchange="ChangeTextAlignment">
                                                    @foreach (var alignment in Enum.GetValues<PictureTextAlignment>())
                                                    {
                                                        <option value="@alignment">@alignment</option>
                                                    }
                                                </select>
                                            </label>
                                        </div>
                                        <div class="picture-check-grid">
                                            <label><input type="checkbox" checked="@textLayer.Bold" @onchange="ToggleTextBold" /> Bold</label>
                                            <label><input type="checkbox" checked="@textLayer.Italic" @onchange="ToggleTextItalic" /> Italic</label>
                                            <label><input type="checkbox" checked="@textLayer.ShadowEnabled" @onchange="ToggleTextShadow" /> Shadow</label>
                                        </div>
                                        <div class="picture-property-grid">
                                            <label>Fill
                                                <input type="color" value="@SafeColor(textLayer.FillColor)" @onchange="ChangeTextFill" />
                                            </label>
                                            <label>Outline
                                                <input type="color" value="@SafeColor(textLayer.OutlineColor)" @onchange="ChangeTextOutline" />
                                            </label>
                                            <label>Outline width
                                                <input type="number" min="0" max="64" step="1" value="@Inv(textLayer.OutlineWidthPx)" @onchange="ChangeTextOutlineWidth" />
                                            </label>
                                            <label>Shadow blur
                                                <input type="number" min="0" max="200" step="1" value="@Inv(textLayer.ShadowBlurPx)" @onchange="ChangeTextShadowBlur" />
                                            </label>
                                        </div>
                                    </section>
                                    break;
                                case ShapePictureLayer shapeLayer:
                                    <section class="picture-property-section">
                                        <h3>Shape</h3>
                                        <label>Shape
                                            <select value="@shapeLayer.Shape" @onchange="ChangeShapeKind">
                                                @foreach (var shape in Enum.GetValues<PictureShapeKind>())
                                                {
                                                    <option value="@shape">@shape</option>
                                                }
                                            </select>
                                        </label>
                                        <label>Fill type
                                            <select value="@shapeLayer.FillKind" @onchange="ChangeShapeFillKind">
                                                @foreach (var fillKind in Enum.GetValues<PictureFillKind>())
                                                {
                                                    <option value="@fillKind">@fillKind</option>
                                                }
                                            </select>
                                        </label>
                                        <div class="picture-property-grid">
                                            <label>Fill 1
                                                <input type="color" value="@SafeColor(shapeLayer.FillColor)" @onchange="ChangeShapeFill" />
                                            </label>
                                            <label>Fill 2
                                                <input type="color" value="@SafeColor(shapeLayer.SecondaryFillColor)" @onchange="ChangeShapeSecondaryFill" />
                                            </label>
                                            <label>Stroke
                                                <input type="color" value="@SafeColor(shapeLayer.StrokeColor)" @onchange="ChangeShapeStroke" />
                                            </label>
                                            <label>Stroke width
                                                <input type="number" min="0" max="200" value="@Inv(shapeLayer.StrokeWidthPx)" @onchange="ChangeShapeStrokeWidth" />
                                            </label>
                                            <label>Corner radius
                                                <input type="number" min="0" max="2000" value="@Inv(shapeLayer.CornerRadiusPx)" @onchange="ChangeShapeRadius" />
                                            </label>
                                        </div>
                                        @if (shapeLayer.FillKind != PictureFillKind.Solid)
                                        {
                                            <label>Fill angle
                                                <input type="range" min="0" max="360" step="1" value="@Inv(shapeLayer.FillAngleDegrees)" @oninput="ChangeShapeFillAngle" @onchange="EndLiveEdit" />
                                                <span class="picture-range-value">@Math.Round(shapeLayer.FillAngleDegrees)°</span>
                                            </label>
                                        }
                                    </section>
                                    break;
                                case FillPictureLayer fillLayer:
                                    <section class="picture-property-section">
                                        <h3>Fill</h3>
                                        <label>Type
                                            <select value="@fillLayer.FillKind" @onchange="ChangeFillKind">
                                                @foreach (var kind in Enum.GetValues<PictureFillKind>())
                                                {
                                                    <option value="@kind">@kind</option>
                                                }
                                            </select>
                                        </label>
                                        <div class="picture-property-grid">
                                            <label>Color 1
                                                <input type="color" value="@SafeColor(fillLayer.PrimaryColor)" @onchange="ChangeFillPrimary" />
                                            </label>
                                            <label>Color 2
                                                <input type="color" value="@SafeColor(fillLayer.SecondaryColor)" @onchange="ChangeFillSecondary" />
                                            </label>
                                        </div>
                                        <label>Angle
                                            <input type="range" min="0" max="360" step="1" value="@Inv(fillLayer.AngleDegrees)" @oninput="ChangeFillAngle" @onchange="EndLiveEdit" />
                                            <span class="picture-range-value">@Math.Round(fillLayer.AngleDegrees)°</span>
                                        </label>
                                    </section>
                                    break;
                                case PaintPictureLayer paintLayer:
                                    <section class="picture-property-section">
                                        <h3>Paint</h3>
                                        <p class="picture-property-note">Brush, pencil, line and eraser strokes stay editable as a separate layer.</p>
                                        <div class="picture-paint-summary">
                                            <strong>@paintLayer.Strokes.Count</strong>
                                            <span>stored strokes</span>
                                        </div>
                                        <DxButton Text="Continue with brush" Click="BrushTool" CssClass="wide-button" />
                                        <DxButton Text="Clear all strokes" Enabled="@(paintLayer.Strokes.Count > 0 && !paintLayer.Locked)" Click="State.ClearSelectedPaint" CssClass="wide-button" />
                                    </section>
                                    break;
                                case RenderPictureLayer renderLayer:
                                    <section id="picture-render-properties" class="picture-property-section picture-selected-property-section">
                                        <h3><span class="pub-icon pub-icon-render"></span> Procedural render · @renderLayer.Name</h3>
                                        <label>Renderer
                                            <select value="@renderLayer.RenderKind" @onchange="ChangeRenderKind">
                                                @foreach (var kind in Enum.GetValues<PictureRenderKind>())
                                                {
                                                    <option value="@kind">@kind</option>
                                                }
                                            </select>
                                        </label>
                                        <div class="picture-property-grid">
                                            <label>Color 1
                                                <input type="color" value="@SafeColor(renderLayer.PrimaryColor)" @onchange="ChangeRenderPrimary" />
                                            </label>
                                            <label>Color 2
                                                <input type="color" value="@SafeColor(renderLayer.SecondaryColor)" @onchange="ChangeRenderSecondary" />
                                            </label>
                                            <label>Seed
                                                <input type="number" value="@renderLayer.Seed" @onchange="ChangeRenderSeed" />
                                            </label>
                                            <label>Scale
                                                <input type="number" min="4" max="2000" value="@Inv(renderLayer.Scale)" @onchange="ChangeRenderScale" />
                                            </label>
                                            <label>Detail
                                                <input type="number" min="1" max="8" value="@renderLayer.Detail" @onchange="ChangeRenderDetail" />
                                            </label>
                                            <label>Softness
                                                <input type="number" min="0" max="1" step="0.05" value="@Inv(renderLayer.Softness)" @onchange="ChangeRenderSoftness" />
                                            </label>
                                            <label>Contrast
                                                <input type="number" min="0.1" max="5" step="0.1" value="@Inv(renderLayer.RenderContrast)" @onchange="ChangeRenderContrast" />
                                            </label>
                                            <label>Stripe width
                                                <input type="number" min="1" max="1000" value="@Inv(renderLayer.StripeWidthPx)" @onchange="ChangeRenderStripeWidth" />
                                            </label>
                                        </div>
                                        <label>Angle
                                            <input type="range" min="0" max="360" step="1" value="@Inv(renderLayer.AngleDegrees)" @oninput="ChangeRenderAngle" @onchange="EndLiveEdit" />
                                            <span class="picture-range-value">@Math.Round(renderLayer.AngleDegrees)°</span>
                                        </label>
                                        <DxButton Text="New random seed" Click="RandomizeRender" CssClass="wide-button" />
                                    </section>
                                    break;
                            }

                            <section class="picture-property-section">
                                <h3>Adjustments</h3>
                                <label>Brightness
                                    <input type="range" min="0" max="2" step="0.01" value="@Inv(selected.Brightness)" @oninput="ChangeBrightness" @onchange="EndLiveEdit" />
                                    <span class="picture-range-value">@Math.Round(selected.Brightness * 100)%</span>
                                </label>
                                <label>Contrast
                                    <input type="range" min="0" max="2" step="0.01" value="@Inv(selected.Contrast)" @oninput="ChangeContrast" @onchange="EndLiveEdit" />
                                    <span class="picture-range-value">@Math.Round(selected.Contrast * 100)%</span>
                                </label>
                                <label>Saturation
                                    <input type="range" min="0" max="2" step="0.01" value="@Inv(selected.Saturation)" @oninput="ChangeSaturation" @onchange="EndLiveEdit" />
                                    <span class="picture-range-value">@Math.Round(selected.Saturation * 100)%</span>
                                </label>
                                <label>Hue
                                    <input type="range" min="-180" max="180" step="1" value="@Inv(selected.HueRotation)" @oninput="ChangeHue" @onchange="EndLiveEdit" />
                                    <span class="picture-range-value">@Math.Round(selected.HueRotation)°</span>
                                </label>
                                <label>Soften / blur
                                    <input type="range" min="0" max="50" step="0.25" value="@Inv(selected.Blur)" @oninput="ChangeBlur" @onchange="EndLiveEdit" />
                                    <span class="picture-range-value">@selected.Blur.ToString("0.##", CultureInfo.InvariantCulture) px</span>
                                </label>
                                <div class="picture-property-grid">
                                    <label>Grayscale
                                        <input type="range" min="0" max="1" step="0.01" value="@Inv(selected.Grayscale)" @oninput="ChangeGrayscale" @onchange="EndLiveEdit" />
                                    </label>
                                    <label>Sepia
                                        <input type="range" min="0" max="1" step="0.01" value="@Inv(selected.Sepia)" @oninput="ChangeSepia" @onchange="EndLiveEdit" />
                                    </label>
                                    <label>Invert
                                        <input type="range" min="0" max="1" step="0.01" value="@Inv(selected.Invert)" @oninput="ChangeInvert" @onchange="EndLiveEdit" />
                                    </label>
                                </div>
                                <DxButton Text="Reset adjustments" Click="ResetAdjustments" CssClass="wide-button" />
                            </section>
                        }
                    </div>
                </aside>
            </div>

            <footer class="picture-studio-footer">
                <div>
                    <span>@StatusText</span>
                    <label>Zoom
                        <input type="range" min="0.05" max="2" step="0.05" value="@Inv(State.Document.Zoom)" @oninput="ChangeZoom" />
                        <b>@Math.Round(State.Document.Zoom * 100)%</b>
                    </label>
                </div>
                <div>
                    <DxButton Text="Cancel" Click="Cancel" />
                    <DxButton Text="@(IsPictureExporting ? "Rendering…" : EditingExisting ? "Apply to picture" : "Insert into publication")" Enabled="@(!IsPictureExporting)" RenderStyle="ButtonRenderStyle.Primary" Click="Apply" />
                </div>
            </footer>
        </section>
    </div>

    <DxContextMenu @ref="_pictureContextMenu">
        <Items>
            <DxContextMenuItem Text="Undo" IconCssClass="pub-icon pub-icon-undo" Enabled="State.CanUndo" Click="State.Undo" />
            <DxContextMenuItem Text="Redo" IconCssClass="pub-icon pub-icon-redo" Enabled="State.CanRedo" Click="State.Redo" />

            @if (State.SelectedLayer is PictureLayer selectedLayer)
            {
                @if (selectedLayer is RasterPictureLayer raster)
                {
                    <DxContextMenuItem Text="Replace image…" IconCssClass="pub-icon pub-icon-picture" BeginGroup="true" Enabled="@(!raster.Locked)" Click="RequestRasterReplacement" />
                    <DxContextMenuItem Text="Image fit" Enabled="@(!raster.Locked)">
                        <Items>
                            <DxContextMenuItem Text="@(CheckedText(raster.FitMode == PictureRasterFitMode.Contain, "Contain"))" Click="RasterContain" />
                            <DxContextMenuItem Text="@(CheckedText(raster.FitMode == PictureRasterFitMode.Cover, "Cover"))" Click="RasterCover" />
                            <DxContextMenuItem Text="@(CheckedText(raster.FitMode == PictureRasterFitMode.Stretch, "Stretch"))" Click="RasterStretch" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="Flip horizontal" Enabled="@(!raster.Locked)" Click="RasterFlipHorizontal" />
                    <DxContextMenuItem Text="Flip vertical" Enabled="@(!raster.Locked)" Click="RasterFlipVertical" />
                    <DxContextMenuItem Text="Rotate image">
                        <Items>
                            <DxContextMenuItem Text="Rotate 90° left" Click="RasterRotateLeft" />
                            <DxContextMenuItem Text="Rotate 90° right" Click="RasterRotateRight" />
                            <DxContextMenuItem Text="Reset rotation" Click="RasterResetRotation" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="Tint">
                        <Items>
                            <DxContextMenuItem Text="No tint" Click="RasterNoTint" />
                            <DxContextMenuItem Text="Blue tint" Click="RasterBlueTint" />
                            <DxContextMenuItem Text="Warm tint" Click="RasterWarmTint" />
                        </Items>
                    </DxContextMenuItem>
                }
                else if (selectedLayer is TextPictureLayer pictureText)
                {
                    <DxContextMenuItem Text="Font" IconCssClass="pub-icon pub-icon-text" BeginGroup="true">
                        <Items>
                            @foreach (var font in PictureFonts)
                            {
                                <DxContextMenuItem Text="@(CheckedText(string.Equals(pictureText.FontFamily, font, StringComparison.OrdinalIgnoreCase), font))" Click="() => SetPictureTextFont(font)" />
                            }
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="Font size · @Math.Round(pictureText.FontSizePx) px">
                        <Items>
                            <DxContextMenuItem Text="24 px" Click="TextSize24" />
                            <DxContextMenuItem Text="48 px" Click="TextSize48" />
                            <DxContextMenuItem Text="72 px" Click="TextSize72" />
                            <DxContextMenuItem Text="120 px" Click="TextSize120" />
                            <DxContextMenuItem Text="180 px" Click="TextSize180" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="@(CheckedText(pictureText.Bold, "Bold"))" Click="TogglePictureTextBold" />
                    <DxContextMenuItem Text="@(CheckedText(pictureText.Italic, "Italic"))" Click="TogglePictureTextItalic" />
                    <DxContextMenuItem Text="@(CheckedText(pictureText.ShadowEnabled, "Shadow"))" Click="TogglePictureTextShadow" />
                    <DxContextMenuItem Text="Alignment">
                        <Items>
                            <DxContextMenuItem Text="@(CheckedText(pictureText.Alignment == PictureTextAlignment.Left, "Left"))" Click="TextAlignLeft" />
                            <DxContextMenuItem Text="@(CheckedText(pictureText.Alignment == PictureTextAlignment.Center, "Center"))" Click="TextAlignCenter" />
                            <DxContextMenuItem Text="@(CheckedText(pictureText.Alignment == PictureTextAlignment.Right, "Right"))" Click="TextAlignRight" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="Text color">
                        <Items>
                            <DxContextMenuItem Text="Dark blue" Click="TextColorBlue" />
                            <DxContextMenuItem Text="Black" Click="TextColorBlack" />
                            <DxContextMenuItem Text="White" Click="TextColorWhite" />
                            <DxContextMenuItem Text="Red" Click="TextColorRed" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="Outline">
                        <Items>
                            <DxContextMenuItem Text="No outline" Click="TextOutlineNone" />
                            <DxContextMenuItem Text="Thin dark outline" Click="TextOutlineThin" />
                            <DxContextMenuItem Text="Thick white outline" Click="TextOutlineThick" />
                        </Items>
                    </DxContextMenuItem>
                }
                else if (selectedLayer is PaintPictureLayer paint)
                {
                    <DxContextMenuItem Text="Continue with brush" IconCssClass="pub-icon pub-icon-edit" BeginGroup="true" Click="BrushTool" />
                    <DxContextMenuItem Text="Continue with pencil" Click="PencilTool" />
                    <DxContextMenuItem Text="Continue with spray can" Click="SprayTool" />
                    <DxContextMenuItem Text="Continue with toothbrush" Click="ToothbrushTool" />
                    <DxContextMenuItem Text="Erase strokes" Click="EraserTool" />
                    <DxContextMenuItem Text="Clear all strokes" Enabled="@(paint.Strokes.Count > 0 && !paint.Locked)" Click="State.ClearSelectedPaint" />
                }
                else if (selectedLayer is RenderPictureLayer render)
                {
                    <DxContextMenuItem Text="Renderer" BeginGroup="true">
                        <Items>
                            <DxContextMenuItem Text="@(CheckedText(render.RenderKind == PictureRenderKind.Clouds, "Clouds"))" Click="MakeRenderClouds" />
                            <DxContextMenuItem Text="@(CheckedText(render.RenderKind == PictureRenderKind.Noise, "Noise"))" Click="MakeRenderNoise" />
                            <DxContextMenuItem Text="@(CheckedText(render.RenderKind == PictureRenderKind.Stripes, "Stripes"))" Click="MakeRenderStripes" />
                            <DxContextMenuItem Text="@(CheckedText(render.RenderKind == PictureRenderKind.Vignette, "Vignette"))" Click="MakeRenderVignette" />
                            <DxContextMenuItem Text="@(CheckedText(render.RenderKind == PictureRenderKind.Bloom, "Bloom"))" Click="MakeRenderBloom" />
                            <DxContextMenuItem Text="@(CheckedText(render.RenderKind == PictureRenderKind.Neon, "Neon"))" Click="MakeRenderNeon" />
                            <DxContextMenuItem Text="@(CheckedText(render.RenderKind == PictureRenderKind.LensFlare, "Lens flare"))" Click="MakeRenderLensFlare" />
                            <DxContextMenuItem Text="@(CheckedText(render.RenderKind == PictureRenderKind.GrainNoise, "Grain noise"))" Click="MakeRenderGrainNoise" />
                            <DxContextMenuItem Text="@(CheckedText(render.RenderKind == PictureRenderKind.MotionBlur, "Motion blur"))" Click="MakeRenderMotionBlur" />
                            <DxContextMenuItem Text="@(CheckedText(render.RenderKind == PictureRenderKind.Wind, "Wind"))" Click="MakeRenderWind" />
                            <DxContextMenuItem Text="@(CheckedText(render.RenderKind == PictureRenderKind.OceanWaves, "Ocean waves"))" Click="MakeRenderOceanWaves" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="Edit all renderer properties…" IconCssClass="pub-icon pub-icon-properties" Click="FocusRenderProperties" />
                    <DxContextMenuItem Text="Colors">
                        <Items>
                            <DxContextMenuItem Text="Primary: white" Click="RenderPrimaryWhite" />
                            <DxContextMenuItem Text="Primary: black" Click="RenderPrimaryBlack" />
                            <DxContextMenuItem Text="Primary: blue" Click="RenderPrimaryBlue" />
                            <DxContextMenuItem Text="Secondary: white" BeginGroup="true" Click="RenderSecondaryWhite" />
                            <DxContextMenuItem Text="Secondary: black" Click="RenderSecondaryBlack" />
                            <DxContextMenuItem Text="Secondary: blue" Click="RenderSecondaryBlue" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="Scale · @Math.Round(render.Scale) px">
                        <Items>
                            <DxContextMenuItem Text="@(CheckedText(Math.Abs(render.Scale - 24) < .01, "24 px"))" Click="RenderScale24" />
                            <DxContextMenuItem Text="@(CheckedText(Math.Abs(render.Scale - 64) < .01, "64 px"))" Click="RenderScale64" />
                            <DxContextMenuItem Text="@(CheckedText(Math.Abs(render.Scale - 128) < .01, "128 px"))" Click="RenderScale128" />
                            <DxContextMenuItem Text="@(CheckedText(Math.Abs(render.Scale - 256) < .01, "256 px"))" Click="RenderScale256" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="Detail · @render.Detail">
                        <Items>
                            <DxContextMenuItem Text="@(CheckedText(render.Detail == 1, "1 · Fast"))" Click="RenderDetail1" />
                            <DxContextMenuItem Text="@(CheckedText(render.Detail == 2, "2"))" Click="RenderDetail2" />
                            <DxContextMenuItem Text="@(CheckedText(render.Detail == 4, "4 · Balanced"))" Click="RenderDetail4" />
                            <DxContextMenuItem Text="@(CheckedText(render.Detail == 6, "6"))" Click="RenderDetail6" />
                            <DxContextMenuItem Text="@(CheckedText(render.Detail == 8, "8 · Fine"))" Click="RenderDetail8" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="Softness · @Math.Round(render.Softness * 100)%">
                        <Items>
                            <DxContextMenuItem Text="@(CheckedText(Math.Abs(render.Softness) < .01, "0%"))" Click="RenderSoftness0" />
                            <DxContextMenuItem Text="@(CheckedText(Math.Abs(render.Softness - .25) < .01, "25%"))" Click="RenderSoftness25" />
                            <DxContextMenuItem Text="@(CheckedText(Math.Abs(render.Softness - .5) < .01, "50%"))" Click="RenderSoftness50" />
                            <DxContextMenuItem Text="@(CheckedText(Math.Abs(render.Softness - .75) < .01, "75%"))" Click="RenderSoftness75" />
                            <DxContextMenuItem Text="@(CheckedText(Math.Abs(render.Softness - 1) < .01, "100%"))" Click="RenderSoftness100" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="@RenderContrastMenuText(render)">
                        <Items>
                            <DxContextMenuItem Text="0.5×" Click="RenderContrast05" />
                            <DxContextMenuItem Text="1.0×" Click="RenderContrast10" />
                            <DxContextMenuItem Text="1.5×" Click="RenderContrast15" />
                            <DxContextMenuItem Text="2.0×" Click="RenderContrast20" />
                            <DxContextMenuItem Text="3.0×" Click="RenderContrast30" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="Angle · @Math.Round(render.AngleDegrees)°">
                        <Items>
                            <DxContextMenuItem Text="0°" Click="RenderAngle0" />
                            <DxContextMenuItem Text="45°" Click="RenderAngle45" />
                            <DxContextMenuItem Text="90°" Click="RenderAngle90" />
                            <DxContextMenuItem Text="180°" Click="RenderAngle180" />
                            <DxContextMenuItem Text="270°" Click="RenderAngle270" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="Stripe width · @Math.Round(render.StripeWidthPx) px" Enabled="@(render.RenderKind == PictureRenderKind.Stripes)">
                        <Items>
                            <DxContextMenuItem Text="8 px" Click="RenderStripe8" />
                            <DxContextMenuItem Text="16 px" Click="RenderStripe16" />
                            <DxContextMenuItem Text="32 px" Click="RenderStripe32" />
                            <DxContextMenuItem Text="64 px" Click="RenderStripe64" />
                            <DxContextMenuItem Text="128 px" Click="RenderStripe128" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="New random seed" IconCssClass="pub-icon pub-icon-random" Click="RandomizeRender" />
                    <DxContextMenuItem Text="Reset renderer settings" Click="ResetRenderSettings" />
                }
                else if (selectedLayer is ShapePictureLayer shape)
                {
                    <DxContextMenuItem Text="Shape" BeginGroup="true">
                        <Items>
                            <DxContextMenuItem Text="@(CheckedText(shape.Shape == PictureShapeKind.Rectangle, "Rectangle"))" Click="ShapeRectangle" />
                            <DxContextMenuItem Text="@(CheckedText(shape.Shape == PictureShapeKind.RoundedRectangle, "Rounded rectangle"))" Click="ShapeRoundedRectangle" />
                            <DxContextMenuItem Text="@(CheckedText(shape.Shape == PictureShapeKind.Ellipse, "Ellipse"))" Click="ShapeEllipse" />
                            <DxContextMenuItem Text="@(CheckedText(shape.Shape == PictureShapeKind.Arrow, "Arrow"))" Click="ShapeArrow" />
                            <DxContextMenuItem Text="@(CheckedText(shape.Shape == PictureShapeKind.Line, "Line"))" Click="ShapeLine" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="Fill type">
                        <Items>
                            <DxContextMenuItem Text="@(CheckedText(shape.FillKind == PictureFillKind.Solid, "Solid"))" Click="ShapeFillSolid" />
                            <DxContextMenuItem Text="@(CheckedText(shape.FillKind == PictureFillKind.LinearGradient, "Linear gradient"))" Click="ShapeFillLinear" />
                            <DxContextMenuItem Text="@(CheckedText(shape.FillKind == PictureFillKind.RadialGradient, "Radial gradient"))" Click="ShapeFillRadial" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="Fill colors">
                        <Items>
                            <DxContextMenuItem Text="Blue" Click="ShapeColorsBlue" />
                            <DxContextMenuItem Text="Green" Click="ShapeColorsGreen" />
                            <DxContextMenuItem Text="Orange" Click="ShapeColorsOrange" />
                            <DxContextMenuItem Text="Black / white" Click="ShapeColorsMono" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="Stroke width">
                        <Items>
                            <DxContextMenuItem Text="None" Click="ShapeStroke0" />
                            <DxContextMenuItem Text="1 px" Click="ShapeStroke1" />
                            <DxContextMenuItem Text="3 px" Click="ShapeStroke3" />
                            <DxContextMenuItem Text="8 px" Click="ShapeStroke8" />
                        </Items>
                    </DxContextMenuItem>
                }
                else if (selectedLayer is FillPictureLayer fill)
                {
                    <DxContextMenuItem Text="Fill type" BeginGroup="true">
                        <Items>
                            <DxContextMenuItem Text="@(CheckedText(fill.FillKind == PictureFillKind.Solid, "Solid"))" Click="FillSolid" />
                            <DxContextMenuItem Text="@(CheckedText(fill.FillKind == PictureFillKind.LinearGradient, "Linear gradient"))" Click="FillLinearGradient" />
                            <DxContextMenuItem Text="@(CheckedText(fill.FillKind == PictureFillKind.RadialGradient, "Radial gradient"))" Click="FillRadialGradient" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="Color preset">
                        <Items>
                            <DxContextMenuItem Text="Blue" Click="FillColorsBlue" />
                            <DxContextMenuItem Text="Green" Click="FillColorsGreen" />
                            <DxContextMenuItem Text="Sunset" Click="FillColorsSunset" />
                            <DxContextMenuItem Text="Black / white" Click="FillColorsMono" />
                        </Items>
                    </DxContextMenuItem>
                    <DxContextMenuItem Text="Angle">
                        <Items>
                            <DxContextMenuItem Text="0°" Click="FillAngle0" />
                            <DxContextMenuItem Text="45°" Click="FillAngle45" />
                            <DxContextMenuItem Text="90°" Click="FillAngle90" />
                            <DxContextMenuItem Text="180°" Click="FillAngle180" />
                            <DxContextMenuItem Text="270°" Click="FillAngle270" />
                        </Items>
                    </DxContextMenuItem>
                }

                <DxContextMenuItem Text="Adjustments" IconCssClass="pub-icon pub-icon-color" BeginGroup="true">
                    <Items>
                        <DxContextMenuItem Text="Brighten" Click="Brighten" />
                        <DxContextMenuItem Text="Darken" Click="Darken" />
                        <DxContextMenuItem Text="More contrast" Click="MoreContrast" />
                        <DxContextMenuItem Text="More saturation" Click="MoreSaturation" />
                        <DxContextMenuItem Text="@(CheckedText(selectedLayer.Grayscale > .5, "Grayscale"))" Click="ToggleGrayscalePreset" />
                        <DxContextMenuItem Text="@(CheckedText(selectedLayer.Sepia > .5, "Sepia"))" Click="ToggleSepiaPreset" />
                        <DxContextMenuItem Text="@(CheckedText(selectedLayer.Invert > .5, "Invert"))" Click="ToggleInvertPreset" />
                        <DxContextMenuItem Text="Soften">
                            <Items>
                                <DxContextMenuItem Text="None" Click="RemoveSoftening" />
                                <DxContextMenuItem Text="Light" Click="SoftenLight" />
                                <DxContextMenuItem Text="Medium" Click="SoftenMedium" />
                            </Items>
                        </DxContextMenuItem>
                        <DxContextMenuItem Text="Reset all adjustments" BeginGroup="true" Click="ResetAdjustments" />
                    </Items>
                </DxContextMenuItem>
                <DxContextMenuItem Text="Opacity">
                    <Items>
                        <DxContextMenuItem Text="100%" Click="LayerOpacity100" />
                        <DxContextMenuItem Text="75%" Click="LayerOpacity75" />
                        <DxContextMenuItem Text="50%" Click="LayerOpacity50" />
                        <DxContextMenuItem Text="25%" Click="LayerOpacity25" />
                    </Items>
                </DxContextMenuItem>

                <DxContextMenuItem Text="Copy" IconCssClass="pub-icon pub-icon-copy" BeginGroup="true" Click="State.CopySelected" />
                <DxContextMenuItem Text="Paste" IconCssClass="pub-icon pub-icon-paste" Enabled="State.CanPaste" Click="State.Paste" />
                <DxContextMenuItem Text="Duplicate" IconCssClass="pub-icon pub-icon-duplicate" Click="State.DuplicateSelected" />
                <DxContextMenuItem Text="Delete" IconCssClass="pub-icon pub-icon-delete" Enabled="CanDelete" Click="State.DeleteSelected" />
                <DxContextMenuItem Text="Arrange" BeginGroup="true">
                    <Items>
                        <DxContextMenuItem Text="Bring to front" Click="State.BringSelectedToFront" />
                        <DxContextMenuItem Text="Bring forward" Click="MoveUp" />
                        <DxContextMenuItem Text="Send backward" Click="MoveDown" />
                        <DxContextMenuItem Text="Send to back" Click="State.SendSelectedToBack" />
                    </Items>
                </DxContextMenuItem>
                <DxContextMenuItem Text="Place on canvas">
                    <Items>
                        <DxContextMenuItem Text="Center on canvas" Click="State.CenterSelected" />
                        <DxContextMenuItem Text="Fit to canvas" Click="State.FitSelectedToCanvas" />
                    </Items>
                </DxContextMenuItem>
                <DxContextMenuItem Text="@(selectedLayer.Locked ? "Unlock layer" : "Lock layer")" BeginGroup="true" Click="ToggleSelectedLockMenu" />
                <DxContextMenuItem Text="@(selectedLayer.Visible ? "Hide layer" : "Show layer")" Click="ToggleSelectedVisibilityMenu" />
            }
            else
            {
                <DxContextMenuItem Text="Paste layer" IconCssClass="pub-icon pub-icon-paste" BeginGroup="true" Enabled="State.CanPaste" Click="State.Paste" />
                <DxContextMenuItem Text="Insert image…" IconCssClass="pub-icon pub-icon-picture" Click="RequestImage" />
                <DxContextMenuItem Text="Insert text" IconCssClass="pub-icon pub-icon-text" Click="AddTextLayer" />
                <DxContextMenuItem Text="Insert shape">
                    <Items>
                        <DxContextMenuItem Text="Rectangle" Click="AddRectangle" />
                        <DxContextMenuItem Text="Ellipse" Click="AddEllipse" />
                        <DxContextMenuItem Text="Arrow" Click="AddArrowShape" />
                        <DxContextMenuItem Text="Line" Click="AddLineShape" />
                    </Items>
                </DxContextMenuItem>
                <DxContextMenuItem Text="Insert fill">
                    <Items>
                        <DxContextMenuItem Text="Solid color" Click="AddSolidFill" />
                        <DxContextMenuItem Text="Gradient" Click="AddGradient" />
                    </Items>
                </DxContextMenuItem>
                <DxContextMenuItem Text="Insert procedural render">
                    <Items>
                        <DxContextMenuItem Text="Clouds" Click="AddClouds" />
                        <DxContextMenuItem Text="Noise" Click="AddNoise" />
                        <DxContextMenuItem Text="Stripes" Click="AddStripes" />
                        <DxContextMenuItem Text="Vignette" Click="AddVignette" />
                        <DxContextMenuItem Text="Bloom" Click="AddBloom" />
                        <DxContextMenuItem Text="Neon" Click="AddNeon" />
                        <DxContextMenuItem Text="Lens flare" Click="AddLensFlare" />
                        <DxContextMenuItem Text="Grain noise" Click="AddGrainNoise" />
                        <DxContextMenuItem Text="Motion blur" Click="AddMotionBlur" />
                        <DxContextMenuItem Text="Wind" Click="AddWind" />
                        <DxContextMenuItem Text="Ocean waves" Click="AddOceanWaves" />
                    </Items>
                </DxContextMenuItem>
                <DxContextMenuItem Text="Insert paint layer" IconCssClass="pub-icon pub-icon-edit" Click="AddPaintLayer" />
                <DxContextMenuItem Text="Area selection" BeginGroup="true"><Items>
                    <DxContextMenuItem Text="Rectangle selection" Click="RectangleSelectTool" />
                    <DxContextMenuItem Text="Ellipse selection" Click="EllipseSelectTool" />
                    <DxContextMenuItem Text="Freehand lasso" Click="FreeSelectTool" />
                    <DxContextMenuItem Text="Magnetic lasso" Click="MagneticSelectTool" />
                    <DxContextMenuItem Text="Clear selection" Click="ClearAreaSelection" />
                </Items></DxContextMenuItem>
                <DxContextMenuItem Text="Fill selected area"><Items>
                    <DxContextMenuItem Text="Solid fill" Click="FillSolidTool" />
                    <DxContextMenuItem Text="Gradient fill" Click="FillGradientTool" />
                </Items></DxContextMenuItem>
                <DxContextMenuItem Text="View" BeginGroup="true">
                    <Items>
                        <DxContextMenuItem Text="Fit canvas" Click="FitCanvas" />
                        <DxContextMenuItem Text="100% zoom" Click="Zoom100" />
                        <DxContextMenuItem Text="@GridText" Click="ToggleGridRibbon" />
                        <DxContextMenuItem Text="@SnapText" Click="ToggleSnapRibbon" />
                    </Items>
                </DxContextMenuItem>
            }
        </Items>
    </DxContextMenu>

    <InputFile id="picture-studio-image-input" class="hidden-file-input" accept="image/png,image/jpeg,image/gif,image/webp,image/svg+xml" OnChange="ImportImage" />
}
