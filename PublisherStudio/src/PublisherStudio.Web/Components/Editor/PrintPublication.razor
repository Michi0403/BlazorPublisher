@namespace PublisherStudio.Components.Editor
@inject PublicationMediaAssetStore MediaAssets

<div class="print-publication" aria-hidden="true"
     data-playback-start="@Document.Playback.StartAutomatically.ToString().ToLowerInvariant()"
     data-playback-loop="@Document.Playback.LoopPresentation.ToString().ToLowerInvariant()"
     data-playback-controls="@Document.Playback.ShowControls.ToString().ToLowerInvariant()">
    @foreach (var publicationPage in Document.Pages)
    {
        <section class="print-page" style="@PageStyle(publicationPage)"
                 data-publisher-print-fill="true"
                 data-page-id="@publicationPage.Id"
                 data-page-width-mm="@Inv(publicationPage.WidthMm)"
                 data-page-height-mm="@Inv(publicationPage.HeightMm)"
                 data-transition-kind="@publicationPage.Transition.Kind"
                 data-transition-direction="@publicationPage.Transition.Direction"
                 data-transition-easing="@publicationPage.Transition.Easing"
                 data-transition-duration="@Inv(publicationPage.Transition.DurationSeconds)"
                 data-advance-on-click="@publicationPage.Transition.AdvanceOnClick.ToString().ToLowerInvariant()"
                 data-auto-advance="@publicationPage.Transition.AutoAdvance.ToString().ToLowerInvariant()"
                 data-auto-advance-seconds="@Inv(publicationPage.Transition.AutoAdvanceSeconds)"
                 data-timeline-duration="@Inv(publicationPage.TimelineDurationSeconds)">
            @foreach (var element in publicationPage.Elements.Where(e => e.Visible).OrderBy(e => e.ZIndex))
            {
                @if (element is ConnectorElement connector && ConnectorGeometry.TryResolve(publicationPage, connector, out var sourcePoint, out var targetPoint))
                {
                    <svg class="print-connector" style="z-index:@connector.ZIndex"
                         data-publication-element data-element-id="@connector.Id"
                         data-group-id="@connector.GroupId"
                         data-animations="@PublicationAnimationData.Animations(connector)"
                         data-interaction="@PublicationAnimationData.Interaction(connector)"
                         data-interaction-action="@connector.Interaction.Action"
                         data-playback-hidden="@connector.HiddenAtPresentationStart.ToString().ToLowerInvariant()" viewBox="0 0 @Inv(publicationPage.WidthMm) @Inv(publicationPage.HeightMm)" preserveAspectRatio="none">
                        <defs>@ConnectorMarkerDefinition(connector, true)@ConnectorMarkerDefinition(connector, false)</defs>
                        <path class="connector-hit" d="@ConnectorGeometry.Path(connector, sourcePoint, targetPoint)" fill="none" stroke="transparent" stroke-width="4"></path>
                        <path class="connector-line" d="@ConnectorGeometry.Path(connector, sourcePoint, targetPoint)" fill="none" stroke="@connector.Stroke" stroke-width="@Inv(connector.StrokeWidthMm)" stroke-dasharray="@ConnectorGeometry.DashArray(connector)" marker-start="@MarkerUrl(connector, true)" marker-end="@MarkerUrl(connector, false)"></path>
                    </svg>
                }
                else
                {
                    <div class="print-element" style="@ElementStyle(element)"
                         data-publication-element data-element-id="@element.Id"
                         data-group-id="@element.GroupId"
                         data-animations="@PublicationAnimationData.Animations(element)"
                         data-interaction="@PublicationAnimationData.Interaction(element)"
                     data-interaction-action="@element.Interaction.Action"
                     data-playback-hidden="@element.HiddenAtPresentationStart.ToString().ToLowerInvariant()"
                     data-media-kind="@(element is PublicationMediaElement ? element.Kind.ToString().ToLowerInvariant() : null)"
                     data-media-start="@(element is PublicationMediaElement mediaData ? Inv(mediaData.TimelineStartSeconds) : null)"
                     data-media-trim-start="@(element is PublicationMediaElement mediaTrimStart ? Inv(mediaTrimStart.TrimStartSeconds) : null)"
                     data-media-trim-end="@(element is PublicationMediaElement mediaTrimEnd ? Inv(mediaTrimEnd.EffectiveTrimEndSeconds) : null)"
                     data-media-volume="@(element is PublicationMediaElement mediaVolume ? Inv(mediaVolume.Volume) : null)"
                     data-media-rate="@(element is PublicationMediaElement mediaRate ? Inv(mediaRate.PlaybackRate) : null)"
                     data-media-muted="@(element is PublicationMediaElement mediaMuted ? mediaMuted.Muted.ToString().ToLowerInvariant() : null)"
                     data-media-loop="@(element is PublicationMediaElement mediaLoop ? mediaLoop.Loop.ToString().ToLowerInvariant() : null)"
                     data-media-autoplay="@(element is PublicationMediaElement mediaAuto ? mediaAuto.AutoPlay.ToString().ToLowerInvariant() : null)"
                     data-media-trigger="@(element is PublicationMediaElement mediaTrigger ? mediaTrigger.PlaybackTrigger.ToString() : null)"
                     data-media-fade-in="@(element is PublicationMediaElement mediaFadeIn ? Inv(mediaFadeIn.FadeInSeconds) : null)"
                     data-media-fade-out="@(element is PublicationMediaElement mediaFadeOut ? Inv(mediaFadeOut.FadeOutSeconds) : null)">
                        @switch (element)
                        {
                            case TextFrameElement text:
                                <div class="text-frame-content" data-publisher-print-fill="true" style="padding:@Mm(text.PaddingMm);background:@StoryBackground(text);--publisher-story-page-background:@text.DocumentBackground;--publisher-print-fill:@StoryBackground(text);border:@Mm(text.BorderWidth) solid @text.BorderColor">
                                    @((MarkupString)text.PreviewHtml)
                                </div>
                                break;
                            case ImageFrameElement image:
                                <div class="image-frame" style="@ImageFrameStyle(image)">
                                    @PictureFilter(image)
                                    <img src="@image.DataUrl" alt="@image.AltText" style="@ImageStyle(image)" />
                                </div>
                                break;
                            case VideoElement video:
                                <div class="publication-video-frame" style="background:@video.Background">
                                    <video src="@MediaSource(video)" poster="@video.PosterDataUrl" controls="@video.ShowControls" muted="@video.Muted" loop="@video.Loop"
                                           preload="metadata" playsinline data-media-control style="object-fit:@VideoFit(video.FitMode)"></video>
                                    <span class="media-object-badge">▶ @Time(video.TimelineLengthSeconds)</span>
                                </div>
                                break;
                            case AudioElement audio:
                                <div class="publication-audio-frame display-@audio.DisplayKind.ToString().ToLowerInvariant()" style="--media-accent:@audio.AccentColor">
                                    @if (audio.DisplayKind != PublicationAudioDisplayKind.Hidden)
                                    {
                                        <div class="publication-audio-heading"><span>♪</span><b>@audio.Name</b><small>@Time(audio.TimelineLengthSeconds)</small></div>
                                        @if (audio.DisplayKind == PublicationAudioDisplayKind.Waveform)
                                        {
                                            <div class="publication-audio-waveform">
                                                @foreach (var sample in AudioSamples(audio))
                                                {
                                                    <i style="height:@WaveHeight(sample)"></i>
                                                }
                                            </div>
                                        }
                                    }
                                    <audio src="@MediaSource(audio)" controls="@audio.ShowControls" muted="@audio.Muted" loop="@audio.Loop" preload="metadata" data-media-control></audio>
                                </div>
                                break;
                            case ShapeElement shape:
                                <div class="shape shape-@shape.Shape.ToString().ToLowerInvariant()" style="@ShapeStyle(shape)"></div>
                                break;
                            case WordArtElement wordArt:
                                <WordArtView Item="wordArt" IdPrefix="print" />
                                break;
                            case DataVisualElement dataVisual:
                                <DataVisualView Document="Document" Item="dataVisual" CurrentPageId="publicationPage.Id" />
                                break;
                            case SpreadsheetElement spreadsheet:
                                <div class="spreadsheet-frame @(spreadsheet.ShowGridLines ? null : "hide-gridlines")" style="background:@spreadsheet.Background;border:@Mm(spreadsheet.BorderWidthMm) solid @spreadsheet.BorderColor">
                                    @((MarkupString)spreadsheet.PreviewHtml)
                                </div>
                                break;
                            case BarcodeElement barcode:
                                <BarcodeView Item="barcode" />
                                break;
                        }
                    </div>
                }
            }
        </section>
    }
</div>

@code {
    [Parameter, EditorRequired] public PublicationDocument Document { get; set; } = default!;

    private RenderFragment PictureFilter(ImageFrameElement image) => builder =>
    {
        var sequence = 0;
        var id = PictureFilterId(image);
        builder.OpenElement(sequence++, "svg");
        builder.AddAttribute(sequence++, "class", "picture-filter-defs");
        builder.AddAttribute(sequence++, "aria-hidden", "true");
        builder.OpenElement(sequence++, "defs");
        builder.OpenElement(sequence++, "filter");
        builder.AddAttribute(sequence++, "id", id);
        builder.AddAttribute(sequence++, "x", "-20%");
        builder.AddAttribute(sequence++, "y", "-20%");
        builder.AddAttribute(sequence++, "width", "140%");
        builder.AddAttribute(sequence++, "height", "140%");
        builder.OpenElement(sequence++, "feFlood");
        builder.AddAttribute(sequence++, "flood-color", image.TintColor);
        builder.AddAttribute(sequence++, "flood-opacity", Inv(image.TintOpacity));
        builder.AddAttribute(sequence++, "result", "tint");
        builder.CloseElement();
        builder.OpenElement(sequence++, "feComposite");
        builder.AddAttribute(sequence++, "in", "tint");
        builder.AddAttribute(sequence++, "in2", "SourceAlpha");
        builder.AddAttribute(sequence++, "operator", "in");
        builder.AddAttribute(sequence++, "result", "colored");
        builder.CloseElement();
        if (image.TintMode == ImageTintMode.Overlay)
        {
            builder.OpenElement(sequence++, "feBlend");
            builder.AddAttribute(sequence++, "in", "SourceGraphic");
            builder.AddAttribute(sequence++, "in2", "colored");
            builder.AddAttribute(sequence++, "mode", BlendMode(image.BlendMode));
            builder.CloseElement();
        }
        else
        {
            builder.OpenElement(sequence++, "feComposite");
            builder.AddAttribute(sequence++, "in", "colored");
            builder.AddAttribute(sequence++, "in2", "SourceGraphic");
            builder.AddAttribute(sequence++, "operator", "over");
            builder.CloseElement();
        }
        builder.CloseElement();
        builder.CloseElement();
        builder.CloseElement();
    };

    private RenderFragment WordArt(WordArtElement item) => builder =>
    {
        var sequence = 0;
        var gradientId = $"print-wordart-gradient-{item.Id:N}";
        var pathId = $"print-wordart-path-{item.Id:N}";
        builder.OpenElement(sequence++, "svg");
        builder.AddAttribute(sequence++, "class", "wordart-svg");
        builder.AddAttribute(sequence++, "viewBox", "0 0 1000 300");
        builder.AddAttribute(sequence++, "preserveAspectRatio", "xMidYMid meet");
        builder.OpenElement(sequence++, "defs");
        builder.OpenElement(sequence++, "linearGradient");
        builder.AddAttribute(sequence++, "id", gradientId);
        builder.AddAttribute(sequence++, "x1", "0"); builder.AddAttribute(sequence++, "y1", "0");
        builder.AddAttribute(sequence++, "x2", "0"); builder.AddAttribute(sequence++, "y2", "1");
        builder.OpenElement(sequence++, "stop"); builder.AddAttribute(sequence++, "offset", "0%"); builder.AddAttribute(sequence++, "stop-color", item.SecondaryColor); builder.CloseElement();
        builder.OpenElement(sequence++, "stop"); builder.AddAttribute(sequence++, "offset", "100%"); builder.AddAttribute(sequence++, "stop-color", item.FillColor); builder.CloseElement();
        builder.CloseElement();
        if (item.Warp != WordArtWarp.None)
        {
            builder.OpenElement(sequence++, "path");
            builder.AddAttribute(sequence++, "id", pathId);
            builder.AddAttribute(sequence++, "d", WordArtPath(item.Warp));
            builder.CloseElement();
        }
        builder.CloseElement();
        foreach (var depth in Enumerable.Range(1, Math.Clamp((int)Math.Round(item.ExtrudeDepth), 0, 18)).Reverse())
            AddWordArtText(builder, ref sequence, item, pathId, item.ExtrudeColor, depth * 4, depth * 4, 0, false);
        AddWordArtText(builder, ref sequence, item, pathId, item.GradientFill ? $"url(#{gradientId})" : item.FillColor, 0, 0, item.OutlineWidth, true);
        builder.CloseElement();
    };

    private static void AddWordArtText(RenderTreeBuilder builder, ref int sequence, WordArtElement item, string pathId, string fill, double dx, double dy, double outline, bool main)
    {
        builder.OpenElement(sequence++, "text");
        builder.AddAttribute(sequence++, "x", "500");
        builder.AddAttribute(sequence++, "y", item.Warp == WordArtWarp.None ? "185" : "0");
        builder.AddAttribute(sequence++, "dx", Inv(dx));
        builder.AddAttribute(sequence++, "dy", Inv(dy));
        builder.AddAttribute(sequence++, "text-anchor", "middle");
        builder.AddAttribute(sequence++, "dominant-baseline", "middle");
        builder.AddAttribute(sequence++, "font-family", item.FontFamily);
        builder.AddAttribute(sequence++, "font-size", Inv(item.FontSizePt * 3.5));
        builder.AddAttribute(sequence++, "font-weight", item.Bold ? "700" : "400");
        builder.AddAttribute(sequence++, "font-style", item.Italic ? "italic" : "normal");
        builder.AddAttribute(sequence++, "letter-spacing", Inv(item.LetterSpacing * 2));
        builder.AddAttribute(sequence++, "fill", fill);
        builder.AddAttribute(sequence++, "stroke", main ? item.OutlineColor : "none");
        builder.AddAttribute(sequence++, "stroke-width", Inv(outline));
        builder.AddAttribute(sequence++, "paint-order", "stroke fill");
        if (main && item.ShadowEnabled) builder.AddAttribute(sequence++, "class", "wordart-main wordart-shadow");
        if (item.Warp == WordArtWarp.None)
        {
            builder.AddContent(sequence++, item.Text);
        }
        else
        {
            builder.OpenElement(sequence++, "textPath");
            builder.AddAttribute(sequence++, "href", $"#{pathId}");
            builder.AddAttribute(sequence++, "startOffset", "50%");
            builder.AddAttribute(sequence++, "text-anchor", "middle");
            builder.AddContent(sequence++, item.Text);
            builder.CloseElement();
        }
        builder.CloseElement();
    }

    private RenderFragment ConnectorMarkerDefinition(ConnectorElement connector, bool start) => builder =>
    {
        var marker = start ? connector.StartMarker : connector.EndMarker;
        if (marker == ConnectorMarker.None) return;
        var sequence = 0;
        builder.OpenElement(sequence++, "marker");
        builder.AddAttribute(sequence++, "id", MarkerId(connector, start));
        builder.AddAttribute(sequence++, "markerWidth", "8");
        builder.AddAttribute(sequence++, "markerHeight", "8");
        builder.AddAttribute(sequence++, "refX", start ? "1" : "7");
        builder.AddAttribute(sequence++, "refY", "4");
        builder.AddAttribute(sequence++, "orient", "auto-start-reverse");
        builder.AddAttribute(sequence++, "markerUnits", "strokeWidth");
        builder.OpenElement(sequence++, "path");
        builder.AddAttribute(sequence++, "d", marker switch
        {
            ConnectorMarker.Diamond => "M 0 4 L 4 0 L 8 4 L 4 8 Z",
            ConnectorMarker.Triangle => "M 0 0 L 8 4 L 0 8 Z",
            _ => "M 0 0 L 8 4 L 0 8 L 2 4 Z"
        });
        builder.AddAttribute(sequence++, "fill", connector.Stroke);
        builder.CloseElement();
        builder.CloseElement();
    };

    private static string MarkerId(ConnectorElement connector, bool start) => $"print-connector-{connector.Id:N}-{(start ? "start" : "end")}";
    private static string MarkerUrl(ConnectorElement connector, bool start)
    {
        var marker = start ? connector.StartMarker : connector.EndMarker;
        return marker == ConnectorMarker.None ? string.Empty : $"url(#{MarkerId(connector, start)})";
    }

    private static string VideoFit(PublicationVideoFitMode mode) => mode switch
    {
        PublicationVideoFitMode.Cover => "cover",
        PublicationVideoFitMode.Stretch => "fill",
        _ => "contain"
    };
    private static IEnumerable<double> AudioSamples(AudioElement audio) => audio.WaveformSamples.Count > 0
        ? audio.WaveformSamples.Take(96)
        : Enumerable.Range(0, 64).Select(index => .22 + Math.Abs(Math.Sin(index * .41)) * .68);
    private static string WaveHeight(double sample) => $"{Math.Clamp(sample, .04, 1) * 100:0.#}%";
    private static string Time(double seconds) => TimeSpan.FromSeconds(Math.Max(0, seconds)).ToString(seconds >= 3600 ? @"h\:mm\:ss" : @"m\:ss");

    private static string PageStyle(PublicationPage p) => $"width:{Mm(p.WidthMm)};height:{Mm(p.HeightMm)};background:{p.Background};--publisher-print-fill:{p.Background}";
    private static string ElementStyle(PublicationElement e) => $"left:{Mm(e.X)};top:{Mm(e.Y)};width:{Mm(e.Width)};height:{Mm(e.Height)};z-index:{e.ZIndex};transform:rotate({Inv(e.Rotation)}deg)";
    private static string ShapeStyle(ShapeElement s) => s.Shape == PublicationShape.Line
        ? $"background:{s.Stroke};height:{Mm(Math.Max(s.StrokeWidth, .3))};top:50%;position:absolute;width:100%"
        : $"background:{s.Fill};border:{Mm(s.StrokeWidth)} solid {s.Stroke};border-radius:{(s.Shape == PublicationShape.Ellipse ? "50%" : s.Shape == PublicationShape.RoundedRectangle ? Mm(s.CornerRadiusMm) : "0")}";

    private static string ImageFrameStyle(ImageFrameElement i)
    {
        var radius = i.MaskShape == ImageMaskShape.Ellipse ? "50%" : i.MaskShape == ImageMaskShape.RoundedRectangle ? Mm(i.CornerRadiusMm) : "0";
        var shadow = i.ShadowEnabled ? "2mm 2mm 4mm rgba(15,23,42,.32)" : "none";
        return $"border-radius:{radius};border:{Mm(i.BorderWidthMm)} solid {i.BorderColor};box-shadow:{shadow}";
    }

    private static string ImageStyle(ImageFrameElement i)
    {
        var fit = i.FitInsideFrame ? "contain" : "cover";
        var sx = i.FlipHorizontal ? -i.CropScale : i.CropScale;
        var sy = i.FlipVertical ? -i.CropScale : i.CropScale;
        var tint = i.TintOpacity > .001 ? $"url(#{PictureFilterId(i)}) " : string.Empty;
        return $"object-fit:{fit};transform:translate({Inv(i.CropX)}%,{Inv(i.CropY)}%) rotate({Inv(i.ImageRotation)}deg) scale({Inv(sx)},{Inv(sy)});opacity:{Inv(i.Opacity)};filter:{tint}brightness({Inv(i.Brightness)}) contrast({Inv(i.Contrast)}) saturate({Inv(i.Saturation)}) hue-rotate({Inv(i.HueRotation)}deg) invert({Inv(i.Invert)}) grayscale({Inv(i.Grayscale)}) sepia({Inv(i.Sepia)}) blur({Inv(i.Blur)}px)";
    }

    private static string PictureFilterId(ImageFrameElement image) => $"print-picture-filter-{image.Id:N}";
    private static string BlendMode(ImageBlendMode mode) => mode.ToString().ToLowerInvariant();
    private static string WordArtPath(WordArtWarp warp) => warp switch
    {
        WordArtWarp.ArchUp => "M 80 225 Q 500 5 920 225",
        WordArtWarp.ArchDown => "M 80 75 Q 500 295 920 75",
        WordArtWarp.Wave => "M 40 165 C 220 20 350 290 520 145 C 690 0 810 280 960 125",
        _ => "M 50 170 L 950 170"
    };
    private static string Mm(double value) => $"{Inv(value)}mm";
    private string MediaSource(PublicationMediaElement media) => MediaAssets.GetOrRegister(media);
    private static string Inv(double value) => value.ToString("0.###", CultureInfo.InvariantCulture);

    private static string StoryBackground(TextFrameElement text) =>
        string.IsNullOrWhiteSpace(text.DocumentBackground) || string.Equals(text.DocumentBackground, "transparent", StringComparison.OrdinalIgnoreCase)
            ? text.Background
            : text.DocumentBackground;


}
