@namespace PublisherStudio.Components.Editor

<DxRibbon CssClass="publication-ribbon categorized-ribbon" SizeMode="SizeMode.Medium" AdaptivityAutoCollapseItemsToGroups="true">
    <DxRibbonApplicationTab Text="File">
        <DxRibbonApplicationTabItem Text="New publication" IconCssClass="pub-icon pub-icon-newpage" Click="RequestNew" />
        <DxRibbonApplicationTabItem Text="Open publication" IconCssClass="pub-icon pub-icon-open" Click="RequestOpen" />
        <DxRibbonApplicationTabItem Text="Save publication" IconCssClass="pub-icon pub-icon-save" Click="RequestSave" />
        <DxRibbonApplicationTabItem Text="Export current page as PNG" IconCssClass="pub-icon pub-icon-image" Click="RequestExportPng" />
        <DxRibbonApplicationTabItem Text="Export current page as JPEG" IconCssClass="pub-icon pub-icon-image" Click="RequestExportJpeg" />
        <DxRibbonApplicationTabItem Text="Export current page as SVG" IconCssClass="pub-icon pub-icon-vector" Click="RequestExportSvg" />
        @if (CanExportSelection)
        {
            <DxRibbonApplicationTabItem Text="Export selected object as PNG" IconCssClass="pub-icon pub-icon-image" Click="RequestExportSelectedPng" />
            <DxRibbonApplicationTabItem Text="Export selected object as SVG" IconCssClass="pub-icon pub-icon-vector" Click="RequestExportSelectedSvg" />
        }
        <DxRibbonApplicationTabItem Text="Export publication as website" IconCssClass="pub-icon pub-icon-web" Click="RequestExportWebsite" />
        <DxRibbonApplicationTabItem Text="Export presentation as video" IconCssClass="pub-icon pub-icon-video" Click="RequestExportVideo" />
        <DxRibbonApplicationTabItem Text="Print / Save as PDF" IconCssClass="pub-icon pub-icon-print" Click="RequestPrint" />
    </DxRibbonApplicationTab>

    <DxRibbonTab Text="Home">
        <DxRibbonGroup Text="History" IconCssClass="pub-icon pub-icon-undo">
            <DxRibbonItem Text="Undo" IconCssClass="pub-icon pub-icon-undo" Enabled="State.CanUndo" Click="Undo" />
            <DxRibbonItem Text="Redo" IconCssClass="pub-icon pub-icon-redo" Enabled="State.CanRedo" Click="Redo" />
        </DxRibbonGroup>
        <DxRibbonGroup Text="Edit" IconCssClass="pub-icon pub-icon-copy">
            <DxRibbonItem Text="Clipboard" IconCssClass="pub-icon pub-icon-copy" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Copy" IconCssClass="pub-icon pub-icon-copy" Enabled="HasSelection" Click="Copy" />
                <DxRibbonItem Text="Paste" IconCssClass="pub-icon pub-icon-paste" Enabled="State.CanPaste" Click="Paste" />
                <DxRibbonItem Text="Duplicate" IconCssClass="pub-icon pub-icon-duplicate" Enabled="HasSelection" Click="Duplicate" />
                <DxRibbonItem Text="Delete" IconCssClass="pub-icon pub-icon-delete" Enabled="HasSelection" Click="Delete" />
            </DxRibbonItem>
        </DxRibbonGroup>
        <DxRibbonGroup Text="Arrange" IconCssClass="pub-icon pub-icon-layers">
            <DxRibbonItem Text="Layer order" IconCssClass="pub-icon pub-icon-layers" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Bring to front" IconCssClass="pub-icon pub-icon-front" Enabled="HasSelection" Click="BringToFront" />
                <DxRibbonItem Text="Bring forward" Enabled="HasSelection" Click="BringForward" />
                <DxRibbonItem Text="Send backward" Enabled="HasSelection" Click="SendBackward" />
                <DxRibbonItem Text="Send to back" Enabled="HasSelection" Click="SendToBack" />
            </DxRibbonItem>
            <DxRibbonItem Text="Align" IconCssClass="pub-icon pub-icon-align" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Left" Enabled="CanAlign" Click="AlignLeft" />
                <DxRibbonItem Text="Horizontal center" Enabled="CanAlign" Click="AlignCenter" />
                <DxRibbonItem Text="Right" Enabled="CanAlign" Click="AlignRight" />
                <DxRibbonItem Text="Top" Enabled="CanAlign" Click="AlignTop" />
                <DxRibbonItem Text="Vertical middle" Enabled="CanAlign" Click="AlignMiddle" />
                <DxRibbonItem Text="Bottom" Enabled="CanAlign" Click="AlignBottom" />
            </DxRibbonItem>
            <DxRibbonItem Text="Group" Enabled="State.CanGroupSelection" Click="GroupSelected" />
            <DxRibbonItem Text="Ungroup" Enabled="State.CanUngroupSelection" Click="UngroupSelected" />
        </DxRibbonGroup>
    </DxRibbonTab>

    <DxRibbonTab Text="Insert">
        <DxRibbonGroup Text="Content" IconCssClass="pub-icon pub-icon-insert">
            <DxRibbonItem Text="Objects" IconCssClass="pub-icon pub-icon-insert" IsPrimary="true" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Text box" IconCssClass="pub-icon pub-icon-text" Click="AddText" />
                <DxRibbonItem Text="WordArt" IconCssClass="pub-icon pub-icon-wordart" Click="AddWordArt" />
                <DxRibbonItem Text="Picture" IconCssClass="pub-icon pub-icon-picture" Click="RequestPicture" />
                <DxRibbonItem Text="Create picture" IconCssClass="pub-icon pub-icon-create-picture" Click="RequestCreatePicture" />
            </DxRibbonItem>
            <DxRibbonItem Text="Media" IconCssClass="pub-icon pub-icon-media" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Insert video" IconCssClass="pub-icon pub-icon-video" Click="RequestVideo" />
                <DxRibbonItem Text="Insert audio" IconCssClass="pub-icon pub-icon-audio" Click="RequestAudio" />
                <DxRibbonItem Text="Create video" Click="RequestCreateVideo" />
                <DxRibbonItem Text="Create audio" Click="RequestCreateAudio" />
            </DxRibbonItem>
        </DxRibbonGroup>
        <DxRibbonGroup Text="Data" IconCssClass="pub-icon pub-icon-chart">
            <DxRibbonItem Text="Charts and data" IconCssClass="pub-icon pub-icon-chart" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Bar / line chart" Click="AddChart" />
                <DxRibbonItem Text="Pie / doughnut" IconCssClass="pub-icon pub-icon-pie" Click="AddPieChart" />
                <DxRibbonItem Text="Polar chart" Click="AddPolarChart" />
                <DxRibbonItem Text="Sparkline" Click="AddSparkline" />
                <DxRibbonItem Text="Bar gauge" Click="AddBarGauge" />
                <DxRibbonItem Text="Data table" IconCssClass="pub-icon pub-icon-table" Click="AddDataTable" />
                <DxRibbonItem Text="KPI progress" Click="AddKpi" />
                <DxRibbonItem Text="Manage data" IconCssClass="pub-icon pub-icon-data" Click="RequestManageData" />
            </DxRibbonItem>
            <DxRibbonItem Text="Barcode / QR" IconCssClass="pub-icon pub-icon-barcode" IsPrimary="true" Click="RequestBarcode" />
        </DxRibbonGroup>
        <DxRibbonGroup Text="Drawing" IconCssClass="pub-icon pub-icon-shape">
            <DxRibbonItem Text="Shapes" IconCssClass="pub-icon pub-icon-shape" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Rectangle" Click="AddRectangle" />
                <DxRibbonItem Text="Rounded rectangle" Click="AddRoundedRectangle" />
                <DxRibbonItem Text="Ellipse" Click="AddEllipse" />
                <DxRibbonItem Text="Line" Click="AddLine" />
            </DxRibbonItem>
            <DxRibbonItem Text="Connectors" IconCssClass="pub-icon pub-icon-connector" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Connector" Click="StartConnector" />
                <DxRibbonItem Text="Arrow connector" IconCssClass="pub-icon pub-icon-arrow" Click="StartArrowConnector" />
            </DxRibbonItem>
        </DxRibbonGroup>
        <DxRibbonGroup Text="Pages" IconCssClass="pub-icon pub-icon-page">
            <DxRibbonItem Text="Page" IconCssClass="pub-icon pub-icon-page" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="New page" IconCssClass="pub-icon pub-icon-newpage" Click="AddPage" />
                <DxRibbonItem Text="Duplicate page" Click="DuplicatePage" />
                <DxRibbonItem Text="Delete page" Enabled="@(State.Document.Pages.Count > 1)" Click="DeletePage" />
            </DxRibbonItem>
        </DxRibbonGroup>
    </DxRibbonTab>

    <DxRibbonTab Text="Page Design">
        <DxRibbonGroup Text="Page setup">
            <DxRibbonItem Text="Page size" IconCssClass="pub-icon pub-icon-page" IsPrimary="true" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="A3 portrait" Click="SetA3Portrait" />
                <DxRibbonItem Text="A3 landscape" Click="SetA3Landscape" />
                <DxRibbonItem Text="A4 portrait" Click="SetA4Portrait" />
                <DxRibbonItem Text="A4 landscape" Click="SetA4Landscape" />
                <DxRibbonItem Text="A5 portrait" Click="SetA5Portrait" />
                <DxRibbonItem Text="A5 landscape" Click="SetA5Landscape" />
                <DxRibbonItem Text="Letter portrait" Click="SetLetterPortrait" />
                <DxRibbonItem Text="Letter landscape" Click="SetLetterLandscape" />
                <DxRibbonItem Text="Legal portrait" Click="SetLegalPortrait" />
                <DxRibbonItem Text="Tabloid landscape" Click="SetTabloidLandscape" />
                <DxRibbonItem Text="Business card" Click="SetBusinessCard" />
                <DxRibbonItem Text="Square" Click="SetSquare" />
            </DxRibbonItem>
            <DxRibbonItem Text="Swap orientation" IconCssClass="pub-icon pub-icon-rotate" Click="SwapOrientation" />
        </DxRibbonGroup>
        <DxRibbonGroup Text="Background">
            <DxRibbonColorPaletteItem Text="Page color" Value="@PagePaletteColor" ValueChanged="OnPageColorChanged">
                <Groups><DxRibbonColorGroup Header="Publication" Colors="@PageColors" /></Groups>
            </DxRibbonColorPaletteItem>
            <DxRibbonItem Text="Background options" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Transparent page" Click="SetTransparentPage" />
                <DxRibbonItem Text="White page" Click="SetWhitePage" />
            </DxRibbonItem>
        </DxRibbonGroup>
        <DxRibbonGroup Text="Guides">
            <DxRibbonItem Text="Guide commands" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Vertical center" Click="AddVerticalGuide" />
                <DxRibbonItem Text="Horizontal center" Click="AddHorizontalGuide" />
                <DxRibbonItem Text="Clear guides" Click="ClearGuides" />
            </DxRibbonItem>
        </DxRibbonGroup>
    </DxRibbonTab>

    <DxRibbonTab Text="Animations">
        <DxRibbonGroup Text="Preview" IconCssClass="pub-icon pub-icon-animation">
            <DxRibbonItem Text="Preview page" IconCssClass="pub-icon pub-icon-animation" IsPrimary="true" Click="RequestPreviewPageAnimations" />
            <DxRibbonItem Text="Preview options" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Preview selected object" Enabled="@(State.SelectedElement?.Animations.Count > 0)" Click="RequestPreviewObjectAnimations" />
                <DxRibbonItem Text="Stop preview" Click="RequestStopAnimations" />
                <DxRibbonItem Text="@TimelinePaneText" IconCssClass="pub-icon pub-icon-timeline" Click="RequestToggleTimeline" />
                <DxRibbonItem Text="Edit selected media" Enabled="IsMediaSelected" Click="RequestEditMedia" />
            </DxRibbonItem>
        </DxRibbonGroup>
        <DxRibbonGroup Text="Add animation">
            <DxRibbonItem Text="Entrance" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Fade in" Enabled="HasSelection" Click="AnimationFadeIn" />
                <DxRibbonItem Text="Fly in" Enabled="HasSelection" Click="AnimationFlyIn" />
                <DxRibbonItem Text="Zoom in" Enabled="HasSelection" Click="AnimationZoomIn" />
                <DxRibbonItem Text="Wipe in" Enabled="HasSelection" Click="AnimationWipeIn" />
            </DxRibbonItem>
            <DxRibbonItem Text="Emphasis / motion" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Pulse" Enabled="HasSelection" Click="AnimationPulse" />
                <DxRibbonItem Text="Spin" Enabled="HasSelection" Click="AnimationSpin" />
                <DxRibbonItem Text="Move" Enabled="HasSelection" Click="AnimationMove" />
                <DxRibbonItem Text="Remove object animations" Enabled="HasSelection" Click="ClearAnimations" />
            </DxRibbonItem>
            <DxRibbonItem Text="Exit" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Fade out" Enabled="HasSelection" Click="AnimationFadeOut" />
                <DxRibbonItem Text="Fly out" Enabled="HasSelection" Click="AnimationFlyOut" />
            </DxRibbonItem>
        </DxRibbonGroup>
        <DxRibbonGroup Text="Transition">
            <DxRibbonItem Text="Page transition" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="None" Click="TransitionNone" />
                <DxRibbonItem Text="Fade" Click="TransitionFade" />
                <DxRibbonItem Text="Push" Click="TransitionPush" />
                <DxRibbonItem Text="Wipe" Click="TransitionWipe" />
                <DxRibbonItem Text="Zoom" Click="TransitionZoom" />
                <DxRibbonItem Text="Flip" Click="TransitionFlip" />
            </DxRibbonItem>
        </DxRibbonGroup>
    </DxRibbonTab>

    <DxRibbonTab Text="View">
        <DxRibbonGroup Text="Workspace" IconCssClass="pub-icon pub-icon-panels">
            <DxRibbonItem Text="Panes" IconCssClass="pub-icon pub-icon-panels" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Pages pane" IconCssClass="pub-icon pub-icon-pages" Click="RequestTogglePagesPane" />
                <DxRibbonItem Text="Properties pane" IconCssClass="pub-icon pub-icon-properties" Click="RequestToggleInspectorPane" />
                <DxRibbonItem Text="@TimelinePaneText" IconCssClass="pub-icon pub-icon-timeline" Click="RequestToggleTimeline" />
                <DxRibbonItem Text="Reset layout" Click="RequestResetWorkspace" />
            </DxRibbonItem>
            <DxRibbonItem Text="Show" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="@RulersText" Click="ToggleRulers" />
                <DxRibbonItem Text="@GridText" Click="ToggleGrid" />
                <DxRibbonItem Text="@GuidesText" Click="ToggleGuides" />
            </DxRibbonItem>
        </DxRibbonGroup>
        <DxRibbonGroup Text="Measurement">
            <DxRibbonItem Text="Units" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Millimetres" Click="UnitMillimeter" />
                <DxRibbonItem Text="Centimetres" Click="UnitCentimeter" />
                <DxRibbonItem Text="Inches" Click="UnitInch" />
                <DxRibbonItem Text="Pixels" Click="UnitPixel" />
            </DxRibbonItem>
            <DxRibbonItem Text="Snapping" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="@SnapGridText" Click="ToggleSnapGrid" />
                <DxRibbonItem Text="@SnapGuidesText" Click="ToggleSnapGuides" />
                <DxRibbonItem Text="@SnapPageText" Click="ToggleSnapPage" />
                <DxRibbonItem Text="@SnapObjectsText" Click="ToggleSnapObjects" />
                <DxRibbonItem Text="@SnapInObjectsText" Click="ToggleSnapInObjects" />
            </DxRibbonItem>
        </DxRibbonGroup>
        <DxRibbonGroup Text="Zoom" IconCssClass="pub-icon pub-icon-zoom">
            <DxRibbonItem Text="Zoom" IconCssClass="pub-icon pub-icon-zoom" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Fit page" IconCssClass="pub-icon pub-icon-fit" Click="RequestFitPage" />
                <DxRibbonItem Text="50%" Click="Zoom50" />
                <DxRibbonItem Text="75%" Click="Zoom75" />
                <DxRibbonItem Text="100%" Click="Zoom100" />
                <DxRibbonItem Text="125%" Click="Zoom125" />
                <DxRibbonItem Text="150%" Click="Zoom150" />
            </DxRibbonItem>
        </DxRibbonGroup>
    </DxRibbonTab>

    <DxRibbonTab Text="Picture Tools" Contextual="true" Visible="IsImageSelected">
        <DxRibbonGroup Text="Picture" IconCssClass="pub-icon pub-icon-picture">
            <DxRibbonItem Text="Edit picture" IconCssClass="pub-icon pub-icon-create-picture" IsPrimary="true" Click="RequestEditPicture" />
            <DxRibbonItem Text="Picture commands" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Replace" Click="RequestPicture" />
                <DxRibbonItem Text="@CropCommandText" Click="ToggleCrop" />
                <DxRibbonItem Text="Fit" Click="PictureFit" />
                <DxRibbonItem Text="Fill" Click="PictureFill" />
                <DxRibbonItem Text="Reset" Click="ResetPicture" />
            </DxRibbonItem>
        </DxRibbonGroup>
        <DxRibbonGroup Text="Adjust">
            <DxRibbonItem Text="Tone and color" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Brighter" Click="BrightenPicture" />
                <DxRibbonItem Text="Darker" Click="DarkenPicture" />
                <DxRibbonItem Text="More contrast" Click="ContrastPicture" />
                <DxRibbonItem Text="Less contrast" Click="ReduceContrastPicture" />
                <DxRibbonItem Text="More color" Click="SaturatePicture" />
                <DxRibbonItem Text="Less color" Click="DesaturatePicture" />
                <DxRibbonItem Text="Grayscale" Click="ToggleGrayscale" />
                <DxRibbonItem Text="Sepia" Click="ToggleSepia" />
                <DxRibbonItem Text="Invert" Click="ToggleInvert" />
            </DxRibbonItem>
            <DxRibbonItem Text="Recolor" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Blue tint" Click="TintBlue" />
                <DxRibbonItem Text="Warm tint" Click="TintWarm" />
                <DxRibbonItem Text="Green tint" Click="TintGreen" />
                <DxRibbonItem Text="Full recolor" Click="FullRecolor" />
                <DxRibbonItem Text="Clear color" Click="ClearTint" />
            </DxRibbonItem>
        </DxRibbonGroup>
        <DxRibbonGroup Text="Frame">
            <DxRibbonItem Text="Style and ratio" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Rectangle" Click="MaskRectangle" />
                <DxRibbonItem Text="Rounded" Click="MaskRounded" />
                <DxRibbonItem Text="Ellipse" Click="MaskEllipse" />
                <DxRibbonItem Text="Shadow" Click="ToggleShadow" />
                <DxRibbonItem Text="Ratio 1:1" Click="RatioSquare" />
                <DxRibbonItem Text="Ratio 4:3" Click="RatioFourThree" />
                <DxRibbonItem Text="Ratio 16:9" Click="RatioSixteenNine" />
            </DxRibbonItem>
            <DxRibbonItem Text="Rotate / flip" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Rotate frame left" Click="RotateLeft" />
                <DxRibbonItem Text="Rotate frame right" Click="RotateRight" />
                <DxRibbonItem Text="Rotate picture left" Click="RotatePictureLeft" />
                <DxRibbonItem Text="Rotate picture right" Click="RotatePictureRight" />
                <DxRibbonItem Text="Flip horizontal" Click="FlipHorizontal" />
                <DxRibbonItem Text="Flip vertical" Click="FlipVertical" />
            </DxRibbonItem>
        </DxRibbonGroup>
    </DxRibbonTab>

    <DxRibbonTab Text="Text Box Tools" Contextual="true" Visible="IsTextSelected">
        <DxRibbonGroup Text="Text"><DxRibbonItem Text="Edit story" IconCssClass="pub-icon pub-icon-edit" IsPrimary="true" Click="RequestStoryEditor" /></DxRibbonGroup>
        <DxRibbonGroup Text="Frame">
            <DxRibbonItem Text="Frame options" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="No fill" Click="TextNoFill" />
                <DxRibbonItem Text="White fill" Click="TextWhiteFill" />
                <DxRibbonItem Text="Rotate left" Click="RotateLeft" />
                <DxRibbonItem Text="Rotate right" Click="RotateRight" />
            </DxRibbonItem>
        </DxRibbonGroup>
    </DxRibbonTab>

    <DxRibbonTab Text="WordArt Tools" Contextual="true" Visible="IsWordArtSelected">
        <DxRibbonGroup Text="WordArt" IconCssClass="pub-icon pub-icon-wordart">
            <DxRibbonItem Text="Style" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Blue gradient" Click="WordArtBlue" />
                <DxRibbonItem Text="Gold gradient" Click="WordArtGold" />
                <DxRibbonItem Text="Green gradient" Click="WordArtGreen" />
                <DxRibbonItem Text="Flat fill" Click="WordArtFlat" />
            </DxRibbonItem>
            <DxRibbonItem Text="Transform" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Straight" Click="WordArtStraight" />
                <DxRibbonItem Text="Arch up" Click="WordArtArchUp" />
                <DxRibbonItem Text="Arch down" Click="WordArtArchDown" />
                <DxRibbonItem Text="Wave" Click="WordArtWave" />
                <DxRibbonItem Text="Draw path" Click="WordArtCustomPath" />
                <DxRibbonItem Text="Reverse path" Click="WordArtReversePath" />
            </DxRibbonItem>
            <DxRibbonItem Text="Depth" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="More 3D" Click="WordArtMoreDepth" />
                <DxRibbonItem Text="Less 3D" Click="WordArtLessDepth" />
                <DxRibbonItem Text="Shadow" Click="WordArtShadow" />
            </DxRibbonItem>
        </DxRibbonGroup>
    </DxRibbonTab>

    <DxRibbonTab Text="Connector Tools" Contextual="true" Visible="IsConnectorSelected">
        <DxRibbonGroup Text="Connector" IconCssClass="pub-icon pub-icon-connector">
            <DxRibbonItem Text="Path" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Straight" Click="ConnectorStraight" />
                <DxRibbonItem Text="Elbow" Click="ConnectorElbow" />
                <DxRibbonItem Text="Curved" Click="ConnectorCurved" />
            </DxRibbonItem>
            <DxRibbonItem Text="Line style" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Solid" Click="ConnectorSolid" />
                <DxRibbonItem Text="Dashed" Click="ConnectorDashed" />
                <DxRibbonItem Text="Dotted" Click="ConnectorDotted" />
                <DxRibbonItem Text="Thicker" Click="ConnectorThicker" />
                <DxRibbonItem Text="Thinner" Click="ConnectorThinner" />
            </DxRibbonItem>
            <DxRibbonItem Text="Arrowheads" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="No arrows" Click="ConnectorNoArrows" />
                <DxRibbonItem Text="Arrow end" Click="ConnectorArrowEnd" />
                <DxRibbonItem Text="Arrows both ends" Click="ConnectorArrowsBoth" />
                <DxRibbonItem Text="Diamond start" Click="ConnectorDiamondStart" />
            </DxRibbonItem>
            <DxRibbonColorPaletteItem Text="Line color" Value="@ConnectorStroke" ValueChanged="OnConnectorStrokeChanged"><Groups><DxRibbonColorGroup Header="Publication" Colors="@PageColors" /></Groups></DxRibbonColorPaletteItem>
        </DxRibbonGroup>
    </DxRibbonTab>

    <DxRibbonTab Text="Data Tools" Contextual="true" Visible="IsDataVisualSelected">
        <DxRibbonGroup Text="Data visual" IconCssClass="pub-icon pub-icon-chart">
            <DxRibbonItem Text="Edit visual" IconCssClass="pub-icon pub-icon-edit" IsPrimary="true" Click="RequestEditDataVisual" />
            <DxRibbonItem Text="Data commands" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Manage data" Click="RequestManageData" />
                <DxRibbonItem Text="Barcode / QR" Click="RequestBarcode" />
                <DxRibbonItem Text="Refresh" Click="RefreshData" />
            </DxRibbonItem>
            <DxRibbonItem Text="Quick type" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Bar / line chart" Click="MakeCartesian" />
                <DxRibbonItem Text="Pie" Click="MakePie" />
                <DxRibbonItem Text="Sparkline" Click="MakeSparkline" />
                <DxRibbonItem Text="Gauge" Click="MakeGauge" />
                <DxRibbonItem Text="Table" Click="MakeTable" />
                <DxRibbonItem Text="KPI" Click="MakeKpi" />
            </DxRibbonItem>
        </DxRibbonGroup>
    </DxRibbonTab>

    <DxRibbonTab Text="Media Tools" Contextual="true" Visible="IsMediaSelected">
        <DxRibbonGroup Text="Media" IconCssClass="pub-icon pub-icon-media">
            <DxRibbonItem Text="Edit in Media Studio" IsPrimary="true" Click="RequestEditMedia" />
            <DxRibbonItem Text="Playback" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="@MediaMutedText" Click="ToggleMediaMuted" />
                <DxRibbonItem Text="@MediaLoopText" Click="ToggleMediaLoop" />
                <DxRibbonItem Text="@MediaAutoPlayText" Click="ToggleMediaAutoPlay" />
            </DxRibbonItem>
            <DxRibbonItem Text="Start behavior" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="@TimelinePaneText" Click="RequestToggleTimeline" />
                <DxRibbonItem Text="Start at page entry" Click="MediaStartAtPageEntry" />
                <DxRibbonItem Text="Start on click" Click="MediaStartOnClick" />
                <DxRibbonItem Text="Start with animation" Click="MediaStartWithAnimation" />
            </DxRibbonItem>
        </DxRibbonGroup>
    </DxRibbonTab>

    <DxRibbonTab Text="Shape Tools" Contextual="true" Visible="IsShapeSelected">
        <DxRibbonGroup Text="Shape" IconCssClass="pub-icon pub-icon-shape">
            <DxRibbonColorPaletteItem Text="Fill" Value="@ShapeFill" ValueChanged="OnShapeFillChanged"><Groups><DxRibbonColorGroup Header="Publication" Colors="@PageColors" /></Groups></DxRibbonColorPaletteItem>
            <DxRibbonColorPaletteItem Text="Outline" Value="@ShapeStroke" ValueChanged="OnShapeStrokeChanged"><Groups><DxRibbonColorGroup Header="Publication" Colors="@PageColors" /></Groups></DxRibbonColorPaletteItem>
            <DxRibbonItem Text="Change shape" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Rectangle" Click="SelectedShapeRectangle" />
                <DxRibbonItem Text="Rounded rectangle" Click="SelectedShapeRoundedRectangle" />
                <DxRibbonItem Text="Ellipse" Click="SelectedShapeEllipse" />
                <DxRibbonItem Text="Line" Click="SelectedShapeLine" />
            </DxRibbonItem>
            <DxRibbonItem Text="Shape commands" DropDownCssClass="publisher-ribbon-menu">
                <DxRibbonItem Text="Draw connector" Click="StartConnector" />
                <DxRibbonItem Text="Draw arrow" Click="StartArrowConnector" />
                <DxRibbonItem Text="Rotate left" Click="RotateLeft" />
                <DxRibbonItem Text="Rotate right" Click="RotateRight" />
            </DxRibbonItem>
        </DxRibbonGroup>
    </DxRibbonTab>
</DxRibbon>

@code {
    [Parameter, EditorRequired] public EditorStateService State { get; set; } = default!;
    [Parameter] public bool TimelineVisible { get; set; }
    [Parameter] public EventCallback OnNew { get; set; }
    [Parameter] public EventCallback OnOpen { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnPrint { get; set; }
    [Parameter] public EventCallback OnExportPng { get; set; }
    [Parameter] public EventCallback OnExportJpeg { get; set; }
    [Parameter] public EventCallback OnExportSvg { get; set; }
    [Parameter] public EventCallback OnExportSelectedPng { get; set; }
    [Parameter] public EventCallback OnExportSelectedSvg { get; set; }
    [Parameter] public EventCallback OnExportWebsite { get; set; }
    [Parameter] public EventCallback OnExportVideo { get; set; }
    [Parameter] public EventCallback OnInsertPicture { get; set; }
    [Parameter] public EventCallback OnCreatePicture { get; set; }
    [Parameter] public EventCallback OnEditPicture { get; set; }
    [Parameter] public EventCallback OnInsertVideo { get; set; }
    [Parameter] public EventCallback OnInsertAudio { get; set; }
    [Parameter] public EventCallback OnCreateVideo { get; set; }
    [Parameter] public EventCallback OnCreateAudio { get; set; }
    [Parameter] public EventCallback OnEditMedia { get; set; }
    [Parameter] public EventCallback OnInsertBarcode { get; set; }
    [Parameter] public EventCallback OnToggleTimeline { get; set; }
    [Parameter] public EventCallback OnEditStory { get; set; }
    [Parameter] public EventCallback OnFitPage { get; set; }
    [Parameter] public EventCallback OnTogglePagesPane { get; set; }
    [Parameter] public EventCallback OnToggleInspectorPane { get; set; }
    [Parameter] public EventCallback OnResetWorkspace { get; set; }
    [Parameter] public EventCallback<DataVisualKind> OnInsertDataVisual { get; set; }
    [Parameter] public EventCallback OnEditDataVisual { get; set; }
    [Parameter] public EventCallback OnManageData { get; set; }
    [Parameter] public EventCallback OnPreviewPageAnimations { get; set; }
    [Parameter] public EventCallback OnPreviewObjectAnimations { get; set; }
    [Parameter] public EventCallback OnStopAnimations { get; set; }

    private string CropCommandText => State.CropMode ? "Finish crop" : "Crop";
    private string RulersText => CheckText(State.Document.View.RulersVisible, "Rulers");
    private string GridText => CheckText(State.Document.View.GridVisible, "Grid");
    private string GuidesText => CheckText(State.Document.View.GuidesVisible, "Guides");
    private string SnapGridText => CheckText(State.Document.View.SnapToGrid, "Snap to grid");
    private string SnapGuidesText => CheckText(State.Document.View.SnapToGuides, "Snap to guides");
    private string SnapPageText => CheckText(State.Document.View.SnapToPage, "Snap to page");
    private string SnapObjectsText => CheckText(State.Document.View.SnapToObjects, "Snap to objects");
    private string SnapInObjectsText => CheckText(State.Document.View.SnapInObjects, "Snap in objects");
    private string TimelinePaneText => CheckText(TimelineVisible, "Timeline pane");
    private static string CheckText(bool value, string text) => value ? $"✓ {text}" : text;

    private Task RequestNew() => OnNew.InvokeAsync();
    private Task RequestOpen() => OnOpen.InvokeAsync();
    private Task RequestSave() => OnSave.InvokeAsync();
    private Task RequestPrint() => OnPrint.InvokeAsync();
    private Task RequestExportPng() => OnExportPng.InvokeAsync();
    private Task RequestExportJpeg() => OnExportJpeg.InvokeAsync();
    private Task RequestExportSvg() => OnExportSvg.InvokeAsync();
    private Task RequestExportSelectedPng() => OnExportSelectedPng.InvokeAsync();
    private Task RequestExportSelectedSvg() => OnExportSelectedSvg.InvokeAsync();
    private Task RequestExportWebsite() => OnExportWebsite.InvokeAsync();
    private Task RequestExportVideo() => OnExportVideo.InvokeAsync();
    private Task RequestPicture() => OnInsertPicture.InvokeAsync();
    private Task RequestCreatePicture() => OnCreatePicture.InvokeAsync();
    private Task RequestEditPicture() => OnEditPicture.InvokeAsync();
    private Task RequestVideo() => OnInsertVideo.InvokeAsync();
    private Task RequestAudio() => OnInsertAudio.InvokeAsync();
    private Task RequestCreateVideo() => OnCreateVideo.InvokeAsync();
    private Task RequestCreateAudio() => OnCreateAudio.InvokeAsync();
    private Task RequestEditMedia() => OnEditMedia.InvokeAsync();
    private Task RequestBarcode() => OnInsertBarcode.InvokeAsync();
    private Task RequestToggleTimeline() => OnToggleTimeline.InvokeAsync();
    private Task RequestStoryEditor() => OnEditStory.InvokeAsync();
    private Task RequestFitPage() => OnFitPage.InvokeAsync();
    private Task RequestTogglePagesPane() => OnTogglePagesPane.InvokeAsync();
    private Task RequestToggleInspectorPane() => OnToggleInspectorPane.InvokeAsync();
    private Task RequestResetWorkspace() => OnResetWorkspace.InvokeAsync();
    private Task RequestEditDataVisual() => OnEditDataVisual.InvokeAsync();
    private Task RequestManageData() => OnManageData.InvokeAsync();
    private Task RequestPreviewPageAnimations() => OnPreviewPageAnimations.InvokeAsync();
    private Task RequestPreviewObjectAnimations() => OnPreviewObjectAnimations.InvokeAsync();
    private Task RequestStopAnimations() => OnStopAnimations.InvokeAsync();

    private bool HasSelection => State.SelectedElements.Count > 0;
    private bool CanExportSelection => State.SelectedElements.Count == 1 && State.SelectedElement is not null and not ConnectorElement;
    private bool CanAlign => State.SelectedElement is not null and not ConnectorElement;
    private bool IsImageSelected => State.SelectedElement is ImageFrameElement;
    private bool IsTextSelected => State.SelectedElement is TextFrameElement;
    private bool IsShapeSelected => State.SelectedElement is ShapeElement;
    private bool IsWordArtSelected => State.SelectedElement is WordArtElement;
    private bool IsConnectorSelected => State.SelectedElement is ConnectorElement;
    private bool IsDataVisualSelected => State.SelectedElement is DataVisualElement;
    private bool IsMediaSelected => State.SelectedElement is PublicationMediaElement;
    private string MediaMutedText => CheckText((State.SelectedElement as PublicationMediaElement)?.Muted == true, "Muted");
    private string MediaLoopText => CheckText((State.SelectedElement as PublicationMediaElement)?.Loop == true, "Loop clip");
    private string MediaAutoPlayText => CheckText((State.SelectedElement as PublicationMediaElement)?.AutoPlay == true, "Play in presentation");
    private string ShapeFill => (State.SelectedElement as ShapeElement)?.Fill ?? "#ffffff";
    private string ShapeStroke => (State.SelectedElement as ShapeElement)?.Stroke ?? "#000000";
    private string ConnectorStroke => (State.SelectedElement as ConnectorElement)?.Stroke ?? "#245b85";
    private string PagePaletteColor => State.CurrentPage.Background.StartsWith('#') ? State.CurrentPage.Background : "#ffffff";
    private static readonly string[] PageColors = ["#ffffff", "#f8fafc", "#fef3c7", "#fee2e2", "#dcfce7", "#dbeafe", "#ede9fe", "#111827"];

    private void UpdateSelectedMedia(Action<PublicationMediaElement> update)
    {
        if (State.SelectedElement is PublicationMediaElement media) State.UpdateMedia(media.Id, update);
    }
    private void ToggleMediaMuted() => UpdateSelectedMedia(media => media.Muted = !media.Muted);
    private void ToggleMediaLoop() => UpdateSelectedMedia(media => media.Loop = !media.Loop);
    private void ToggleMediaAutoPlay() => UpdateSelectedMedia(media => media.AutoPlay = !media.AutoPlay);
    private void MediaStartAtPageEntry() => UpdateSelectedMedia(media => media.PlaybackTrigger = PublicationMediaPlaybackTrigger.OnPageEnter);
    private void MediaStartOnClick() => UpdateSelectedMedia(media => media.PlaybackTrigger = PublicationMediaPlaybackTrigger.OnClick);
    private void MediaStartWithAnimation() => UpdateSelectedMedia(media => media.PlaybackTrigger = PublicationMediaPlaybackTrigger.WithAnimation);

    private void Undo() => State.Undo();
    private void Redo() => State.Redo();
    private void Copy() => State.CopySelected();
    private void Paste() => State.Paste();
    private void Duplicate() => State.DuplicateSelected();
    private void Delete() => State.DeleteSelected();
    private void GroupSelected() => State.GroupSelected();
    private void UngroupSelected() => State.UngroupSelected();
    private void BringToFront() => State.BringToFront();
    private void BringForward() => State.BringForward();
    private void SendBackward() => State.SendBackward();
    private void SendToBack() => State.SendToBack();
    private void AlignLeft() => State.Align("left");
    private void AlignCenter() => State.Align("center");
    private void AlignRight() => State.Align("right");
    private void AlignTop() => State.Align("top");
    private void AlignMiddle() => State.Align("middle");
    private void AlignBottom() => State.Align("bottom");
    private void AddAnimation(PublicationAnimationEffect effect, PublicationAnimationPhase phase) => State.AddAnimation(effect, phase);
    private void AnimationFadeIn() => AddAnimation(PublicationAnimationEffect.Fade, PublicationAnimationPhase.Entrance);
    private void AnimationFlyIn() => AddAnimation(PublicationAnimationEffect.Fly, PublicationAnimationPhase.Entrance);
    private void AnimationZoomIn() => AddAnimation(PublicationAnimationEffect.Zoom, PublicationAnimationPhase.Entrance);
    private void AnimationWipeIn() => AddAnimation(PublicationAnimationEffect.Wipe, PublicationAnimationPhase.Entrance);
    private void AnimationPulse() => AddAnimation(PublicationAnimationEffect.Pulse, PublicationAnimationPhase.Emphasis);
    private void AnimationSpin() => AddAnimation(PublicationAnimationEffect.Spin, PublicationAnimationPhase.Emphasis);
    private void AnimationMove() => AddAnimation(PublicationAnimationEffect.Move, PublicationAnimationPhase.Motion);
    private void AnimationFadeOut() => AddAnimation(PublicationAnimationEffect.Fade, PublicationAnimationPhase.Exit);
    private void AnimationFlyOut() => AddAnimation(PublicationAnimationEffect.Fly, PublicationAnimationPhase.Exit);
    private void ClearAnimations() => State.ClearSelectedAnimations();
    private void SetTransition(PublicationPageTransitionKind kind) => State.UpdatePageTransition(item => item.Kind = kind);
    private void TransitionNone() => SetTransition(PublicationPageTransitionKind.None);
    private void TransitionFade() => SetTransition(PublicationPageTransitionKind.Fade);
    private void TransitionPush() => SetTransition(PublicationPageTransitionKind.Push);
    private void TransitionWipe() => SetTransition(PublicationPageTransitionKind.Wipe);
    private void TransitionZoom() => SetTransition(PublicationPageTransitionKind.Zoom);
    private void TransitionFlip() => SetTransition(PublicationPageTransitionKind.Flip);

    private void AddText() => State.AddText();
    private void AddWordArt() => State.AddWordArt();
    private void AddRectangle() => State.AddShape(PublicationShape.Rectangle);
    private void AddRoundedRectangle() => State.AddShape(PublicationShape.RoundedRectangle);
    private void AddEllipse() => State.AddShape(PublicationShape.Ellipse);
    private void AddLine() => State.AddShape(PublicationShape.Line);
    private Task AddChart() => OnInsertDataVisual.InvokeAsync(DataVisualKind.CartesianChart);
    private Task AddPieChart() => OnInsertDataVisual.InvokeAsync(DataVisualKind.PieChart);
    private Task AddPolarChart() => OnInsertDataVisual.InvokeAsync(DataVisualKind.PolarChart);
    private Task AddSparkline() => OnInsertDataVisual.InvokeAsync(DataVisualKind.Sparkline);
    private Task AddBarGauge() => OnInsertDataVisual.InvokeAsync(DataVisualKind.BarGauge);
    private Task AddDataTable() => OnInsertDataVisual.InvokeAsync(DataVisualKind.DataTable);
    private Task AddKpi() => OnInsertDataVisual.InvokeAsync(DataVisualKind.KpiProgress);
    private void RefreshData() => State.RefreshDataVisuals();
    private void MakeCartesian() => SetDataVisualKind(DataVisualKind.CartesianChart);
    private void MakePie() => SetDataVisualKind(DataVisualKind.PieChart);
    private void MakeSparkline() => SetDataVisualKind(DataVisualKind.Sparkline);
    private void MakeGauge() => SetDataVisualKind(DataVisualKind.BarGauge);
    private void MakeTable() => SetDataVisualKind(DataVisualKind.DataTable);
    private void MakeKpi() => SetDataVisualKind(DataVisualKind.KpiProgress);
    private void SetDataVisualKind(DataVisualKind kind) => State.UpdateSelected(element => { if (element is DataVisualElement visual) visual.VisualKind = kind; });
    private void StartConnector() => State.SetConnectorTool(ConnectorToolKind.Line);
    private void StartArrowConnector() => State.SetConnectorTool(ConnectorToolKind.Arrow);
    private void AddPage() => State.AddPage();
    private void DuplicatePage() => State.DuplicatePage();
    private void DeletePage() => State.DeletePage();

    private void SetA3Portrait() => SetPage(297, 420);
    private void SetA3Landscape() => SetPage(420, 297);
    private void SetA4Portrait() => SetPage(210, 297);
    private void SetA4Landscape() => SetPage(297, 210);
    private void SetA5Portrait() => SetPage(148, 210);
    private void SetA5Landscape() => SetPage(210, 148);
    private void SetLetterPortrait() => SetPage(215.9, 279.4);
    private void SetLetterLandscape() => SetPage(279.4, 215.9);
    private void SetLegalPortrait() => SetPage(215.9, 355.6);
    private void SetTabloidLandscape() => SetPage(431.8, 279.4);
    private void SetBusinessCard() => SetPage(85, 55);
    private void SetSquare() => SetPage(210, 210);
    private void SwapOrientation() => State.SwapPageOrientation();

    private void ToggleCrop() => State.ToggleCropMode();
    private void AddVerticalGuide() => State.AddGuide(GuideOrientation.Vertical);
    private void AddHorizontalGuide() => State.AddGuide(GuideOrientation.Horizontal);
    private void ClearGuides() => State.ClearGuides();
    private void ToggleRulers() => State.SetViewOption(view => view.RulersVisible = !view.RulersVisible);
    private void ToggleGrid() => State.SetViewOption(view => view.GridVisible = !view.GridVisible);
    private void ToggleGuides() => State.SetViewOption(view => view.GuidesVisible = !view.GuidesVisible);
    private void ToggleSnapGrid() => State.SetViewOption(view => view.SnapToGrid = !view.SnapToGrid);
    private void ToggleSnapGuides() => State.SetViewOption(view => view.SnapToGuides = !view.SnapToGuides);
    private void ToggleSnapPage() => State.SetViewOption(view => view.SnapToPage = !view.SnapToPage);
    private void ToggleSnapObjects() => State.SetViewOption(view => view.SnapToObjects = !view.SnapToObjects);
    private void ToggleSnapInObjects() => State.SetViewOption(view => view.SnapInObjects = !view.SnapInObjects);
    private void UnitMillimeter() => State.SetRulerUnit(MeasurementUnit.Millimeter);
    private void UnitCentimeter() => State.SetRulerUnit(MeasurementUnit.Centimeter);
    private void UnitInch() => State.SetRulerUnit(MeasurementUnit.Inch);
    private void UnitPixel() => State.SetRulerUnit(MeasurementUnit.Pixel);
    private void Zoom50() => State.SetZoom(.5);
    private void Zoom75() => State.SetZoom(.75);
    private void Zoom100() => State.SetZoom(1);
    private void Zoom125() => State.SetZoom(1.25);
    private void Zoom150() => State.SetZoom(1.5);

    private void PictureFit() => SetImage(image => image.FitInsideFrame = true);
    private void PictureFill() => SetImage(image => image.FitInsideFrame = false);
    private void BrightenPicture() => SetImage(image => image.Brightness = Math.Min(2, image.Brightness + .15));
    private void DarkenPicture() => SetImage(image => image.Brightness = Math.Max(0, image.Brightness - .15));
    private void ContrastPicture() => SetImage(image => image.Contrast = Math.Min(2, image.Contrast + .15));
    private void ReduceContrastPicture() => SetImage(image => image.Contrast = Math.Max(0, image.Contrast - .15));
    private void SaturatePicture() => SetImage(image => image.Saturation = Math.Min(2, image.Saturation + .15));
    private void DesaturatePicture() => SetImage(image => image.Saturation = Math.Max(0, image.Saturation - .15));
    private void ToggleGrayscale() => SetImage(image => image.Grayscale = image.Grayscale > 0 ? 0 : 1);
    private void ToggleSepia() => SetImage(image => image.Sepia = image.Sepia > 0 ? 0 : .85);
    private void ToggleInvert() => SetImage(image => image.Invert = image.Invert > 0 ? 0 : 1);
    private void TintBlue() => Tint("#2f75b5", ImageTintMode.Overlay);
    private void TintWarm() => Tint("#d97706", ImageTintMode.Overlay);
    private void TintGreen() => Tint("#16a34a", ImageTintMode.Overlay);
    private void FullRecolor() => SetImage(image => { image.TintMode = ImageTintMode.Recolor; image.TintOpacity = 1; });
    private void ClearTint() => SetImage(image => image.TintOpacity = 0);
    private void Tint(string color, ImageTintMode mode) => SetImage(image => { image.TintColor = color; image.TintMode = mode; image.TintOpacity = .55; });
    private void MaskRectangle() => SetImage(image => image.MaskShape = ImageMaskShape.Rectangle);
    private void MaskRounded() => SetImage(image => image.MaskShape = ImageMaskShape.RoundedRectangle);
    private void MaskEllipse() => SetImage(image => image.MaskShape = ImageMaskShape.Ellipse);
    private void ToggleShadow() => SetImage(image => image.ShadowEnabled = !image.ShadowEnabled);
    private void RatioSquare() => SetImageRatio(1);
    private void RatioFourThree() => SetImageRatio(4d / 3d);
    private void RatioSixteenNine() => SetImageRatio(16d / 9d);
    private void RotateLeft() => Rotate(-90);
    private void RotateRight() => Rotate(90);
    private void RotatePictureLeft() => SetImage(image => image.ImageRotation = NormalizeAngle(image.ImageRotation - 90));
    private void RotatePictureRight() => SetImage(image => image.ImageRotation = NormalizeAngle(image.ImageRotation + 90));
    private void FlipHorizontal() => SetImage(image => image.FlipHorizontal = !image.FlipHorizontal);
    private void FlipVertical() => SetImage(image => image.FlipVertical = !image.FlipVertical);
    private void TextNoFill() => SetText(text => text.Background = "transparent");
    private void TextWhiteFill() => SetText(text => text.Background = "#ffffff");

    private void WordArtBlue() => SetWordArt(item => { item.FillColor = "#175b9c"; item.SecondaryColor = "#8ec5ff"; item.GradientFill = true; });
    private void WordArtGold() => SetWordArt(item => { item.FillColor = "#b45309"; item.SecondaryColor = "#fde68a"; item.GradientFill = true; item.ExtrudeColor = "#78350f"; });
    private void WordArtGreen() => SetWordArt(item => { item.FillColor = "#15803d"; item.SecondaryColor = "#86efac"; item.GradientFill = true; });
    private void WordArtFlat() => SetWordArt(item => item.GradientFill = false);
    private void WordArtStraight() => SetWordArt(item => item.Warp = WordArtWarp.None);
    private void WordArtArchUp() => SetWordArt(item => item.Warp = WordArtWarp.ArchUp);
    private void WordArtArchDown() => SetWordArt(item => item.Warp = WordArtWarp.ArchDown);
    private void WordArtWave() => SetWordArt(item => item.Warp = WordArtWarp.Wave);
    private void WordArtCustomPath() => SetWordArt(item =>
    {
        item.Warp = WordArtWarp.Custom;
        item.CustomPathPoints = WordArtPathGeometry.Normalize(item.CustomPathPoints);
    });
    private void WordArtReversePath() => SetWordArt(item =>
    {
        item.Warp = WordArtWarp.Custom;
        item.CustomPathPoints = WordArtPathGeometry.Reverse(item.CustomPathPoints);
    });
    private void WordArtMoreDepth() => SetWordArt(item => item.ExtrudeDepth = Math.Min(18, item.ExtrudeDepth + 2));
    private void WordArtLessDepth() => SetWordArt(item => item.ExtrudeDepth = Math.Max(0, item.ExtrudeDepth - 2));
    private void WordArtShadow() => SetWordArt(item => item.ShadowEnabled = !item.ShadowEnabled);

    private void SetConnector(Action<ConnectorElement> update) { if (State.SelectedElement is ConnectorElement connector) State.UpdateSelected(_ => update(connector)); }
    private void ConnectorStraight() => SetConnector(connector => connector.PathKind = ConnectorPathKind.Straight);
    private void ConnectorElbow() => SetConnector(connector => connector.PathKind = ConnectorPathKind.Elbow);
    private void ConnectorCurved() => SetConnector(connector => connector.PathKind = ConnectorPathKind.Curved);
    private void ConnectorSolid() => SetConnector(connector => connector.DashStyle = ConnectorDashStyle.Solid);
    private void ConnectorDashed() => SetConnector(connector => connector.DashStyle = ConnectorDashStyle.Dash);
    private void ConnectorDotted() => SetConnector(connector => connector.DashStyle = ConnectorDashStyle.Dot);
    private void ConnectorThicker() => SetConnector(connector => connector.StrokeWidthMm = Math.Min(6, connector.StrokeWidthMm + .2));
    private void ConnectorThinner() => SetConnector(connector => connector.StrokeWidthMm = Math.Max(.15, connector.StrokeWidthMm - .2));
    private void ConnectorNoArrows() => SetConnector(connector => { connector.StartMarker = ConnectorMarker.None; connector.EndMarker = ConnectorMarker.None; });
    private void ConnectorArrowEnd() => SetConnector(connector => { connector.StartMarker = ConnectorMarker.None; connector.EndMarker = ConnectorMarker.Arrow; });
    private void ConnectorArrowsBoth() => SetConnector(connector => { connector.StartMarker = ConnectorMarker.Arrow; connector.EndMarker = ConnectorMarker.Arrow; });
    private void ConnectorDiamondStart() => SetConnector(connector => connector.StartMarker = ConnectorMarker.Diamond);
    private void OnConnectorStrokeChanged(string value) => SetConnector(connector => connector.Stroke = value);

    private void SetPage(double width, double height) => State.SetPageSize(width, height);
    private void Rotate(double amount) => State.UpdateSelected(element => element.Rotation = NormalizeAngle(element.Rotation + amount));
    private static double NormalizeAngle(double value) => (value % 360 + 360) % 360;
    private void SetImage(Action<ImageFrameElement> update) { if (State.SelectedElement is ImageFrameElement image) State.UpdateSelected(_ => update(image)); }
    private void SetImageRatio(double ratio) => SetImage(image => image.Height = Math.Max(2, image.Width / ratio));
    private void SetText(Action<TextFrameElement> update) { if (State.SelectedElement is TextFrameElement text) State.UpdateSelected(_ => update(text)); }
    private void SetWordArt(Action<WordArtElement> update) { if (State.SelectedElement is WordArtElement item) State.UpdateSelected(_ => update(item)); }
    private void OnPageColorChanged(string value) => State.UpdatePage(publicationPage => publicationPage.Background = value);
    private void SetTransparentPage() => State.UpdatePage(publicationPage => publicationPage.Background = "transparent");
    private void SetWhitePage() => State.UpdatePage(publicationPage => publicationPage.Background = "#ffffff");
    private void SetSelectedShape(PublicationShape shapeKind)
    {
        if (State.SelectedElement is not ShapeElement shape) return;
        State.UpdateSelected(_ =>
        {
            shape.Shape = shapeKind;
            if (shapeKind == PublicationShape.RoundedRectangle && shape.CornerRadiusMm < 1) shape.CornerRadiusMm = 3;
            if (shapeKind == PublicationShape.Line && shape.Height > 3) shape.Height = 2;
        });
    }
    private void SelectedShapeRectangle() => SetSelectedShape(PublicationShape.Rectangle);
    private void SelectedShapeRoundedRectangle() => SetSelectedShape(PublicationShape.RoundedRectangle);
    private void SelectedShapeEllipse() => SetSelectedShape(PublicationShape.Ellipse);
    private void SelectedShapeLine() => SetSelectedShape(PublicationShape.Line);
    private void OnShapeFillChanged(string value) { if (State.SelectedElement is ShapeElement shape) State.UpdateSelected(_ => shape.Fill = value); }
    private void OnShapeStrokeChanged(string value) { if (State.SelectedElement is ShapeElement shape) State.UpdateSelected(_ => shape.Stroke = value); }

    private void ResetPicture()
    {
        SetImage(image =>
        {
            image.CropX = 0; image.CropY = 0; image.CropScale = 1; image.ImageRotation = 0;
            image.Opacity = 1; image.Brightness = 1; image.Contrast = 1; image.Saturation = 1;
            image.HueRotation = 0; image.Invert = 0; image.Grayscale = 0; image.Sepia = 0; image.Blur = 0;
            image.FlipHorizontal = false; image.FlipVertical = false; image.MaskShape = ImageMaskShape.Rectangle;
            image.CornerRadiusMm = 4; image.BorderColor = "transparent"; image.BorderWidthMm = 0;
            image.ShadowEnabled = false; image.FitInsideFrame = false; image.TintOpacity = 0;
        });
    }
}
