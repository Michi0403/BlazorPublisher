@namespace PublisherStudio.Components.Editor
@inject IJSRuntime JS

@if (Visible && TextFrame is not null)
{
    <div class="modal-backdrop" role="presentation">
        <section id="story-editor-shell" class="story-editor-dialog" role="dialog" aria-modal="true" aria-label="Edit text story">
            <header>
                <div><strong>Edit story</strong><span>@TextFrame.Name</span></div>
                <button class="window-close" @onclick="Cancel" aria-label="Close">×</button>
            </header>

            <DxRibbon CssClass="story-editor-ribbon categorized-ribbon" SizeMode="SizeMode.Small" AdaptivityAutoCollapseItemsToGroups="true">
                <DxRibbonTab Text="Story">
                    <DxRibbonGroup Text="Dynamic fields">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-insert" Text="Insert field" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-insert" Text="Date" Click="InsertDateField" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-insert" Text="Time" Click="InsertTimeField" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-page" Text="Page number" Click="InsertPageField" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-page" Text="Page count" Click="InsertPageCountField" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-insert" Text="Publication name" Click="InsertPublicationField" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-page" Text="Page name" Click="InsertPageNameField" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-text" Text="Story name" Click="InsertStoryNameField" />
                        </DxRibbonItem>
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-command" Text="Update fields" IsPrimary="true" Click="UpdateFields" />
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-play" Text="Field display" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-visible" Text="Show results" Click="ShowFieldResults" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-visible" Text="Show codes" Click="ShowFieldCodes" />
                        </DxRibbonItem>
                    </DxRibbonGroup>
                </DxRibbonTab>
                <DxRibbonTab Text="Export">
                    <DxRibbonGroup Text="Download">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-download" Text="Download document" IsPrimary="true" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-download" Text="DOCX" Click="ExportDocx" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-download" Text="RTF" Click="ExportRtf" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-download" Text="Plain text" Click="ExportText" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-download" Text="HTML" Click="ExportHtml" />
                        </DxRibbonItem>
                    </DxRibbonGroup>
                    <DxRibbonGroup Text="Output"><DxRibbonItem Text="Print" IconCssClass="pub-icon pub-icon-print" Click="PrintStory" /></DxRibbonGroup>
                </DxRibbonTab>
            </DxRibbon>
            <details class="story-field-help story-field-help-strip">
                <summary>Available dynamic fields</summary>
                <div>
                    <strong>Dynamic fields in this publication</strong>
                    <span><code>DATE</code> Current date</span>
                    <span><code>TIME</code> Current time</span>
                    <span><code>PAGE</code> Current story page</span>
                    <span><code>NUMPAGES</code> Story page count</span>
                    <span><code>PublicationName</code> Publication title</span>
                    <span><code>PageName</code> Canvas page name</span>
                    <span><code>StoryName</code> Text-frame name</span>
                    <small>The RichEdit References → Add Text menu contains the additional built-in field commands.</small>
                </div>
            </details>

            <div id="story-editor-host" class="story-editor-host">
                <DxRichEdit @key="_editorRevision" @ref="_richEdit"
                            DocumentFormat="@_documentFormat"
                            @bind-DocumentContent="_content"
                            @bind-Selection="_selection"
                            BarMode="BarMode.Ribbon"
                            ViewType="ViewType.PrintLayout"
                            ReadOnly="false"
                            HorizontalRulerVisible="true"
                            CssClass="story-rich-edit">
                    <MailMergeSettings>
                        <DxMailMergeSettings Data="@_fieldData" ViewMergedData="true" ActiveRecord="0" />
                    </MailMergeSettings>
                </DxRichEdit>
                @if (_upgradingLegacyStory)
                {
                    <div class="story-upgrade-notice">Upgrading this legacy HTML story to DOCX so page layout, fonts, fields, colors, headers, and footers work correctly…</div>
                }
            </div>
            <footer>
                <span>Stories are stored as Office Open XML (DOCX). The canvas preview is generated as HTML.</span>
                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <strong class="story-error">@_error</strong>
                }
                <div>
                    <DxButton Text="Cancel" Click="Cancel" />
                    <DxButton Text="Apply to frame" RenderStyle="ButtonRenderStyle.Primary" Click="Apply" />
                </div>
            </footer>
        </section>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public TextFrameElement? TextFrame { get; set; }
    [Parameter] public string PublicationName { get; set; } = "Publication";
    [Parameter] public string PageName { get; set; } = "Page";
    [Parameter] public int PageNumber { get; set; } = 1;
    [Parameter] public int PageCount { get; set; } = 1;
    [Parameter] public EventCallback<(byte[] Content, string PreviewHtml, string DocumentBackground, StoryStorageFormat Format)> Saved { get; set; }
    [Parameter] public EventCallback Cancelled { get; set; }

    private DxRichEdit? _richEdit;
    private Selection _selection = default!;
    private byte[] _content = [];
    private Guid? _loadedId;
    private DocumentFormat _documentFormat = DocumentFormat.OpenXml;
    private int _editorRevision;
    private bool _legacyConversionPending;
    private bool _upgradingLegacyStory;
    private string? _error;
    private IReadOnlyList<PublicationFieldRecord> _fieldData = [];
    private string? _storyPreviewTransferId;
    private readonly System.Text.StringBuilder _storyPreviewBuffer = new();
    private int _storyPreviewExpectedLength;
    private int _storyPreviewExpectedChunks;
    private int _storyPreviewNextChunk;
    private string _storyPreviewBackground = "transparent";
    private StoryPreviewResult? _storyPreviewResult;
    private string? _storyPreviewTransferError;

    protected override void OnParametersSet()
    {
        if (Visible && TextFrame is not null && _loadedId != TextFrame.Id)
        {
            _editorRevision++;
            _content = TextFrame.DocumentContent.ToArray();
            _documentFormat = TextFrame.StoryFormat == StoryStorageFormat.Html ? DocumentFormat.Html : DocumentFormat.OpenXml;
            _legacyConversionPending = TextFrame.StoryFormat == StoryStorageFormat.Html;
            _loadedId = TextFrame.Id;
            _error = null;
            _fieldData =
            [
                new PublicationFieldRecord
                {
                    PublicationName = PublicationName,
                    PageName = PageName,
                    StoryName = TextFrame.Name,
                    PageNumber = PageNumber,
                    PageCount = PageCount,
                    CurrentDate = DateTime.Today,
                    CurrentDateTime = DateTime.Now
                }
            ];
        }

        if (!Visible)
        {
            _loadedId = null;
            _legacyConversionPending = false;
            _upgradingLegacyStory = false;
            _error = null;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Visible)
        {
            try { await JS.InvokeVoidAsync("publisherStudio.initializeStoryEditorLayout", "story-editor-shell", "story-editor-host"); }
            catch (JSDisconnectedException) { }
        }
        if (!_legacyConversionPending || _richEdit is null || _upgradingLegacyStory) return;

        _upgradingLegacyStory = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var openXml = await _richEdit.ExportDocumentAsync(DocumentFormat.OpenXml);
            _documentFormat = DocumentFormat.OpenXml;
            _content = openXml;
            _legacyConversionPending = false;
            _editorRevision++;
        }
        catch (Exception ex)
        {
            _error = $"Legacy story conversion failed: {ex.Message}";
        }
        finally
        {
            _upgradingLegacyStory = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task Apply()
    {
        if (_richEdit is null || _upgradingLegacyStory) return;
        _error = null;
        try
        {
            // Export the live RichEdit document directly. SaveDocumentAsync can rebind the
            // DocumentContent parameter before the export completes and used to drop direct
            // formatting in the persisted copy even though a manual DOCX download was correct.
            var openXml = await _richEdit.ExportDocumentAsync(DocumentFormat.OpenXml);
            var html = await _richEdit.ExportDocumentAsync(DocumentFormat.Html);
            var openXmlBackground = PublicationFileService.ExtractOpenXmlDocumentBackground(openXml);
            var prepared = await PrepareStoryPreview(html, openXmlBackground);
            var preview = prepared.Html;
            var documentBackground = prepared.Background;
            _content = openXml.ToArray();
            _documentFormat = DocumentFormat.OpenXml;
            await Saved.InvokeAsync((openXml, preview, documentBackground, StoryStorageFormat.OpenXml));
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task InsertField(string code)
    {
        if (_richEdit is null || _selection is null) return;
        try
        {
            var field = await _selection.ActiveSubDocument.Fields.CreateAsync(_selection.CaretPosition, code);
            await _selection.ActiveSubDocument.Fields.UpdateAsync(field);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private Task InsertDateField() => InsertField("DATE");
    private Task InsertTimeField() => InsertField("TIME");
    private Task InsertPageField() => InsertField("PAGE");
    private Task InsertPageCountField() => InsertField("NUMPAGES");
    private Task InsertPublicationField() => InsertField("MERGEFIELD PublicationName");
    private Task InsertPageNameField() => InsertField("MERGEFIELD PageName");
    private Task InsertStoryNameField() => InsertField("MERGEFIELD StoryName");

    private async Task UpdateFields()
    {
        if (_richEdit is null) return;
        try { await _richEdit.DocumentAPI.Fields.UpdateAllAsync(true); }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task ShowFieldCodes()
    {
        if (_richEdit is null) return;
        try { await _richEdit.DocumentAPI.Fields.ShowAllFieldCodesAsync(true); }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task ShowFieldResults()
    {
        if (_richEdit is null) return;
        try { await _richEdit.DocumentAPI.Fields.ShowAllFieldResultsAsync(true); }
        catch (Exception ex) { _error = ex.Message; }
    }

    private Task ExportDocx() => ExportStory(DocumentFormat.OpenXml, ".docx", "application/vnd.openxmlformats-officedocument.wordprocessingml.document");
    private Task ExportRtf() => ExportStory(DocumentFormat.Rtf, ".rtf", "application/rtf");
    private Task ExportText() => ExportStory(DocumentFormat.PlainText, ".txt", "text/plain;charset=utf-8");
    private Task ExportHtml() => ExportStory(DocumentFormat.Html, ".html", "text/html;charset=utf-8");

    private async Task ExportStory(DocumentFormat format, string extension, string mimeType)
    {
        if (_richEdit is null || TextFrame is null) return;
        try
        {
            var content = await _richEdit.ExportDocumentAsync(format);
            if (format == DocumentFormat.Html)
            {
                var openXml = await _richEdit.ExportDocumentAsync(DocumentFormat.OpenXml);
                var prepared = await PrepareStoryPreview(
                    content,
                    PublicationFileService.ExtractOpenXmlDocumentBackground(openXml));
                content = System.Text.Encoding.UTF8.GetBytes(StandaloneStoryHtml(prepared, $"{PublicationName} – {TextFrame.Name}"));
            }
            var baseName = PublicationFileService.SafeFileName($"{PublicationName}-{TextFrame.Name}");
            await using var stream = new MemoryStream(content);
            using var reference = new DotNetStreamReference(stream);
            await JS.InvokeVoidAsync("publisherStudio.downloadStream", baseName + extension, reference, mimeType);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task PrintStory()
    {
        if (_richEdit is null || TextFrame is null) return;
        try
        {
            var openXml = await _richEdit.ExportDocumentAsync(DocumentFormat.OpenXml);
            var html = await _richEdit.ExportDocumentAsync(DocumentFormat.Html);
            var prepared = await PrepareStoryPreview(
                html,
                PublicationFileService.ExtractOpenXmlDocumentBackground(openXml));
            await JS.InvokeVoidAsync("publisherStudio.printStoryHtml", StandaloneStoryHtml(prepared, $"{PublicationName} – {TextFrame.Name}"));
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task<StoryPreviewResult> PrepareStoryPreview(byte[] html, string? preferredBackground = null)
    {
        var normalizedPreferredBackground = PublicationFileService.NormalizeCssBackground(preferredBackground);
        var fallback = new StoryPreviewResult
        {
            Html = PublicationFileService.ExtractHtmlBody(html),
            Background = IsVisibleBackground(normalizedPreferredBackground)
                ? normalizedPreferredBackground
                : TextFrame?.DocumentBackground ?? "transparent"
        };
        try
        {
            ResetStoryPreviewTransfer();
            using var htmlStream = new MemoryStream(html, writable: false);
            using var htmlReference = new DotNetStreamReference(htmlStream);
            using var receiverReference = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync(
                "publisherStudio.prepareStoryPreviewHtmlInChunks",
                htmlReference,
                normalizedPreferredBackground,
                receiverReference);

            var prepared = _storyPreviewResult
                ?? throw new JSException(_storyPreviewTransferError ?? "The formatted story preview transfer did not complete.");
            if (IsVisibleBackground(normalizedPreferredBackground))
                prepared.Background = normalizedPreferredBackground;
            prepared.Background = PublicationFileService.NormalizeCssBackground(prepared.Background);
            ResetStoryPreviewTransfer();
            return prepared;
        }
        catch (JSDisconnectedException) { ResetStoryPreviewTransfer(); return fallback; }
        catch (TaskCanceledException) { ResetStoryPreviewTransfer(); return fallback; }
        catch (JSException) { ResetStoryPreviewTransfer(); return fallback; }
    }

    [JSInvokable]
    public bool BeginStoryPreviewTransfer(string transferId, int totalLength, int chunkCount, string background)
    {
        ResetStoryPreviewTransfer();
        if (string.IsNullOrWhiteSpace(transferId) || totalLength < 0 || chunkCount <= 0)
        {
            _storyPreviewTransferError = "The story preview transfer metadata is invalid.";
            return false;
        }

        _storyPreviewTransferId = transferId;
        _storyPreviewExpectedLength = totalLength;
        _storyPreviewExpectedChunks = chunkCount;
        _storyPreviewBackground = PublicationFileService.NormalizeCssBackground(background);
        return true;
    }

    [JSInvokable]
    public bool AppendStoryPreviewChunk(string transferId, int chunkIndex, string chunk)
    {
        if (!string.Equals(_storyPreviewTransferId, transferId, StringComparison.Ordinal)
            || chunkIndex != _storyPreviewNextChunk)
        {
            _storyPreviewTransferError = "The formatted story preview chunks arrived out of order.";
            return false;
        }

        _storyPreviewBuffer.Append(chunk ?? string.Empty);
        _storyPreviewNextChunk++;
        return true;
    }

    [JSInvokable]
    public bool CompleteStoryPreviewTransfer(string transferId)
    {
        if (!string.Equals(_storyPreviewTransferId, transferId, StringComparison.Ordinal)
            || _storyPreviewNextChunk != _storyPreviewExpectedChunks
            || _storyPreviewBuffer.Length != _storyPreviewExpectedLength)
        {
            _storyPreviewTransferError = "The formatted story preview transfer was incomplete.";
            return false;
        }

        _storyPreviewResult = new StoryPreviewResult
        {
            Html = _storyPreviewBuffer.ToString(),
            Background = _storyPreviewBackground
        };
        return true;
    }

    private void ResetStoryPreviewTransfer()
    {
        _storyPreviewTransferId = null;
        _storyPreviewBuffer.Clear();
        _storyPreviewExpectedLength = 0;
        _storyPreviewExpectedChunks = 0;
        _storyPreviewNextChunk = 0;
        _storyPreviewBackground = "transparent";
        _storyPreviewResult = null;
        _storyPreviewTransferError = null;
    }

    private static string StandaloneStoryHtml(StoryPreviewResult prepared, string title)
    {
        var safeTitle = System.Net.WebUtility.HtmlEncode(title);
        var background = PublicationFileService.NormalizeCssBackground(prepared.Background);
        return $$"""
            <!doctype html>
            <html lang="en">
            <head>
              <meta charset="utf-8">
              <meta name="viewport" content="width=device-width,initial-scale=1">
              <title>{{safeTitle}}</title>
              <style>
                * { box-sizing:border-box; -webkit-print-color-adjust:exact; print-color-adjust:exact; }
                html,body { min-height:100%; margin:0; background:#e5e7eb; }
                body { display:grid; place-items:start center; padding:24px; font-family:Segoe UI,Arial,sans-serif; --publisher-story-page-background:{{background}}; }
                .publisher-story-document { position:relative; isolation:isolate; width:min(100%,1200px); min-height:calc(100vh - 48px); background:var(--publisher-story-page-background,white); box-shadow:0 3px 18px #0003; }
                .publisher-story-document::before { content:""; position:absolute; z-index:-1; inset:0; background:var(--publisher-story-page-background,white); }
                @media print {
                  @page { margin:0; }
                  html,body { background:white; }
                  body { display:block; padding:0; }
                  .publisher-story-document { width:100%; min-height:100vh; margin:0; box-shadow:none; }
                  .publisher-story-document[data-publisher-print-fill],
                  .publisher-story-document [data-publisher-print-fill] {
                    background-color:var(--publisher-print-fill,transparent) !important;
                    -webkit-box-shadow:inset 0 0 0 100vmax var(--publisher-print-fill,transparent) !important;
                    box-shadow:inset 0 0 0 100vmax var(--publisher-print-fill,transparent) !important;
                  }
                }
              </style>
            </head>
            <body>{{prepared.Html}}</body>
            </html>
            """;
    }

    private static bool IsVisibleBackground(string? value) =>
        !string.IsNullOrWhiteSpace(value)
        && !string.Equals(value, "transparent", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(value, "none", StringComparison.OrdinalIgnoreCase);

    private Task Cancel() => Cancelled.InvokeAsync();

    public sealed class StoryPreviewResult
    {
        public string Html { get; set; } = "<div class=\"publisher-story-document\"><p></p></div>";
        public string Background { get; set; } = "transparent";
    }
}
