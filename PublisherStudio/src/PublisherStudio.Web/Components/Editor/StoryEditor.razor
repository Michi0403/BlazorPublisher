@namespace PublisherStudio.Components.Editor
@implements IDisposable
@inject IJSRuntime JS
@inject SystemFontCatalog SystemFonts

@if (Visible && TextFrame is not null)
{
    <div class="modal-backdrop" role="presentation">
        <section id="story-editor-shell" class="story-editor-dialog" role="dialog" aria-modal="true" aria-label="Edit text story">
            <header>
                <div><strong>Edit story</strong><span>@TextFrame.Name</span></div>
                <button class="window-close" @onclick="Cancel" aria-label="Close">×</button>
            </header>

            <DxRibbon CssClass="story-editor-ribbon categorized-ribbon" SizeMode="SizeMode.Small" AdaptivityAutoCollapseItemsToGroups="true">
                <DxRibbonTab Text="Story">
                    <DxRibbonGroup Text="Dynamic fields">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-insert" Text="Insert field" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-insert" Text="Date" Click="InsertDateField" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-insert" Text="Time" Click="InsertTimeField" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-page" Text="Page number" Click="InsertPageField" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-page" Text="Page count" Click="InsertPageCountField" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-insert" Text="Publication name" Click="InsertPublicationField" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-page" Text="Page name" Click="InsertPageNameField" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-text" Text="Story name" Click="InsertStoryNameField" />
                        </DxRibbonItem>
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-command" Text="Update fields" IsPrimary="true" Click="UpdateFields" />
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-play" Text="Field display" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-visible" Text="Show results" Click="ShowFieldResults" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-visible" Text="Show codes" Click="ShowFieldCodes" />
                        </DxRibbonItem>
                    </DxRibbonGroup>
                </DxRibbonTab>
                <DxRibbonTab Text="Export">
                    <DxRibbonGroup Text="Download">
                        <DxRibbonItem IconCssClass="pub-icon pub-icon-download" Text="Download document" IsPrimary="true" DropDownCssClass="publisher-ribbon-menu">
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-download" Text="DOCX" Click="ExportDocx" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-download" Text="RTF" Click="ExportRtf" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-download" Text="Plain text" Click="ExportText" />
                            <DxRibbonItem IconCssClass="pub-icon pub-icon-download" Text="HTML" Click="ExportHtml" />
                        </DxRibbonItem>
                    </DxRibbonGroup>
                    <DxRibbonGroup Text="Output"><DxRibbonItem Text="Print" IconCssClass="pub-icon pub-icon-print" Click="PrintStory" /></DxRibbonGroup>
                </DxRibbonTab>
            </DxRibbon>
            <details class="story-field-help story-field-help-strip">
                <summary>Available dynamic fields</summary>
                <div>
                    <strong>Dynamic fields in this publication</strong>
                    <span><code>DATE</code> Current date</span>
                    <span><code>TIME</code> Current time</span>
                    <span><code>PAGE</code> Current story page</span>
                    <span><code>NUMPAGES</code> Story page count</span>
                    <span><code>PublicationName</code> Publication title</span>
                    <span><code>PageName</code> Canvas page name</span>
                    <span><code>StoryName</code> Text-frame name</span>
                    <small>The RichEdit References → Add Text menu contains the additional built-in field commands.</small>
                </div>
            </details>

            <div id="story-editor-host" class="story-editor-host">
                <DxRichEdit @key="_editorRevision" @ref="_richEdit"
                            DocumentFormat="@_documentFormat"
                            @bind-DocumentContent="_content"
                            @bind-Selection="_selection"
                            DocumentLoaded="HandleDocumentLoaded"
                            CustomizeRibbon="CustomizeRichEditRibbon"
                            MailMergeSettings="@_mailMergeSettingsContent"
                            BarMode="BarMode.Ribbon"
                            ViewType="ViewType.PrintLayout"
                            ReadOnly="false"
                            HorizontalRulerVisible="true"
                            CssClass="story-rich-edit" />
                @if (_upgradingLegacyStory)
                {
                    <div class="story-upgrade-notice">Upgrading this legacy HTML story to DOCX so page layout, fonts, fields, colors, headers, and footers work correctly…</div>
                }
            </div>
            <footer>
                <span>Stories are stored as Office Open XML (DOCX). The canvas preview is generated as HTML.</span>
                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <strong class="story-error">@_error</strong>
                }
                <div>
                    <DxButton Text="Cancel" Click="Cancel" />
                    <DxButton Text="Apply to frame" RenderStyle="ButtonRenderStyle.Primary" Click="Apply" />
                </div>
            </footer>
        </section>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public TextFrameElement? TextFrame { get; set; }
    [Parameter] public string PublicationName { get; set; } = "Publication";
    [Parameter] public string PageName { get; set; } = "Page";
    [Parameter] public int PageNumber { get; set; } = 1;
    [Parameter] public int PageCount { get; set; } = 1;
    [Parameter] public EventCallback<(byte[] Content, string PreviewHtml, string DocumentBackground, StoryStorageFormat Format)> Saved { get; set; }
    [Parameter] public EventCallback Cancelled { get; set; }

    private DxRichEdit? _richEdit;
    private DotNetObjectReference<StoryEditor>? _selfReference;
    private Selection _selection = default!;
    private byte[] _content = [];
    private Guid? _loadedId;
    private DocumentFormat _documentFormat = DocumentFormat.OpenXml;
    private int _editorRevision;
    private bool _legacyConversionPending;
    private bool _upgradingLegacyStory;
    private int _documentLoadGeneration;
    private RenderFragment? _mailMergeSettingsContent;
    private string? _error;
    private IReadOnlyList<PublicationFieldRecord> _fieldData = [];
    private string? _storyPreviewTransferId;
    private readonly System.Text.StringBuilder _storyPreviewBuffer = new();
    private int _storyPreviewExpectedLength;
    private int _storyPreviewExpectedChunks;
    private int _storyPreviewNextChunk;
    private string _storyPreviewBackground = "transparent";
    private StoryPreviewResult? _storyPreviewResult;
    private string? _storyPreviewTransferError;

    private void CustomizeRichEditRibbon(IRibbon ribbon)
    {
        var fontGroup = ribbon.Tabs[RichEditRibbonTabNames.Home].Groups[RichEditRibbonGroupNames.HomeFont];
        var fontNameItem = fontGroup.Items[RichEditBarItemNames.FontName];
        if (fontNameItem.Type != BarItemTypes.ComboBox) return;

        var fontNameComboBox = (IBarComboBox)fontNameItem;
        fontNameComboBox.Items.Clear();
        foreach (var font in SystemFonts.FontFamilies)
            fontNameComboBox.Items.Add(font, font);
        fontNameComboBox.AllowUserInput = true;
        fontNameComboBox.Tooltip = "Select an installed system font or type another font family.";
    }

    protected override void OnParametersSet()
    {
        if (Visible && TextFrame is not null && _loadedId != TextFrame.Id)
        {
            _editorRevision++;
            _documentLoadGeneration++;
            _mailMergeSettingsContent = null;
            _content = TextFrame.DocumentContent.ToArray();
            _documentFormat = TextFrame.StoryFormat == StoryStorageFormat.Html ? DocumentFormat.Html : DocumentFormat.OpenXml;
            _legacyConversionPending = TextFrame.StoryFormat == StoryStorageFormat.Html;
            _upgradingLegacyStory = false;
            _loadedId = TextFrame.Id;
            _error = null;
            _fieldData =
            [
                new PublicationFieldRecord
                {
                    PublicationName = PublicationName,
                    PageName = PageName,
                    StoryName = TextFrame.Name,
                    PageNumber = PageNumber,
                    PageCount = PageCount,
                    CurrentDate = DateTime.Today,
                    CurrentDateTime = DateTime.Now
                }
            ];
        }

        if (!Visible)
        {
            _documentLoadGeneration++;
            _mailMergeSettingsContent = null;
            _loadedId = null;
            _legacyConversionPending = false;
            _upgradingLegacyStory = false;
            _error = null;
            ResetStoryPreviewTransfer();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!Visible) return;
        try
        {
            _selfReference ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync(
                "publisherStudio.initializeStoryEditorLayout",
                "story-editor-shell",
                "story-editor-host",
                _selfReference);
        }
        catch (JSDisconnectedException) { }
        catch (TaskCanceledException) { }
    }

    private async Task HandleDocumentLoaded(Document _)
    {
        var generation = _documentLoadGeneration;
        if (!IsCurrentStoryLoad(generation)) return;

        if (_legacyConversionPending)
        {
            await UpgradeLegacyStoryAfterLoad(generation);
            return;
        }

        await EnableMailMergeAfterLoad(generation);
    }

    private async Task UpgradeLegacyStoryAfterLoad(int generation)
    {
        if (_richEdit is null || _upgradingLegacyStory || !IsCurrentStoryLoad(generation)) return;

        _upgradingLegacyStory = true;
        await SafeStateHasChanged();
        try
        {
            // HTML stories (including older dropped text/Markdown frames) must first be
            // fully loaded by RichEdit. Exporting from OnAfterRender raced the component's
            // JavaScript initialization and could also make mail-merge settings run against
            // a document that did not yet exist.
            var openXml = await _richEdit.ExportDocumentAsync(DocumentFormat.OpenXml);
            if (!IsCurrentStoryLoad(generation)) return;

            _content = openXml.ToArray();
            _documentFormat = DocumentFormat.OpenXml;
            _legacyConversionPending = false;
            _mailMergeSettingsContent = null;
            _editorRevision++;
            _documentLoadGeneration++;
            _upgradingLegacyStory = false;
            await SafeStateHasChanged();
        }
        catch (OperationCanceledException)
        {
            if (IsCurrentStoryLoad(generation))
            {
                _upgradingLegacyStory = false;
                _error = "The story editor was closed before the legacy story finished loading.";
                await SafeStateHasChanged();
            }
        }
        catch (JSDisconnectedException)
        {
            _upgradingLegacyStory = false;
        }
        catch (ObjectDisposedException)
        {
            _upgradingLegacyStory = false;
        }
        catch (Exception ex)
        {
            if (IsCurrentStoryLoad(generation))
            {
                _upgradingLegacyStory = false;
                _error = $"Legacy story conversion failed: {ex.Message}";
                await SafeStateHasChanged();
            }
        }
    }

    private async Task EnableMailMergeAfterLoad(int generation)
    {
        if (!IsCurrentStoryLoad(generation) || _mailMergeSettingsContent is not null) return;

        // DxRichEdit's mail-merge settings perform JavaScript interop as soon as the
        // settings parameter changes. Keep the RenderFragment stable and attach it only
        // after DocumentLoaded confirms that the editor has created the document.
        var fieldData = _fieldData;
        _mailMergeSettingsContent = builder =>
        {
            builder.OpenComponent<DxMailMergeSettings>(0);
            builder.AddAttribute(1, nameof(DxMailMergeSettings.Data), fieldData);
            builder.AddAttribute(2, nameof(DxMailMergeSettings.ViewMergedData), true);
            builder.AddAttribute(3, nameof(DxMailMergeSettings.ActiveRecord), 0);
            builder.CloseComponent();
        };
        await SafeStateHasChanged();
    }

    private bool IsCurrentStoryLoad(int generation) =>
        Visible
        && TextFrame is not null
        && _loadedId == TextFrame.Id
        && generation == _documentLoadGeneration;

    private async Task SafeStateHasChanged()
    {
        try { await InvokeAsync(StateHasChanged); }
        catch (ObjectDisposedException) { }
        catch (InvalidOperationException) when (!Visible) { }
    }

    private async Task Apply()
    {
        if (_richEdit is null || _upgradingLegacyStory) return;
        _error = null;
        try
        {
            // Export the live RichEdit document directly. SaveDocumentAsync can rebind the
            // DocumentContent parameter before the export completes and used to drop direct
            // formatting in the persisted copy even though a manual DOCX download was correct.
            var openXml = await _richEdit.ExportDocumentAsync(DocumentFormat.OpenXml);
            var html = await _richEdit.ExportDocumentAsync(DocumentFormat.Html);
            var openXmlBackground = PublicationFileService.ExtractOpenXmlDocumentBackground(openXml);
            var prepared = await PrepareStoryPreview(html, openXmlBackground);
            var preview = prepared.Html;
            var documentBackground = prepared.Background;
            _content = openXml.ToArray();
            _documentFormat = DocumentFormat.OpenXml;
            await Saved.InvokeAsync((openXml, preview, documentBackground, StoryStorageFormat.OpenXml));
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task InsertField(string code)
    {
        if (_richEdit is null || _selection is null) return;
        try
        {
            var field = await _selection.ActiveSubDocument.Fields.CreateAsync(_selection.CaretPosition, code);
            await _selection.ActiveSubDocument.Fields.UpdateAsync(field);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private Task InsertDateField() => InsertField("DATE");
    private Task InsertTimeField() => InsertField("TIME");
    private Task InsertPageField() => InsertField("PAGE");
    private Task InsertPageCountField() => InsertField("NUMPAGES");
    private Task InsertPublicationField() => InsertField("MERGEFIELD PublicationName");
    private Task InsertPageNameField() => InsertField("MERGEFIELD PageName");
    private Task InsertStoryNameField() => InsertField("MERGEFIELD StoryName");

    private async Task UpdateFields()
    {
        if (_richEdit is null) return;
        try { await _richEdit.DocumentAPI.Fields.UpdateAllAsync(true); }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task ShowFieldCodes()
    {
        if (_richEdit is null) return;
        try { await _richEdit.DocumentAPI.Fields.ShowAllFieldCodesAsync(true); }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task ShowFieldResults()
    {
        if (_richEdit is null) return;
        try { await _richEdit.DocumentAPI.Fields.ShowAllFieldResultsAsync(true); }
        catch (Exception ex) { _error = ex.Message; }
    }

    private Task ExportDocx() => ExportStory(DocumentFormat.OpenXml, ".docx", "application/vnd.openxmlformats-officedocument.wordprocessingml.document");
    private Task ExportRtf() => ExportStory(DocumentFormat.Rtf, ".rtf", "application/rtf");
    private Task ExportText() => ExportStory(DocumentFormat.PlainText, ".txt", "text/plain;charset=utf-8");
    private Task ExportHtml() => ExportStory(DocumentFormat.Html, ".html", "text/html;charset=utf-8");

    private async Task ExportStory(DocumentFormat format, string extension, string mimeType)
    {
        if (_richEdit is null || TextFrame is null) return;
        try
        {
            var content = await _richEdit.ExportDocumentAsync(format);
            if (format == DocumentFormat.Html)
            {
                var openXml = await _richEdit.ExportDocumentAsync(DocumentFormat.OpenXml);
                var prepared = await PrepareStoryPreview(
                    content,
                    PublicationFileService.ExtractOpenXmlDocumentBackground(openXml));
                var pageLayout = PublicationFileService.ExtractOpenXmlPageLayout(openXml);
                content = System.Text.Encoding.UTF8.GetBytes(StandaloneStoryHtml(
                    prepared,
                    $"{PublicationName} – {TextFrame.Name}",
                    pageLayout));
            }
            var baseName = PublicationFileService.SafeFileName($"{PublicationName}-{TextFrame.Name}");
            await using var stream = new MemoryStream(content);
            using var reference = new DotNetStreamReference(stream);
            await JS.InvokeVoidAsync("publisherStudio.downloadStream", baseName + extension, reference, mimeType);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    [JSInvokable]
    public Task PrintStoryFromClient() => PrintStory();

    private async Task PrintStory()
    {
        if (_richEdit is null || TextFrame is null) return;
        _error = null;
        var title = $"{PublicationName} – {TextFrame.Name}";
        string? previewId = null;
        try
        {
            // Open the preview window before the first asynchronous document export so the
            // browser still treats it as a direct user action instead of blocking the popup.
            previewId = await JS.InvokeAsync<string?>("publisherStudio.claimStoryPrintPreview", title);
            if (string.IsNullOrWhiteSpace(previewId))
                throw new InvalidOperationException("The browser blocked the story print-preview window. Allow popups for this local PublisherStudio address and try again.");

            var openXml = await _richEdit.ExportDocumentAsync(DocumentFormat.OpenXml);
            var html = await _richEdit.ExportDocumentAsync(DocumentFormat.Html);
            var prepared = await PrepareStoryPreview(
                html,
                PublicationFileService.ExtractOpenXmlDocumentBackground(openXml));
            var pageLayout = PublicationFileService.ExtractOpenXmlPageLayout(openXml);
            await JS.InvokeVoidAsync(
                "publisherStudio.completeStoryPrintPreview",
                previewId,
                StandaloneStoryHtml(prepared, title, pageLayout, printPreview: true));
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            if (!string.IsNullOrWhiteSpace(previewId))
            {
                try { await JS.InvokeVoidAsync("publisherStudio.failStoryPrintPreview", previewId, ex.Message); }
                catch (JSDisconnectedException) { }
                catch (TaskCanceledException) { }
                catch (JSException) { }
            }
        }
    }

    private async Task<StoryPreviewResult> PrepareStoryPreview(byte[] html, string? preferredBackground = null)
    {
        var normalizedPreferredBackground = PublicationFileService.NormalizeCssBackground(preferredBackground);
        var fallback = new StoryPreviewResult
        {
            Html = PublicationFileService.ExtractHtmlBody(html),
            Background = IsVisibleBackground(normalizedPreferredBackground)
                ? normalizedPreferredBackground
                : TextFrame?.DocumentBackground ?? "transparent"
        };
        try
        {
            ResetStoryPreviewTransfer();
            using var htmlStream = new MemoryStream(html, writable: false);
            using var htmlReference = new DotNetStreamReference(htmlStream);
            using var receiverReference = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync(
                "publisherStudio.prepareStoryPreviewHtmlInChunks",
                htmlReference,
                normalizedPreferredBackground,
                receiverReference);

            var prepared = _storyPreviewResult
                ?? throw new JSException(_storyPreviewTransferError ?? "The formatted story preview transfer did not complete.");
            if (IsVisibleBackground(normalizedPreferredBackground))
                prepared.Background = normalizedPreferredBackground;
            prepared.Background = PublicationFileService.NormalizeCssBackground(prepared.Background);
            ResetStoryPreviewTransfer();
            return prepared;
        }
        catch (JSDisconnectedException) { ResetStoryPreviewTransfer(); return fallback; }
        catch (TaskCanceledException) { ResetStoryPreviewTransfer(); return fallback; }
        catch (JSException) { ResetStoryPreviewTransfer(); return fallback; }
    }

    [JSInvokable]
    public bool BeginStoryPreviewTransfer(string transferId, int totalLength, int chunkCount, string background)
    {
        ResetStoryPreviewTransfer();
        if (string.IsNullOrWhiteSpace(transferId) || totalLength < 0 || chunkCount <= 0)
        {
            _storyPreviewTransferError = "The story preview transfer metadata is invalid.";
            return false;
        }

        _storyPreviewTransferId = transferId;
        _storyPreviewExpectedLength = totalLength;
        _storyPreviewExpectedChunks = chunkCount;
        _storyPreviewBackground = PublicationFileService.NormalizeCssBackground(background);
        return true;
    }

    [JSInvokable]
    public bool AppendStoryPreviewChunk(string transferId, int chunkIndex, string chunk)
    {
        if (!string.Equals(_storyPreviewTransferId, transferId, StringComparison.Ordinal)
            || chunkIndex != _storyPreviewNextChunk)
        {
            _storyPreviewTransferError = "The formatted story preview chunks arrived out of order.";
            return false;
        }

        _storyPreviewBuffer.Append(chunk ?? string.Empty);
        _storyPreviewNextChunk++;
        return true;
    }

    [JSInvokable]
    public bool CompleteStoryPreviewTransfer(string transferId)
    {
        if (!string.Equals(_storyPreviewTransferId, transferId, StringComparison.Ordinal)
            || _storyPreviewNextChunk != _storyPreviewExpectedChunks
            || _storyPreviewBuffer.Length != _storyPreviewExpectedLength)
        {
            _storyPreviewTransferError = "The formatted story preview transfer was incomplete.";
            return false;
        }

        _storyPreviewResult = new StoryPreviewResult
        {
            Html = _storyPreviewBuffer.ToString(),
            Background = _storyPreviewBackground
        };
        return true;
    }

    private void ResetStoryPreviewTransfer()
    {
        _storyPreviewTransferId = null;
        _storyPreviewBuffer.Clear();
        _storyPreviewExpectedLength = 0;
        _storyPreviewExpectedChunks = 0;
        _storyPreviewNextChunk = 0;
        _storyPreviewBackground = "transparent";
        _storyPreviewResult = null;
        _storyPreviewTransferError = null;
    }

    private static string StandaloneStoryHtml(
        StoryPreviewResult prepared,
        string title,
        StoryPageLayout pageLayout,
        bool printPreview = false)
    {
        var safeTitle = System.Net.WebUtility.HtmlEncode(title);
        var background = PublicationFileService.NormalizeCssBackground(prepared.Background);
        var pageBackground = IsVisibleBackground(background) ? background : "#ffffff";
        var pageWidth = CssMillimeters(pageLayout.PageWidthMm);
        var pageHeight = CssMillimeters(pageLayout.PageHeightMm);
        var marginTop = CssMillimeters(pageLayout.MarginTopMm);
        var marginRight = CssMillimeters(pageLayout.MarginRightMm);
        var marginBottom = CssMillimeters(pageLayout.MarginBottomMm);
        var marginLeft = CssMillimeters(pageLayout.MarginLeftMm);
        var contentWidth = CssMillimeters(pageLayout.ContentWidthMm);
        var contentHeight = CssMillimeters(pageLayout.ContentHeightMm);
        var pageDescription = System.Net.WebUtility.HtmlEncode(
            $"{FormatMeasurement(pageLayout.PageWidthMm)} × {FormatMeasurement(pageLayout.PageHeightMm)} mm, "
            + (pageLayout.IsLandscape ? "landscape" : "portrait"));
        var previewMode = printPreview ? "true" : "false";
        var toolbar = printPreview
            ? $$"""<nav class="publisher-print-toolbar" aria-label="Story PDF preview status"><strong>Preparing exact story PDF…</strong><span id="publisher-print-status">Document page: {{pageDescription}}. The generated PDF is the print preview.</span><button type="button" onclick="window.close()">Close</button></nav>"""
            : string.Empty;
        var rendererScript = printPreview
            ? """<script src="__PUBLISHER_HTML2CANVAS_URL__"></script>"""
            : string.Empty;

        return $$"""
            <!doctype html>
            <html lang="en">
            <head>
              <meta charset="utf-8">
              <meta name="viewport" content="width=device-width,initial-scale=1">
              <title>{{safeTitle}}</title>
              <style>
                * { box-sizing:border-box; -webkit-print-color-adjust:exact !important; print-color-adjust:exact !important; }
                @page { size:{{pageWidth}} {{pageHeight}}; margin:0; }
                :root {
                  --publisher-page-width:{{pageWidth}};
                  --publisher-page-height:{{pageHeight}};
                  --publisher-margin-top:{{marginTop}};
                  --publisher-margin-right:{{marginRight}};
                  --publisher-margin-bottom:{{marginBottom}};
                  --publisher-margin-left:{{marginLeft}};
                  --publisher-content-width:{{contentWidth}};
                  --publisher-content-height:{{contentHeight}};
                  --publisher-story-page-background:{{pageBackground}};
                }
                html,body { min-height:100%; margin:0; background:#e5e7eb; }
                body { padding:24px; font-family:Segoe UI,Arial,sans-serif; }
                .publisher-print-toolbar { position:sticky; z-index:20; top:0; display:flex; align-items:center; gap:12px; width:min(100%,1200px); margin:0 auto 14px; padding:10px 12px; border:1px solid #cbd5e1; border-radius:5px; background:white; box-shadow:0 3px 14px #0002; }
                .publisher-print-toolbar span { flex:1; color:#526071; font-size:12px; }
                .publisher-print-toolbar button { padding:7px 13px; border:1px solid #9ba5b1; border-radius:4px; background:white; cursor:pointer; }
                .publisher-print-toolbar.error { border-color:#ef9a9a; }
                .publisher-print-toolbar.error strong { color:#a61b1b; }
                .publisher-story-source { display:none !important; }
                .publisher-story-pages { display:grid; justify-content:center; gap:18px; }
                .publisher-story-sheet { position:relative; isolation:isolate; width:var(--publisher-page-width); height:var(--publisher-page-height); padding:var(--publisher-margin-top) var(--publisher-margin-right) var(--publisher-margin-bottom) var(--publisher-margin-left); overflow:hidden; background:var(--publisher-story-page-background); box-shadow:0 3px 18px #0003; break-after:page; page-break-after:always; }
                .publisher-story-sheet:last-child { break-after:auto; page-break-after:auto; }
                .publisher-story-viewport { position:relative; width:var(--publisher-content-width); height:var(--publisher-content-height); overflow:hidden; }
                .publisher-story-flow, .publisher-story-measure { position:absolute; top:0; left:0; width:var(--publisher-content-width); height:var(--publisher-content-height); max-width:none; min-width:0; margin:0; padding:0; overflow:visible; column-width:var(--publisher-content-width); column-gap:0; column-fill:auto; }
                .publisher-story-measure { position:fixed; z-index:-1000; top:0; left:-100000px; opacity:0; pointer-events:none; }
                .publisher-story-flow > *, .publisher-story-measure > * { max-width:100%; }
                .publisher-story-flow [data-publisher-print-fill], .publisher-story-measure [data-publisher-print-fill] { background-color:var(--publisher-print-fill,transparent) !important; }
                @media print {
                  html,body { min-height:0; background:var(--publisher-story-page-background) !important; }
                  body { padding:0; }
                  .publisher-print-toolbar, .publisher-story-source, .publisher-story-measure { display:none !important; }
                  .publisher-story-pages { display:block; }
                  .publisher-story-sheet { margin:0; box-shadow:none; }
                }
              </style>
            </head>
            <body data-page-width-mm="{{FormatMeasurement(pageLayout.PageWidthMm)}}" data-page-height-mm="{{FormatMeasurement(pageLayout.PageHeightMm)}}">
              {{toolbar}}
              <div id="publisher-story-source" class="publisher-story-source" aria-hidden="true">{{prepared.Html}}</div>
              <div id="publisher-story-measure" class="publisher-story-measure" aria-hidden="true"></div>
              <main id="publisher-story-pages" class="publisher-story-pages" aria-label="Story pages"></main>
              {{rendererScript}}
              <script>
                (() => {
                  'use strict';
                  const previewMode = {{previewMode}};
                  const sourceHost = document.getElementById('publisher-story-source');
                  const sourceDocument = sourceHost?.querySelector('.publisher-story-document');
                  const measure = document.getElementById('publisher-story-measure');
                  const pageHost = document.getElementById('publisher-story-pages');
                  const status = document.getElementById('publisher-print-status');
                  const toolbar = document.querySelector('.publisher-print-toolbar');
                  const pageBackground = getComputedStyle(document.documentElement)
                    .getPropertyValue('--publisher-story-page-background').trim() || '#ffffff';
                  const inheritedRootProperties = [
                    'color','font-family','font-size','font-weight','font-style','font-variant','font-stretch','line-height',
                    'letter-spacing','word-spacing','text-align','text-indent','text-transform','text-shadow',
                    'text-decoration-line','text-decoration-style','text-decoration-color','text-decoration-thickness',
                    'white-space','overflow-wrap','word-break','hyphens','vertical-align','direction','unicode-bidi'
                  ];

                  const nextFrame = () => new Promise(resolve => requestAnimationFrame(() => resolve()));
                  const visibleFill = value => {
                    const normalized = String(value || '').replaceAll(' ', '').toLowerCase();
                    return normalized && normalized !== 'transparent' && normalized !== 'rgba(0,0,0,0)';
                  };
                  const waitForImages = root => Promise.all([...root.querySelectorAll('img')].map(image => image.complete
                    ? Promise.resolve()
                    : new Promise(resolve => {
                        const finish = () => resolve();
                        image.addEventListener('load', finish, { once:true });
                        image.addEventListener('error', finish, { once:true });
                        setTimeout(finish, 5000);
                      })));
                  const materializePrintFills = root => {
                    root.querySelectorAll('[data-publisher-print-fill]').forEach(node => {
                      const computed = getComputedStyle(node);
                      const fill = computed.getPropertyValue('--publisher-print-fill').trim() || computed.backgroundColor;
                      if (!visibleFill(fill)) return;
                      node.style.setProperty('--publisher-print-fill', fill);
                      node.style.setProperty('background-color', fill, 'important');
                      node.style.setProperty('-webkit-print-color-adjust', 'exact', 'important');
                      node.style.setProperty('print-color-adjust', 'exact', 'important');
                    });
                  };
                  const normalizeColumnBreaks = root => {
                    root.querySelectorAll('*').forEach(node => {
                      const before = `${node.style.getPropertyValue('break-before')} ${node.style.getPropertyValue('page-break-before')}`.toLowerCase();
                      const after = `${node.style.getPropertyValue('break-after')} ${node.style.getPropertyValue('page-break-after')}`.toLowerCase();
                      if (before.includes('page') || before.includes('always')) node.style.setProperty('break-before', 'column');
                      if (after.includes('page') || after.includes('always')) node.style.setProperty('break-after', 'column');
                    });
                  };
                  const createFlow = className => {
                    const flow = document.createElement('div');
                    flow.className = className;
                    const sourceStyle = sourceDocument?.style;
                    if (sourceStyle) {
                      for (const property of inheritedRootProperties) {
                        const value = sourceStyle.getPropertyValue(property);
                        if (value) flow.style.setProperty(property, value, sourceStyle.getPropertyPriority(property));
                      }
                    }
                    flow.innerHTML = sourceDocument?.innerHTML || '<p></p>';
                    normalizeColumnBreaks(flow);
                    materializePrintFills(flow);
                    return flow;
                  };

                  const paginate = async () => {
                    if (!sourceHost || !measure || !pageHost)
                      throw new Error('The Story preview page could not be initialized.');
                    measure.replaceChildren(createFlow('publisher-story-measure-content'));
                    try { await document.fonts?.ready; } catch { }
                    await waitForImages(measure);
                    await nextFrame();
                    await nextFrame();
                    const columnWidth = measure.getBoundingClientRect().width;
                    if (!(columnWidth > 0)) throw new Error('The DOCX content width is invalid.');
                    const pageCount = Math.max(1, Math.ceil(measure.scrollWidth / columnWidth - .001));
                    const fragment = document.createDocumentFragment();
                    for (let pageIndex = 0; pageIndex < pageCount; pageIndex++) {
                      const page = document.createElement('section');
                      page.className = 'publisher-story-sheet';
                      page.setAttribute('aria-label', `Story page ${pageIndex + 1} of ${pageCount}`);
                      const viewport = document.createElement('div');
                      viewport.className = 'publisher-story-viewport';
                      const flow = createFlow('publisher-story-flow');
                      flow.style.transform = `translate3d(${-pageIndex * columnWidth}px,0,0)`;
                      viewport.append(flow);
                      page.append(viewport);
                      fragment.append(page);
                    }
                    pageHost.replaceChildren(fragment);
                    measure.remove();
                    sourceHost.remove();
                    document.body.dataset.publisherReady = 'true';
                    await waitForImages(pageHost);
                    await nextFrame();
                    await nextFrame();
                    return [...pageHost.querySelectorAll('.publisher-story-sheet')];
                  };

                  const ascii = value => new TextEncoder().encode(value);
                  const pdfNumber = value => Number(value).toFixed(3).replace(/\.000$/, '').replace(/(\.\d*?)0+$/, '$1');
                  const canvasJpeg = canvas => new Promise((resolve, reject) => canvas.toBlob(async blob => {
                    if (!blob) { reject(new Error('The browser could not encode a Story page image.')); return; }
                    resolve(new Uint8Array(await blob.arrayBuffer()));
                  }, 'image/jpeg', .985));
                  const createImagePdf = (images, pageWidthMm, pageHeightMm) => {
                    const pageWidthPoints = pageWidthMm * 72 / 25.4;
                    const pageHeightPoints = pageHeightMm * 72 / 25.4;
                    const objectCount = 2 + images.length * 3;
                    const objects = new Array(objectCount + 1);
                    const pageIds = images.map((_, index) => 3 + index * 3);
                    objects[1] = [ascii('<< /Type /Catalog /Pages 2 0 R >>')];
                    objects[2] = [ascii(`<< /Type /Pages /Count ${images.length} /Kids [${pageIds.map(id => `${id} 0 R`).join(' ')}] >>`)];
                    images.forEach((image, index) => {
                      const pageId = 3 + index * 3;
                      const imageId = pageId + 1;
                      const contentId = pageId + 2;
                      const draw = ascii(`q\n${pdfNumber(pageWidthPoints)} 0 0 ${pdfNumber(pageHeightPoints)} 0 0 cm\n/Im0 Do\nQ\n`);
                      objects[pageId] = [ascii(`<< /Type /Page /Parent 2 0 R /MediaBox [0 0 ${pdfNumber(pageWidthPoints)} ${pdfNumber(pageHeightPoints)}] /Resources << /XObject << /Im0 ${imageId} 0 R >> >> /Contents ${contentId} 0 R >>`)];
                      objects[imageId] = [
                        ascii(`<< /Type /XObject /Subtype /Image /Width ${image.width} /Height ${image.height} /ColorSpace /DeviceRGB /BitsPerComponent 8 /Filter /DCTDecode /Length ${image.bytes.length} >>\nstream\n`),
                        image.bytes,
                        ascii('\nendstream')
                      ];
                      objects[contentId] = [ascii(`<< /Length ${draw.length} >>\nstream\n`), draw, ascii('endstream')];
                    });

                    const header = new Uint8Array([37,80,68,70,45,49,46,52,10,37,226,227,207,211,10]);
                    const chunks = [header];
                    const offsets = new Array(objectCount + 1).fill(0);
                    let length = header.length;
                    const push = chunk => { chunks.push(chunk); length += chunk.length; };
                    for (let objectId = 1; objectId <= objectCount; objectId++) {
                      offsets[objectId] = length;
                      push(ascii(`${objectId} 0 obj\n`));
                      for (const chunk of objects[objectId]) push(chunk);
                      push(ascii('\nendobj\n'));
                    }
                    const xrefOffset = length;
                    push(ascii(`xref\n0 ${objectCount + 1}\n`));
                    push(ascii('0000000000 65535 f \n'));
                    for (let objectId = 1; objectId <= objectCount; objectId++)
                      push(ascii(`${String(offsets[objectId]).padStart(10, '0')} 00000 n \n`));
                    push(ascii(`trailer\n<< /Size ${objectCount + 1} /Root 1 0 R >>\nstartxref\n${xrefOffset}\n%%EOF\n`));
                    return new Blob(chunks, { type:'application/pdf' });
                  };

                  const openExactPdfPreview = async pages => {
                    if (typeof window.html2canvas !== 'function')
                      throw new Error('The local Story PDF renderer did not load.');
                    const pageWidthMm = Number(document.body.dataset.pageWidthMm);
                    const pageHeightMm = Number(document.body.dataset.pageHeightMm);
                    if (!(pageWidthMm > 0 && pageHeightMm > 0))
                      throw new Error('The DOCX paper size is invalid.');
                    const images = [];
                    for (let index = 0; index < pages.length; index++) {
                      if (status) status.textContent = `Rendering exact PDF page ${index + 1} of ${pages.length}…`;
                      const page = pages[index];
                      const bounds = page.getBoundingClientRect();
                      const scale = Math.max(1, Math.min(2, 4096 / Math.max(bounds.width, 1), 4096 / Math.max(bounds.height, 1)));
                      const canvas = await window.html2canvas(page, {
                        backgroundColor:pageBackground,
                        scale,
                        useCORS:true,
                        allowTaint:false,
                        logging:false,
                        removeContainer:true,
                        width:bounds.width,
                        height:bounds.height,
                        windowWidth:Math.ceil(bounds.width),
                        windowHeight:Math.ceil(bounds.height),
                        scrollX:0,
                        scrollY:0
                      });
                      const bytes = await canvasJpeg(canvas);
                      images.push({ bytes, width:canvas.width, height:canvas.height });
                      canvas.width = 1;
                      canvas.height = 1;
                    }
                    if (status) status.textContent = 'Opening the exact PDF print preview…';
                    const pdf = createImagePdf(images, pageWidthMm, pageHeightMm);
                    const pdfUrl = URL.createObjectURL(pdf);
                    globalThis.__publisherStoryPdfUrl = pdfUrl;
                    location.replace(pdfUrl);
                  };

                  const fail = error => {
                    console.error('Story PDF preview failed.', error);
                    toolbar?.classList.add('error');
                    const strong = toolbar?.querySelector('strong');
                    if (strong) strong.textContent = 'Story PDF preview failed';
                    if (status) status.textContent = error?.message || String(error);
                  };

                  addEventListener('beforeprint', () => materializePrintFills(document));
                  addEventListener('load', async () => {
                    try {
                      const pages = await paginate();
                      if (previewMode) await openExactPdfPreview(pages);
                    } catch (error) {
                      fail(error);
                    }
                  }, { once:true });
                })();
              </script>
            </body>
            </html>
            """;
    }

    private static string CssMillimeters(double value) => FormatMeasurement(value) + "mm";

    private static string FormatMeasurement(double value) =>
        value.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);

    private static bool IsVisibleBackground(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return false;
        var normalized = value.Trim();
        return !string.Equals(normalized, "transparent", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(normalized, "none", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(normalized, "rgba(0, 0, 0, 0)", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(normalized, "rgba(0,0,0,0)", StringComparison.OrdinalIgnoreCase);
    }

    private Task Cancel() => Cancelled.InvokeAsync();

    public void Dispose()
    {
        _documentLoadGeneration++;
        _mailMergeSettingsContent = null;
        ResetStoryPreviewTransfer();
        _selfReference?.Dispose();
        _selfReference = null;
    }

    public sealed class StoryPreviewResult
    {
        public string Html { get; set; } = "<div class=\"publisher-story-document\"><p></p></div>";
        public string Background { get; set; } = "transparent";
    }
}
