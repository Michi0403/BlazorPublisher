    {
        if (_contextId is not { } id) return;
        var output = _draft.Outputs.FirstOrDefault(item => item.Id == id);
        if (output is null) return;
        _selectedOutputId = id;
        ApplySelectedOutputDefaults();
    }

    private void DuplicateContextOutput()
    {
        if (_contextId is not { } id) return;
        var output = _draft.Outputs.FirstOrDefault(item => item.Id == id);
        if (output is not null) DuplicateOutput(output);
    }

    private void RemoveContextOutput()
    {
        if (_contextId is { } id) RemoveOutput(id);
    }

    private void DuplicateContextDevice()
    {
        var profile = _machine.Devices.FirstOrDefault(item => item.Id == _contextId);
        if (profile is not null) DuplicateDeviceProfile(profile);
    }

    private void RemoveContextDevice()
    {
        if (_contextId is { } id) RemoveDeviceProfile(id);
    }

    private void DuplicateContextHotkey()
    {
        var hotkey = _draft.Hotkeys.FirstOrDefault(item => item.Id == _contextId);
        if (hotkey is not null) DuplicateHotkey(hotkey);
    }

    private void RemoveContextHotkey()
    {
        if (_contextId is { } id) RemoveHotkey(id);
    }

    private string EstimatedRecordingStorageText
    {
        get
        {
            if (!_draft.Recording.Enabled) return "Recording disabled";
            long totalKbps;
            if (_draft.Recording.Variant == PublicationStreamRecordingVariant.CleanMaster)
            {
                totalKbps = Math.Clamp(
                    (long)Math.Round(_draft.MasterWidth * (double)_draft.MasterHeight * _draft.MasterFrameRate * 0.16 / 1000.0),
                    12_000L,
                    120_000L) + 192;
            }
            else
            {
                var outputs = _draft.Recording.Variant == PublicationStreamRecordingVariant.SelectedOutputs
                    ? _draft.Outputs.Where(output => _draft.Recording.SelectedOutputIds.Contains(output.Id))
                    : _draft.Outputs.Where(output => output.Enabled);
                totalKbps = outputs.Sum(output => (long)output.VideoBitrateKbps + output.AudioBitrateKbps);
            }
            var gigabytesPerHour = totalKbps * 1000d * 3600d / 8d / 1_000_000_000d;
            return totalKbps <= 0 ? "No recording variants selected" : $"Approximately {gigabytesPerHour:0.0} GB per hour";
        }
    }

    private static string RecordingVariantName(PublicationStreamRecordingVariant value) => value switch
    {
        PublicationStreamRecordingVariant.CleanMaster => "Clean master",
        PublicationStreamRecordingVariant.EachEnabledOutput => "Each enabled output",
        PublicationStreamRecordingVariant.SelectedOutputs => "Selected outputs",
        _ => value.ToString()
    };

    private async Task Apply()
    {
        _twitchOAuthCancellation?.Cancel();
        await CloseTwitchAuthorizationWindowAsync();
        await Saved.InvokeAsync(_draft);
    }

    private async Task Cancel()
    {
        _twitchOAuthCancellation?.Cancel();
        await CloseTwitchAuthorizationWindowAsync();
        await Cancelled.InvokeAsync();
    }
    private static T Clone<T>(T value) => JsonSerializer.Deserialize<T>(JsonSerializer.Serialize(value))!;
    private static string ShortId(string value) => string.IsNullOrWhiteSpace(value) ? "default" : value.Length <= 16 ? value : value[..16] + "…";

    private sealed record WorkflowStep(int Number, string Title, string Text);
