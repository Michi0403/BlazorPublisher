@namespace PublisherStudio.Components.Editor
@inject StreamingProfileStore ProfileStore
@inject TwitchOAuthService TwitchOAuth
@inject StreamingMediaHostClient MediaHost
@inject IJSRuntime JS
@using System.Text.Json

@if (Visible)
{
    <div class="editor-modal-backdrop streaming-studio-backdrop">
        <section class="streaming-studio-window" role="dialog" aria-modal="true" aria-label="Streaming Studio">
            <header class="subapp-titlebar streaming-studio-titlebar">
                <div>
                    <strong>Streaming Studio</strong>
                    <span>Configure reusable provider accounts, publication outputs, recording, LAN delivery, devices, and timing.</span>
                </div>
                <button type="button" class="window-close" aria-label="Close Streaming Studio" data-help="Close Streaming Studio without applying publication changes. Machine profiles already saved remain available." @onclick="Cancel"><span aria-hidden="true">×</span></button>
            </header>

            <DxRibbon CssClass="streaming-studio-ribbon categorized-ribbon" SizeMode="SizeMode.Small" AdaptivityAutoCollapseItemsToGroups="true">
                <DxRibbonTab Text="Home">
                    <DxRibbonGroup Text="Workspace" IconCssClass="pub-icon pub-icon-panels">
                        <DxRibbonItem Text="Providers" IconCssClass="pub-icon pub-icon-web" IsPrimary="@(_tab == "providers")" Click="ShowProviders" />
                        <DxRibbonItem Text="Outputs" IconCssClass="pub-icon pub-icon-video" IsPrimary="@(_tab == "outputs")" Click="ShowOutputs" />
                        <DxRibbonItem Text="Recording" IconCssClass="pub-icon pub-icon-media" IsPrimary="@(_tab == "recording")" Click="ShowRecording" />
                        <DxRibbonItem Text="Company / LAN" IconCssClass="pub-icon pub-icon-web" IsPrimary="@(_tab == "lan")" Click="ShowLan" />
                        <DxRibbonItem Text="Devices" IconCssClass="pub-icon pub-icon-media" IsPrimary="@(_tab == "devices")" Click="ShowDevices" />
                        <DxRibbonItem Text="Advanced" IconCssClass="pub-icon pub-icon-properties" IsPrimary="@(_tab == "advanced")" Click="ShowAdvanced" />
                    </DxRibbonGroup>

                    @if (_tab == "providers")
                    {
                        <DxRibbonGroup Text="Provider profile" IconCssClass="pub-icon pub-icon-web">
                            <DxRibbonItem Text="New provider" IconCssClass="pub-icon pub-icon-newpage" IsPrimary="true" Click="NewProvider" />
                            <DxRibbonItem Text="Save provider" IconCssClass="pub-icon pub-icon-save" Enabled="@(_providerDraft is not null)" Click="SaveProvider" />
                            <DxRibbonItem Text="Duplicate provider" IconCssClass="pub-icon pub-icon-duplicate" Enabled="@(_providerDraft is not null)" Click="DuplicateCurrentProvider" />
                            <DxRibbonItem Text="Delete provider" IconCssClass="pub-icon pub-icon-delete" Enabled="@(_providerDraft is not null)" Click="DeleteProvider" />
                        </DxRibbonGroup>
                    }
                    else if (_tab == "outputs")
                    {
                        <DxRibbonGroup Text="Publication output" IconCssClass="pub-icon pub-icon-video">
                            <DxRibbonItem Text="Add output" IconCssClass="pub-icon pub-icon-newpage" IsPrimary="true" Click="AddOutput" />
                            <DxRibbonItem Text="Recommended settings" IconCssClass="pub-icon pub-icon-fit" Enabled="@(SelectedOutput is not null)" Click="ApplySelectedOutputDefaults" />
                            <DxRibbonItem Text="Duplicate output" IconCssClass="pub-icon pub-icon-duplicate" Enabled="@(SelectedOutput is not null)" Click="DuplicateSelectedOutput" />
                            <DxRibbonItem Text="Remove output" IconCssClass="pub-icon pub-icon-delete" Enabled="@(SelectedOutput is not null)" Click="RemoveSelectedOutput" />
                        </DxRibbonGroup>
                    }
                    else if (_tab == "recording")
                    {
                        <DxRibbonGroup Text="Recording" IconCssClass="pub-icon pub-icon-media">
                            <DxRibbonItem Text="@(_draft.Recording.Enabled ? "Disable recording" : "Enable recording")" IconCssClass="pub-icon pub-icon-media" IsPrimary="true" Click="ToggleRecording" />
                            <DxRibbonItem Text="Use clean master" IconCssClass="pub-icon pub-icon-video" Click="UseCleanMasterRecording" />
                            <DxRibbonItem Text="Use enabled outputs" IconCssClass="pub-icon pub-icon-layers" Click="UseEnabledOutputRecording" />
                        </DxRibbonGroup>
                    }
                    else if (_tab == "lan")
                    {
                        <DxRibbonGroup Text="LAN delivery" IconCssClass="pub-icon pub-icon-web">
                            <DxRibbonItem Text="@(_draft.Lan.Enabled ? "Disable LAN output" : "Enable LAN output")" IconCssClass="pub-icon pub-icon-web" IsPrimary="true" Click="ToggleLan" />
                            <DxRibbonItem Text="Local computer only" IconCssClass="pub-icon pub-icon-lock" Click="UseLoopbackLan" />
                            <DxRibbonItem Text="Browser + HLS" IconCssClass="pub-icon pub-icon-play" Click="UseBrowserAndHlsLan" />
                        </DxRibbonGroup>
                    }
                    else if (_tab == "devices")
                    {
                        <DxRibbonGroup Text="Device profiles" IconCssClass="pub-icon pub-icon-media">
                            <DxRibbonItem Text="Add device profile" IconCssClass="pub-icon pub-icon-newpage" IsPrimary="true" Click="AddDeviceProfile" />
                            <DxRibbonItem Text="Refresh browser devices" IconCssClass="pub-icon pub-icon-redo" Click="RefreshDevices" />
                            <DxRibbonItem Text="Refresh native devices" IconCssClass="pub-icon pub-icon-redo" Click="RefreshNativeDevices" />
                            <DxRibbonItem Text="Save profiles" IconCssClass="pub-icon pub-icon-save" Click="SaveMachineOptions" />
                        </DxRibbonGroup>
                    }
                    else
                    {
                        <DxRibbonGroup Text="Machine options" IconCssClass="pub-icon pub-icon-properties">
                            <DxRibbonItem Text="Add hotkey" IconCssClass="pub-icon pub-icon-newpage" IsPrimary="true" Click="AddHotkey" />
                            <DxRibbonItem Text="Save machine options" IconCssClass="pub-icon pub-icon-save" Click="SaveMachineOptions" />
                        </DxRibbonGroup>
                    }

                    <DxRibbonGroup Text="Help" IconCssClass="pub-icon pub-icon-command">
                        <DxRibbonItem Text="@(_showWorkflowHelp ? "Hide workflow help" : "Show workflow help")" IconCssClass="pub-icon pub-icon-command" Click="ToggleWorkflowHelp" />
                    </DxRibbonGroup>
                </DxRibbonTab>
            </DxRibbon>

            <div class="streaming-section-strip" role="status">
                <span class="streaming-section-identity"><i class="pub-icon @SectionIcon"></i><b>@SectionTitle</b></span>
                <span>@SectionDescription</span>
                <small>Double-click editable canvas objects to open their studio. Right-click for object commands.</small>
            </div>

            <div class="streaming-studio-workspace @(_showWorkflowHelp ? "help-open" : null)"
                 @oncontextmenu="ShowWorkspaceContextMenu" @oncontextmenu:preventDefault>
                @if (_tab == "providers")
                {
                    <aside class="streaming-navigation-pane" aria-label="Provider profiles">
                        <div class="streaming-pane-heading">
                            <div><b>Provider profiles</b><span>Stored on this machine</span></div>
                            <button type="button" class="icon-command-button" aria-label="Add provider profile" data-help="Create a reusable streaming provider profile. The publication stores only its profile ID." @onclick="NewProvider">＋</button>
                        </div>
                        <div class="streaming-navigation-list">
                            @foreach (var profile in _machine.Providers)
                            {
                                <button type="button"
                                        class="streaming-navigation-item @(_providerDraft?.Id == profile.Id ? "selected" : null)"
                                        @onclick="() => EditProvider(profile)"
                                        @ondblclick="() => EditProvider(profile)"
                                        @oncontextmenu="args => ShowProviderContextMenu(profile, args)"
                                        @oncontextmenu:preventDefault
                                        @oncontextmenu:stopPropagation
                                        data-help="Select this provider profile. Double-click also opens it; right-click provides duplicate and delete commands.">
                                    <span class="streaming-item-icon"><i class="pub-icon pub-icon-web"></i></span>
                                    <span><b>@profile.Name</b><small>@profile.Provider · @profile.Transport</small></span>
                                    <em class="status-dot @(profile.Enabled ? "online" : null)" title="@(profile.Enabled ? "Available to publications" : "Disabled")"></em>
                                </button>
                            }
                        </div>
                        @if (_machine.Providers.Count == 0)
                        {
                            <div class="streaming-navigation-empty">
                                <i class="pub-icon pub-icon-web"></i>
                                <b>No provider profiles</b>
                                <span>Create Twitch, YouTube, Kick, TikTok, custom RTMP/RTMPS, SRT, or local profiles.</span>
                            </div>
                        }
                    </aside>

                    <main class="streaming-content-pane">
                        <header class="streaming-page-heading">
                            <div><h2>@(_providerDraft?.Name ?? "Provider profile")</h2><p>Reusable delivery and Chat credentials remain outside the publication file.</p></div>
                            @if (_providerDraft is not null)
                            {
                                <span class="streaming-state-badge @(_providerDraft.Enabled ? "enabled" : null)">@(_providerDraft.Enabled ? "Available" : "Disabled")</span>
                            }
                        </header>

                        @if (_providerDraft is null)
                        {
                            <div class="streaming-empty-state">
                                <i class="pub-icon pub-icon-web"></i>
                                <b>Select or create a provider</b>
                                <span>Profiles keep endpoints and encrypted secrets reusable across publications.</span>
                                <button type="button" class="primary-button" @onclick="NewProvider">Create provider profile</button>
                            </div>
                        }
                        else
                        {
                            <section class="streaming-settings-card">
                                <div class="streaming-card-heading"><div><h3>Identity and delivery</h3><p>Name the profile and choose how PublisherStudio reaches the provider.</p></div></div>
                                <div class="streaming-form-grid two-column">
                                    <label data-help="A friendly reusable name shown when publication outputs choose this profile."><span>Profile name</span><input @bind="_providerDraft.Name" /></label>
                                    <label data-help="Select the streaming platform. Recommended output defaults follow this choice."><span>Provider</span><select value="@_providerDraft.Provider" @onchange="ChangeProvider">@foreach (var value in Enum.GetValues<PublicationStreamProvider>()) { <option value="@value">@value</option> }</select></label>
                                    @if (_providerDraft.Provider == PublicationStreamProvider.Twitch)
                                    {
                                        <label data-help="Use Twitch browser/device authorization or keep the existing manual stream-key workflow."><span>Connection method</span><select value="@_providerDraft.AuthenticationMode" @onchange="ChangeAuthenticationMode"><option value="Manual">Manual stream key</option><option value="OAuth">Twitch web login (OAuth)</option></select></label>
                                    }
                                    <label data-help="Choose RTMP, secure RTMPS, or SRT transport for the provider ingest connection. Twitch OAuth currently uses the official RTMP ingest templates."><span>Transport</span><select @bind="_providerDraft.Transport" disabled="@IsTwitchOAuth">@foreach (var value in ProviderTransports) { <option value="@value">@value</option> }</select></label>
                                    <label data-help="Provider ingest server or complete custom endpoint. Twitch endpoint templates may contain {streamKey}."><span>Ingest endpoint</span><input @bind="_providerDraft.Endpoint" placeholder="Provider ingest server or custom URL" /></label>
                                    <label data-help="The channel, account, or live-chat identifier used for provider routing and Chat context."><span>Channel / account ID</span><input @bind="_providerDraft.ChannelId" disabled="@IsTwitchOAuth" /></label>
                                    <label data-help="Public account or channel name. Twitch OAuth fills this from the authorized account."><span>Account name</span><input @bind="_providerDraft.AccountName" disabled="@IsTwitchOAuth" /></label>
                                </div>
                            </section>

                            @if (_providerDraft.Provider == PublicationStreamProvider.Twitch)
                            {
                                <section class="streaming-settings-card">
                                    <div class="streaming-card-heading">
                                        <div><h3>Twitch connection</h3><p>OAuth uses Twitch's public-client device authorization. Password and MFA stay on Twitch.</p></div>
                                        <span class="streaming-state-badge @(_providerDraft.HasStoredOAuthSession ? "enabled" : null)">@TwitchConnectionLabel</span>
                                    </div>
                                    @if (IsTwitchOAuth)
                                    {
                                        <div class="streaming-form-grid two-column">
                                            <label class="span-2" data-help="Public Client ID from a Twitch developer application configured for the Device Code Grant flow. It is not a secret."><span>Twitch application Client ID</span><input @bind="_providerDraft.OAuthClientId" placeholder="@TwitchClientIdPlaceholder" /></label>
                                            <label class="streaming-check-field span-2" data-help="Use Twitch's ingest list and measure TCP connection latency from this computer after authorization."><input type="checkbox" @bind="_providerDraft.AutoSelectIngest" /><span><b>Automatically choose the best Twitch ingest</b><small>Tests the official Twitch ingest list from this machine and selects the lowest reachable latency.</small></span></label>
                                        </div>
                                        <div class="streaming-oauth-actions">
                                            <button type="button" class="primary-button" disabled="@_twitchOAuthBusy" @onclick="ConnectTwitchOAuth"><i class="pub-icon pub-icon-web"></i>@(_providerDraft.HasStoredOAuthSession ? "Reconnect Twitch" : "Connect Twitch")</button>
                                            @if (_twitchOAuthBusy)
                                            {
                                                <button type="button" @onclick="CancelTwitchOAuth">Cancel sign-in</button>
                                            }
                                            @if (_providerDraft.HasStoredOAuthSession)
                                            {
                                                <button type="button" class="danger-button" disabled="@_twitchOAuthBusy" @onclick="DisconnectTwitchOAuth">Disconnect OAuth</button>
                                            }
                                        </div>
                                        @if (_twitchAuthorization is not null)
                                        {
                                            <div class="streaming-information-box"><i class="pub-icon pub-icon-command"></i><span>Complete Twitch sign-in in the browser. Activation code: <b>@_twitchAuthorization.UserCode</b>. <a href="@_twitchAuthorization.VerificationUri" target="_blank" rel="noopener">Open Twitch authorization</a></span></div>
                                        }
                                        <div class="streaming-information-box"><i class="pub-icon pub-icon-lock"></i><span>PublisherStudio never receives the Twitch password or MFA value. It stores the access token, rotating refresh token, and stream key encrypted for the current operating-system user.</span></div>
                                        @if (_providerDraft.HasStoredOAuthSession)
                                        {
                                            <div class="streaming-oauth-summary">
                                                <span><b>Account</b>@_providerDraft.AccountName</span>
                                                <span><b>Access token</b>@OAuthExpiryText</span>
                                                <span><b>Scopes</b>@(_providerDraft.OAuthScopes.Length == 0 ? "Unknown" : _providerDraft.OAuthScopes)</span>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="streaming-information-box"><i class="pub-icon pub-icon-command"></i><span>Manual mode keeps the existing endpoint, stream-key, account, and Chat-token fields. Switch to Twitch web login to retrieve the broadcaster identity and stream key through Twitch OAuth.</span></div>
                                    }
                                </section>

                                <section class="streaming-settings-card">
                                    <div class="streaming-card-heading"><div><h3>Twitch ingest selection</h3><p>Refresh the official endpoint list and measure connection latency from this computer.</p></div><span class="streaming-summary-value">@TwitchIngestSummary</span></div>
                                    <div class="streaming-oauth-actions">
                                        <button type="button" disabled="@_twitchIngestBusy" @onclick="TestTwitchIngestEndpoints"><i class="pub-icon pub-icon-redo"></i>@(_twitchIngestBusy ? "Testing endpoints…" : "Test Twitch endpoints")</button>
                                    </div>
                                    @if (_twitchIngestCandidates.Count > 0)
                                    {
                                        <div class="streaming-form-grid compact-top">
                                            <label><span>Measured Twitch endpoints</span><select value="@_providerDraft.Endpoint" @onchange="SelectTwitchIngestEndpoint">@foreach (var candidate in _twitchIngestCandidates) { <option value="@candidate.Endpoint">@TwitchIngestOption(candidate)</option> }</select></label>
                                        </div>
                                    }
                                </section>
                            }

                            <section class="streaming-settings-card">
                                <div class="streaming-card-heading"><div><h3>Credentials and Chat</h3><p>Secrets are encrypted for the signed-in operating-system user and never exported with the publication.</p></div></div>
                                <div class="streaming-form-grid">
                                    @if (!IsTwitchOAuth)
                                    {
                                        <label data-help="Enter the stream key or ingest token. Leave it blank when editing to retain the encrypted value already stored."><span>Stream key / ingest token</span><input type="password" @bind="_providerDraft.Secret" placeholder="@(_providerDraft.HasStoredSecret ? "Stored securely — leave blank to keep" : "Stored encrypted for this user")" /></label>
                                    }
                                    else
                                    {
                                        <div class="streaming-information-box"><i class="pub-icon pub-icon-lock"></i><span>The stream key is managed by the Twitch OAuth connection and is not displayed in the editor.</span></div>
                                    }
                                    <label class="streaming-check-field" data-help="Enable the provider-specific operator Chat connection for this profile. Broadcast viewers never receive the token."><input type="checkbox" @bind="_providerDraft.ChatEnabled" /><span><b>Connect live Chat</b><small>Use this provider and channel as a compositor Chat context.</small></span></label>
                                    @if (_providerDraft.ChatEnabled && !IsTwitchOAuth)
                                    {
                                        <label data-help="OAuth access token used only for Chat receive/send operations. It is stored separately from the stream key."><span>Chat OAuth access token</span><input type="password" @bind="_providerDraft.ChatSecret" placeholder="@(_providerDraft.HasStoredChatSecret ? "Stored securely — leave blank to keep" : "Provider OAuth token, stored encrypted")" /></label>
                                        <div class="streaming-information-box"><i class="pub-icon pub-icon-command"></i><span>Twitch manual Chat uses account name, channel, and an OAuth token. YouTube uses the Channel / account ID as the live-chat ID plus an OAuth token with live-chat permissions.</span></div>
                                    }
                                    @if (_providerDraft.ChatEnabled && IsTwitchOAuth && !TwitchOAuthHasChatScopes)
                                    {
                                        <div class="streaming-information-box"><i class="pub-icon pub-icon-command"></i><span>This Twitch authorization does not include Chat scopes. Reconnect Twitch while “Connect live Chat” is enabled.</span></div>
                                    }
                                    <label class="streaming-check-field" data-help="When enabled, publications can select this provider profile for outputs."><input type="checkbox" @bind="_providerDraft.Enabled" /><span><b>Available to publications</b><small>Hide incomplete or retired profiles without deleting them.</small></span></label>
                                </div>
                            </section>

                            <div class="streaming-content-actions">
                                <button type="button" class="primary-button" @onclick="SaveProvider"><i class="pub-icon pub-icon-save"></i>Save provider</button>
                                <button type="button" @onclick="DuplicateCurrentProvider"><i class="pub-icon pub-icon-duplicate"></i>Duplicate</button>
                                <button type="button" class="danger-button" @onclick="DeleteProvider"><i class="pub-icon pub-icon-delete"></i>Delete</button>
                            </div>
                        }
                    </main>
                }
                else if (_tab == "outputs")
                {
                    <main class="streaming-content-pane streaming-content-wide">
                        <header class="streaming-page-heading">
                            <div><h2>Publication outputs</h2><p>One publication render feeds independently scaled and encoded provider variants.</p></div>
                            <button type="button" class="primary-button" @onclick="AddOutput"><i class="pub-icon pub-icon-newpage"></i>Add output</button>
                        </header>

                        <section class="streaming-settings-card">
                            <div class="streaming-card-heading"><div><h3>Master program</h3><p>The compositor captures the publication once at this resolution and frame rate.</p></div><span class="streaming-summary-value">@_draft.MasterWidth × @_draft.MasterHeight · @_draft.MasterFrameRate fps</span></div>
                            <div class="streaming-form-grid four-column">
                                <label data-help="Horizontal pixel size of the shared master publication render."><span>Master width</span><input type="number" min="640" max="7680" step="2" @bind="_draft.MasterWidth" /></label>
                                <label data-help="Vertical pixel size of the shared master publication render."><span>Master height</span><input type="number" min="360" max="4320" step="2" @bind="_draft.MasterHeight" /></label>
                                <label data-help="Frames per second produced by the shared compositor before provider scaling."><span>Master FPS</span><input type="number" min="15" max="120" @bind="_draft.MasterFrameRate" /></label>
                                <label class="streaming-check-field compact" data-help="Prefer source timestamps from cameras and capture devices to reduce drift when available."><input type="checkbox" @bind="_draft.PreferDeviceTimestamps" /><span><b>Device timestamps</b><small>Prefer capture timing over browser arrival timing.</small></span></label>
                            </div>
                        </section>

                        @if (_draft.Outputs.Count == 0)
                        {
                            <div class="streaming-empty-state">
                                <i class="pub-icon pub-icon-video"></i>
                                <b>No publication outputs</b>
                                <span>Add a provider profile first, then create an independently encoded output.</span>
                                <button type="button" class="primary-button" @onclick="AddOutput">Add output</button>
                            </div>
                        }
                        else
                        {
                            <div class="streaming-output-list">
                                @foreach (var output in _draft.Outputs)
                                {
                                    <section class="streaming-output-card @(_selectedOutputId == output.Id ? "selected" : null)"
                                             @onclick="() => SelectOutput(output.Id)"
                                             @oncontextmenu="args => ShowOutputContextMenu(output, args)"
                                             @oncontextmenu:preventDefault
                                             @oncontextmenu:stopPropagation
                                             data-help="Click to select this output. Right-click for recommended settings, duplicate, and remove commands.">
                                        <header>
                                            <label class="streaming-output-enabled" @onclick:stopPropagation data-help="Turn this provider output on or off without deleting its settings."><input type="checkbox" @bind="output.Enabled" /><span><b>@output.Name</b><small>@output.Provider · @output.Width × @output.Height · @output.FrameRate fps</small></span></label>
                                            <div class="streaming-output-badges">
                                                <span>@output.QualityPreset</span>
                                                <span>@output.VideoBitrateKbps kbps</span>
                                                <button type="button" class="icon-command-button danger" aria-label="Remove output" data-help="Remove this publication output and its selected recording reference." @onclick:stopPropagation @onclick="() => RemoveOutput(output.Id)">×</button>
                                            </div>
                                        </header>
                                        <div class="streaming-form-grid four-column">
                                            <label><span>Output name</span><input @bind="output.Name" /></label>
                                            <label data-help="Choose the reusable machine provider profile used by this output."><span>Provider profile</span><select value="@output.ProfileId" @onchange="args => ChangeOutputProfile(output, args)"><option value="">Select profile</option>@foreach (var profile in _machine.Providers.Where(item => item.Enabled)) { <option value="@profile.Id">@profile.Name</option> }</select></label>
                                            <label data-help="Apply provider-oriented resolution and bitrate defaults, or choose Custom to keep manual values."><span>Quality preset</span><select value="@output.QualityPreset" @onchange="args => ChangeOutputPreset(output, args)">@foreach (var value in Enum.GetValues<PublicationStreamQualityPreset>()) { <option value="@value">@value</option> }</select></label>
                                            <label class="streaming-check-field compact"><input type="checkbox" @bind="output.UseProviderTestMode" /><span><b>Provider test mode</b><small>Use the platform's test route when supported.</small></span></label>
                                            <label><span>Width</span><input type="number" min="320" max="7680" step="2" @bind="output.Width" /></label>
                                            <label><span>Height</span><input type="number" min="180" max="4320" step="2" @bind="output.Height" /></label>
                                            <label><span>Frame rate</span><input type="number" min="15" max="120" @bind="output.FrameRate" /></label>
                                            <label><span>Video bitrate (kbps)</span><input type="number" min="500" max="100000" step="100" @bind="output.VideoBitrateKbps" /></label>
                                            <label><span>Video codec</span><select @bind="output.VideoCodec">@foreach (var value in Enum.GetValues<PublicationStreamVideoCodec>()) { <option value="@value">@value</option> }</select></label>
                                            <label><span>Audio bitrate (kbps)</span><input type="number" min="64" max="512" step="16" @bind="output.AudioBitrateKbps" /></label>
                                            <label><span>Keyframe interval (s)</span><input type="number" min="1" max="10" @bind="output.KeyFrameIntervalSeconds" /></label>
                                            <label data-help="Override the provider profile's Chat channel for this output. Leave blank to inherit the profile channel."><span>Chat channel override</span><input @bind="output.ChatChannel" placeholder="Use provider channel when blank" /></label>
                                        </div>
                                    </section>
                                }
                            </div>
                        }
                    </main>
                }
                else if (_tab == "recording")
                {
                    <main class="streaming-content-pane streaming-content-wide">
                        <header class="streaming-page-heading">
                            <div><h2>Recording</h2><p>Recording stays independent from provider delivery and can write a clean master or selected output variants.</p></div>
                            <span class="streaming-state-badge @(_draft.Recording.Enabled ? "enabled" : null)">@(_draft.Recording.Enabled ? "Recording enabled" : "Recording disabled")</span>
                        </header>

                        <div class="streaming-dashboard-grid">
                            <section class="streaming-settings-card">
                                <div class="streaming-card-heading"><div><h3>Recording plan</h3><p>Choose what is written when a streaming or dry-run session starts.</p></div></div>
                                <div class="streaming-form-grid two-column">
                                    <label class="streaming-check-field span-2"><input type="checkbox" @bind="_draft.Recording.Enabled" /><span><b>Record when a session starts</b><small>The recording pipeline remains isolated from every provider encoder.</small></span></label>
                                    <label data-help="Clean Master records the shared publication before provider scaling. Other variants record output-specific encodes."><span>Variant</span><select @bind="_draft.Recording.Variant">@foreach (var value in Enum.GetValues<PublicationStreamRecordingVariant>()) { <option value="@value">@RecordingVariantName(value)</option> }</select></label>
                                    <label><span>Container</span><select @bind="_draft.Recording.Container"><option value="mkv">MKV — crash tolerant</option><option value="mp4">MP4</option><option value="webm">WebM</option></select></label>
                                    <label class="span-2" data-help="Native folder used by PublisherStudio. Leave blank to use the machine default recording directory."><span>Destination directory</span><input @bind="_draft.Recording.DestinationDirectory" placeholder="Use machine default when blank" /><small>Enter a native path; browsers intentionally do not reveal a selected folder's full path.</small></label>
                                    <label><span>Segment seconds</span><input type="number" min="2" max="120" @bind="_draft.Recording.SegmentSeconds" /></label>
                                    <label class="streaming-check-field compact"><input type="checkbox" @bind="_draft.Recording.RemuxToMp4AfterStop" /><span><b>Remux MKV to MP4</b><small>Create a convenient MP4 after clean shutdown.</small></span></label>
                                </div>
                            </section>

                            <aside class="streaming-summary-card">
                                <i class="pub-icon pub-icon-media"></i>
                                <span>Estimated storage</span>
                                <strong>@EstimatedRecordingStorageText</strong>
                                <small>Actual usage varies with content complexity, codecs, and encoder behavior.</small>
                            </aside>
                        </div>

                        @if (_draft.Recording.Variant == PublicationStreamRecordingVariant.SelectedOutputs)
                        {
                            <section class="streaming-settings-card">
                                <div class="streaming-card-heading"><div><h3>Selected output variants</h3><p>These variants may be recorded even when their public provider output is disabled.</p></div></div>
                                <div class="streaming-selection-grid">
                                    @foreach (var output in _draft.Outputs)
                                    {
                                        <label class="streaming-check-field"><input type="checkbox" checked="@_draft.Recording.SelectedOutputIds.Contains(output.Id)" @onchange="_ => ToggleRecordingOutput(output.Id)" /><span><b>@output.Name</b><small>@output.Width × @output.Height · @output.VideoBitrateKbps kbps</small></span></label>
                                    }
                                </div>
                                @if (_draft.Outputs.Count == 0)
                                {
                                    <p class="streaming-inline-empty">Create publication outputs before selecting output-specific recording variants.</p>
                                }
                            </section>
                        }
                    </main>
                }
                else if (_tab == "lan")
                {
                    <main class="streaming-content-pane streaming-content-wide">
                        <header class="streaming-page-heading">
                            <div><h2>Company / LAN streaming</h2><p>Bind internal playback explicitly to an IP address and enable browser, HLS, or RTSP delivery independently.</p></div>
                            <span class="streaming-state-badge @(_draft.Lan.Enabled ? "enabled" : null)">@(_draft.Lan.Enabled ? "LAN output enabled" : "LAN output disabled")</span>
                        </header>

                        <div class="streaming-dashboard-grid lan">
                            <section class="streaming-settings-card">
                                <div class="streaming-card-heading"><div><h3>Listener and access</h3><p>LAN exposure remains disabled until you explicitly enable it.</p></div></div>
                                <div class="streaming-form-grid three-column">
                                    <label class="streaming-check-field span-3"><input type="checkbox" @bind="_draft.Lan.Enabled" /><span><b>Enable LAN output</b><small>Start the listener only while a streaming session is active.</small></span></label>
                                    <label data-help="Use 127.0.0.1 for this computer only, or enter an explicit LAN adapter address for other devices."><span>Bind address</span><input @bind="_draft.Lan.BindAddress" placeholder="127.0.0.1 or selected LAN IP" /></label>
                                    <label><span>HTTP/WebRTC port</span><input type="number" min="1024" max="65535" @bind="_draft.Lan.Port" /></label>
                                    <label><span>Viewer limit</span><input type="number" min="1" max="10000" @bind="_draft.Lan.ViewerLimit" /></label>
                                    <label class="streaming-check-field compact"><input type="checkbox" @bind="_draft.Lan.RequireAccessToken" /><span><b>Require access token</b><small>Protect browser and HLS URLs.</small></span></label>
                                </div>
                            </section>

                            <aside class="streaming-summary-card security">
                                <i class="pub-icon pub-icon-lock"></i>
                                <span>Exposure</span>
                                <strong>@LanExposureText</strong>
                                <small>PublisherStudio reports final browser, HLS, and RTSP URLs after the session starts.</small>
                            </aside>
                        </div>

                        <section class="streaming-settings-card">
                            <div class="streaming-card-heading"><div><h3>Output and protocols</h3><p>Use one LAN encode for the enabled internal delivery protocols.</p></div></div>
                            <div class="streaming-form-grid four-column">
                                <label><span>Output width</span><input type="number" min="320" max="7680" step="2" @bind="_draft.Lan.Width" /></label>
                                <label><span>Output height</span><input type="number" min="180" max="4320" step="2" @bind="_draft.Lan.Height" /></label>
                                <label><span>Frame rate</span><input type="number" min="15" max="120" @bind="_draft.Lan.FrameRate" /></label>
                                <label><span>Video bitrate (kbps)</span><input type="number" min="250" max="200000" step="250" @bind="_draft.Lan.VideoBitrateKbps" /></label>
                            </div>
                            <div class="streaming-selection-grid protocols">
                                <label class="streaming-check-field"><input type="checkbox" @bind="_draft.Lan.EnableBrowserWebRtc" /><span><b>Browser watch page</b><small>Low-latency WebRTC with MediaSource fallback.</small></span></label>
                                <label class="streaming-check-field"><input type="checkbox" @bind="_draft.Lan.EnableHls" /><span><b>HLS</b><small>Browser and VLC-compatible segmented playback.</small></span></label>
                                <label class="streaming-check-field"><input type="checkbox" @bind="_draft.Lan.EnableRtsp" /><span><b>RTSP</b><small>VLC and production receiver delivery.</small></span></label>
                            </div>
                            @if (_draft.Lan.EnableRtsp)
                            {
                                <div class="streaming-form-grid three-column compact-top">
                                    <label><span>RTSP port</span><input type="number" min="1024" max="65535" @bind="_draft.Lan.RtspPort" /></label>
                                </div>
                            }
                        </section>
                    </main>
                }
                else if (_tab == "devices")
                {
                    <main class="streaming-content-pane streaming-content-wide">
                        <header class="streaming-page-heading">
                            <div><h2>Reusable device profiles</h2><p>Save capture identities once and select them from publication live-source objects.</p></div>
                            <button type="button" class="primary-button" @onclick="AddDeviceProfile"><i class="pub-icon pub-icon-newpage"></i>Add device profile</button>
                        </header>

                        <section class="streaming-settings-card">
                            <div class="streaming-card-heading"><div><h3>Saved profiles</h3><p>These machine profiles are reusable across publications.</p></div><span class="streaming-summary-value">@_machine.Devices.Count saved</span></div>
                            @if (_machine.Devices.Count == 0)
                            {
                                <div class="streaming-inline-empty">No saved profiles yet. Add one manually or save a discovered browser/native device below.</div>
                            }
                            else
                            {
                                <div class="streaming-device-profile-list">
                                    @foreach (var profile in _machine.Devices)
                                    {
                                        <article class="streaming-device-profile-card"
                                                 @oncontextmenu="args => ShowDeviceContextMenu(profile, args)"
                                                 @oncontextmenu:preventDefault
                                                 @oncontextmenu:stopPropagation>
                                            <header><span class="streaming-item-icon"><i class="pub-icon pub-icon-media"></i></span><div><b>@profile.Name</b><small>@profile.Kind · @profile.CaptureBackend</small></div><button type="button" class="icon-command-button danger" aria-label="Remove device profile" @onclick="() => RemoveDeviceProfile(profile.Id)">×</button></header>
                                            <div class="streaming-form-grid three-column">
                                                <label><span>Name</span><input @bind="profile.Name" placeholder="Studio microphone" /></label>
                                                <label><span>Source kind</span><select @bind="profile.Kind">@foreach (var value in Enum.GetValues<PublicationLiveSourceKind>()) { <option value="@value">@value</option> }</select></label>
                                                <label><span>Capture backend</span><select @bind="profile.CaptureBackend">@foreach (var value in Enum.GetValues<PublicationCaptureBackend>()) { <option value="@value">@value</option> }</select></label>
                                                <label><span>Video / primary device ID</span><input @bind="profile.DeviceId" placeholder="Browser/native device identifier" /></label>
                                                <label><span>Audio device ID</span><input @bind="profile.AudioDeviceId" placeholder="Optional paired audio device" /></label>
                                                <label><span>Native backend</span><input @bind="profile.NativeBackend" placeholder="dshow, avfoundation, v4l2…" /></label>
                                                <label><span>Application / process</span><input @bind="profile.ApplicationId" placeholder="discord.exe or process ID" /></label>
                                                <label><span>Window-title hint</span><input @bind="profile.WindowTitle" /></label>
                                                <label class="streaming-check-field compact"><input type="checkbox" @bind="profile.UseDeviceTimestamps" /><span><b>Use device timestamps</b><small>Prefer capture timing when available.</small></span></label>
                                            </div>
                                        </article>
                                    }
                                </div>
                            }
                        </section>

                        <section class="streaming-settings-card">
                            <div class="streaming-card-heading"><div><h3>Browser devices</h3><p>Grant permission to reveal camera and microphone labels.</p></div><button type="button" @onclick="RefreshDevices"><i class="pub-icon pub-icon-redo"></i>Refresh browser devices</button></div>
                            @if (_browserDevices.Count == 0)
                            {
                                <div class="streaming-inline-empty">No browser devices listed. Refresh and grant camera/microphone permission.</div>
                            }
                            else
                            {
                                <div class="streaming-discovery-grid">
                                    @foreach (var device in _browserDevices)
                                    {
                                        <article>
                                            <span class="streaming-item-icon"><i class="pub-icon pub-icon-media"></i></span>
                                            <div><b>@device.Label</b><small>@device.Kind</small><code>@ShortId(device.DeviceId)</code></div>
                                            <button type="button" disabled="@(!CanSaveBrowserDevice(device))" @onclick="() => SaveBrowserDevice(device)">Save as profile</button>
                                        </article>
                                    }
                                </div>
                            }
                        </section>

                        <section class="streaming-settings-card">
                            <div class="streaming-card-heading"><div><h3>Native devices and applications</h3><p>PublisherStudio discovers capture cards, audio devices, and visible processes through its integrated runtime.</p></div><button type="button" @onclick="RefreshNativeDevices"><i class="pub-icon pub-icon-redo"></i>Refresh native devices</button></div>
                            @if (_nativeDevices.Count == 0)
                            {
                                <div class="streaming-inline-empty">No native targets listed. Verify FFmpeg and the operating-system capture permissions, then refresh.</div>
                            }
                            else
                            {
                                <div class="streaming-discovery-grid">
                                    @foreach (var device in _nativeDevices)
                                    {
                                        <article>
                                            <span class="streaming-item-icon"><i class="pub-icon pub-icon-media"></i></span>
                                            <div><b>@device.Name</b><small>@device.Kind · @device.Backend</small><code>@ShortId(device.Id)</code>@if (!string.IsNullOrWhiteSpace(device.WindowTitle)) { <em>@device.WindowTitle</em> }</div>
                                            <button type="button" @onclick="() => SaveNativeDevice(device)">Save as profile</button>
                                        </article>
                                    }
                                </div>
                            }
                        </section>

                        <div class="streaming-content-actions"><button type="button" class="primary-button" @onclick="SaveMachineOptions"><i class="pub-icon pub-icon-save"></i>Save device profiles</button></div>
                    </main>
                }
                else
                {
                    <main class="streaming-content-pane streaming-content-wide">
                        <header class="streaming-page-heading">
                            <div><h2>Advanced streaming options</h2><p>Configure the integrated streaming runtime, program-page behavior, encoders, and session hotkeys.</p></div>
                            <button type="button" class="primary-button" @onclick="SaveMachineOptions"><i class="pub-icon pub-icon-save"></i>Save machine options</button>
                        </header>

                        <section class="streaming-settings-card">
                            <div class="streaming-card-heading"><div><h3>Streaming runtime and program</h3><p>The runtime is part of PublisherStudio; machine settings stay local and page-following behavior is stored with the publication.</p></div></div>
                            <div class="streaming-form-grid three-column">
                                <label data-help="Path to FFmpeg. Leave blank to search the application folder and the operating-system PATH."><span>FFmpeg path</span><input @bind="_machine.FfmpegPath" placeholder="Auto-detect when blank" /></label>
                                <label data-help="Streaming capture, device discovery, recording, and ingest run inside this PublisherStudio process."><span>Streaming runtime</span><input value="Integrated into PublisherStudio" readonly /></label>
                                <label data-help="Auto probes hardware encoders and falls back to software encoding when initialization fails."><span>Encoder preference</span><select @bind="_machine.HardwareEncoder">@foreach (var value in Enum.GetValues<StreamingHardwareEncoderPreference>()) { <option value="@value">@value</option> }</select></label>
                                <label class="span-2"><span>Default recording directory</span><input @bind="_machine.DefaultRecordingDirectory" /></label>
                                <label class="streaming-check-field compact"><input type="checkbox" @bind="_draft.FollowSelectedPage" /><span><b>Follow selected Publisher page</b><small>Use the current editor page as program.</small></span></label>
                                <label><span>Fixed program page</span><select @bind="_draft.ProgramPageId" disabled="@_draft.FollowSelectedPage"><option value="">First page</option>@foreach (var documentPage in Document.Pages) { <option value="@documentPage.Id">@documentPage.Name</option> }</select></label>
                            </div>
                            <div class="streaming-information-box"><i class="pub-icon pub-icon-command"></i><span>Auto prefers NVENC, Quick Sync, AMF, or VideoToolbox before software encoding. Capture and encoder services run in the same PublisherStudio process; browser reconnects do not create a second application.</span></div>
                        </section>

                        <section class="streaming-settings-card">
                            <div class="streaming-card-heading"><div><h3>Streaming hotkeys</h3><p>In-app hotkeys require focus. Global hotkeys are registered by PublisherStudio on Windows while a session is active.</p></div><button type="button" @onclick="AddHotkey"><i class="pub-icon pub-icon-newpage"></i>Add hotkey</button></div>
                            <div class="streaming-hotkey-list">
                                @foreach (var hotkey in _draft.Hotkeys)
                                {
                                    <article class="streaming-hotkey-row"
                                             @oncontextmenu="args => ShowHotkeyContextMenu(hotkey, args)"
                                             @oncontextmenu:preventDefault
                                             @oncontextmenu:stopPropagation>
                                        <label><span>Gesture</span><input @bind="hotkey.Gesture" placeholder="F9 or Ctrl+Shift+S" /></label>
                                        <label><span>Command</span><select @bind="hotkey.Command">
                                            <option value="ToggleStreaming">Start / stop streaming</option>
                                            <option value="ToggleRecording">Toggle recording</option>
                                            <option value="NextPage">Next program page</option>
                                            <option value="PreviousPage">Previous program page</option>
                                            <option value="SelectPage">Select program page</option>
                                            <option value="ToggleOutput">Toggle provider output</option>
                                        </select></label>
                                        @if (hotkey.Command == "SelectPage")
                                        {
                                            <label><span>Page</span><select @bind="hotkey.TargetId"><option value="">Choose page</option>@foreach (var documentPage in Document.Pages) { <option value="@documentPage.Id">@documentPage.Name</option> }</select></label>
                                        }
                                        else if (hotkey.Command == "ToggleOutput")
                                        {
                                            <label><span>Output</span><select @bind="hotkey.TargetId"><option value="">Choose output</option>@foreach (var output in _draft.Outputs) { <option value="@output.Id">@output.Name</option> }</select></label>
                                        }
                                        else
                                        {
                                            <div class="hotkey-target-placeholder"><b>No target</b><small>This command applies to the active session.</small></div>
                                        }
                                        <label class="streaming-check-field compact"><input type="checkbox" @bind="hotkey.Global" /><span><b>Global</b><small>PublisherStudio registers it system-wide.</small></span></label>
                                        <button type="button" class="icon-command-button danger" aria-label="Remove hotkey" @onclick="() => RemoveHotkey(hotkey.Id)">×</button>
                                    </article>
                                }
                            </div>
                        </section>
                    </main>
                }

                @if (_showWorkflowHelp)
                {
                    <aside class="streaming-help-pane">
                        <header><div><b>@SectionTitle workflow</b><span>Simple rules for predictable sessions</span></div><button type="button" class="icon-command-button" aria-label="Hide workflow help" @onclick="ToggleWorkflowHelp">×</button></header>
                        @foreach (var step in WorkflowSteps)
                        {
                            <article><span>@step.Number</span><div><b>@step.Title</b><p>@step.Text</p></div></article>
                        }
                        <div class="streaming-help-tip"><i class="pub-icon pub-icon-command"></i><span>@WorkflowTip</span></div>
                    </aside>
                }
            </div>

            <footer class="subapp-footer streaming-studio-footer">
                <span><b>@SectionTitle:</b> @_status</span>
                <div>
                    <DxButton Text="Cancel" Click="Cancel" />
                    <DxButton Text="Apply streaming setup" Click="Apply" RenderStyle="ButtonRenderStyle.Primary" />
                </div>
            </footer>
        </section>
    </div>
}

<DxContextMenu @ref="_streamingContextMenu">
    <Items>
        @if (_contextKind == "provider")
        {
            <DxContextMenuItem Text="Edit provider" IconCssClass="pub-icon pub-icon-edit" Click="EditContextProvider" />
            <DxContextMenuItem Text="Duplicate provider" IconCssClass="pub-icon pub-icon-duplicate" Click="DuplicateContextProvider" />
            <DxContextMenuItem Text="New provider" IconCssClass="pub-icon pub-icon-newpage" BeginGroup="true" Click="NewProvider" />
            <DxContextMenuItem Text="Delete provider" IconCssClass="pub-icon pub-icon-delete" BeginGroup="true" Click="DeleteContextProvider" />
        }
        else if (_contextKind == "output")
        {
            <DxContextMenuItem Text="Select output" IconCssClass="pub-icon pub-icon-select" Click="SelectContextOutput" />
            <DxContextMenuItem Text="Apply recommended settings" IconCssClass="pub-icon pub-icon-fit" Click="ApplyContextOutputDefaults" />
            <DxContextMenuItem Text="Duplicate output" IconCssClass="pub-icon pub-icon-duplicate" Click="DuplicateContextOutput" />
            <DxContextMenuItem Text="Remove output" IconCssClass="pub-icon pub-icon-delete" BeginGroup="true" Click="RemoveContextOutput" />
        }
        else if (_contextKind == "device")
        {
            <DxContextMenuItem Text="Duplicate device profile" IconCssClass="pub-icon pub-icon-duplicate" Click="DuplicateContextDevice" />
            <DxContextMenuItem Text="Remove device profile" IconCssClass="pub-icon pub-icon-delete" BeginGroup="true" Click="RemoveContextDevice" />
        }
        else if (_contextKind == "hotkey")
        {
            <DxContextMenuItem Text="Duplicate hotkey" IconCssClass="pub-icon pub-icon-duplicate" Click="DuplicateContextHotkey" />
            <DxContextMenuItem Text="Remove hotkey" IconCssClass="pub-icon pub-icon-delete" BeginGroup="true" Click="RemoveContextHotkey" />
        }
        else
        {
            @if (_tab == "providers")
            {
                <DxContextMenuItem Text="New provider" IconCssClass="pub-icon pub-icon-newpage" Click="NewProvider" />
            }
            else if (_tab == "outputs")
            {
                <DxContextMenuItem Text="Add output" IconCssClass="pub-icon pub-icon-newpage" Click="AddOutput" />
            }
            else if (_tab == "devices")
            {
                <DxContextMenuItem Text="Add device profile" IconCssClass="pub-icon pub-icon-newpage" Click="AddDeviceProfile" />
                <DxContextMenuItem Text="Refresh browser devices" IconCssClass="pub-icon pub-icon-redo" Click="RefreshDevices" />
                <DxContextMenuItem Text="Refresh native devices" IconCssClass="pub-icon pub-icon-redo" Click="RefreshNativeDevices" />
            }
            else if (_tab == "advanced")
            {
                <DxContextMenuItem Text="Add hotkey" IconCssClass="pub-icon pub-icon-newpage" Click="AddHotkey" />
            }
            <DxContextMenuItem Text="@(_showWorkflowHelp ? "Hide workflow help" : "Show workflow help")" IconCssClass="pub-icon pub-icon-command" BeginGroup="true" Click="ToggleWorkflowHelp" />
        }
    </Items>
</DxContextMenu>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter, EditorRequired] public PublicationDocument Document { get; set; } = default!;
    [Parameter] public EventCallback<PublicationStreamingSettings> Saved { get; set; }
    [Parameter] public EventCallback Cancelled { get; set; }

    private const string DefaultTwitchEndpoint = "rtmp://ingest.global-contribute.live-video.net/app/{streamKey}";

    private static readonly PublicationStreamTransport[] ProviderTransports =
    [
        PublicationStreamTransport.Rtmp,
        PublicationStreamTransport.Rtmps,
        PublicationStreamTransport.Srt
    ];

    private string _tab = "providers";
    private bool _wasVisible;
    private bool _showWorkflowHelp = true;
    private PublicationStreamingSettings _draft = new();
    private StreamingMachineSettings _machine = new();
    private StreamingProviderProfile? _providerDraft;
    private List<TwitchIngestCandidate> _twitchIngestCandidates = [];
    private TwitchDeviceAuthorization? _twitchAuthorization;
    private CancellationTokenSource? _twitchOAuthCancellation;
    private bool _twitchOAuthBusy;
    private bool _twitchIngestBusy;
    private List<BrowserMediaDeviceInfo> _browserDevices = [];
    private List<NativeMediaDeviceInfo> _nativeDevices = [];
    private Guid? _selectedOutputId;
    private string _status = "Ready";
    private DxContextMenu _streamingContextMenu = default!;
    private string _contextKind = "workspace";
    private Guid? _contextId;

    private PublicationStreamOutput? SelectedOutput => _selectedOutputId is { } id
        ? _draft.Outputs.FirstOrDefault(item => item.Id == id)
        : null;

    private bool IsTwitchOAuth => _providerDraft is
    {
        Provider: PublicationStreamProvider.Twitch,
        AuthenticationMode: StreamingProviderAuthenticationMode.OAuth
    };

    private bool TwitchOAuthHasChatScopes => _providerDraft is not null
        && _providerDraft.OAuthScopes.Contains("chat:read", StringComparison.OrdinalIgnoreCase)
        && _providerDraft.OAuthScopes.Contains("chat:edit", StringComparison.OrdinalIgnoreCase);

    private string TwitchClientIdPlaceholder => string.IsNullOrWhiteSpace(TwitchOAuth.DefaultClientId)
        ? "Twitch public application Client ID"
        : "Configured by PublisherStudio — leave blank to use it";

    private string TwitchConnectionLabel => _providerDraft is null
        ? "Not configured"
        : _providerDraft.AuthenticationMode == StreamingProviderAuthenticationMode.Manual
            ? "Manual mode"
            : _providerDraft.HasStoredOAuthSession ? "OAuth connected" : "OAuth not connected";

    private string OAuthExpiryText => _providerDraft?.OAuthAccessTokenExpiresUtc is { } expiresUtc
        ? expiresUtc <= DateTimeOffset.UtcNow ? "Refresh required" : $"Refreshes automatically · {expiresUtc.ToLocalTime():g}"
        : "Managed automatically";

    private string TwitchIngestSummary => _providerDraft is null || string.IsNullOrWhiteSpace(_providerDraft.IngestServerName)
        ? "Not measured"
        : _providerDraft.IngestLatencyMilliseconds is { } milliseconds
            ? $"{_providerDraft.IngestServerName} · {milliseconds:0} ms"
            : _providerDraft.IngestServerName;

    private string SectionTitle => _tab switch
    {
        "providers" => "Provider profiles",
        "outputs" => "Publication outputs",
        "recording" => "Recording",
        "lan" => "Company / LAN",
        "devices" => "Devices",
        _ => "Advanced"
    };

    private string SectionDescription => _tab switch
    {
        "providers" => "Create reusable provider identities and keep stream/Chat secrets in the machine profile store.",
        "outputs" => "Map the shared publication program to independently scaled and encoded destinations.",
        "recording" => "Choose clean-master or output-specific files without coupling recording reliability to public delivery.",
        "lan" => "Expose internal browser, HLS, or RTSP playback only on an explicitly selected address.",
        "devices" => "Discover browser/native sources and save stable machine profiles for live-source objects.",
        _ => "Control the integrated streaming runtime, program page, encoder preference, and session hotkeys."
    };

    private string SectionIcon => _tab switch
    {
        "providers" => "pub-icon-web",
        "outputs" => "pub-icon-video",
        "recording" => "pub-icon-media",
        "lan" => "pub-icon-web",
        "devices" => "pub-icon-media",
        _ => "pub-icon-properties"
    };

    private IReadOnlyList<WorkflowStep> WorkflowSteps => _tab switch
    {
        "providers" =>
        [
            new(1, "Create a machine profile", "Choose the provider and use OAuth where supported, or keep manual endpoint and key entry."),
            new(2, "Store credentials", "OAuth sessions, stream keys, and optional Chat secrets are encrypted for the current Windows user."),
            new(3, "Use it in outputs", "The publication stores only the provider profile ID, never the secret values.")
        ],
        "outputs" =>
        [
            new(1, "Set the master program", "Choose the shared compositor resolution and frame rate."),
            new(2, "Add provider variants", "Each output can scale, encode, test, and route Chat independently."),
            new(3, "Apply the setup", "The publication keeps output settings while machine profiles remain reusable.")
        ],
        "recording" =>
        [
            new(1, "Enable recording", "Recording begins with a live or dry-run session."),
            new(2, "Choose the variant", "Record the clean master, each enabled output, or only selected outputs."),
            new(3, "Prefer crash tolerance", "MKV segments can be remuxed to MP4 after a clean stop.")
        ],
        "lan" =>
        [
            new(1, "Choose an address", "Use loopback for this computer or a specific LAN adapter address."),
            new(2, "Enable protocols", "Browser/WebRTC, HLS, and RTSP can be switched independently."),
            new(3, "Protect access", "Keep viewer limits and access tokens enabled when other devices can connect.")
        ],
        "devices" =>
        [
            new(1, "Discover sources", "Browser permission reveals cameras/microphones; PublisherStudio finds native devices."),
            new(2, "Save stable profiles", "Store the identifiers and backend hints once on this machine."),
            new(3, "Select from live objects", "Publication live-source elements reference the reusable device profile.")
        ],
        _ =>
        [
            new(1, "Check FFmpeg", "Leave FFmpeg blank for automatic discovery or specify the native executable path."),
