    private void DuplicateDeviceProfile(StreamingDeviceProfile profile)
    {
        var copy = Clone(profile);
        copy.Id = Guid.NewGuid();
        copy.Name = $"{copy.Name} copy";
        _machine.Devices.Add(copy);
        _status = $"Duplicated {profile.Name}.";
    }

    private static bool CanSaveBrowserDevice(BrowserMediaDeviceInfo device) =>
        !string.IsNullOrWhiteSpace(device.DeviceId)
        && (string.Equals(device.Kind, "videoinput", StringComparison.OrdinalIgnoreCase)
            || string.Equals(device.Kind, "audioinput", StringComparison.OrdinalIgnoreCase));

    private void SaveBrowserDevice(BrowserMediaDeviceInfo device)
    {
        if (!CanSaveBrowserDevice(device)) return;
        var existing = _machine.Devices.FirstOrDefault(profile =>
            string.Equals(profile.DeviceId, device.DeviceId, StringComparison.Ordinal));
        if (existing is not null)
        {
            existing.Name = string.IsNullOrWhiteSpace(device.Label) ? existing.Name : device.Label;
            _status = $"Updated {existing.Name}.";
            return;
        }

        var profile = new StreamingDeviceProfile
        {
            Name = string.IsNullOrWhiteSpace(device.Label) || device.Label == "Permission required"
                ? (string.Equals(device.Kind, "videoinput", StringComparison.OrdinalIgnoreCase) ? "Browser camera" : "Browser microphone")
                : device.Label,
            Kind = string.Equals(device.Kind, "videoinput", StringComparison.OrdinalIgnoreCase)
                ? PublicationLiveSourceKind.Camera
                : PublicationLiveSourceKind.Microphone,
            DeviceId = device.DeviceId,
            CaptureBackend = PublicationCaptureBackend.Browser,
            NativeBackend = string.Empty,
            UseDeviceTimestamps = _draft.PreferDeviceTimestamps
        };
        _machine.Devices.Add(profile);
        _status = $"Added {profile.Name}. Save device profiles to reuse it.";
    }

