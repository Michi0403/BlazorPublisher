    private async Task SaveProvider()
    {
        if (_providerDraft is null) return;
        if (_providerDraft.Provider == PublicationStreamProvider.Twitch
            && _providerDraft.AuthenticationMode == StreamingProviderAuthenticationMode.OAuth)
        {
            _providerDraft.Transport = PublicationStreamTransport.Rtmp;
            _providerDraft.OAuthClientId = TwitchOAuth.ResolveClientId(_providerDraft.OAuthClientId);
            if (string.IsNullOrWhiteSpace(_providerDraft.Endpoint)) _providerDraft.Endpoint = DefaultTwitchEndpoint;
        }

        var saved = await ProfileStore.SaveProviderAsync(_providerDraft);
        _machine = await ProfileStore.LoadAsync();
        _providerDraft = Clone(saved);
        _status = saved.AuthenticationMode == StreamingProviderAuthenticationMode.OAuth && !saved.HasStoredOAuthSession
            ? $"Saved {saved.Name}. Connect Twitch to complete OAuth authorization."
            : $"Saved {saved.Name}.";
    }

