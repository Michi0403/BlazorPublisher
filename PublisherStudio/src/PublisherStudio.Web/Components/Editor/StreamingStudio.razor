    private string EstimatedRecordingStorageText
    {
        get
        {
            if (!_draft.Recording.Enabled) return "Recording disabled";
            long totalKbps;
            if (_draft.Recording.Variant == PublicationStreamRecordingVariant.CleanMaster)
            {
                totalKbps = Math.Clamp(
                    (long)Math.Round(_draft.MasterWidth * (double)_draft.MasterHeight * _draft.MasterFrameRate * 0.16 / 1000.0),
                    12_000L,
                    120_000L) + 192;
            }
            else
            {
                var outputs = _draft.Recording.Variant == PublicationStreamRecordingVariant.SelectedOutputs
                    ? _draft.Outputs.Where(output => _draft.Recording.SelectedOutputIds.Contains(output.Id))
                    : _draft.Outputs.Where(output => output.Enabled);
                totalKbps = outputs.Sum(output => (long)output.VideoBitrateKbps + output.AudioBitrateKbps);
            }
            var gigabytesPerHour = totalKbps * 1000d * 3600d / 8d / 1_000_000_000d;
            return totalKbps <= 0 ? "No recording variants selected" : $"Approximately {gigabytesPerHour:0.0} GB per hour";
        }
    }

    private static string RecordingVariantName(PublicationStreamRecordingVariant value) => value switch
    {
        PublicationStreamRecordingVariant.CleanMaster => "Clean master",
        PublicationStreamRecordingVariant.EachEnabledOutput => "Each enabled output",
        PublicationStreamRecordingVariant.SelectedOutputs => "Selected outputs",
        _ => value.ToString()
    };

