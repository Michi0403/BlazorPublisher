    private async Task RefreshNativeDevices()
    {
        try
        {
            var ffmpeg = FfmpegLocator.Resolve(_machine.FfmpegPath);
            _nativeDevices = await MediaHost.DiscoverNativeDevicesAsync();
            if (_nativeDevices.Count > 0)
            {
                _status = ffmpeg is null
                    ? $"Found {_nativeDevices.Count} operating-system application targets. Install FFmpeg to discover and use native camera/capture devices."
                    : $"Found {_nativeDevices.Count} native devices and application targets. FFmpeg: {Path.GetFileName(ffmpeg)}.";
            }
            else
            {
                _status = ffmpeg is null
                    ? "FFmpeg was not found. Run PublisherStudio.Setup --install-ffmpeg or configure the executable path, then refresh."
                    : "No native devices were reported. Check operating-system capture permissions and whether the devices are in use.";
            }
        }
        catch (Exception exception)
        {
            _nativeDevices = [];
            _status = $"Native device discovery failed: {exception.Message}";
        }
    }

    private void SaveNativeDevice(NativeMediaDeviceInfo device)
    {
        var kind = Enum.TryParse<PublicationLiveSourceKind>(device.Kind, true, out var parsed) ? parsed : PublicationLiveSourceKind.CaptureDevice;
        var existing = _machine.Devices.FirstOrDefault(profile =>
            profile.CaptureBackend == PublicationCaptureBackend.Native
            && string.Equals(profile.NativeBackend, device.Backend, StringComparison.OrdinalIgnoreCase)
            && string.Equals(profile.DeviceId, device.Id, StringComparison.OrdinalIgnoreCase));
        if (existing is null)
        {
            existing = new StreamingDeviceProfile { Id = Guid.NewGuid() };
            _machine.Devices.Add(existing);
        }
        existing.Name = device.Name;
        existing.Kind = kind;
        existing.DeviceId = device.Id;
        existing.ApplicationId = device.ProcessId ?? (kind == PublicationLiveSourceKind.ApplicationAudio ? device.Id : string.Empty);
        existing.WindowTitle = device.WindowTitle ?? string.Empty;
        existing.CaptureBackend = PublicationCaptureBackend.Native;
        existing.NativeBackend = device.Backend;
        existing.UseDeviceTimestamps = _draft.PreferDeviceTimestamps;
        _status = $"Added {existing.Name}. Save device profiles to reuse it.";
    }

