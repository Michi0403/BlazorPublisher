    private void ChangeProvider(ChangeEventArgs args)
    {
        if (_providerDraft is null
            || !Enum.TryParse<PublicationStreamProvider>(args.Value?.ToString(), out var provider)) return;
        _providerDraft.Provider = provider;
        _twitchOAuthCancellation?.Cancel();
        _twitchIngestCandidates = [];
        _twitchAuthorization = null;
        if (provider == PublicationStreamProvider.Twitch)
        {
            _providerDraft.Transport = PublicationStreamTransport.Rtmp;
            if (string.IsNullOrWhiteSpace(_providerDraft.Endpoint)) _providerDraft.Endpoint = DefaultTwitchEndpoint;
            if (string.IsNullOrWhiteSpace(_providerDraft.OAuthClientId)) _providerDraft.OAuthClientId = TwitchOAuth.DefaultClientId;
        }
        else
        {
            _providerDraft.AuthenticationMode = StreamingProviderAuthenticationMode.Manual;
        }
        _status = $"Provider changed to {provider}.";
    }

    private void ChangeAuthenticationMode(ChangeEventArgs args)
    {
        if (_providerDraft is null
            || !Enum.TryParse<StreamingProviderAuthenticationMode>(args.Value?.ToString(), out var mode)) return;
        _providerDraft.AuthenticationMode = mode;
        if (mode == StreamingProviderAuthenticationMode.OAuth)
        {
            _providerDraft.Transport = PublicationStreamTransport.Rtmp;
            if (string.IsNullOrWhiteSpace(_providerDraft.Endpoint)) _providerDraft.Endpoint = DefaultTwitchEndpoint;
            if (string.IsNullOrWhiteSpace(_providerDraft.OAuthClientId)) _providerDraft.OAuthClientId = TwitchOAuth.DefaultClientId;
            _status = "Twitch OAuth selected. Connect Twitch to retrieve the account, stream key, and refresh session.";
        }
        else
        {
            _twitchOAuthCancellation?.Cancel();
            _status = "Manual Twitch configuration selected.";
        }
    }

    private async Task ConnectTwitchOAuth()
    {
        if (_providerDraft is null || _providerDraft.Provider != PublicationStreamProvider.Twitch || _twitchOAuthBusy) return;
        _twitchOAuthCancellation?.Cancel();
        _twitchOAuthCancellation?.Dispose();
        var cancellation = new CancellationTokenSource();
        _twitchOAuthCancellation = cancellation;
        _twitchOAuthBusy = true;
        _twitchAuthorization = null;
        try
        {
            await JS.InvokeVoidAsync("publisherStreaming.reserveExternalAuthorizationWindow", "publisherstudio-twitch-oauth");
            _providerDraft.AuthenticationMode = StreamingProviderAuthenticationMode.OAuth;
            _providerDraft.Transport = PublicationStreamTransport.Rtmp;
            _providerDraft.OAuthClientId = TwitchOAuth.ResolveClientId(_providerDraft.OAuthClientId);
            if (string.IsNullOrWhiteSpace(_providerDraft.Endpoint)) _providerDraft.Endpoint = DefaultTwitchEndpoint;
            var saved = await ProfileStore.SaveProviderAsync(_providerDraft, cancellation.Token);
            _providerDraft = Clone(saved);
            var authorization = await TwitchOAuth.StartDeviceAuthorizationAsync(
                _providerDraft.OAuthClientId,
                _providerDraft.ChatEnabled,
                cancellation.Token);
            _twitchAuthorization = authorization;
            _status = $"Twitch sign-in is waiting in the browser. Activation code: {authorization.UserCode}.";
            await JS.InvokeVoidAsync(
                "publisherStreaming.navigateExternalAuthorizationWindow",
                "publisherstudio-twitch-oauth",
                authorization.VerificationUri);
            await InvokeAsync(StateHasChanged);

            var result = await TwitchOAuth.CompleteDeviceAuthorizationAsync(
                _providerDraft.Id,
                authorization,
                _providerDraft.AutoSelectIngest,
                _providerDraft.Endpoint,
                cancellation.Token);
            _machine = await ProfileStore.LoadAsync(cancellation.Token);
            _providerDraft = result.Profile is not null
                ? Clone(result.Profile)
                : _machine.Providers.FirstOrDefault(profile => profile.Id == saved.Id) is { } stored
                    ? Clone(stored)
                    : null;
            _twitchIngestCandidates = result.IngestCandidates;
            _twitchAuthorization = null;
            _status = result.Message;
            await CloseTwitchAuthorizationWindowAsync();
        }
        catch (OperationCanceledException)
        {
            _status = "Twitch sign-in was cancelled.";
        }
        catch (Exception exception)
        {
            _status = $"Twitch connection failed: {exception.Message}";
        }
        finally
        {
            _twitchAuthorization = null;
            _twitchOAuthBusy = false;
            if (ReferenceEquals(_twitchOAuthCancellation, cancellation)) _twitchOAuthCancellation = null;
            cancellation.Dispose();
            await CloseTwitchAuthorizationWindowAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task CancelTwitchOAuth()
    {
        _twitchOAuthCancellation?.Cancel();
        await CloseTwitchAuthorizationWindowAsync();
    }

    private async Task CloseTwitchAuthorizationWindowAsync()
    {
        try { await JS.InvokeVoidAsync("publisherStreaming.closeExternalAuthorizationWindow", "publisherstudio-twitch-oauth"); }
        catch { }
    }

    private async Task DisconnectTwitchOAuth()
    {
        if (_providerDraft is null) return;
        var profileId = _providerDraft.Id;
        await TwitchOAuth.DisconnectAsync(profileId);
        _machine = await ProfileStore.LoadAsync();
        _providerDraft = _machine.Providers.FirstOrDefault(profile => profile.Id == profileId) is { } stored
            ? Clone(stored)
            : null;
        _twitchAuthorization = null;
        _twitchIngestCandidates = [];
        _status = "Twitch OAuth disconnected. The provider remains available for manual configuration.";
    }

    private async Task TestTwitchIngestEndpoints()
    {
        if (_providerDraft is null || _providerDraft.Provider != PublicationStreamProvider.Twitch || _twitchIngestBusy) return;
        _twitchIngestBusy = true;
        try
        {
            _status = "Testing Twitch ingest endpoints from this computer…";
            await InvokeAsync(StateHasChanged);
            _twitchIngestCandidates = await TwitchOAuth.TestIngestEndpointsAsync();
            var selected = _twitchIngestCandidates.FirstOrDefault(candidate => candidate.Reachable)
                ?? _twitchIngestCandidates.FirstOrDefault(candidate => candidate.IsGlobal);
            if (selected is not null) ApplyTwitchIngestCandidate(selected);
            _status = selected is null
                ? "Twitch did not return a usable ingest endpoint. The existing manual endpoint was left unchanged."
                : selected.LatencyMilliseconds is { } milliseconds
                    ? $"Selected {selected.Name} at approximately {milliseconds:0} ms TCP connection latency."
                    : $"Selected {selected.Name}. Direct latency testing was unavailable, so Twitch global routing remains the fallback.";
        }
        catch (Exception exception)
        {
            _status = $"Twitch endpoint test failed: {exception.Message}";
        }
        finally
        {
            _twitchIngestBusy = false;
        }
    }

    private void SelectTwitchIngestEndpoint(ChangeEventArgs args)
    {
        if (_providerDraft is null) return;
        var endpoint = args.Value?.ToString() ?? string.Empty;
        var candidate = _twitchIngestCandidates.FirstOrDefault(item => string.Equals(item.Endpoint, endpoint, StringComparison.Ordinal));
        if (candidate is not null) ApplyTwitchIngestCandidate(candidate);
    }

    private void ApplyTwitchIngestCandidate(TwitchIngestCandidate candidate)
    {
        if (_providerDraft is null) return;
        _providerDraft.Transport = PublicationStreamTransport.Rtmp;
        _providerDraft.Endpoint = candidate.Endpoint;
        _providerDraft.IngestServerName = candidate.Name;
        _providerDraft.IngestLatencyMilliseconds = candidate.LatencyMilliseconds;
        _providerDraft.IngestLastTestedUtc = DateTimeOffset.UtcNow;
    }

    private static string TwitchIngestOption(TwitchIngestCandidate candidate) =>
        candidate.Reachable && candidate.LatencyMilliseconds is { } milliseconds
            ? $"{candidate.Name} — {milliseconds:0} ms"
            : candidate.Reachable
                ? $"{candidate.Name} — reachable"
                : $"{candidate.Name} — unreachable (fallback only)";

