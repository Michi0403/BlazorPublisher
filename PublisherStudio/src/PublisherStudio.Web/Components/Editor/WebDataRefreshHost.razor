@namespace PublisherStudio.Components.Editor
@implements IAsyncDisposable

@code {
    [Parameter, EditorRequired] public EditorStateService State { get; set; } = default!;

    private readonly CancellationTokenSource _cancellation = new();
    private Task? _loop;
    private int _refreshing;
    private Guid _observedDocumentId;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender) _loop = RunAsync(_cancellation.Token);
    }

    private async Task RunAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                if (_observedDocumentId != State.Document.Id)
                {
                    _observedDocumentId = State.Document.Id;
                    await RefreshAsync(onOpen: true, cancellationToken);
                }
                if (!await timer.WaitForNextTickAsync(cancellationToken)) break;
                if (State.HasDueWebData) await RefreshAsync(onOpen: false, cancellationToken);
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested) { }
    }

    private async Task RefreshAsync(bool onOpen, CancellationToken cancellationToken)
    {
        if (Interlocked.Exchange(ref _refreshing, 1) != 0) return;
        try
        {
            if (onOpen)
                await InvokeAsync(() => State.RefreshWebDataOnOpenAsync(cancellationToken));
            else
                await InvokeAsync(() => State.RefreshWebDataAsync(force: false, cancellationToken: cancellationToken));
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested) { }
        catch (Exception ex) { Console.Error.WriteLine($"Web data refresh failed: {ex}"); }
        finally { Interlocked.Exchange(ref _refreshing, 0); }
    }

    public async ValueTask DisposeAsync()
    {
        _cancellation.Cancel();
        if (_loop is not null)
        {
            try { await _loop; }
            catch (OperationCanceledException) { }
        }
        _cancellation.Dispose();
    }
}
