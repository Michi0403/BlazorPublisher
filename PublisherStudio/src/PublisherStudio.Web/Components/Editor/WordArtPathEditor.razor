@namespace PublisherStudio.Components.Editor
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="wordart-path-editor">
    <div class="wordart-path-heading">
        <strong>Custom text path</strong>
        <span>Choose a curve or draw one. Drag the round points to refine it.</span>
    </div>

    <div class="wordart-path-presets" role="group" aria-label="WordArt path presets">
        <button type="button" title="Straight" @onclick="StraightPresetAsync">—</button>
        <button type="button" title="Rising" @onclick="RisePresetAsync">↗</button>
        <button type="button" title="Falling" @onclick="FallPresetAsync">↘</button>
        <button type="button" title="Arch up" @onclick="ArchUpPresetAsync">⌒</button>
        <button type="button" title="Arch down" @onclick="ArchDownPresetAsync">⌣</button>
        <button type="button" title="Gentle wave" @onclick="GentleWavePresetAsync">∿</button>
        <button type="button" title="S curve" @onclick="SCurvePresetAsync">S</button>
        <button type="button" title="Circular arc" @onclick="CircleArcPresetAsync">◠</button>
    </div>

    <svg id="@EditorId"
         class="wordart-path-canvas @(_drawingArmed ? "drawing-armed" : null)"
         viewBox="0 0 1000 300"
         preserveAspectRatio="none"
         role="application"
         aria-label="Draw and edit the WordArt baseline">
        <defs>
            <pattern id="@GridId" width="50" height="50" patternUnits="userSpaceOnUse">
                <path d="M 50 0 L 0 0 0 50" class="wordart-path-grid-line" />
            </pattern>
        </defs>
        <rect class="wordart-path-background" width="1000" height="300" fill="@GridFill" />
        <line class="wordart-path-center-line" x1="0" y1="150" x2="1000" y2="150" />
        <path class="wordart-path-preview" data-wordart-editor-path d="@PathData" />
        <g data-wordart-editor-points></g>
    </svg>

    <div class="wordart-path-actions">
        <DxButton Text="@(_drawingArmed ? "Draw on the canvas…" : "Draw freehand")" Click="ArmDrawingAsync" CssClass="path-action-primary" />
        <DxButton Text="Reverse" Click="ReverseAsync" />
        <DxButton Text="Fewer points" Enabled="@((Item.CustomPathPoints?.Count ?? 0) > 4)" Click="ReduceAsync" />
    </div>
    <p class="property-note">Draw from left to right for normal reading direction. A new stroke replaces the previous path; Undo restores it.</p>
</div>

@code {
    [Parameter, EditorRequired] public WordArtElement Item { get; set; } = default!;
    [Parameter] public EventCallback<List<WordArtPathPoint>> PathChanged { get; set; }

    private IJSObjectReference? _module;
    private DotNetObjectReference<WordArtPathEditor>? _self;
    private bool _initialized;
    private bool _drawingArmed;
    private string EditorId => $"wordart-path-editor-{Item.Id:N}";
    private string GridId => $"wordart-path-grid-{Item.Id:N}";
    private string GridFill => $"url(#{GridId})";
    private string PathData => WordArtPathGeometry.Build(Item.CustomPathPoints);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/publisherInterop.js");
        _self ??= DotNetObjectReference.Create(this);

        if (!_initialized)
        {
            await _module.InvokeVoidAsync("initializeWordArtPathEditor", EditorId, _self, Item.CustomPathPoints);
            _initialized = true;
        }
        else
        {
            await _module.InvokeVoidAsync("updateWordArtPathEditor", EditorId, Item.CustomPathPoints);
        }
    }

    private Task StraightPresetAsync() => ApplyPresetAsync("Straight");
    private Task RisePresetAsync() => ApplyPresetAsync("Rise");
    private Task FallPresetAsync() => ApplyPresetAsync("Fall");
    private Task ArchUpPresetAsync() => ApplyPresetAsync("ArchUp");
    private Task ArchDownPresetAsync() => ApplyPresetAsync("ArchDown");
    private Task GentleWavePresetAsync() => ApplyPresetAsync("GentleWave");
    private Task SCurvePresetAsync() => ApplyPresetAsync("SCurve");
    private Task CircleArcPresetAsync() => ApplyPresetAsync("CircleArc");

    private async Task ApplyPresetAsync(string key)
    {
        _drawingArmed = false;
        await SetDrawModeAsync(false);
        await PathChanged.InvokeAsync(WordArtPathGeometry.CreatePreset(key));
    }

    private async Task ArmDrawingAsync()
    {
        _drawingArmed = !_drawingArmed;
        await SetDrawModeAsync(_drawingArmed);
    }

    private async Task ReverseAsync()
    {
        _drawingArmed = false;
        await SetDrawModeAsync(false);
        await PathChanged.InvokeAsync(WordArtPathGeometry.Reverse(Item.CustomPathPoints));
    }

    private async Task ReduceAsync()
    {
        _drawingArmed = false;
        await SetDrawModeAsync(false);
        await PathChanged.InvokeAsync(WordArtPathGeometry.Reduce(Item.CustomPathPoints));
    }

    private async Task SetDrawModeAsync(bool enabled)
    {
        if (_module is not null)
            await _module.InvokeVoidAsync("setWordArtPathDrawMode", EditorId, enabled);
    }

    [JSInvokable]
    public async Task CommitWordArtPath(WordArtPathPoint[] points)
    {
        _drawingArmed = false;
        var normalized = WordArtPathGeometry.Normalize(points);
        await PathChanged.InvokeAsync(normalized);
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null && _initialized)
        {
            try { await _module.InvokeVoidAsync("disposeWordArtPathEditor", EditorId); }
            catch (JSDisconnectedException) { }
        }
        _self?.Dispose();
        if (_module is not null) await _module.DisposeAsync();
    }
}
