@namespace PublisherStudio.Components.Editor

<svg class="wordart-svg"
     viewBox="0 0 1000 300"
     preserveAspectRatio="xMidYMid meet"
     role="img"
     aria-label="@DisplayText">
    <defs>
        <linearGradient id="@GradientId"
                        gradientUnits="userSpaceOnUse"
                        x1="0" y1="0" x2="0" y2="300">
            <stop offset="0%" stop-color="@SecondaryColor" />
            <stop offset="100%" stop-color="@FillColor" />
        </linearGradient>

        @if (Item.Warp != WordArtWarp.None)
        {
            <path id="@PathId" d="@WarpPath" fill="none" />
        }
    </defs>

    @if (Item.ShadowEnabled)
    {
        @if (Item.Warp == WordArtWarp.None)
        {
            <SvgWordArtText CssClass="wordart-shadow-face"
                            X="500" Y="150" Dx="10" Dy="12"
                            TextAnchor="middle"
                            DominantBaseline="middle"
                            FontFamily="@FontFamily"
                            FontSize="@FontSize"
                            FontWeight="@FontWeight"
                            FontStyle="@FontStyle"
                            LetterSpacing="@LetterSpacing"
                            Fill="@ShadowColor"
                            FillOpacity="0.45"
                            Text="@DisplayText" />
        }
        else
        {
            <SvgWordArtText CssClass="wordart-shadow-face"
                            X="0" Y="0" Dx="10" Dy="@Inv(Item.PathBaselineOffset + 12)"
                            TextAnchor="middle"
                            FontFamily="@FontFamily"
                            FontSize="@FontSize"
                            FontWeight="@FontWeight"
                            FontStyle="@FontStyle"
                            LetterSpacing="@LetterSpacing"
                            Fill="@ShadowColor"
                            FillOpacity="0.45"
                            PathHref="@PathHref"
                            PathStartOffset="@PathStartOffset"
                            PathTextAnchor="middle"
                            Text="@DisplayText" />
        }
    }

    @foreach (var depth in ExtrusionLayers)
    {
        @if (Item.Warp == WordArtWarp.None)
        {
            <SvgWordArtText CssClass="wordart-extrusion"
                            X="500" Y="150"
                            Dx="@Inv(depth * 4)" Dy="@Inv(Item.PathBaselineOffset + depth * 4)"
                            TextAnchor="middle"
                            DominantBaseline="middle"
                            FontFamily="@FontFamily"
                            FontSize="@FontSize"
                            FontWeight="@FontWeight"
                            FontStyle="@FontStyle"
                            LetterSpacing="@LetterSpacing"
                            Fill="@ExtrudeColor"
                            Text="@DisplayText" />
        }
        else
        {
            <SvgWordArtText CssClass="wordart-extrusion"
                            X="0" Y="0"
                            Dx="@Inv(depth * 4)" Dy="@Inv(Item.PathBaselineOffset + depth * 4)"
                            TextAnchor="middle"
                            FontFamily="@FontFamily"
                            FontSize="@FontSize"
                            FontWeight="@FontWeight"
                            FontStyle="@FontStyle"
                            LetterSpacing="@LetterSpacing"
                            Fill="@ExtrudeColor"
                            PathHref="@PathHref"
                            PathStartOffset="@PathStartOffset"
                            PathTextAnchor="middle"
                            Text="@DisplayText" />
        }
    }

    @* A solid face is deliberately rendered first. It guarantees readable text if a browser,
       print engine, or rasterizer rejects the local SVG gradient paint server. *@
    @if (Item.Warp == WordArtWarp.None)
    {
        <SvgWordArtText CssClass="wordart-face wordart-face-fallback"
                        X="500" Y="150"
                        TextAnchor="middle"
                        DominantBaseline="middle"
                        FontFamily="@FontFamily"
                        FontSize="@FontSize"
                        FontWeight="@FontWeight"
                        FontStyle="@FontStyle"
                        LetterSpacing="@LetterSpacing"
                        Fill="@FillColor"
                        Stroke="@OutlineColor"
                        StrokeWidth="@OutlineWidth"
                        PaintOrder="stroke fill"
                        Text="@DisplayText" />

        @if (Item.GradientFill)
        {
            <SvgWordArtText CssClass="wordart-face wordart-face-gradient"
                            X="500" Y="150"
                            TextAnchor="middle"
                            DominantBaseline="middle"
                            FontFamily="@FontFamily"
                            FontSize="@FontSize"
                            FontWeight="@FontWeight"
                            FontStyle="@FontStyle"
                            LetterSpacing="@LetterSpacing"
                            Fill="@GradientFill"
                            Text="@DisplayText" />
        }
    }
    else
    {
        <SvgWordArtText CssClass="wordart-face wordart-face-fallback"
                        X="0" Y="0" Dy="@Inv(Item.PathBaselineOffset)"
                        TextAnchor="middle"
                        FontFamily="@FontFamily"
                        FontSize="@FontSize"
                        FontWeight="@FontWeight"
                        FontStyle="@FontStyle"
                        LetterSpacing="@LetterSpacing"
                        Fill="@FillColor"
                        Stroke="@OutlineColor"
                        StrokeWidth="@OutlineWidth"
                        PaintOrder="stroke fill"
                        PathHref="@PathHref"
                        PathStartOffset="@PathStartOffset"
                        PathTextAnchor="middle"
                        Text="@DisplayText" />

        @if (Item.GradientFill)
        {
            <SvgWordArtText CssClass="wordart-face wordart-face-gradient"
                            X="0" Y="0" Dy="@Inv(Item.PathBaselineOffset)"
                            TextAnchor="middle"
                            FontFamily="@FontFamily"
                            FontSize="@FontSize"
                            FontWeight="@FontWeight"
                            FontStyle="@FontStyle"
                            LetterSpacing="@LetterSpacing"
                            Fill="@GradientFill"
                            PathHref="@PathHref"
                            PathStartOffset="@PathStartOffset"
                            PathTextAnchor="middle"
                            Text="@DisplayText" />
        }
    }
</svg>

@code {
    [Parameter, EditorRequired] public WordArtElement Item { get; set; } = default!;
    [Parameter] public string IdPrefix { get; set; } = "canvas";

    private string GradientId => $"{IdPrefix}-wordart-gradient-{Item.Id:N}";
    private string PathId => $"{IdPrefix}-wordart-path-{Item.Id:N}";
    private string PathHref => $"#{PathId}";
    private string GradientFill => $"url(#{GradientId})";
    private string DisplayText => string.IsNullOrWhiteSpace(Item.Text) ? "WordArt" : Item.Text;
    private string FontFamily => string.IsNullOrWhiteSpace(Item.FontFamily) ? "Arial Black, Arial, sans-serif" : Item.FontFamily;
    private string FontSize => Inv(Math.Clamp(Item.FontSizePt, 8, 300) * 3.5);
    private string FontWeight => Item.Bold ? "700" : "400";
    private string FontStyle => Item.Italic ? "italic" : "normal";
    private string LetterSpacing => Inv(Math.Clamp(Item.LetterSpacing, -5, 30) * 2);
    private string FillColor => SafeColor(Item.FillColor, "#2f75b5");
    private string SecondaryColor => SafeColor(Item.SecondaryColor, "#8ec5ff");
    private string OutlineColor => SafeColor(Item.OutlineColor, "#17365d");
    private string ExtrudeColor => SafeColor(Item.ExtrudeColor, "#17365d");
    private string ShadowColor => SafeColor(Item.ShadowColor, "#000000");
    private string OutlineWidth => Inv(Math.Clamp(Item.OutlineWidth, 0, 20));
    private IEnumerable<int> ExtrusionLayers => Enumerable.Range(1, Math.Clamp((int)Math.Round(Item.ExtrudeDepth), 0, 18)).Reverse();

    private string WarpPath => WordArtPathGeometry.Build(Item);
    private string PathStartOffset => $"{Math.Clamp(Item.PathStartOffsetPercent, 0, 100).ToString("0.##", CultureInfo.InvariantCulture)}%";

    private static string SafeColor(string? value, string fallback)
    {
        if (string.IsNullOrWhiteSpace(value)) return fallback;
        var color = value.Trim();
        if (color.Equals("transparent", StringComparison.OrdinalIgnoreCase)) return fallback;
        return color;
    }

    private static string Inv(double value) => value.ToString("0.###", CultureInfo.InvariantCulture);
}
