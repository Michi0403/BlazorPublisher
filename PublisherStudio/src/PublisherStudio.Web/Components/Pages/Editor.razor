@page "/"
@rendermode InteractiveServer
@implements IDisposable
@inject EditorStateService State
@inject PublicationFileService Files
@inject PublicationMediaAssetStore MediaAssets
@inject IJSRuntime JS

<PageTitle>BlazorPublisher</PageTitle>

<div class="publisher-shell">
    <header class="title-bar">
        <div class="brand-mark">P</div>
        <input class="document-name" value="@State.Document.Name" @onchange="RenameDocument" aria-label="Publication name" />
        <span class="modified-label">Modified @State.Document.ModifiedUtc.LocalDateTime.ToString("g")</span>
    </header>

    <PublicationRibbon State="State"
                       TimelineVisible="_timelineVisible"
                       OnNew="NewDocument"
                       OnOpen="OpenPublicationPicker"
                       OnSave="SavePublication"
                       OnPrint="Print"
                       OnExportPng="ExportPng"
                       OnExportJpeg="ExportJpeg"
                       OnExportSvg="ExportSvg"
                       OnExportSelectedPng="ExportSelectedPng"
                       OnExportSelectedSvg="ExportSelectedSvg"
                       OnExportWebsite="ExportWebsite"
                       OnExportVideo="ExportVideo"
                       OnInsertPicture="OpenPicturePicker"
                       OnCreatePicture="CreatePicture"
                       OnEditPicture="EditSelectedPicture"
                       OnInsertVideo="OpenVideoPicker"
                       OnInsertAudio="OpenAudioPicker"
                       OnCreateVideo="CreateVideo"
                       OnCreateAudio="CreateAudio"
                       OnEditMedia="EditSelectedMedia"
                       OnInsertBarcode="InsertBarcode"
                       OnToggleTimeline="ToggleTimeline"
                       OnEditStory="OpenStoryEditor"
                       OnFitPage="FitPage"
                       OnTogglePagesPane="TogglePagesPane"
                       OnToggleInspectorPane="ToggleInspectorPane"
                       OnResetWorkspace="ResetWorkspace"
                       OnInsertDataVisual="InsertDataVisual"
                       OnEditDataVisual="OpenDataVisualEditor"
                       OnManageData="OpenDataManager"
                       OnPreviewPageAnimations="PreviewPageAnimations"
                       OnPreviewObjectAnimations="PreviewObjectAnimations"
                       OnStopAnimations="StopAnimations" />

    <div class="publisher-quick-insert" aria-label="Drag objects onto the publication page">
        <span>Drag to canvas</span>
        <button type="button" draggable="true" data-publisher-insert="text" title="Drag a text box to an exact position, or click to insert" @onclick="AddTextQuick"><i class="pub-icon pub-icon-text"></i>Text</button>
        <button type="button" draggable="true" data-publisher-insert="picture" title="Drag to choose and place a picture, or click to insert" @onclick="OpenPicturePicker"><i class="pub-icon pub-icon-picture"></i>Picture</button>
        <button type="button" draggable="true" data-publisher-insert="video" title="Drag to create or import and place a video, or click to insert" @onclick="OpenVideoPicker"><i class="pub-icon pub-icon-video"></i>Video</button>
        <small>Ctrl/Shift-click objects for multi-selection</small>
    </div>

    <div id="publisher-workspace" class="editor-workspace @(_timelineVisible ? "timeline-open" : null)">
        <PageNavigator State="State" TimelineVisible="_timelineVisible" RequestToggleTimeline="ToggleTimeline" />
        <button type="button" class="workspace-splitter splitter-left" data-workspace-splitter="left" title="Drag to resize pages pane; double-click to collapse" aria-label="Resize pages pane"></button>
        <PageSurface @ref="_pageSurface" State="State" EditTextRequested="OpenStoryEditorById" RequestPicture="OpenPicturePicker" RequestCreatePicture="CreatePicture" RequestEditPicture="EditSelectedPicture"
                     RequestInsertDataVisual="InsertDataVisual" RequestEditDataVisual="OpenDataVisualEditor" RequestManageData="OpenDataManager"
                     RequestInsertVideo="OpenVideoPicker" RequestInsertAudio="OpenAudioPicker" RequestCreateVideo="CreateVideo" RequestCreateAudio="CreateAudio" RequestEditMedia="EditSelectedMedia"
                     RequestInsertBarcode="InsertBarcode" RequestEditBarcode="EditBarcode"
                     TimelineVisible="_timelineVisible" RequestToggleTimeline="ToggleTimeline" RequestCanvasInsert="HandleCanvasInsert" />
        <button type="button" class="workspace-splitter splitter-right" data-workspace-splitter="right" title="Drag to resize properties pane; double-click to collapse" aria-label="Resize properties pane"></button>
        <InspectorPanel State="State"
                        OnEditStory="OpenStoryEditor"
                        OnReplacePicture="OpenPicturePicker"
                        OnInsertPicture="OpenPicturePicker"
                        OnCreatePicture="CreatePicture"
                        OnEditPicture="EditSelectedPicture"
                        OnApplyTransparentColor="ApplyTransparentColor"
                        OnRestoreOriginalPicture="RestoreOriginalPicture"
                        OnInsertDataVisual="InsertDataVisual"
                        OnEditDataVisual="OpenDataVisualEditor"
                        OnManageData="OpenDataManager"
                        OnInsertVideo="OpenVideoPicker"
                        OnInsertAudio="OpenAudioPicker"
                        OnCreateVideo="CreateVideo"
                        OnCreateAudio="CreateAudio"
                        OnEditMedia="EditSelectedMedia"
                        OnInsertBarcode="InsertBarcode"
                        OnEditBarcode="EditBarcode" />

        @if (_timelineVisible)
        {
            <PublicationTimeline State="State"
                                 RequestClose="HideTimeline"
                                 RequestInsertAudio="OpenAudioPicker"
                                 RequestInsertVideo="OpenVideoPicker"
                                 RequestCreateAudio="CreateAudio"
                                 RequestCreateVideo="CreateVideo"
                                 RequestEditMedia="EditSelectedMedia" />
        }
    </div>

    <footer class="status-bar">
        <span>Page @(State.Document.Pages.FindIndex(p => p.Id == State.SelectedPageId) + 1) of @State.Document.Pages.Count</span>
        <span>@SelectionStatus</span>
        <span>@State.CurrentPage.WidthMm.ToString("0.#", CultureInfo.InvariantCulture) × @State.CurrentPage.HeightMm.ToString("0.#", CultureInfo.InvariantCulture) mm</span>
        <label class="zoom-control">Zoom
            <button type="button" title="Zoom out" @onclick="ZoomOut">−</button>
            <input type="range" min="0.2" max="4" step="0.05" value="@State.Document.Zoom.ToString(CultureInfo.InvariantCulture)" @oninput="ChangeZoom" />
            <button type="button" title="Zoom in" @onclick="ZoomIn">+</button>
            <b>@Math.Round(State.Document.Zoom * 100)%</b>
        </label>
    </footer>
</div>

<InputFile id="publication-file-input" class="hidden-file-input" accept=".json,.pubstudio.json,application/json" OnChange="OpenPublication" />
<InputFile id="picture-file-input" class="hidden-file-input" accept="image/png,image/jpeg,image/gif,image/webp,image/svg+xml" OnChange="InsertPicture" />
<InputFile id="video-file-input" class="hidden-file-input" accept=".mp4,.m4v,.webm,.ogv,.ogg,.mov,video/mp4,video/x-m4v,video/webm,video/ogg,video/quicktime" OnChange="InsertVideo" />
<InputFile id="audio-file-input" class="hidden-file-input" accept="audio/mpeg,audio/mp4,audio/wav,audio/x-wav,audio/ogg,audio/webm,audio/flac" OnChange="InsertAudio" />

<PrintPublication Document="State.Document" />

<StoryEditor Visible="_storyEditorVisible"
             TextFrame="@(State.SelectedElement as TextFrameElement)"
             PublicationName="@State.Document.Name"
             PageName="@State.CurrentPage.Name"
             PageNumber="@CurrentPageNumber"
             PageCount="@State.Document.Pages.Count"
             Saved="SaveStory"
             Cancelled="CloseStoryEditor" />

<PictureEditor Visible="@_pictureEditorVisible"
               SessionId="@_pictureEditorSessionId"
               InitialDocument="@_pictureEditorInitialDocument"
               InitialRasterDataUrl="@_pictureEditorInitialRaster"
               InitialName="@_pictureEditorInitialName"
               EditingExisting="@(_pictureEditorTargetId is not null)"
               Saved="SavePictureStudio"
               Cancelled="ClosePictureStudio" />

<MediaStudio Visible="_mediaStudioVisible"
             SessionId="_mediaStudioSessionId"
             Kind="_mediaStudioKind"
             InitialMedia="_mediaStudioInitial"
             EditingExisting="@(_mediaStudioTargetId is not null)"
             Saved="SaveMediaStudio"
             Cancelled="CloseMediaStudio" />

<DataVisualEditor Visible="_dataVisualEditorVisible" State="State" Saved="SaveDataVisualEditor" Cancelled="CancelDataVisualEditor" ManageDataRequested="OpenDataManagerFromVisual" />
<DataManager Visible="_dataManagerVisible" State="State" Closed="CloseDataManager" DataChanged="DataManagerChanged" />
<BarcodeEditor Visible="_barcodeEditorVisible" Item="@(State.SelectedElement as BarcodeElement)" Saved="SaveBarcode" Cancelled="CancelBarcode" />

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="toast error" @onclick="() => _error = null">@_error</div>
}

@if (!string.IsNullOrWhiteSpace(_notice))
{
    <div class="toast notice" @onclick="() => _notice = null">@_notice</div>
}

@code {
    private PageSurface? _pageSurface;
    private bool _storyEditorVisible;
    private bool _pictureEditorVisible;
    private bool _dataVisualEditorVisible;
    private bool _dataManagerVisible;
    private bool _mediaStudioVisible;
    private bool _timelineVisible;
    private bool _barcodeEditorVisible;
    private bool _videoExporting;
    private Guid? _pendingNewBarcodeId;
    private Guid _mediaStudioSessionId;
    private Guid? _mediaStudioTargetId;
    private PublicationElementKind _mediaStudioKind = PublicationElementKind.Audio;
    private PublicationMediaElement? _mediaStudioInitial;
    private Guid? _pendingNewDataVisualId;
    private bool _resumeDataVisualAfterManager;
    private Guid _pictureEditorSessionId;
    private Guid? _pictureEditorTargetId;
    private PictureDocument? _pictureEditorInitialDocument;
    private string? _pictureEditorInitialRaster;
    private string _pictureEditorInitialName = "Picture";
    private CanvasInsertRequest? _pendingCanvasInsert;
    private bool _workspaceInitialized;
    private string? _error;
    private string? _notice;
    private string SelectionStatus => State.ConnectorTool != ConnectorToolKind.None
        ? $"{State.ConnectorTool} connector tool — drag from one object port to another; Esc cancels"
        : State.SelectedElements.Count > 1
            ? $"{State.SelectedElements.Count} objects selected{(State.SelectedElements.Any(item => item.GroupId is not null) ? " · grouped" : string.Empty)}"
            : State.SelectedElement is null ? "No selection" : $"{State.SelectedElement.Kind}: {State.SelectedElement.Name}";

    protected override void OnInitialized() => State.Changed += StateChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_workspaceInitialized)
        {
            _workspaceInitialized = true;
            await JS.InvokeVoidAsync("publisherStudio.initializeWorkspace", "publisher-workspace");
        }
    }

    private void StateChanged() => InvokeAsync(StateHasChanged);
    private void NewDocument() => State.NewDocument();
    private void AddTextQuick() => State.AddText();

    private async Task HandleCanvasInsert(CanvasInsertRequest request)
    {
        var kind = request.Kind.Trim().ToLowerInvariant();
        if (kind == "text")
        {
            State.AddText(request.X, request.Y);
            return;
        }

        _pendingCanvasInsert = request with { Kind = kind };
        if (kind == "picture")
        {
            await CancelPublisherPointerAsync();
            await OpenHiddenFileInput("picture-file-input");
            return;
        }
        if (kind == "video")
        {
            await OpenMediaStudio(PublicationElementKind.Video, null);
            return;
        }
        _pendingCanvasInsert = null;
    }
    private async Task OpenPublicationPicker()
    {
        await CancelPublisherPointerAsync();
        await OpenHiddenFileInput("publication-file-input");
    }
    private async Task OpenPicturePicker()
    {
        _pendingCanvasInsert = null;
        await CancelPublisherPointerAsync();
        await OpenHiddenFileInput("picture-file-input");
    }
    private Task OpenVideoPicker()
    {
        _pendingCanvasInsert = null;
        return OpenMediaStudio(PublicationElementKind.Video, null);
    }
    private async Task OpenAudioPicker()
    {
        await CancelPublisherPointerAsync();
        await OpenHiddenFileInput("audio-file-input");
    }

    private async Task OpenHiddenFileInput(string id)
    {
        try
        {
            await JS.InvokeVoidAsync("publisherStudio.clickElement", id);
        }
        catch (JSException)
        {
            await using var module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/publisherInterop.js");
            await module.InvokeVoidAsync("clickElementById", id);
        }
    }

    private async Task SavePublication()
    {
        var json = Files.Serialize(State.Document);
        var name = PublicationFileService.SafeFileName(State.Document.Name) + ".pubstudio.json";
        await using var stream = new MemoryStream(Encoding.UTF8.GetBytes(json));
        using var streamReference = new DotNetStreamReference(stream);
        await JS.InvokeVoidAsync("publisherStudio.downloadStream", name, streamReference, "application/json");
        ShowNotice($"Saved {name}");
    }

    private async Task ExportPng() => await ExportRasterPages("png");
    private async Task ExportJpeg() => await ExportRasterPages("jpeg");
    private async Task ExportSvg() => await ExportPage("svg");
    private async Task ExportSelectedPng() => await ExportSelectedObject("png");
    private async Task ExportSelectedSvg() => await ExportSelectedObject("svg");

    private async Task ExportSelectedObject(string format)
    {
        try
        {
            var selected = State.SelectedElement;
            if (selected is null) throw new InvalidOperationException("Select an object before exporting it.");
            if (selected is ConnectorElement) throw new InvalidOperationException("Connector-only export is not supported yet.");
            var extension = format == "svg" ? "svg" : "png";
            var baseName = PublicationFileService.SafeFileName(State.Document.Name);
            var objectName = PublicationFileService.SafeFileName(selected.Name);
            var fileName = $"{baseName}-{objectName}.{extension}";
            ShowNotice($"Rendering {selected.Name} as {format.ToUpperInvariant()}…");
            await InvokeAsync(StateHasChanged);
            await Task.Yield();
            await JS.InvokeVoidAsync(
                "publisherStudio.exportPublicationElement",
                selected.Id.ToString(),
                fileName,
                format,
                State.Document.View.ExportDpi);
            ShowNotice($"Exported {selected.Name} as {format.ToUpperInvariant()}.");
        }
        catch (Exception ex)
        {
            ShowError(ex);
        }
    }

    private async Task ExportRasterPages(string format)
    {
        try
        {
            var baseName = PublicationFileService.SafeFileName(State.Document.Name);
            ShowNotice($"Rendering {format.ToUpperInvariant()} page export…");
            await InvokeAsync(StateHasChanged);
            await Task.Yield();
            var result = await JS.InvokeAsync<PageExportResult>(
                "publisherStudio.exportPublicationPages",
                ".print-publication",
                baseName,
                format,
                State.Document.View.ExportDpi);
            ShowNotice(result.Count == 1
                ? $"Exported {result.FileName}."
                : $"Exported {result.Count} page images in {result.FileName}.");
        }
        catch (Exception ex)
        {
            ShowError(ex);
        }
    }

    private async Task ExportPage(string format)
    {
        try
        {
            var fileName = $"{PublicationFileService.SafeFileName(State.Document.Name)}-page-{CurrentPageNumber}.{(format == "jpeg" ? "jpg" : format)}";
            ShowNotice($"Rendering current page as {format.ToUpperInvariant()}…");
            await InvokeAsync(StateHasChanged);
            await Task.Yield();
            await JS.InvokeVoidAsync("publisherStudio.exportPage", "publisher-page", fileName, format, State.Document.View.ExportDpi, State.Document.Zoom);
            ShowNotice($"Exported current page as {format.ToUpperInvariant()}.");
        }
        catch (Exception ex)
        {
            ShowError(ex);
        }
    }

    private async Task ExportWebsite()
    {
        try
        {
            var fileName = PublicationFileService.SafeFileName(State.Document.Name) + ".html";
            ShowNotice("Preparing website export…");
            await InvokeAsync(StateHasChanged);
            await Task.Yield();
            await JS.InvokeVoidAsync("publisherStudio.exportWebsite", fileName, State.Document.Name);
            ShowNotice($"Exported {fileName}");
        }
        catch (Exception ex)
        {
            ShowError(ex);
        }
    }

    private async Task ExportVideo()
    {
        if (_videoExporting) return;
        _videoExporting = true;
        try
        {
            var fileName = PublicationFileService.SafeFileName(State.Document.Name) + ".webm";
            ShowNotice("Choose this browser tab in the capture dialog and enable tab audio when media sound should be included.");
            var result = await JS.InvokeAsync<VideoExportResult>(
                "publisherStudio.exportPresentationVideo",
                System.Threading.CancellationToken.None,
                [".print-publication", fileName, State.Document.Name]);
            var frame = result.PageSizedCapture && result.Width > 0 && result.Height > 0
                ? $" · page frame {result.Width} × {result.Height}"
                : " · full-tab fallback";
            ShowNotice($"Exported {result.FileName} ({result.DurationSeconds:0.##} seconds){frame}.");
        }
        catch (Exception ex) { ShowError(ex); }
        finally { _videoExporting = false; }
    }

    private async Task Print() => await JS.InvokeVoidAsync("publisherStudio.printPublication");

    private Task PreviewPageAnimations() => JS.InvokeVoidAsync("publisherStudio.previewPageAnimations", "publisher-page").AsTask();
    private Task PreviewObjectAnimations() => State.SelectedElementId is { } id
        ? JS.InvokeVoidAsync("publisherStudio.previewElementAnimations", $"element-{id}").AsTask()
        : Task.CompletedTask;
    private Task StopAnimations() => JS.InvokeVoidAsync("publisherStudio.stopAnimationPreview", "publisher-page").AsTask();

    private async Task FitPage()
    {
        if (_pageSurface is not null)
            await _pageSurface.FitPageAsync();
    }

    private Task TogglePagesPane() => JS.InvokeVoidAsync("publisherStudio.toggleWorkspacePane", "publisher-workspace", "left").AsTask();
    private Task ToggleInspectorPane() => JS.InvokeVoidAsync("publisherStudio.toggleWorkspacePane", "publisher-workspace", "right").AsTask();
    private async Task ResetWorkspace()
    {
        _timelineVisible = false;
        await JS.InvokeVoidAsync("publisherStudio.resetWorkspaceLayout", "publisher-workspace");
    }

    private int CurrentPageNumber => Math.Max(1, State.Document.Pages.FindIndex(publicationPage => publicationPage.Id == State.SelectedPageId) + 1);

    private async Task OpenPublication(InputFileChangeEventArgs args)
    {
        try
        {
            await using var stream = args.File.OpenReadStream(64 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            State.Load(await reader.ReadToEndAsync());
        }
        catch (Exception ex)
        {
            ShowError(ex);
        }
    }

    private async Task InsertPicture(InputFileChangeEventArgs args)
    {
        try
        {
            var file = args.File;
            var allowed = new[] { "image/png", "image/jpeg", "image/gif", "image/webp", "image/svg+xml" };
            if (!allowed.Contains(file.ContentType, StringComparer.OrdinalIgnoreCase))
                throw new InvalidDataException("Unsupported picture format.");

            await using var stream = file.OpenReadStream(64 * 1024 * 1024);
            using var buffer = new MemoryStream();
            await stream.CopyToAsync(buffer);
            var dataUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer.ToArray())}";
            double[]? dropPlacement = null;
            try
            {
                dropPlacement = await JS.InvokeAsync<double[]?>("publisherStudio.consumeCanvasInsertPlacement", "picture-file-input");
            }
            catch (JSException)
            {
                // A cached pre-v1.0.11 script must not block normal picture insertion.
            }
            if (dropPlacement is { Length: >= 2 })
            {
                State.AddImage(dataUrl, file.Name, centerX: dropPlacement[0], centerY: dropPlacement[1]);
                _pendingCanvasInsert = null;
            }
            else if (_pendingCanvasInsert is { Kind: "picture" } placement)
            {
                State.AddImage(dataUrl, file.Name, centerX: placement.X, centerY: placement.Y);
                _pendingCanvasInsert = null;
            }
            else if (State.SelectedElement is ImageFrameElement image)
            {
                State.UpdateSelected(_ =>
                {
                    image.DataUrl = dataUrl;
                    image.OriginalDataUrl = dataUrl;
                    image.AltText = file.Name;
                    image.Name = file.Name;
                    image.CropX = 0;
                    image.CropY = 0;
                    image.CropScale = 1;
                    image.PictureSource = null;
                });
            }
            else
            {
                State.AddImage(dataUrl, file.Name);
            }
        }
        catch (Exception ex)
        {
            _pendingCanvasInsert = null;
            ShowError(ex);
        }
    }

    private async Task InsertVideo(InputFileChangeEventArgs args) => await InsertMediaFile(args, PublicationElementKind.Video);
    private async Task InsertAudio(InputFileChangeEventArgs args) => await InsertMediaFile(args, PublicationElementKind.Audio);

    private async Task InsertMediaFile(InputFileChangeEventArgs args, PublicationElementKind kind)
    {
        IJSObjectReference? module = null;
        Guid temporaryAssetId = Guid.Empty;
        var usedMetadataFallback = false;
        try
        {
            var file = args.File;
            var mimeType = ResolveMediaMimeType(file, kind);
            var expected = kind == PublicationElementKind.Video ? "video/" : "audio/";
            if (!mimeType.StartsWith(expected, StringComparison.OrdinalIgnoreCase))
                throw new InvalidDataException($"Unsupported {kind.ToString().ToLowerInvariant()} format: {Path.GetExtension(file.Name)}.");

            await using var stream = file.OpenReadStream(160 * 1024 * 1024);
            using var buffer = new MemoryStream();
            await stream.CopyToAsync(buffer);
            var bytes = buffer.ToArray();
            if (bytes.Length == 0) throw new InvalidDataException("The selected media file is empty.");

            module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/mediaStudioInterop.js");
            temporaryAssetId = Guid.NewGuid();
            var inspectionUrl = MediaAssets.RegisterBytes(temporaryAssetId, bytes, mimeType);
            MediaSourceInfo info;
            try
            {
                info = await module.InvokeAsync<MediaSourceInfo>(
                    "inspectMediaDataUrl",
                    inspectionUrl,
                    kind == PublicationElementKind.Video ? "video" : "audio");
            }
            catch (Exception metadataError)
            {
                usedMetadataFallback = true;
                info = new MediaSourceInfo
                {
                    MimeType = mimeType,
                    DurationSeconds = 5,
                    WaveformSamples = []
                };
                Console.WriteLine($"Media metadata inspection failed: {metadataError.Message}");
            }

            mimeType = PublicationMediaData.NormalizeMimeType(
                string.IsNullOrWhiteSpace(info.MimeType) ? mimeType : info.MimeType,
                kind == PublicationElementKind.Video ? "video/mp4" : "audio/mpeg");
            var dataUrl = PublicationMediaData.NormalizeDataUrl(
                $"data:{mimeType};base64,{Convert.ToBase64String(bytes)}",
                mimeType);

            PublicationMediaElement media;
            if (kind == PublicationElementKind.Video)
            {
                media = State.AddVideo(dataUrl, mimeType, file.Name, info.DurationSeconds, info.PosterDataUrl);
                State.UpdateMedia(media.Id, item => item.WaveformSamples = info.WaveformSamples ?? [], capture: false);
            }
            else
            {
                media = State.AddAudio(dataUrl, mimeType, file.Name, info.DurationSeconds, info.WaveformSamples ?? []);
            }

            if (temporaryAssetId != Guid.Empty && MediaAssets.Copy(temporaryAssetId, media.Id))
                MediaAssets.Remove(temporaryAssetId);
            else
                MediaAssets.RegisterBytes(media.Id, bytes, mimeType);
            temporaryAssetId = Guid.Empty;

            State.SelectElement(media.Id);
            _timelineVisible = true;
            ShowNotice(usedMetadataFallback
                ? $"Inserted {file.Name} without browser duration metadata. The clip uses a 5 second editable fallback."
                : $"Inserted {file.Name}. The timeline pane is open for timing and trimming.");
        }
        catch (Exception ex)
        {
            ShowError(ex);
        }
        finally
        {
            if (temporaryAssetId != Guid.Empty) MediaAssets.Remove(temporaryAssetId);
            if (module is not null)
            {
                try { await module.DisposeAsync(); }
                catch (JSDisconnectedException) { }
                catch (TaskCanceledException) { }
                catch (ObjectDisposedException) { }
                catch (InvalidOperationException) { }
            }
        }
    }

    private static string ResolveMediaMimeType(IBrowserFile file, PublicationElementKind kind)
    {
        var fallback = kind == PublicationElementKind.Video ? "video/mp4" : "audio/mpeg";
        var declared = PublicationMediaData.NormalizeMimeType(file.ContentType, string.Empty);
        if (declared.StartsWith(kind == PublicationElementKind.Video ? "video/" : "audio/", StringComparison.OrdinalIgnoreCase))
            return declared;

        var extension = Path.GetExtension(file.Name).ToLowerInvariant();
        return extension switch
        {
            ".mp4" => kind == PublicationElementKind.Video ? "video/mp4" : "audio/mp4",
            ".m4v" => "video/x-m4v",
            ".webm" => kind == PublicationElementKind.Video ? "video/webm" : "audio/webm",
            ".ogv" => "video/ogg",
            ".ogg" or ".oga" => kind == PublicationElementKind.Video ? "video/ogg" : "audio/ogg",
            ".mov" => "video/quicktime",
            ".mp3" => "audio/mpeg",
            ".m4a" or ".aac" => "audio/mp4",
            ".wav" => "audio/wav",
            ".flac" => "audio/flac",
            _ => fallback
        };
    }

    private Task CreateVideo() => OpenMediaStudio(PublicationElementKind.Video, null);
    private Task CreateAudio() => OpenMediaStudio(PublicationElementKind.Audio, null);

    private Task EditSelectedMedia()
    {
        return State.SelectedElement is PublicationMediaElement media
            ? OpenMediaStudio(media.Kind, media)
            : Task.CompletedTask;
    }

    private async Task OpenMediaStudio(PublicationElementKind kind, PublicationMediaElement? media)
    {
        await CancelPublisherPointerAsync();
        _mediaStudioTargetId = media?.Id;
        _mediaStudioKind = kind;
        _mediaStudioInitial = media;
        _mediaStudioSessionId = Guid.NewGuid();
        _mediaStudioVisible = true;
    }

    private Task SaveMediaStudio(MediaEditorResult result)
    {
        var targetId = _mediaStudioTargetId;

        try
        {
            PublicationMediaElement media;
            if (targetId is Guid existingId && State.CurrentPage.Elements.OfType<PublicationMediaElement>().Any(item => item.Id == existingId))
            {
                State.SelectElement(existingId);
                media = State.CurrentPage.Elements.OfType<PublicationMediaElement>().First(item => item.Id == existingId);
                State.UpdateMedia(existingId, item => ApplyMediaResult(item, result));
            }
            else if (result.Kind == PublicationElementKind.Video)
            {
                media = _pendingCanvasInsert is { Kind: "video" } placement
                    ? State.AddVideo(result.DataUrl, result.MimeType, result.Name, result.DurationSeconds, result.PosterDataUrl, placement.X, placement.Y)
                    : State.AddVideo(result.DataUrl, result.MimeType, result.Name, result.DurationSeconds, result.PosterDataUrl);
                State.UpdateMedia(media.Id, item => ApplyMediaResult(item, result), capture: false);
            }
            else
            {
                media = State.AddAudio(result.DataUrl, result.MimeType, result.Name, result.DurationSeconds, result.WaveformSamples);
                State.UpdateMedia(media.Id, item => ApplyMediaResult(item, result), capture: false);
            }

            if (!MediaAssets.Copy(result.PreviewAssetId, media.Id))
                MediaAssets.Register(media.Id, media.DataUrl, media.MimeType);
            State.SelectElement(media.Id);
            _mediaStudioVisible = false;
            _mediaStudioTargetId = null;
            _mediaStudioInitial = null;
            _pendingCanvasInsert = null;
            _timelineVisible = true;
            ShowNotice($"{(result.Kind == PublicationElementKind.Video ? "Video" : "Audio")} applied to the publication timeline.");
        }
        catch (Exception ex)
        {
            ShowError(ex);
            throw;
        }
        return Task.CompletedTask;
    }

    private static void ApplyMediaResult(PublicationMediaElement item, MediaEditorResult result)
    {
        item.Name = result.Name;
        item.DataUrl = result.DataUrl;
        item.MimeType = result.MimeType;
        item.DurationSeconds = result.DurationSeconds;
        item.TrimStartSeconds = result.TrimStartSeconds;
        item.TrimEndSeconds = result.TrimEndSeconds;
        item.Volume = result.Volume;
        item.PlaybackRate = result.PlaybackRate;
        item.FadeInSeconds = result.FadeInSeconds;
        item.FadeOutSeconds = result.FadeOutSeconds;
        item.Muted = result.Muted;
        item.Loop = result.Loop;
        item.AutoPlay = result.AutoPlay;
        item.PlaybackTrigger = result.PlaybackTrigger;
        item.WaveformSamples = result.WaveformSamples ?? [];
        if (item is VideoElement video)
        {
            video.PosterDataUrl = result.PosterDataUrl;
            video.AltText = result.Name;
        }
    }

    private Task CloseMediaStudio()
    {
        _mediaStudioVisible = false;
        _mediaStudioTargetId = null;
        _mediaStudioInitial = null;
        _pendingCanvasInsert = null;
        return Task.CompletedTask;
    }

    private Task ToggleTimeline()
    {
        _timelineVisible = !_timelineVisible;
        return Task.CompletedTask;
    }

    private Task HideTimeline()
    {
        _timelineVisible = false;
        return Task.CompletedTask;
    }

    private async Task ApplyTransparentColor()
    {
        if (State.SelectedElement is not ImageFrameElement image) return;
        try
        {
            var result = await JS.InvokeAsync<string>("publisherStudio.makeColorTransparent", image.DataUrl, image.TransparentColor, image.TransparentColorTolerance);
            State.UpdateSelected(_ => image.DataUrl = result);
            ShowNotice("The selected color was made transparent. Restore Original remains available.");
        }
        catch (Exception ex)
        {
            ShowError(ex);
        }
    }

    private Task RestoreOriginalPicture()
    {
        if (State.SelectedElement is ImageFrameElement image && !string.IsNullOrWhiteSpace(image.OriginalDataUrl))
        {
            State.UpdateSelected(_ => image.DataUrl = image.OriginalDataUrl);
            ShowNotice("Original picture restored.");
        }
        return Task.CompletedTask;
    }

    private async Task InsertBarcode()
    {
        await CancelPublisherPointerAsync();
        var item = State.AddBarcode();
        _pendingNewBarcodeId = item.Id;
        _barcodeEditorVisible = true;
    }

    private async Task EditBarcode()
    {
        if (State.SelectedElement is not BarcodeElement) return;
        await CancelPublisherPointerAsync();
        _barcodeEditorVisible = true;
    }

    private Task SaveBarcode(BarcodeElement result)
    {
        if (State.SelectedElement is BarcodeElement target)
        {
            State.UpdateSelected(_ =>
            {
                target.Format = result.Format; target.Value = result.Value; target.ForegroundColor = result.ForegroundColor;
                target.BackgroundColor = result.BackgroundColor; target.TransparentBackground = result.TransparentBackground;
                target.ShowText = result.ShowText; target.Margin = result.Margin; target.LineWidth = result.LineWidth;
                target.BarHeight = result.BarHeight; target.FontSize = result.FontSize; target.ErrorCorrection = result.ErrorCorrection;
                target.ModuleShape = result.ModuleShape; target.SvgMarkup = result.SvgMarkup;
            });
        }
        _pendingNewBarcodeId = null;
        _barcodeEditorVisible = false;
        return Task.CompletedTask;
    }

    private Task CancelBarcode()
    {
        if (_pendingNewBarcodeId is Guid id)
        {
            State.SelectElement(id);
            State.DeleteSelected();
        }
        _pendingNewBarcodeId = null;
        _barcodeEditorVisible = false;
        return Task.CompletedTask;
    }

    private async Task CancelPublisherPointerAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("publisherStudio.cancelCanvasInteraction", "publisher-stage");
        }
        catch (JSDisconnectedException) { }
        catch (TaskCanceledException) { }
        catch (JSException) { }
    }

    private async Task CreatePicture()
    {
        await CancelPublisherPointerAsync();
        _pictureEditorTargetId = null;
        _pictureEditorInitialDocument = null;
        _pictureEditorInitialRaster = null;
        _pictureEditorInitialName = "Untitled Picture";
        _pictureEditorSessionId = Guid.NewGuid();
        _pictureEditorVisible = true;
    }

    private async Task EditSelectedPicture()
    {
        if (State.SelectedElement is not ImageFrameElement image) return;
        await CancelPublisherPointerAsync();
        _pictureEditorTargetId = image.Id;
        _pictureEditorInitialDocument = image.PictureSource;
        _pictureEditorInitialRaster = image.PictureSource is null ? image.DataUrl : null;
        _pictureEditorInitialName = string.IsNullOrWhiteSpace(image.Name) ? "Picture" : image.Name;
        _pictureEditorSessionId = Guid.NewGuid();
        _pictureEditorVisible = true;
    }

    private Task SavePictureStudio(PictureEditorResult result)
    {
        if (_pictureEditorTargetId is Guid targetId)
        {
            State.SelectElement(targetId);
            if (State.SelectedElement is ImageFrameElement image)
            {
                State.UpdateSelected(_ =>
                {
                    image.DataUrl = result.DataUrl;
                    image.OriginalDataUrl = result.DataUrl;
                    image.PictureSource = result.SourceDocument;
                    image.Name = result.Name;
                    image.AltText = result.Name;
                });
            }
        }
        else
        {
            State.AddImage(result.DataUrl, result.Name, result.SourceDocument);
        }
        _pictureEditorVisible = false;
        _pictureEditorTargetId = null;
        _pictureEditorInitialDocument = null;
        _pictureEditorInitialRaster = null;
        ShowNotice("Picture Studio image inserted into the publication.");
        return Task.CompletedTask;
    }

    private Task ClosePictureStudio()
    {
        _pictureEditorVisible = false;
        _pictureEditorTargetId = null;
        _pictureEditorInitialDocument = null;
        _pictureEditorInitialRaster = null;
        return Task.CompletedTask;
    }

    private async Task InsertDataVisual(DataVisualKind kind)
    {
        await CancelPublisherPointerAsync();
        var visual = State.AddDataVisual(kind);
        _pendingNewDataVisualId = visual.Id;
        _dataVisualEditorVisible = true;
