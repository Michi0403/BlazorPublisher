    private void HandleGlobalStreamingHotkey(MediaHostHotkeyEvent hotkeyEvent) =>
        _ = HandleStreamingHotkey(hotkeyEvent.Command, hotkeyEvent.TargetId?.ToString("D"));

    [JSInvokable]
    public Task HandleStreamingHotkey(string command, string? targetId) => InvokeAsync(async () =>
    {
        switch (command?.Trim())
        {
            case "ToggleStreaming":
                if (StreamingSession.Snapshot.Mode == PublicationStreamSessionMode.Idle) await StartStreaming();
                else await StopStreaming();
                break;
            case "ToggleRecording":
                if (StreamingSession.Snapshot.Mode != PublicationStreamSessionMode.Idle) await ToggleStreamRecording();
                else ShowNotice("Start a dry run or stream before toggling recording.");
                break;
            case "NextPage":
                await SelectAdjacentStreamingPage(1);
                break;
            case "PreviousPage":
                await SelectAdjacentStreamingPage(-1);
                break;
            case "SelectPage" when Guid.TryParse(targetId, out var pageId):
                await SelectProgramPage(pageId);
                break;
            case "ToggleOutput" when Guid.TryParse(targetId, out var outputId):
                await ToggleStreamOutput(outputId);
                break;
        }
    });

    private async Task SelectAdjacentStreamingPage(int offset)
    {
        if (State.Document.Pages.Count == 0) return;
        var currentId = StreamingSession.Snapshot.ProgramPageId ?? State.SelectedPageId;
        var currentIndex = State.Document.Pages.FindIndex(page => page.Id == currentId);
        if (currentIndex < 0) currentIndex = 0;
        var nextIndex = (currentIndex + offset + State.Document.Pages.Count) % State.Document.Pages.Count;
        await SelectProgramPage(State.Document.Pages[nextIndex].Id);
    }

