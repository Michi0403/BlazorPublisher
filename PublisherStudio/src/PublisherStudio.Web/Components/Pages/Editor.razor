    private async Task InsertPicture(InputFileChangeEventArgs args)
    {
        try
        {
            var file = args.File;
            var allowed = new[] { "image/png", "image/jpeg", "image/gif", "image/webp", "image/svg+xml" };
            if (!allowed.Contains(file.ContentType, StringComparer.OrdinalIgnoreCase))
                throw new InvalidDataException("Unsupported picture format.");

            await using var stream = file.OpenReadStream(64 * 1024 * 1024);
            using var buffer = new MemoryStream();
            await stream.CopyToAsync(buffer);
            var dataUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer.ToArray())}";
            double[]? dropPlacement = null;
            try
            {
                dropPlacement = await JS.InvokeAsync<double[]?>("publisherStudio.consumeCanvasInsertPlacement", "picture-file-input");
            }
            catch (JSException)
            {
                // A cached pre-v1.0.11 script must not block normal picture insertion.
            }
            if (dropPlacement is { Length: >= 2 })
            {
                State.AddImage(dataUrl, file.Name, centerX: dropPlacement[0], centerY: dropPlacement[1]);
                _pendingCanvasInsert = null;
            }
            else if (_pendingCanvasInsert is { Kind: "picture" } placement)
            {
                State.AddImage(dataUrl, file.Name, centerX: placement.X, centerY: placement.Y);
                _pendingCanvasInsert = null;
            }
            else if (_replacePictureTargetId is Guid replaceId &&
                     State.CurrentPage.Elements.OfType<ImageFrameElement>().FirstOrDefault(item => item.Id == replaceId) is { } image)
            {
                State.SelectElement(image.Id);
                State.UpdateSelected(_ =>
                {
                    image.DataUrl = dataUrl;
                    image.OriginalDataUrl = dataUrl;
                    image.AltText = file.Name;
                    image.Name = file.Name;
                    image.CropX = 0;
                    image.CropY = 0;
                    image.CropScale = 1;
                    image.PictureSource = null;
                });
            }
            else
            {
                State.AddImage(dataUrl, file.Name);
            }
            _replacePictureTargetId = null;
        }
        catch (Exception ex)
        {
            _pendingCanvasInsert = null;
            _replacePictureTargetId = null;
            ShowError(ex);
        }
    }

    private async Task InsertVideo(InputFileChangeEventArgs args) => await InsertMediaFile(args, PublicationElementKind.Video);
    private async Task InsertAudio(InputFileChangeEventArgs args) => await InsertMediaFile(args, PublicationElementKind.Audio);

    private async Task InsertMediaFile(InputFileChangeEventArgs args, PublicationElementKind kind)
    {
        IJSObjectReference? module = null;
        Guid temporaryAssetId = Guid.Empty;
        var usedMetadataFallback = false;
        try
        {
            var file = args.File;
            var mimeType = ResolveMediaMimeType(file, kind);
            var expected = kind == PublicationElementKind.Video ? "video/" : "audio/";
            if (!mimeType.StartsWith(expected, StringComparison.OrdinalIgnoreCase))
                throw new InvalidDataException($"Unsupported {kind.ToString().ToLowerInvariant()} format: {Path.GetExtension(file.Name)}.");

            await using var stream = file.OpenReadStream(long.MaxValue);
            using var buffer = new MemoryStream();
            await stream.CopyToAsync(buffer);
            var bytes = buffer.ToArray();
            if (bytes.Length == 0) throw new InvalidDataException("The selected media file is empty.");

            module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/mediaStudioInterop.js");
            temporaryAssetId = Guid.NewGuid();
            var inspectionUrl = MediaAssets.RegisterBytes(temporaryAssetId, bytes, mimeType);
            MediaSourceInfo info;
            try
            {
                info = await module.InvokeAsync<MediaSourceInfo>(
                    "inspectMediaDataUrl",
                    inspectionUrl,
                    kind == PublicationElementKind.Video ? "video" : "audio");
            }
            catch (Exception metadataError)
            {
                usedMetadataFallback = true;
                info = new MediaSourceInfo
                {
                    MimeType = mimeType,
                    DurationSeconds = 5,
                    WaveformSamples = []
                };
                Console.WriteLine($"Media metadata inspection failed: {metadataError.Message}");
            }

            mimeType = PublicationMediaData.NormalizeMimeType(
                string.IsNullOrWhiteSpace(info.MimeType) ? mimeType : info.MimeType,
                kind == PublicationElementKind.Video ? "video/mp4" : "audio/mpeg");
            var dataUrl = PublicationMediaData.NormalizeDataUrl(
                $"data:{mimeType};base64,{Convert.ToBase64String(bytes)}",
                mimeType);

            PublicationMediaElement media;
            if (kind == PublicationElementKind.Video)
            {
                media = State.AddVideo(dataUrl, mimeType, file.Name, info.DurationSeconds, info.PosterDataUrl);
                State.UpdateMedia(media.Id, item => item.WaveformSamples = info.WaveformSamples ?? [], capture: false);
            }
            else
            {
                media = State.AddAudio(dataUrl, mimeType, file.Name, info.DurationSeconds, info.WaveformSamples ?? []);
            }

            if (temporaryAssetId != Guid.Empty && MediaAssets.Copy(temporaryAssetId, media.Id))
                MediaAssets.Remove(temporaryAssetId);
            else
                MediaAssets.RegisterBytes(media.Id, bytes, mimeType);
            temporaryAssetId = Guid.Empty;

            State.SelectElement(media.Id);
            _timelineVisible = true;
            ShowNotice(usedMetadataFallback
                ? $"Inserted {file.Name} without browser duration metadata. The clip uses a 5 second editable fallback."
                : $"Inserted {file.Name}. The timeline pane is open for timing and trimming.");
        }
        catch (Exception ex)
        {
            ShowError(ex);
        }
        finally
        {
            if (temporaryAssetId != Guid.Empty) MediaAssets.Remove(temporaryAssetId);
            if (module is not null)
            {
                try { await module.DisposeAsync(); }
                catch (JSDisconnectedException) { }
                catch (TaskCanceledException) { }
                catch (ObjectDisposedException) { }
                catch (InvalidOperationException) { }
            }
        }
    }

    private static string ResolveMediaMimeType(IBrowserFile file, PublicationElementKind kind)
    {
        var fallback = kind == PublicationElementKind.Video ? "video/mp4" : "audio/mpeg";
        var declared = PublicationMediaData.NormalizeMimeType(file.ContentType, string.Empty);
        if (declared.StartsWith(kind == PublicationElementKind.Video ? "video/" : "audio/", StringComparison.OrdinalIgnoreCase))
            return declared;

        var extension = Path.GetExtension(file.Name).ToLowerInvariant();
        return extension switch
        {
            ".mp4" => kind == PublicationElementKind.Video ? "video/mp4" : "audio/mp4",
            ".m4v" => "video/x-m4v",
            ".webm" => kind == PublicationElementKind.Video ? "video/webm" : "audio/webm",
            ".ogv" => "video/ogg",
            ".ogg" or ".oga" => kind == PublicationElementKind.Video ? "video/ogg" : "audio/ogg",
            ".mov" => "video/quicktime",
            ".mp3" => "audio/mpeg",
            ".m4a" or ".aac" => "audio/mp4",
            ".wav" => "audio/wav",
            ".flac" => "audio/flac",
            _ => fallback
        };
    }

