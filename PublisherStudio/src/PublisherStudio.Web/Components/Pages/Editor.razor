    public void Dispose()
    {
        if (_disposed) return;
        _disposed = true;
        State.Changed -= StateChanged;
        StreamingSession.Changed -= StateChanged;
        StreamingSession.HotkeyTriggered -= HandleGlobalStreamingHotkey;
        try { _ = JS.InvokeVoidAsync("publisherStreaming.unbindHotkeys"); } catch { }
        _streamingHotkeyReference?.Dispose();
        _recoverySaveCancellation?.Cancel();
        _recoverySaveCancellation?.Dispose();
        if (_spreadsheetEditorSessionId != Guid.Empty) SpreadsheetSessions.Remove(_spreadsheetEditorSessionId);
        if (State.IsDirty)
        {
            try
            {
                var json = Files.Serialize(State.Document);
                _ = Recovery.SaveAsync(State.Document.Id, State.Document.Name, State.Document.ModifiedUtc, json);
            }
            catch { }
        }
    }
