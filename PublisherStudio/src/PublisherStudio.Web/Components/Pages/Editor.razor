@page "/"
@rendermode InteractiveServer
@implements IDisposable
@inject EditorStateService State
@inject PublicationFileService Files
@inject PublicationMediaAssetStore MediaAssets
@inject SpreadsheetDocumentService Spreadsheets
@inject SpreadsheetSessionStore SpreadsheetSessions
@inject PublicationRecoveryService Recovery
@inject StreamingSessionService StreamingSession
@inject StreamingProfileStore StreamingProfiles
@inject IJSRuntime JS

<PageTitle>BlazorPublisher</PageTitle>

<div class="publisher-shell @(_recoveryCandidate is not null ? "has-recovery" : null)">
    <WebDataRefreshHost State="State" />
    <header class="title-bar">
        <div class="brand-mark">P</div>
        <input class="document-name" value="@State.Document.Name" @onchange="RenameDocument" aria-label="Publication name" />
        <span class="modified-label">Modified @State.Document.ModifiedUtc.LocalDateTime.ToString("g")</span>
    </header>

    @if (_recoveryCandidate is not null)
    {
        <aside class="publisher-recovery-banner" role="status">
            <span><b>Recovered work is available:</b> @_recoveryCandidate.DocumentName · @_recoveryCandidate.SavedUtc.LocalDateTime.ToString("g")</span>
            <button type="button" @onclick="RestoreRecovery">Restore</button>
            <button type="button" @onclick="DismissRecovery">Dismiss</button>
        </aside>
    }

    <PublicationRibbon State="State"
                       TimelineVisible="_timelineVisible"
                       OnNew="NewDocument"
                       OnOpen="OpenPublicationPicker"
                       OnSave="SavePublication"
                       OnPrint="Print"
                       OnExportPng="ExportPng"
                       OnExportJpeg="ExportJpeg"
                       OnExportSvg="ExportSvg"
                       OnExportSelectedPng="ExportSelectedPng"
                       OnExportSelectedSvg="ExportSelectedSvg"
                       OnExportWebsite="ExportPresentationHtml"
                       OnExportSite="ExportSite"
                       OnExportVideo="ExportVideo"
                       OnInsertPicture="OpenPicturePicker"
                       OnCreatePicture="CreatePicture"
                       OnEditPicture="EditSelectedPicture"
                       OnInsertSpreadsheet="OpenSpreadsheetPicker"
                       OnCreateSpreadsheet="CreateSpreadsheet"
                       OnEditSpreadsheet="OpenSpreadsheetEditor"
                       OnDownloadSpreadsheet="DownloadSelectedSpreadsheet"
                       OnInsertVideo="OpenVideoPicker"
                       OnInsertAudio="OpenAudioPicker"
                       OnCreateVideo="CreateVideo"
                       OnCreateAudio="CreateAudio"
                       OnEditMedia="EditSelectedMedia"
                       OnInsertBarcode="InsertBarcode"
                       OnToggleTimeline="ToggleTimeline"
                       OnEditStory="OpenStoryEditor"
                       OnFitPage="FitPage"
                       OnTogglePagesPane="TogglePagesPane"
                       OnToggleInspectorPane="ToggleInspectorPane"
                       OnResetWorkspace="ResetWorkspace"
                       OnInsertDataVisual="InsertDataVisual"
                       OnEditDataVisual="OpenDataVisualEditor"
                       OnManageData="OpenDataManager"
                       OnInsertComponent="InsertComponent"
                       OnEditComponent="OpenComponentEditor"
                       OnPreviewPageAnimations="PreviewPageAnimations"
                       OnPreviewObjectAnimations="PreviewObjectAnimations"
                       OnStopAnimations="StopAnimations"
                       Streaming="StreamingSession.Snapshot"
                       OnStreamingSetup="OpenStreamingStudio"
                       OnStartDryRun="StartDryRun"
                       OnStartStreaming="StartStreaming"
                       OnStopStreaming="StopStreaming"
                       OnToggleRecording="ToggleStreamRecording"
                       OnToggleStreamOutput="ToggleStreamOutput"
                       OnSelectProgramPage="SelectProgramPage"
                       OnInsertLiveSource="InsertLiveSource"
                       OnSelectChatOutput="SelectChatOutput" />

    <div class="publisher-quick-insert" aria-label="Drag objects onto the publication page">
        <span>Drag to canvas</span>
        <button type="button" draggable="true" data-publisher-insert="text" title="Drag a text box to an exact position, or click to insert" @onclick="AddTextQuick"><i class="pub-icon pub-icon-text"></i>Text</button>
        <button type="button" draggable="true" data-publisher-insert="picture" title="Drag to choose and place a picture, or click to insert" @onclick="OpenPicturePicker"><i class="pub-icon pub-icon-picture"></i>Picture</button>
        <button type="button" draggable="true" data-publisher-insert="spreadsheet" title="Drag to create and place a spreadsheet, or click to open a workbook" @onclick="OpenSpreadsheetPicker"><i class="pub-icon pub-icon-spreadsheet"></i>Sheet</button>
        <button type="button" draggable="true" data-publisher-insert="video" title="Drag to create or import and place a video, or click to insert" @onclick="OpenVideoPicker"><i class="pub-icon pub-icon-video"></i>Video</button>
        <small>Ctrl/Shift-click objects for multi-selection</small>
    </div>

    <div id="publisher-workspace" class="editor-workspace @(_timelineVisible ? "timeline-open" : null)">
        <PageNavigator State="State" TimelineVisible="_timelineVisible" RequestToggleTimeline="ToggleTimeline" />
        <button type="button" class="workspace-splitter splitter-left" data-workspace-splitter="left" title="Drag to resize pages pane; double-click to collapse" aria-label="Resize pages pane"></button>
        <PageSurface @ref="_pageSurface" State="State" EditTextRequested="OpenStoryEditorById" RequestPicture="OpenPicturePicker" RequestReplacePicture="OpenReplacePicturePicker" RequestCreatePicture="CreatePicture" RequestEditPicture="EditSelectedPicture"
                     RequestInsertSpreadsheet="OpenSpreadsheetPicker" RequestCreateSpreadsheet="CreateSpreadsheet" RequestEditSpreadsheet="OpenSpreadsheetEditor" RequestDownloadSpreadsheet="DownloadSelectedSpreadsheet"
                     RequestInsertDataVisual="InsertDataVisual" RequestEditDataVisual="OpenDataVisualEditor" RequestManageData="OpenDataManager"
                     RequestInsertComponent="InsertComponent" RequestEditComponent="OpenComponentEditor"
                     RequestInsertVideo="OpenVideoPicker" RequestInsertAudio="OpenAudioPicker" RequestCreateVideo="CreateVideo" RequestCreateAudio="CreateAudio" RequestEditMedia="EditSelectedMedia"
                     RequestInsertBarcode="InsertBarcode" RequestEditBarcode="EditBarcode"
                     TimelineVisible="_timelineVisible" RequestToggleTimeline="ToggleTimeline" RequestCanvasInsert="HandleCanvasInsert"
                     RequestExternalFileDrop="HandleExternalFileDrop" RequestExternalDropError="HandleExternalDropError" />
        <button type="button" class="workspace-splitter splitter-right" data-workspace-splitter="right" title="Drag to resize properties pane; double-click to collapse" aria-label="Resize properties pane"></button>
        <InspectorPanel State="State"
                        OnEditStory="OpenStoryEditor"
                        OnReplacePicture="OpenReplacePicturePicker"
                        OnInsertPicture="OpenPicturePicker"
                        OnCreatePicture="CreatePicture"
                        OnEditPicture="EditSelectedPicture"
                        OnInsertSpreadsheet="OpenSpreadsheetPicker"
                        OnCreateSpreadsheet="CreateSpreadsheet"
                        OnEditSpreadsheet="OpenSpreadsheetEditor"
                        OnDownloadSpreadsheet="DownloadSelectedSpreadsheet"
                        OnApplyTransparentColor="ApplyTransparentColor"
                        OnRestoreOriginalPicture="RestoreOriginalPicture"
                        OnInsertDataVisual="InsertDataVisual"
                        OnEditDataVisual="OpenDataVisualEditor"
                        OnManageData="OpenDataManager"
                        OnInsertComponent="InsertComponent"
                        OnEditComponent="OpenComponentEditor"
                        OnInsertVideo="OpenVideoPicker"
                        OnInsertAudio="OpenAudioPicker"
                        OnCreateVideo="CreateVideo"
                        OnCreateAudio="CreateAudio"
                        OnEditMedia="EditSelectedMedia"
                        OnInsertBarcode="InsertBarcode"
                        OnEditBarcode="EditBarcode" />

        @if (_timelineVisible)
        {
            <PublicationTimeline State="State"
                                 RequestClose="HideTimeline"
                                 RequestInsertAudio="OpenAudioPicker"
                                 RequestInsertVideo="OpenVideoPicker"
                                 RequestCreateAudio="CreateAudio"
                                 RequestCreateVideo="CreateVideo"
                                 RequestEditMedia="EditSelectedMedia" />
        }
    </div>

    <footer class="status-bar">
        <span>Page @(State.Document.Pages.FindIndex(p => p.Id == State.SelectedPageId) + 1) of @State.Document.Pages.Count</span>
        <span>@SelectionStatus</span>
        <span>@State.CurrentPage.WidthMm.ToString("0.#", CultureInfo.InvariantCulture) × @State.CurrentPage.HeightMm.ToString("0.#", CultureInfo.InvariantCulture) mm</span>
        <label class="zoom-control">Zoom
            <button type="button" title="Zoom out" @onclick="ZoomOut">−</button>
            <input type="range" min="0.2" max="4" step="0.05" value="@State.Document.Zoom.ToString(CultureInfo.InvariantCulture)" @oninput="ChangeZoom" />
            <button type="button" title="Zoom in" @onclick="ZoomIn">+</button>
            <b>@Math.Round(State.Document.Zoom * 100)%</b>
        </label>
    </footer>
</div>

<InputFile id="publication-file-input" class="hidden-file-input" accept=".json,.pubstudio.json,application/json" OnChange="OpenPublication" />
<InputFile id="picture-file-input" class="hidden-file-input" accept="image/png,image/jpeg,image/gif,image/webp,image/svg+xml" OnChange="InsertPicture" />
<InputFile id="spreadsheet-file-input" class="hidden-file-input" accept=".xlsx,.xlsm,.xls,.csv,.txt,.tsv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel,text/csv,text/plain" OnChange="InsertSpreadsheet" />
<InputFile id="video-file-input" class="hidden-file-input" accept=".mp4,.m4v,.webm,.ogv,.ogg,.mov,video/mp4,video/x-m4v,video/webm,video/ogg,video/quicktime" OnChange="InsertVideo" />
<InputFile id="audio-file-input" class="hidden-file-input" accept="audio/mpeg,audio/mp4,audio/wav,audio/x-wav,audio/ogg,audio/webm,audio/flac" OnChange="InsertAudio" />

<PrintPublication Document="State.Document" />

<StoryEditor Visible="_storyEditorVisible"
             TextFrame="@(State.SelectedElement as TextFrameElement)"
             PublicationName="@State.Document.Name"
             PageName="@State.CurrentPage.Name"
             PageNumber="@CurrentPageNumber"
             PageCount="@State.Document.Pages.Count"
             Saved="SaveStory"
             Cancelled="CloseStoryEditor" />

<SpreadsheetEditor Visible="@_spreadsheetEditorVisible"
                   SessionId="@_spreadsheetEditorSessionId"
                   FileName="@_spreadsheetEditorFileName"
                   Saved="SaveSpreadsheet"
                   DataObjectCreated="CreateSpreadsheetDataObject"
                   Cancelled="CloseSpreadsheetEditor" />

<PictureEditor Visible="@_pictureEditorVisible"
               SessionId="@_pictureEditorSessionId"
               InitialDocument="@_pictureEditorInitialDocument"
               InitialRasterDataUrl="@_pictureEditorInitialRaster"
               InitialName="@_pictureEditorInitialName"
               EditingExisting="@(_pictureEditorTargetId is not null)"
               Saved="SavePictureStudio"
               Cancelled="ClosePictureStudio" />

<MediaStudio Visible="_mediaStudioVisible"
             SessionId="_mediaStudioSessionId"
             Kind="_mediaStudioKind"
             InitialMedia="_mediaStudioInitial"
             EditingExisting="@(_mediaStudioTargetId is not null)"
             Saved="SaveMediaStudio"
             Cancelled="CloseMediaStudio" />

<DataVisualEditor Visible="_dataVisualEditorVisible" State="State" Saved="SaveDataVisualEditor" Cancelled="CancelDataVisualEditor" ManageDataRequested="OpenDataManagerFromVisual" />
<DevExtremeComponentEditor Visible="_componentEditorVisible" State="State" Saved="SaveComponentEditor" Cancelled="CancelComponentEditor" ManageDataRequested="OpenDataManagerFromComponent" />
<DataManager Visible="_dataManagerVisible" State="State" Closed="CloseDataManager" DataChanged="DataManagerChanged" />
<BarcodeEditor Visible="_barcodeEditorVisible" Item="@(State.SelectedElement as BarcodeElement)" Saved="SaveBarcode" Cancelled="CancelBarcode" />
<StreamingStudio Visible="_streamingStudioVisible" Document="State.Document" Saved="SaveStreamingStudio" Cancelled="CloseStreamingStudio" />

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="toast error" @onclick="() => _error = null">@_error</div>
}

@if (!string.IsNullOrWhiteSpace(_notice))
{
    <div class="toast notice" @onclick="() => _notice = null">@_notice</div>
}

@code {
    private PageSurface? _pageSurface;
    private bool _storyEditorVisible;
    private bool _spreadsheetEditorVisible;
    private Guid _spreadsheetEditorSessionId;
    private Guid? _spreadsheetEditorTargetId;
    private Guid? _pendingNewSpreadsheetId;
    private string _spreadsheetEditorFileName = "Spreadsheet.xlsx";
    private bool _pictureEditorVisible;
    private bool _dataVisualEditorVisible;
    private bool _componentEditorVisible;
    private bool _dataManagerVisible;
    private bool _mediaStudioVisible;
    private bool _timelineVisible;
    private bool _barcodeEditorVisible;
    private bool _streamingStudioVisible;
    private bool _videoExporting;
    private Guid? _pendingNewBarcodeId;
    private Guid _mediaStudioSessionId;
    private Guid? _mediaStudioTargetId;
    private PublicationElementKind _mediaStudioKind = PublicationElementKind.Audio;
    private PublicationMediaElement? _mediaStudioInitial;
    private Guid? _pendingNewDataVisualId;
    private Guid? _pendingNewComponentId;
    private bool _resumeDataVisualAfterManager;
    private bool _resumeComponentAfterManager;
    private Guid _pictureEditorSessionId;
    private Guid? _pictureEditorTargetId;
    private PictureDocument? _pictureEditorInitialDocument;
    private string? _pictureEditorInitialRaster;
    private string _pictureEditorInitialName = "Picture";
    private CanvasInsertRequest? _pendingCanvasInsert;
    private Guid? _replacePictureTargetId;
    private bool _workspaceInitialized;
    private PublicationRecoverySnapshot? _recoveryCandidate;
    private CancellationTokenSource? _recoverySaveCancellation;
    private long _scheduledRecoveryRevision = -1;
    private bool _disposed;
    private DotNetObjectReference<Editor>? _streamingHotkeyReference;
    private string _boundStreamingHotkeys = string.Empty;
    private string? _error;
    private string? _notice;
    private string SelectionStatus => State.ConnectorTool != ConnectorToolKind.None
        ? $"{State.ConnectorTool} connector tool — drag from one object port to another; Esc cancels"
        : State.SelectedElements.Count > 1
            ? $"{State.SelectedElements.Count} objects selected{(State.SelectedElements.Any(item => item.GroupId is not null) ? " · grouped" : string.Empty)}"
            : State.SelectedElement is null ? "No selection" : $"{State.SelectedElement.Kind}: {State.SelectedElement.Name}";

    protected override void OnInitialized()
    {
        State.Changed += StateChanged;
        StreamingSession.Changed += StateChanged;
        StreamingSession.HotkeyTriggered += HandleGlobalStreamingHotkey;
        _recoveryCandidate = Recovery.TryReadLatest();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_workspaceInitialized)
        {
            _workspaceInitialized = true;
            await JS.InvokeVoidAsync("publisherStudio.initializeWorkspace", "publisher-workspace");
            await JS.InvokeVoidAsync("publisherStudio.setDocumentDirty", State.IsDirty);
        }

        var hotkeySignature = System.Text.Json.JsonSerializer.Serialize(State.Document.Streaming.Hotkeys);
        if (!string.Equals(hotkeySignature, _boundStreamingHotkeys, StringComparison.Ordinal))
        {
            _streamingHotkeyReference ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("publisherStreaming.bindHotkeys", State.Document.Streaming.Hotkeys, _streamingHotkeyReference);
            _boundStreamingHotkeys = hotkeySignature;
        }
    }

    private void StateChanged()
    {
        if (StreamingSession.Snapshot.Mode != PublicationStreamSessionMode.Idle
            && State.Document.Streaming.FollowSelectedPage
            && StreamingSession.Snapshot.ProgramPageId != State.SelectedPageId)
            StreamingSession.SetProgramPage(State.SelectedPageId);
        _ = InvokeAsync(async () =>
        {
            try { await JS.InvokeVoidAsync("publisherStudio.setDocumentDirty", State.IsDirty); }
            catch (InvalidOperationException) { }
            catch (JSDisconnectedException) { }
            catch (TaskCanceledException) { }
            StateHasChanged();
        });
        if (State.IsDirty && State.Revision != _scheduledRecoveryRevision)
            ScheduleRecoverySave();
    }
    private void NewDocument() => State.NewDocument();
    private void AddTextQuick() => State.AddText();

    private async Task HandleCanvasInsert(CanvasInsertRequest request)
    {
        var kind = request.Kind.Trim().ToLowerInvariant();
        if (kind == "text")
        {
            State.AddText(request.X, request.Y);
            return;
        }

        _pendingCanvasInsert = request with { Kind = kind };
        if (kind == "picture")
        {
            await CancelPublisherPointerAsync();
            await OpenHiddenFileInput("picture-file-input");
            return;
        }
        if (kind == "spreadsheet")
        {
            await CreateSpreadsheet();
            return;
        }
        if (kind == "video")
        {
            await OpenMediaStudio(PublicationElementKind.Video, null);
            return;
        }
        _pendingCanvasInsert = null;
    }

    private async Task HandleExternalFileDrop(ExternalFileDropRequest request)
    {
        if (!MediaAssets.TryGet(request.AssetId, out var bytes, out var storedMimeType, out _))
        {
            ShowError(new InvalidDataException("The dropped file was not available after upload."));
            return;
        }

        try
        {
            State.SetInsertionPoint(request.X, request.Y);
            var kind = request.Kind.Trim().ToLowerInvariant();
            var mimeType = ResolveDroppedMimeType(request.Name, request.MimeType, storedMimeType, kind);
            if (kind == "picture")
            {
                var dataUrl = $"data:{mimeType};base64,{Convert.ToBase64String(bytes)}";
                State.AddImage(dataUrl, request.Name, centerX: request.X, centerY: request.Y,
                    pixelWidth: request.PixelWidth, pixelHeight: request.PixelHeight);
                ShowNotice($"Inserted {request.Name} at the drop position.");
                return;
            }

            if (kind == "video")
            {
                mimeType = PublicationMediaData.NormalizeMimeType(mimeType, "video/webm");
                var dataUrl = PublicationMediaData.NormalizeDataUrl($"data:{mimeType};base64,{Convert.ToBase64String(bytes)}", mimeType);
                var video = State.AddVideo(dataUrl, mimeType, request.Name,
                    request.DurationSeconds > 0 ? request.DurationSeconds : 5,
                    centerX: request.X, centerY: request.Y);
                MediaAssets.Copy(request.AssetId, video.Id);
                _timelineVisible = true;
                ShowNotice($"Inserted {request.Name} at the drop position. The timeline is open for timing and trimming.");
                return;
            }

            if (kind == "spreadsheet")
            {
                var format = Spreadsheets.DetectFormat(request.Name, mimeType);
                var spreadsheet = State.AddSpreadsheet(bytes, request.Name, format, request.X, request.Y);
                _pendingNewSpreadsheetId = spreadsheet.Id;
                await OpenSpreadsheetEditorById(spreadsheet.Id, pendingNew: true);
                ShowNotice($"Opened {request.Name} in Spreadsheet Studio. Apply it to keep the new frame.");
                return;
            }

            if (kind is "text" or "markdown" or "docx")
            {
                if (kind == "docx" && !PublicationFileService.IsOpenXmlDocument(bytes))
                    throw new InvalidDataException($"'{request.Name}' is not a valid Office Open XML DOCX document.");

                var text = State.AddText(request.X, request.Y);
                State.UpdateSelected(_ =>
                {
                    text.Name = string.IsNullOrWhiteSpace(request.Name)
                        ? kind == "docx" ? "Imported Word document" : "Dropped text"
                        : request.Name;
                    if (kind == "docx")
                    {
                        text.DocumentContent = bytes.ToArray();
                        text.PreviewHtml = PublicationFileService.CreateOpenXmlPreviewHtml(bytes, text.Name);
                        text.DocumentBackground = PublicationFileService.ExtractOpenXmlDocumentBackground(bytes);
                    }
                    else
                    {
                        var content = DecodeText(bytes);
                        text.PreviewHtml = kind == "markdown" ? MarkdownToHtml(content) : PlainTextToHtml(content);
                        text.DocumentContent = kind == "markdown"
                            ? RichTextDocumentFactory.CreateOpenXmlFromMarkdown(content)
                            : RichTextDocumentFactory.CreateOpenXmlFromPlainText(content);
                        text.DocumentBackground = "transparent";
                    }
                    text.StoryFormat = StoryStorageFormat.OpenXml;
                    text.Width = Math.Min(125, Math.Max(75, State.CurrentPage.WidthMm * .48));
                    text.Height = Math.Min(95, Math.Max(40, State.CurrentPage.HeightMm * .30));
                    text.X = Math.Clamp(request.X - text.Width / 2, -text.Width + 2, State.CurrentPage.WidthMm - 2);
                    text.Y = Math.Clamp(request.Y - text.Height / 2, -text.Height + 2, State.CurrentPage.HeightMm - 2);
                });
                ShowNotice(kind == "docx"
                    ? $"Inserted {request.Name} as an editable DOCX story. Double-click the frame for full Word-document fidelity."
                    : $"Inserted {request.Name} as an editable text frame.");
                return;
            }

            throw new InvalidDataException("Drop a picture, spreadsheet, video, DOCX, text, or Markdown file.");
        }
        catch (Exception ex)
        {
            ShowError(ex);
        }
        finally
        {
            MediaAssets.Remove(request.AssetId);
        }
    }

    private Task HandleExternalDropError(string message)
    {
        ShowError(new InvalidDataException(message));
        return Task.CompletedTask;
    }

    private static string DecodeText(byte[] bytes)
    {
        if (bytes.Length >= 3 && bytes[0] == 0xef && bytes[1] == 0xbb && bytes[2] == 0xbf)
            return Encoding.UTF8.GetString(bytes, 3, bytes.Length - 3);
        if (bytes.Length >= 2 && bytes[0] == 0xff && bytes[1] == 0xfe)
            return Encoding.Unicode.GetString(bytes, 2, bytes.Length - 2);
        if (bytes.Length >= 2 && bytes[0] == 0xfe && bytes[1] == 0xff)
            return Encoding.BigEndianUnicode.GetString(bytes, 2, bytes.Length - 2);
        return Encoding.UTF8.GetString(bytes);
    }

    private static string ResolveDroppedMimeType(string name, string requested, string stored, string kind)
    {
        var declared = PublicationMediaData.NormalizeMimeType(requested, stored);
        if ((kind == "picture" && declared.StartsWith("image/", StringComparison.OrdinalIgnoreCase)) ||
            (kind == "video" && declared.StartsWith("video/", StringComparison.OrdinalIgnoreCase)) ||
            kind is "spreadsheet" or "text" or "markdown" or "docx")
            return declared;
        return Path.GetExtension(name).ToLowerInvariant() switch
        {
            ".png" => "image/png",
            ".jpg" or ".jpeg" => "image/jpeg",
            ".gif" => "image/gif",
            ".webp" => "image/webp",
            ".svg" => "image/svg+xml",
            ".mp4" => "video/mp4",
            ".m4v" => "video/x-m4v",
            ".webm" => "video/webm",
            ".ogv" or ".ogg" => "video/ogg",
            ".mov" => "video/quicktime",
            ".md" or ".markdown" => "text/markdown",
            ".docx" => "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
            ".xlsx" => "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            ".xlsm" or ".xls" => "application/vnd.ms-excel",
            ".csv" => "text/csv",
            ".tsv" or ".txt" => "text/plain",
            _ => kind == "picture" ? "image/png" : kind == "video" ? "video/mp4" : kind == "docx" ? "application/vnd.openxmlformats-officedocument.wordprocessingml.document" : "text/plain"
        };
    }

    private static string PlainTextToHtml(string text) =>
        $"<p style=\"margin:0;white-space:pre-wrap;font:12pt Segoe UI\">{System.Net.WebUtility.HtmlEncode(text)}</p>";

    private static string MarkdownToHtml(string markdown)
    {
        var builder = new StringBuilder();
        var inList = false;
        foreach (var rawLine in markdown.Replace("\r\n", "\n").Split('\n'))
        {
            var line = rawLine.TrimEnd();
            var trimmed = line.TrimStart();
            if (trimmed.StartsWith("- ") || trimmed.StartsWith("* "))
            {
                if (!inList) { builder.Append("<ul>"); inList = true; }
                builder.Append("<li>").Append(MarkdownInline(trimmed[2..])).Append("</li>");
                continue;
            }
            if (inList) { builder.Append("</ul>"); inList = false; }
            if (string.IsNullOrWhiteSpace(trimmed)) { builder.Append("<p><br></p>"); continue; }
            var heading = trimmed.TakeWhile(character => character == '#').Count();
            if (heading is >= 1 and <= 6 && trimmed.Length > heading && char.IsWhiteSpace(trimmed[heading]))
                builder.Append($"<h{heading}>").Append(MarkdownInline(trimmed[(heading + 1)..])).Append($"</h{heading}>");
            else
                builder.Append("<p>").Append(MarkdownInline(trimmed)).Append("</p>");
        }
        if (inList) builder.Append("</ul>");
        return builder.Length == 0 ? "<p><br></p>" : builder.ToString();
    }

    private static string MarkdownInline(string value)
    {
        var encoded = System.Net.WebUtility.HtmlEncode(value);
        encoded = System.Text.RegularExpressions.Regex.Replace(encoded, @"\*\*(.+?)\*\*", "<strong>$1</strong>");
        encoded = System.Text.RegularExpressions.Regex.Replace(encoded, @"(?<!\*)\*(?!\*)(.+?)(?<!\*)\*(?!\*)", "<em>$1</em>");
        encoded = System.Text.RegularExpressions.Regex.Replace(encoded, @"`(.+?)`", "<code>$1</code>");
        return encoded;
    }
    private async Task OpenPublicationPicker()
    {
        await CancelPublisherPointerAsync();
        await OpenHiddenFileInput("publication-file-input");
    }
    private async Task OpenPicturePicker()
    {
        _pendingCanvasInsert = null;
        _replacePictureTargetId = null;
        await CancelPublisherPointerAsync();
        await OpenHiddenFileInput("picture-file-input");
    }
    private async Task OpenSpreadsheetPicker()
    {
        _pendingCanvasInsert = null;
        await CancelPublisherPointerAsync();
        await OpenHiddenFileInput("spreadsheet-file-input");
    }

    private async Task OpenReplacePicturePicker()
    {
        if (State.SelectedElement is not ImageFrameElement image) return;
        _pendingCanvasInsert = null;
        _replacePictureTargetId = image.Id;
        await CancelPublisherPointerAsync();
        await OpenHiddenFileInput("picture-file-input");
    }
    private Task OpenVideoPicker()
    {
        _pendingCanvasInsert = null;
        return OpenMediaStudio(PublicationElementKind.Video, null);
    }
    private async Task OpenAudioPicker()
    {
        await CancelPublisherPointerAsync();
        await OpenHiddenFileInput("audio-file-input");
    }

    private async Task OpenHiddenFileInput(string id)
    {
        try
        {
            await JS.InvokeVoidAsync("publisherStudio.clickElement", id);
        }
        catch (JSException)
        {
            await using var module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/publisherInterop.js");
            await module.InvokeVoidAsync("clickElementById", id);
        }
    }

    private async Task SavePublication()
    {
        var json = Files.Serialize(State.Document);
        var name = PublicationFileService.SafeFileName(State.Document.Name) + ".pubstudio.json";
        await using var stream = new MemoryStream(Encoding.UTF8.GetBytes(json));
        using var streamReference = new DotNetStreamReference(stream);
        await JS.InvokeVoidAsync("publisherStudio.downloadStream", name, streamReference, "application/json");
        State.MarkSaved();
        await Recovery.DeleteAsync(State.Document.Id);
        await JS.InvokeVoidAsync("publisherStudio.setDocumentDirty", false);
        ShowNotice($"Saved {name}");
    }

    private void ScheduleRecoverySave()
    {
        _scheduledRecoveryRevision = State.Revision;
        _recoverySaveCancellation?.Cancel();
        _recoverySaveCancellation?.Dispose();
        var cancellation = _recoverySaveCancellation = new CancellationTokenSource();
        _ = DebouncedRecoverySaveAsync(cancellation);
    }

    private async Task DebouncedRecoverySaveAsync(CancellationTokenSource cancellation)
    {
        try
        {
            await Task.Delay(1800, cancellation.Token);
            await InvokeAsync(() => SaveRecoveryNow(cancellation.Token));
        }
        catch (OperationCanceledException) { }
        catch (Exception ex) { Console.Error.WriteLine($"Publication recovery save failed: {ex}"); }
    }

    private async Task SaveRecoveryNow(CancellationToken cancellationToken = default)
    {
        if (!State.IsDirty) return;
        var json = Files.Serialize(State.Document);
        await Recovery.SaveAsync(State.Document.Id, State.Document.Name, State.Document.ModifiedUtc, json, cancellationToken);
    }

    private Task RestoreRecovery()
    {
        if (_recoveryCandidate is null) return Task.CompletedTask;
        State.LoadRecovery(_recoveryCandidate.Json);
        _recoveryCandidate = null;
        ShowNotice("Recovered the latest automatically saved publication state.");
        return Task.CompletedTask;
    }

    private async Task DismissRecovery()
    {
        if (_recoveryCandidate is { } recovery)
            await Recovery.DeleteAsync(recovery.DocumentId);
        _recoveryCandidate = null;
    }

