    private async Task OpenMediaStudio(PublicationElementKind kind, PublicationMediaElement? media)
    {
        await CancelPublisherPointerAsync();
        _mediaStudioTargetId = media?.Id;
        _mediaStudioKind = kind;
        _mediaStudioInitial = media;
        _mediaStudioSessionId = Guid.NewGuid();
        _mediaStudioVisible = true;
    }

    private Task SaveMediaStudio(MediaEditorResult result)
    {
        var targetId = _mediaStudioTargetId;

        try
        {
            PublicationMediaElement media;
            if (targetId is Guid existingId && State.CurrentPage.Elements.OfType<PublicationMediaElement>().Any(item => item.Id == existingId))
            {
                State.SelectElement(existingId);
                media = State.CurrentPage.Elements.OfType<PublicationMediaElement>().First(item => item.Id == existingId);
                State.UpdateMedia(existingId, item => ApplyMediaResult(item, result));
            }
            else if (result.Kind == PublicationElementKind.Video)
            {
                media = _pendingCanvasInsert is { Kind: "video" } placement
                    ? State.AddVideo(result.DataUrl, result.MimeType, result.Name, result.DurationSeconds, result.PosterDataUrl, placement.X, placement.Y)
                    : State.AddVideo(result.DataUrl, result.MimeType, result.Name, result.DurationSeconds, result.PosterDataUrl);
                State.UpdateMedia(media.Id, item => ApplyMediaResult(item, result), capture: false);
            }
            else
            {
                media = State.AddAudio(result.DataUrl, result.MimeType, result.Name, result.DurationSeconds, result.WaveformSamples);
                State.UpdateMedia(media.Id, item => ApplyMediaResult(item, result), capture: false);
            }

            if (!MediaAssets.Copy(result.PreviewAssetId, media.Id))
                MediaAssets.Register(media.Id, media.DataUrl, media.MimeType);
            State.SelectElement(media.Id);
            _mediaStudioVisible = false;
            _mediaStudioTargetId = null;
            _mediaStudioInitial = null;
            _pendingCanvasInsert = null;
            _timelineVisible = true;
            ShowNotice($"{(result.Kind == PublicationElementKind.Video ? "Video" : "Audio")} applied to the publication timeline.");
        }
        catch (Exception ex)
        {
            ShowError(ex);
            throw;
        }
        return Task.CompletedTask;
    }

    private static void ApplyMediaResult(PublicationMediaElement item, MediaEditorResult result)
    {
        item.Name = result.Name;
        item.DataUrl = result.DataUrl;
        item.MimeType = result.MimeType;
        item.DurationSeconds = result.DurationSeconds;
        item.TrimStartSeconds = result.TrimStartSeconds;
        item.TrimEndSeconds = result.TrimEndSeconds;
        item.Volume = result.Volume;
        item.PlaybackRate = result.PlaybackRate;
        item.FadeInSeconds = result.FadeInSeconds;
        item.FadeOutSeconds = result.FadeOutSeconds;
        item.Muted = result.Muted;
        item.Loop = result.Loop;
        item.AutoPlay = result.AutoPlay;
        item.PlaybackTrigger = result.PlaybackTrigger;
        item.WaveformSamples = result.WaveformSamples ?? [];
        if (item is VideoElement video)
        {
            video.PosterDataUrl = result.PosterDataUrl;
            video.AltText = result.Name;
        }
    }

