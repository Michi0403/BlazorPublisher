    private Task StartDryRun() => StartStreamingSession(dryRun: true);
    private Task StartStreaming() => StartStreamingSession(dryRun: false);

    private async Task StartStreamingSession(bool dryRun)
    {
        if (StreamingSession.Snapshot.Mode != PublicationStreamSessionMode.Idle) return;
        try
        {
            var machine = await StreamingProfiles.LoadAsync();
            var configuredOutputs = State.Document.Streaming.Outputs
                .Select(output => new
                {
                    Output = output,
                    Profile = machine.Providers.FirstOrDefault(profile => profile.Id == output.ProfileId && profile.Enabled)
                })
                .ToArray();
            var enabledOutputs = configuredOutputs.Where(item => item.Output.Enabled).ToArray();
            if (!dryRun)
            {
                if (enabledOutputs.Length == 0
                    && !State.Document.Streaming.Recording.Enabled
                    && !State.Document.Streaming.Lan.Enabled)
                    throw new InvalidOperationException("Enable a provider output, recording, or Company/LAN delivery before starting a live session.");

                var missingProfile = enabledOutputs.FirstOrDefault(item => item.Profile is null);
                if (missingProfile is not null)
                    throw new InvalidOperationException($"The output '{missingProfile.Output.Name}' has no enabled machine provider profile.");

                var missingEndpoint = enabledOutputs.FirstOrDefault(item => string.IsNullOrWhiteSpace(item.Profile?.Endpoint));
                if (missingEndpoint is not null)
                    throw new InvalidOperationException($"The provider profile for '{missingEndpoint.Output.Name}' has no ingest endpoint.");
            }

            var firstOutput = enabledOutputs.FirstOrDefault(item => item.Profile is not null)?.Output;
            var platform = dryRun || firstOutput is null ? "Preview" : firstOutput.Provider.ToString();
            var channel = firstOutput?.ChatChannel ?? string.Empty;
            if (firstOutput is not null && string.IsNullOrWhiteSpace(channel))
                channel = configuredOutputs.First(item => item.Output.Id == firstOutput.Id).Profile?.ChannelId ?? string.Empty;
            await JS.InvokeVoidAsync("publisherStreaming.setOutputContext", new
            {
                mode = "operator",
                platform,
                channel,
                outputId = firstOutput?.Id.ToString("D") ?? string.Empty
            });
            var prepared = await JS.InvokeAsync<bool>("publisherStreaming.prepareProgramCapture", new
            {
                pageElementId = "publisher-page",
                width = State.Document.Streaming.MasterWidth,
                height = State.Document.Streaming.MasterHeight,
                frameRate = State.Document.Streaming.MasterFrameRate
            });
            if (!prepared) throw new InvalidOperationException("The browser did not prepare the Publisher program capture.");

            await StreamingSession.StartAsync(State.Document, dryRun);
            if (StreamingSession.Snapshot.SessionId is not { } sessionId)
                throw new InvalidOperationException(StreamingSession.Snapshot.StatusText);
            var configuredOutputBitrate = State.Document.Streaming.Outputs
                .Where(output => output.Enabled)
                .Select(output => (long)output.VideoBitrateKbps * 1000L)
                .DefaultIfEmpty(16_000_000L)
                .Max();
            var masterQualityBitrate = Math.Clamp(
                (long)Math.Round(
                    State.Document.Streaming.MasterWidth
                    * (double)State.Document.Streaming.MasterHeight
                    * State.Document.Streaming.MasterFrameRate
                    * 0.16,
                    MidpointRounding.AwayFromZero),
                12_000_000L,
                120_000_000L);
            var videoBitrate = (int)Math.Min(int.MaxValue, Math.Max(masterQualityBitrate, configuredOutputBitrate * 2L));
            var browserOutputs = configuredOutputs.Select(item =>
            {
                var selectedForRecording = State.Document.Streaming.Recording.Enabled
                    && (State.Document.Streaming.Recording.Variant == PublicationStreamRecordingVariant.EachEnabledOutput && item.Output.Enabled
                        || State.Document.Streaming.Recording.Variant == PublicationStreamRecordingVariant.SelectedOutputs
                            && State.Document.Streaming.Recording.SelectedOutputIds.Contains(item.Output.Id));
                return new
                {
                    outputId = item.Output.Id.ToString("D"),
                    enabled = item.Output.Enabled,
                    captureRequired = item.Output.Enabled || selectedForRecording,
                    platform = item.Output.Provider.ToString(),
                    channel = string.IsNullOrWhiteSpace(item.Output.ChatChannel)
                        ? item.Profile?.ChannelId ?? string.Empty
                        : item.Output.ChatChannel,
                    width = item.Output.Width,
                    height = item.Output.Height,
                    frameRate = item.Output.FrameRate,
                    videoBitrateKbps = item.Output.VideoBitrateKbps,
                    chatEnabled = item.Profile?.ChatEnabled == true
                };
            }).ToArray();
            await JS.InvokeAsync<bool>("publisherStreaming.configureChatBridge", new
            {
                mediaHostUrl = string.Empty,
                sessionId = sessionId.ToString("D"),
                outputs = browserOutputs
            });
            await JS.InvokeAsync<object>("publisherStreaming.startProgramIngest", new
            {
                mediaHostUrl = string.Empty,
                sessionId = sessionId.ToString("D"),
                videoBitsPerSecond = videoBitrate,
                audioBitsPerSecond = 192_000,
                outputs = browserOutputs,
                enableWebRtc = State.Document.Streaming.Lan.Enabled
                    && State.Document.Streaming.Lan.EnableBrowserWebRtc
            });
            ShowNotice(dryRun ? "Dry run active. The current tab is captured but no public provider receives it." : "Streaming session active.");
        }
        catch (Exception exception)
        {
            try { await JS.InvokeVoidAsync("publisherStreaming.stopChatBridge"); } catch { }
            try { await JS.InvokeVoidAsync("publisherStreaming.stopProgramIngest"); } catch { }
            if (StreamingSession.Snapshot.Mode != PublicationStreamSessionMode.Idle) await StreamingSession.StopAsync();
            await JS.InvokeVoidAsync("publisherStreaming.setOutputContext", new { mode = "operator", platform = "Preview", channel = "" });
            ShowError(exception);
        }
    }

    private async Task StopStreaming()
    {
        try { await JS.InvokeVoidAsync("publisherStreaming.stopChatBridge"); } catch { }
        try { await JS.InvokeVoidAsync("publisherStreaming.stopProgramIngest"); } catch { }
        await StreamingSession.StopAsync();
        await JS.InvokeVoidAsync("publisherStreaming.setOutputContext", new { mode = "operator", platform = "Preview", channel = "" });
        ShowNotice("Streaming session stopped.");
    }

    private async Task ToggleStreamRecording()
