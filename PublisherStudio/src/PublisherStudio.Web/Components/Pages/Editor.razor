    private async Task ToggleStreamOutput(Guid outputId)
    {
        if (StreamingSession.Snapshot.Mode != PublicationStreamSessionMode.Idle)
        {
            await StreamingSession.ToggleOutputAsync(outputId);
            return;
        }
        var settings = CloneStreaming(State.Document.Streaming);
        var output = settings.Outputs.FirstOrDefault(item => item.Id == outputId);
        if (output is null) return;
        output.Enabled = !output.Enabled;
        State.ApplyStreamingSettings(settings);
    }

    private async Task SelectChatOutput(Guid? outputId)
    {
        if (outputId is null)
        {
            await JS.InvokeVoidAsync("publisherStreaming.setOutputContext", new { mode = "operator", platform = "Preview", channel = "", outputId = "" });
            ShowNotice("Chat switched to preview messages.");
            return;
        }
        var output = State.Document.Streaming.Outputs.FirstOrDefault(item => item.Id == outputId.Value);
        if (output is null) return;
        var channel = output.ChatChannel;
        if (string.IsNullOrWhiteSpace(channel))
        {
            var machine = await StreamingProfiles.LoadAsync();
            channel = machine.Providers.FirstOrDefault(profile => profile.Id == output.ProfileId)?.ChannelId ?? string.Empty;
        }
        await JS.InvokeVoidAsync("publisherStreaming.setOutputContext", new
        {
            mode = "operator",
            platform = output.Provider.ToString(),
            channel,
            outputId = output.Id.ToString("D")
        });
        ShowNotice($"Operator Chat: {output.Name}. Broadcast outputs remain isolated.");
    }

    private Task SelectProgramPage(Guid pageId)
    {
        var page = State.Document.Pages.FirstOrDefault(item => item.Id == pageId);
        if (page is null) return Task.CompletedTask;
        StreamingSession.SetProgramPage(pageId);
        var settings = CloneStreaming(State.Document.Streaming);
        settings.ProgramPageId = pageId;
        settings.FollowSelectedPage = false;
        State.ApplyStreamingSettings(settings);
        if (State.SelectedPageId != pageId) State.SelectPage(pageId);
        ShowNotice($"Program page: {page.Name}");
        return Task.CompletedTask;
    }

    private static PublicationStreamingSettings CloneStreaming(PublicationStreamingSettings settings) =>
        System.Text.Json.JsonSerializer.Deserialize<PublicationStreamingSettings>(
            System.Text.Json.JsonSerializer.Serialize(settings)) ?? new PublicationStreamingSettings();

