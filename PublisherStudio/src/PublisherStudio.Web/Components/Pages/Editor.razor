    public void Dispose()
    {
        if (_disposed) return;
        _disposed = true;
        State.Changed -= StateChanged;
        _recoverySaveCancellation?.Cancel();
        _recoverySaveCancellation?.Dispose();
        if (State.IsDirty)
        {
            try
            {
                var json = Files.Serialize(State.Document);
                _ = Recovery.SaveAsync(State.Document.Id, State.Document.Name, State.Document.ModifiedUtc, json);
            }
            catch { }
        }
    }
