@page "/"
@rendermode InteractiveServer
@implements IDisposable
@inject EditorStateService State
@inject PublicationFileService Files
@inject IJSRuntime JS

<PageTitle>BlazorPublisher</PageTitle>

<div class="publisher-shell">
    <header class="title-bar">
        <div class="brand-mark">P</div>
        <input class="document-name" value="@State.Document.Name" @onchange="RenameDocument" aria-label="Publication name" />
        <span class="modified-label">Modified @State.Document.ModifiedUtc.LocalDateTime.ToString("g")</span>
    </header>

    <PublicationRibbon State="State"
                       OnNew="NewDocument"
                       OnOpen="OpenPublicationPicker"
                       OnSave="SavePublication"
                       OnPrint="Print"
                       OnExportPng="ExportPng"
                       OnExportJpeg="ExportJpeg"
                       OnExportSvg="ExportSvg"
                       OnExportWebsite="ExportWebsite"
                       OnInsertPicture="OpenPicturePicker"
                       OnCreatePicture="CreatePicture"
                       OnEditPicture="EditSelectedPicture"
                       OnEditStory="OpenStoryEditor"
                       OnFitPage="FitPage"
                       OnTogglePagesPane="TogglePagesPane"
                       OnToggleInspectorPane="ToggleInspectorPane"
                       OnResetWorkspace="ResetWorkspace"
                       OnInsertDataVisual="InsertDataVisual"
                       OnEditDataVisual="OpenDataVisualEditor"
                       OnManageData="OpenDataManager" />

    <div id="publisher-workspace" class="editor-workspace">
        <PageNavigator State="State" />
        <button type="button" class="workspace-splitter splitter-left" data-workspace-splitter="left" title="Drag to resize pages pane; double-click to collapse" aria-label="Resize pages pane"></button>
        <PageSurface @ref="_pageSurface" State="State" EditTextRequested="OpenStoryEditorById" RequestPicture="OpenPicturePicker" RequestCreatePicture="CreatePicture" RequestEditPicture="EditSelectedPicture"
                     RequestInsertDataVisual="InsertDataVisual" RequestEditDataVisual="OpenDataVisualEditor" RequestManageData="OpenDataManager" />
        <button type="button" class="workspace-splitter splitter-right" data-workspace-splitter="right" title="Drag to resize properties pane; double-click to collapse" aria-label="Resize properties pane"></button>
        <InspectorPanel State="State"
                        OnEditStory="OpenStoryEditor"
                        OnReplacePicture="OpenPicturePicker"
                        OnInsertPicture="OpenPicturePicker"
                        OnCreatePicture="CreatePicture"
                        OnEditPicture="EditSelectedPicture"
                        OnApplyTransparentColor="ApplyTransparentColor"
                        OnRestoreOriginalPicture="RestoreOriginalPicture"
                        OnInsertDataVisual="InsertDataVisual"
                        OnEditDataVisual="OpenDataVisualEditor"
                        OnManageData="OpenDataManager" />
    </div>

    <footer class="status-bar">
        <span>Page @(State.Document.Pages.FindIndex(p => p.Id == State.SelectedPageId) + 1) of @State.Document.Pages.Count</span>
        <span>@SelectionStatus</span>
        <span>@State.CurrentPage.WidthMm.ToString("0.#", CultureInfo.InvariantCulture) × @State.CurrentPage.HeightMm.ToString("0.#", CultureInfo.InvariantCulture) mm</span>
        <label class="zoom-control">Zoom
            <button type="button" title="Zoom out" @onclick="ZoomOut">−</button>
            <input type="range" min="0.2" max="4" step="0.05" value="@State.Document.Zoom.ToString(CultureInfo.InvariantCulture)" @oninput="ChangeZoom" />
            <button type="button" title="Zoom in" @onclick="ZoomIn">+</button>
            <b>@Math.Round(State.Document.Zoom * 100)%</b>
        </label>
    </footer>
</div>

<InputFile id="publication-file-input" class="hidden-file-input" accept=".json,.pubstudio.json,application/json" OnChange="OpenPublication" />
<InputFile id="picture-file-input" class="hidden-file-input" accept="image/png,image/jpeg,image/gif,image/webp,image/svg+xml" OnChange="InsertPicture" />

<PrintPublication Document="State.Document" />

<StoryEditor Visible="_storyEditorVisible"
             TextFrame="@(State.SelectedElement as TextFrameElement)"
             PublicationName="@State.Document.Name"
             PageName="@State.CurrentPage.Name"
             PageNumber="@CurrentPageNumber"
             PageCount="@State.Document.Pages.Count"
             Saved="SaveStory"
             Cancelled="CloseStoryEditor" />

<PictureEditor Visible="@_pictureEditorVisible"
               SessionId="@_pictureEditorSessionId"
               InitialDocument="@_pictureEditorInitialDocument"
               InitialRasterDataUrl="@_pictureEditorInitialRaster"
               InitialName="@_pictureEditorInitialName"
               EditingExisting="@(_pictureEditorTargetId is not null)"
               Saved="SavePictureStudio"
               Cancelled="ClosePictureStudio" />

<DataVisualEditor Visible="_dataVisualEditorVisible" State="State" Saved="SaveDataVisualEditor" Cancelled="CancelDataVisualEditor" ManageDataRequested="OpenDataManagerFromVisual" />
<DataManager Visible="_dataManagerVisible" State="State" Closed="CloseDataManager" DataChanged="DataManagerChanged" />

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="toast error" @onclick="() => _error = null">@_error</div>
}

@if (!string.IsNullOrWhiteSpace(_notice))
{
    <div class="toast notice" @onclick="() => _notice = null">@_notice</div>
}

@code {
    private PageSurface? _pageSurface;
    private bool _storyEditorVisible;
    private bool _pictureEditorVisible;
    private bool _dataVisualEditorVisible;
    private bool _dataManagerVisible;
    private Guid? _pendingNewDataVisualId;
    private bool _resumeDataVisualAfterManager;
    private Guid _pictureEditorSessionId;
    private Guid? _pictureEditorTargetId;
    private PictureDocument? _pictureEditorInitialDocument;
    private string? _pictureEditorInitialRaster;
    private string _pictureEditorInitialName = "Picture";
    private bool _workspaceInitialized;
    private string? _error;
    private string? _notice;
    private string SelectionStatus => State.ConnectorTool != ConnectorToolKind.None
        ? $"{State.ConnectorTool} connector tool — drag from one object port to another; Esc cancels"
        : State.SelectedElement is null ? "No selection" : $"{State.SelectedElement.Kind}: {State.SelectedElement.Name}";

    protected override void OnInitialized() => State.Changed += StateChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_workspaceInitialized)
        {
            _workspaceInitialized = true;
            await JS.InvokeVoidAsync("publisherStudio.initializeWorkspace", "publisher-workspace");
        }
    }

    private void StateChanged() => InvokeAsync(StateHasChanged);
    private void NewDocument() => State.NewDocument();
    private async Task OpenPublicationPicker() => await JS.InvokeVoidAsync("publisherStudio.clickElement", "publication-file-input");
    private async Task OpenPicturePicker() => await JS.InvokeVoidAsync("publisherStudio.clickElement", "picture-file-input");

    private async Task SavePublication()
    {
        var json = Files.Serialize(State.Document);
        var name = PublicationFileService.SafeFileName(State.Document.Name) + ".pubstudio.json";
        await using var stream = new MemoryStream(Encoding.UTF8.GetBytes(json));
        using var streamReference = new DotNetStreamReference(stream);
        await JS.InvokeVoidAsync("publisherStudio.downloadStream", name, streamReference, "application/json");
        ShowNotice($"Saved {name}");
    }

    private async Task ExportPng() => await ExportPage("png");
    private async Task ExportJpeg() => await ExportPage("jpeg");
    private async Task ExportSvg() => await ExportPage("svg");

    private async Task ExportPage(string format)
    {
        try
        {
            var fileName = $"{PublicationFileService.SafeFileName(State.Document.Name)}-page-{CurrentPageNumber}.{(format == "jpeg" ? "jpg" : format)}";
            await JS.InvokeVoidAsync("publisherStudio.exportPage", "publisher-page", fileName, format, State.Document.View.ExportDpi, State.Document.Zoom);
            ShowNotice($"Exported current page as {format.ToUpperInvariant()}.");
        }
        catch (Exception ex)
        {
            ShowError(ex);
        }
    }

    private async Task ExportWebsite()
    {
        try
        {
            var fileName = PublicationFileService.SafeFileName(State.Document.Name) + ".html";
            await JS.InvokeVoidAsync("publisherStudio.exportWebsite", fileName, State.Document.Name);
            ShowNotice($"Exported {fileName}");
        }
        catch (Exception ex)
        {
            ShowError(ex);
        }
    }

    private async Task Print() => await JS.InvokeVoidAsync("publisherStudio.printPublication");

    private async Task FitPage()
    {
        if (_pageSurface is not null)
            await _pageSurface.FitPageAsync();
    }

    private Task TogglePagesPane() => JS.InvokeVoidAsync("publisherStudio.toggleWorkspacePane", "publisher-workspace", "left").AsTask();
    private Task ToggleInspectorPane() => JS.InvokeVoidAsync("publisherStudio.toggleWorkspacePane", "publisher-workspace", "right").AsTask();
    private Task ResetWorkspace() => JS.InvokeVoidAsync("publisherStudio.resetWorkspaceLayout", "publisher-workspace").AsTask();

    private int CurrentPageNumber => Math.Max(1, State.Document.Pages.FindIndex(publicationPage => publicationPage.Id == State.SelectedPageId) + 1);

    private async Task OpenPublication(InputFileChangeEventArgs args)
    {
        try
        {
            await using var stream = args.File.OpenReadStream(64 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            State.Load(await reader.ReadToEndAsync());
        }
        catch (Exception ex)
        {
            ShowError(ex);
        }
    }

    private async Task InsertPicture(InputFileChangeEventArgs args)
    {
        try
        {
            var file = args.File;
            var allowed = new[] { "image/png", "image/jpeg", "image/gif", "image/webp", "image/svg+xml" };
            if (!allowed.Contains(file.ContentType, StringComparer.OrdinalIgnoreCase))
                throw new InvalidDataException("Unsupported picture format.");

            await using var stream = file.OpenReadStream(64 * 1024 * 1024);
            using var buffer = new MemoryStream();
            await stream.CopyToAsync(buffer);
            var dataUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer.ToArray())}";
            if (State.SelectedElement is ImageFrameElement image)
            {
                State.UpdateSelected(_ =>
                {
                    image.DataUrl = dataUrl;
                    image.OriginalDataUrl = dataUrl;
                    image.AltText = file.Name;
                    image.Name = file.Name;
                    image.CropX = 0;
                    image.CropY = 0;
                    image.CropScale = 1;
                    image.PictureSource = null;
                });
            }
            else
            {
                State.AddImage(dataUrl, file.Name);
            }
        }
        catch (Exception ex)
        {
            ShowError(ex);
        }
    }

    private async Task ApplyTransparentColor()
    {
        if (State.SelectedElement is not ImageFrameElement image) return;
        try
        {
            var result = await JS.InvokeAsync<string>("publisherStudio.makeColorTransparent", image.DataUrl, image.TransparentColor, image.TransparentColorTolerance);
            State.UpdateSelected(_ => image.DataUrl = result);
            ShowNotice("The selected color was made transparent. Restore Original remains available.");
        }
        catch (Exception ex)
        {
            ShowError(ex);
        }
    }

    private Task RestoreOriginalPicture()
    {
        if (State.SelectedElement is ImageFrameElement image && !string.IsNullOrWhiteSpace(image.OriginalDataUrl))
        {
            State.UpdateSelected(_ => image.DataUrl = image.OriginalDataUrl);
            ShowNotice("Original picture restored.");
        }
        return Task.CompletedTask;
    }

    private Task CreatePicture()
    {
        _pictureEditorTargetId = null;
        _pictureEditorInitialDocument = null;
        _pictureEditorInitialRaster = null;
        _pictureEditorInitialName = "Untitled Picture";
        _pictureEditorSessionId = Guid.NewGuid();
        _pictureEditorVisible = true;
        return Task.CompletedTask;
    }

    private Task EditSelectedPicture()
    {
        if (State.SelectedElement is not ImageFrameElement image) return Task.CompletedTask;
        _pictureEditorTargetId = image.Id;
        _pictureEditorInitialDocument = image.PictureSource;
        _pictureEditorInitialRaster = image.PictureSource is null ? image.DataUrl : null;
        _pictureEditorInitialName = string.IsNullOrWhiteSpace(image.Name) ? "Picture" : image.Name;
        _pictureEditorSessionId = Guid.NewGuid();
        _pictureEditorVisible = true;
        return Task.CompletedTask;
    }

    private Task SavePictureStudio(PictureEditorResult result)
    {
        if (_pictureEditorTargetId is Guid targetId)
        {
            State.SelectElement(targetId);
            if (State.SelectedElement is ImageFrameElement image)
            {
                State.UpdateSelected(_ =>
                {
                    image.DataUrl = result.DataUrl;
                    image.OriginalDataUrl = result.DataUrl;
                    image.PictureSource = result.SourceDocument;
                    image.Name = result.Name;
                    image.AltText = result.Name;
                });
            }
        }
        else
        {
            State.AddImage(result.DataUrl, result.Name, result.SourceDocument);
        }
        _pictureEditorVisible = false;
        _pictureEditorTargetId = null;
        _pictureEditorInitialDocument = null;
        _pictureEditorInitialRaster = null;
        ShowNotice("Picture Studio image inserted into the publication.");
        return Task.CompletedTask;
    }

    private Task ClosePictureStudio()
    {
        _pictureEditorVisible = false;
        _pictureEditorTargetId = null;
        _pictureEditorInitialDocument = null;
        _pictureEditorInitialRaster = null;
        return Task.CompletedTask;
    }

    private Task InsertDataVisual(DataVisualKind kind)
    {
        var visual = State.AddDataVisual(kind);
        _pendingNewDataVisualId = visual.Id;
        _dataVisualEditorVisible = true;
        return Task.CompletedTask;
    }

    private Task OpenDataVisualEditor()
    {
        if (State.SelectedElement is DataVisualElement)
        {
            _pendingNewDataVisualId = null;
            _dataVisualEditorVisible = true;
        }
        return Task.CompletedTask;
    }

    private Task SaveDataVisualEditor()
    {
        _dataVisualEditorVisible = false;
        _pendingNewDataVisualId = null;
        ShowNotice("Data visual applied to the publication.");
        return Task.CompletedTask;
    }

    private Task CancelDataVisualEditor()
    {
        _dataVisualEditorVisible = false;
        if (_pendingNewDataVisualId is Guid id)
        {
            State.SelectElement(id);
            if (State.SelectedElement is DataVisualElement)
                State.DeleteSelected();
        }
        _pendingNewDataVisualId = null;
        return Task.CompletedTask;
    }

    private Task OpenDataManager()
    {
        _dataManagerVisible = true;
        return Task.CompletedTask;
    }

    private Task OpenDataManagerFromVisual()
    {
        _resumeDataVisualAfterManager = true;
        _dataVisualEditorVisible = false;
        _dataManagerVisible = true;
        return Task.CompletedTask;
    }

    private Task CloseDataManager()
    {
        _dataManagerVisible = false;
        if (_resumeDataVisualAfterManager && State.SelectedElement is DataVisualElement)
            _dataVisualEditorVisible = true;
        _resumeDataVisualAfterManager = false;
        return Task.CompletedTask;
    }

    private Task DataManagerChanged()
    {
        State.RefreshDataVisuals();
        ShowNotice("Publication data updated.");
        return Task.CompletedTask;
    }

    private Task OpenStoryEditorById(Guid id)
    {
        State.SelectElement(id);
        return OpenStoryEditor();
    }

    private Task OpenStoryEditor()
    {
        if (State.SelectedElement is TextFrameElement) _storyEditorVisible = true;
        return Task.CompletedTask;
    }

    private Task CloseStoryEditor()
    {
        _storyEditorVisible = false;
        return Task.CompletedTask;
    }

    private Task SaveStory((byte[] Content, string PreviewHtml, StoryStorageFormat Format) result)
    {
        State.UpdateTextDocument(result.Content, result.PreviewHtml, result.Format);
        _storyEditorVisible = false;
        return Task.CompletedTask;
    }

    private void RenameDocument(ChangeEventArgs args)
    {
        State.Document.Name = string.IsNullOrWhiteSpace(args.Value?.ToString()) ? "Untitled Publication" : args.Value!.ToString()!;
        State.Document.ModifiedUtc = DateTimeOffset.UtcNow;
        StateChanged();
    }

    private void ChangeZoom(ChangeEventArgs args)
    {
        if (double.TryParse(args.Value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var zoom))
            State.SetZoom(zoom);
    }

    private void ZoomIn() => State.ZoomBy(1.15);
    private void ZoomOut() => State.ZoomBy(1 / 1.15);

    private void ShowError(Exception ex)
    {
        _error = ex.Message;
        _notice = null;
        StateChanged();
    }

    private void ShowNotice(string message)
    {
        _notice = message;
        _error = null;
        StateChanged();
    }

    public void Dispose() => State.Changed -= StateChanged;
}
