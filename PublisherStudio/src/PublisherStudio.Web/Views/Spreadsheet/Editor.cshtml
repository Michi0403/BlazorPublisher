@model SpreadsheetEditorViewModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@inject PublisherStudio.Services.SystemFontCatalog SystemFonts
@{
    Layout = null;
    var requestToken = Antiforgery.GetAndStoreTokens(Context).RequestToken ?? string.Empty;
    var encodedFileName = System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(Model.FileName);
    var systemFontFamiliesJson = System.Text.Json.JsonSerializer.Serialize(SystemFonts.FontFamilies);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@Model.FileName</title>
    <link href="~/vendor/devextreme-dist/css/dx.light.css" rel="stylesheet" />
    <link href="~/vendor/devexpress-aspnetcore-spreadsheet/dist/dx-aspnetcore-spreadsheet.css" rel="stylesheet" />
    <link href="~/css/spreadsheet-island.css" rel="stylesheet" />
    <script src="~/vendor/jquery/jquery.min.js"></script>
    <script src="~/vendor/devextreme-dist/js/dx.all.js"></script>
    <script src="~/vendor/devextreme-license.js"
            onerror="console.error('PublisherStudio: the generated DevExtreme runtime license is missing. Run Prepare-DevExpressAssets.cmd on the licensed build machine.')"></script>
    <script src="~/vendor/devexpress-aspnetcore-spreadsheet/dist/dx-aspnetcore-spreadsheet.js"></script>
    <script>
        "use strict";
        const publisherSpreadsheetRequestToken = "@requestToken";
        const publisherSpreadsheetSessionId = "@Model.SessionId";
        const publisherSpreadsheetParentOrigin = window.location.origin;
        const publisherSystemFontFamilies = @Html.Raw(systemFontFamiliesJson);

        function publisherSpreadsheetApplySystemFonts(control) {
            try {
                const item = control?.getRibbonManager?.().getRibbonItemByName?.("FormatFontName");
                for (const ribbonItem of item?.items || []) {
                    const widget = ribbonItem?.widget;
                    if (!widget?.option) continue;
                    widget.option({
                        dataSource: publisherSystemFontFamilies,
                        acceptCustomValue: true,
                        searchEnabled: true,
                        onCustomItemCreating: event => {
                            const value = String(event?.text || "").trim();
                            event.customItem = value || null;
                        }
                    });
                }
            } catch (error) {
                console.warn("PublisherStudio could not apply the system font catalog to Spreadsheet Studio.", error);
            }
        }

        window.publisherSpreadsheetBridge = {
            control: null,
            synchronizing: false,
            awaitingSynchronization: false,
            inFlight: false,
            pendingIntent: null,
            saveTimer: 0,
            saveStartedAt: 0,
            openingWorkbook: false,
            dirty: false,

            post(type, payload) {
                window.parent.postMessage(
                    Object.assign({ type, sessionId: publisherSpreadsheetSessionId }, payload || {}),
                    publisherSpreadsheetParentOrigin);
            },

            notifyReady() {
                if (this.control) this.post("publisher-spreadsheet-ready", { fileName: "@encodedFileName" });
            },

            chooseWorkbook() {
                if (this.openingWorkbook || this.inFlight) return;
                if (this.dirty && !window.confirm("Open another workbook and discard the current unsaved spreadsheet changes?")) return;
                const input = document.getElementById("publisher-spreadsheet-open-input");
                if (!input) return;
                input.value = "";
                input.click();
            },

            async newWorkbook() {
                if (this.openingWorkbook || this.inFlight) return;
                if (this.dirty && !window.confirm("Create a blank workbook and discard the current unsaved spreadsheet changes?")) return;
                this.openingWorkbook = true;
                this.post("publisher-spreadsheet-opening", { fileName: "Spreadsheet.xlsx" });
                try {
                    const response = await fetch("@Url.Action("New", "Spreadsheet", new { sessionId = Model.SessionId })", { method: "POST", headers: { RequestVerificationToken: publisherSpreadsheetRequestToken }, credentials: "same-origin" });
                    let result = null; try { result = await response.json(); } catch (_) { }
                    if (!response.ok || !result?.success) throw new Error(result?.message || `A blank workbook could not be created (${response.status}).`);
                    this.dirty = false; window.location.replace(result.reloadUrl || `${window.location.pathname}?revision=${Date.now()}`);
                } catch (error) { this.openingWorkbook = false; this.post("publisher-spreadsheet-error", { message: error?.message || "A blank workbook could not be created." }); }
            },

            async openWorkbook(file) {
                if (!file || this.openingWorkbook || this.inFlight) return;
                if (file.size <= 0) {
                    this.post("publisher-spreadsheet-error", { message: "The selected spreadsheet is empty." });
                    return;
                }

                this.openingWorkbook = true;
                this.post("publisher-spreadsheet-opening", { fileName: file.name });
                try { this.control?.applyCellEdit(); } catch (_) { }

                const formData = new FormData();
                formData.append("workbook", file, file.name);
                try {
                    const response = await fetch("@Url.Action("Open", "Spreadsheet", new { sessionId = Model.SessionId })", {
                        method: "POST",
                        headers: { RequestVerificationToken: publisherSpreadsheetRequestToken },
                        body: formData,
                        credentials: "same-origin"
                    });
                    let result = null;
                    try { result = await response.json(); } catch (_) { }
                    if (!response.ok || !result?.success)
                        throw new Error(result?.message || `The workbook could not be opened (${response.status}).`);
                    this.dirty = false;
                    window.location.replace(result.reloadUrl || `${window.location.pathname}?revision=${Date.now()}`);
                } catch (error) {
                    this.openingWorkbook = false;
                    this.post("publisher-spreadsheet-error", {
                        message: error?.message || "The workbook could not be opened."
                    });
                }
            },

            onInit(spreadsheet) {
                this.control = spreadsheet || window.publisherSpreadsheet;
                this.notifyReady();
                window.setTimeout(() => {
                    try { this.control?.focus(); } catch (_) { }
                    publisherSpreadsheetRenameRibbonTabs();
                    publisherSpreadsheetApplySystemFonts(this.control);
                    window.setTimeout(() => publisherSpreadsheetApplySystemFonts(this.control), 400);
                }, 100);
            },

            queueSave(intent) {
                if (this.inFlight) return;
                this.pendingIntent = intent || "apply";
                this.saveStartedAt = Date.now();
                try { this.control?.applyCellEdit(); } catch (_) { }
                this.scheduleSave(120);
            },

            createDataObject() {
                if (!this.control || this.openingWorkbook || this.inFlight) return;
                try { this.control.applyCellEdit(); } catch (_) { }

                let selection;
                try { selection = this.control.getSelection(); }
                catch (error) {
                    this.post("publisher-spreadsheet-error", { message: error?.message || "The selected spreadsheet cells could not be read." });
                    return;
                }

                const left = Number(selection?.leftColumnIndex);
                const top = Number(selection?.topRowIndex);
                const right = Number(selection?.rightColumnIndex);
                const bottom = Number(selection?.bottomRowIndex);
                if (![left, top, right, bottom].every(Number.isInteger) || left < 0 || top < 0 || right < left || bottom < top) {
                    this.post("publisher-spreadsheet-error", { message: "Select a rectangular spreadsheet range first." });
                    return;
                }
                if (right >= 16383 || bottom >= 1048575) {
                    this.post("publisher-spreadsheet-error", { message: "Select a bounded cell range instead of an entire row, column, or worksheet." });
                    return;
                }

                const cellText = value => {
                    if (value === null || value === undefined) return "";
                    if (value instanceof Date) return value.toISOString();
                    if (typeof value === "string") return value;
                    if (typeof value === "number" || typeof value === "boolean") return String(value);
                    try { return String(value); } catch (_) { return ""; }
                };
                const rows = [];
                let lastNonEmptyRow = -1;
                let lastNonEmptyColumn = -1;
                for (let rowIndex = top; rowIndex <= bottom; rowIndex++) {
                    const row = [];
                    for (let columnIndex = left; columnIndex <= right; columnIndex++) {
                        let value = "";
                        try { value = cellText(this.control.getCellValue(columnIndex, rowIndex)); } catch (_) { }
                        row.push(value);
                        if (value.trim().length > 0)
                            lastNonEmptyColumn = Math.max(lastNonEmptyColumn, columnIndex - left);
                    }
                    rows.push(row);
                    if (row.some(value => value.trim().length > 0)) lastNonEmptyRow = rows.length - 1;
                }

                if (lastNonEmptyRow < 0 || lastNonEmptyColumn < 0) {
                    this.post("publisher-spreadsheet-error", { message: "The selected spreadsheet range is empty." });
                    return;
                }
                const trimmedRows = rows.slice(0, lastNonEmptyRow + 1).map(row => row.slice(0, lastNonEmptyColumn + 1));
                const columnName = index => {
                    let value = index + 1;
                    let result = "";
                    while (value > 0) {
                        const remainder = (value - 1) % 26;
                        result = String.fromCharCode(65 + remainder) + result;
                        value = Math.floor((value - 1) / 26);
                    }
                    return result;
                };
                const trimmedRight = left + lastNonEmptyColumn;
                const trimmedBottom = top + lastNonEmptyRow;
                const rangeAddress = `${columnName(left)}${top + 1}:${columnName(trimmedRight)}${trimmedBottom + 1}`;
                this.post("publisher-spreadsheet-data-selection", {
                    sheetName: this.control.getActiveSheetName?.() || "Sheet1",
                    rangeAddress,
                    rows: trimmedRows
                });
            },

            scheduleSave(delay) {
                window.clearTimeout(this.saveTimer);
                this.saveTimer = window.setTimeout(() => this.flushSave(), delay || 0);
            },

            flushSave() {
                if (!this.pendingIntent || this.inFlight || !this.control) return;
                if (this.synchronizing || this.awaitingSynchronization) {
                    if (Date.now() - this.saveStartedAt > 15000) {
                        const intent = this.pendingIntent;
                        this.pendingIntent = null;
                        this.post("publisher-spreadsheet-error", {
                            intent,
                            message: "The last spreadsheet change did not finish synchronizing with the local server."
                        });
                        return;
                    }
                    this.scheduleSave(100);
                    return;
                }
                const intent = this.pendingIntent;
                this.pendingIntent = null;
                this.inFlight = true;

                let spreadsheetState;
                try {
                    spreadsheetState = this.control.getSpreadsheetState();
                } catch (error) {
                    this.inFlight = false;
                    this.post("publisher-spreadsheet-error", {
                        intent,
                        message: error?.message || "The spreadsheet state could not be read."
                    });
                    return;
                }

                $.ajax({
                    type: "POST",
                    url: "@Url.Action("Save", "Spreadsheet", new { sessionId = Model.SessionId })",
                    data: { spreadsheetState },
                    headers: { RequestVerificationToken: publisherSpreadsheetRequestToken },
                    success: result => {
                        this.post("publisher-spreadsheet-saved", Object.assign({ intent }, result));
                        if (intent === "download" && result.downloadUrl) {
                            const link = document.createElement("a");
                            link.href = result.downloadUrl;
                            link.download = result.fileName || "Spreadsheet.xlsx";
                            document.body.appendChild(link);
                            link.click();
                            link.remove();
                        }
                    },
                    error: request => {
                        let message = "The spreadsheet could not be saved.";
                        try { message = request.responseJSON?.message || request.responseText || message; } catch (_) { }
                        this.post("publisher-spreadsheet-error", { intent, message });
                    },
                    complete: () => {
                        this.inFlight = false;
                        if (this.pendingIntent) this.scheduleSave(0);
                    }
                });
            }
        };

        function publisherSpreadsheetBeforeSend(_spreadsheet, eventArgs) {
            eventArgs.request.setRequestHeader("RequestVerificationToken", publisherSpreadsheetRequestToken);
        }

        function publisherSpreadsheetOnInit(spreadsheet) {
            window.publisherSpreadsheetBridge.onInit(spreadsheet);
        }

        function publisherSpreadsheetRenameRibbonTabs() {
            const root = document.getElementById("publisher-spreadsheet-island");
            if (!root) return;
            const candidates = Array.from(root.querySelectorAll('[role="tab"], .dx-tab, .dxbs-tabs-item, .dxr-tab'))
                .filter(element => element.textContent?.trim() === "Home");
            for (const element of candidates) {
                const textNode = Array.from(element.childNodes).find(node => node.nodeType === Node.TEXT_NODE && node.textContent.trim() === "Home");
                if (textNode) textNode.textContent = "All";
                else {
                    const label = Array.from(element.querySelectorAll("span,div,a")).find(node => node.children.length === 0 && node.textContent?.trim() === "Home");
                    if (label) label.textContent = "All";
                }
            }
        }

        const publisherSpreadsheetRibbonObserver = new MutationObserver(() => publisherSpreadsheetRenameRibbonTabs());
        window.addEventListener("DOMContentLoaded", () => {
            const island = document.getElementById("publisher-spreadsheet-island");
            if (island) publisherSpreadsheetRibbonObserver.observe(island, { childList: true, subtree: true });
        });

        function publisherSpreadsheetOnDocumentChanged() {
            window.publisherSpreadsheetBridge.awaitingSynchronization = true;
            window.publisherSpreadsheetBridge.dirty = true;
        }

        function publisherSpreadsheetOnCustomCommandExecuted(_spreadsheet, eventArgs) {
            const bridge = window.publisherSpreadsheetBridge;
            switch (eventArgs.commandName) {
                case "publisherOpenWorkbook": bridge.chooseWorkbook(); break;
                case "publisherNewWorkbook": bridge.newWorkbook(); break;
                case "publisherCreateDataObject": bridge.createDataObject(); break;
                case "publisherApplyWorkbook": bridge.queueSave("apply"); break;
                case "publisherDownloadWorkbook": bridge.queueSave("download"); break;
            }
        }

        function publisherSpreadsheetOnBeginSynchronization() {
            const bridge = window.publisherSpreadsheetBridge;
            bridge.awaitingSynchronization = true;
            bridge.synchronizing = true;
        }

        function publisherSpreadsheetOnEndSynchronization() {
            const bridge = window.publisherSpreadsheetBridge;
            bridge.synchronizing = false;
            bridge.awaitingSynchronization = false;
            if (bridge.pendingIntent) bridge.scheduleSave(60);
        }
    </script>
</head>
<body>
    <div class="publisher-spreadsheet-commandbar" role="toolbar" aria-label="Workbook commands">
        <button type="button" id="publisher-open-workbook"><img src="/icons/open-workbook.svg" alt="" />Open workbook</button><button type="button" id="publisher-new-workbook">＋ Blank workbook</button>
        <button type="button" id="publisher-create-data-object">▤ Create data object</button>
        <span class="publisher-spreadsheet-commandbar-spacer"></span><button type="button" id="publisher-apply-workbook">Apply to frame</button><button type="button" id="publisher-download-workbook">Download</button>
    </div>
    <main id="publisher-spreadsheet-island">
        @(Html.DevExpress()
            .Spreadsheet("publisherSpreadsheet")
            .Width("100%")
            .Height("100%")
            .DocumentRequestHandlerUrl(Url.Action("RequestHandler", "Spreadsheet"))
            .ConfirmOnLosingChanges(options => options.Enabled(false))
            .Ribbon(ribbon => ribbon.Tabs(tabs =>
            {
                // The standard Spreadsheet ribbon hides lower-priority commands as the
                // editor narrows. The far-left Start tab keeps the publication workflow
                // directly reachable; Format and Cells & Data split dense command sets so
                // they do not disappear into the adaptive overflow menu.
                tabs.Insert(0).Title("Start").Name("PublisherStart").Items(items =>
                {
                    items.AddButton("Open workbook", "publisherOpenWorkbook", false, "/icons/open-workbook.svg", true);
                    items.AddButton("Blank workbook", "publisherNewWorkbook", false, "new", true);
                    items.AddButton("Create data object", "publisherCreateDataObject", true, "table", true);
                    items.AddButton("Apply to frame", "publisherApplyWorkbook", true, "save", true);
                    items.AddButton("Download", "publisherDownloadWorkbook", false, "download", true);
                    items.AddUndoItem();
                    items.AddRedoItem();
                    items.AddCutItem();
                    items.AddCopyItem();
                    items.AddPasteItem();
                    items.AddFindItem();
                    items.AddPrintItem();
                });
                tabs.Insert(1).Title("Format").Name("PublisherFormat").Items(items =>
                {
                    items.AddFontNameItem();
                    items.AddFontSizeItem();
                    items.AddFontBoldItem();
                    items.AddFontItalicItem();
                    items.AddFontUnderlineItem();
                    items.AddForeColorItem();
                    items.AddBackgroundColorItem();
                    items.AddBordersItem();
                    items.AddAlignParagraphLeftItem();
                    items.AddAlignParagraphCenterItem();
                    items.AddAlignParagraphRightItem();
                    items.AddAlignTopItem();
                    items.AddAlignMiddleItem();
                    items.AddAlignBottomItem();
                    items.AddWrapTextItem();
                    items.AddMergeCellsItem();
                });
                tabs.Insert(2).Title("Cells & Data").Name("PublisherCellsData").Items(items =>
                {
                    items.AddInsertCellsItem();
                    items.AddDeleteCellsItem();
                    items.AddFormatItem();
                    items.AddAutoSumItem();
                    items.AddSortAndFilterItem();
                    items.AddFormatAsTableItem();
                    items.AddInsertTableItem();
                    items.AddInsertHyperlinkItem();
                    items.AddFreezePanesItem();
                    items.AddGridlinesItem();
                    items.AddHeadingsItem();
                });
            }))
            .Open(Model.DocumentId, Model.DocumentFormat, Model.ContentAccessor)
            .ClientSideEvents(events =>
            {
                events.OnBeforeSend("publisherSpreadsheetBeforeSend");
                events.OnInit("publisherSpreadsheetOnInit");
                events.OnDocumentChanged("publisherSpreadsheetOnDocumentChanged");
                events.OnCustomCommandExecuted("publisherSpreadsheetOnCustomCommandExecuted");
                events.OnBeginSynchronization("publisherSpreadsheetOnBeginSynchronization");
                events.OnEndSynchronization("publisherSpreadsheetOnEndSynchronization");
            }))
    </main>
    <input id="publisher-spreadsheet-open-input" type="file" hidden
           accept=".xlsx,.xlsm,.xls,.csv,.txt,.tsv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel,text/csv,text/plain" />

    <script>
        (() => {
            const bridge = window.publisherSpreadsheetBridge;
            const openInput = document.getElementById("publisher-spreadsheet-open-input");
            document.getElementById("publisher-open-workbook")?.addEventListener("click", () => bridge.chooseWorkbook());
            document.getElementById("publisher-new-workbook")?.addEventListener("click", () => bridge.newWorkbook());
            document.getElementById("publisher-create-data-object")?.addEventListener("click", () => bridge.createDataObject());
            document.getElementById("publisher-apply-workbook")?.addEventListener("click", () => bridge.queueSave("apply"));
            document.getElementById("publisher-download-workbook")?.addEventListener("click", () => bridge.queueSave("download"));
            openInput?.addEventListener("change", async () => {
                const file = openInput.files?.[0];
                openInput.value = "";
                if (file) await bridge.openWorkbook(file);
            });

            window.addEventListener("message", event => {
                if (event.origin !== publisherSpreadsheetParentOrigin || event.data?.sessionId !== publisherSpreadsheetSessionId) return;
                if (event.data.type === "publisher-spreadsheet-probe") bridge.notifyReady();
                if (event.data.type === "publisher-spreadsheet-save") bridge.queueSave(event.data.intent || "apply");
                if (event.data.type === "publisher-spreadsheet-create-data-object") bridge.createDataObject();
                if (event.data.type === "publisher-spreadsheet-focus") {
                    try { bridge.control?.focus(); } catch (_) { }
                }
            });
        })();
    </script>
</body>
</html>
